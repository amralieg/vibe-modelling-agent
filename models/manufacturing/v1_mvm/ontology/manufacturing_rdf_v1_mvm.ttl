# RDFS Schema for Business: Manufacturing

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/manufacturing#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Manufacturing ---
ind:Manufacturing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Manufacturing' ;
    rdfs:comment 'Industrial Manufacturing encompasses the design, production, and delivery of automation systems, electrification solutions, and smart infrastructure components for factories, buildings, transportation, and urban environments.' .

# --- Domain Classes ---
ind:Production rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Production' ;
    rdfs:comment 'Manages all shop floor execution, manufacturing scheduling, work orders, production order lifecycle, and real-time manufacturing operations using MES and ERP systems. Serves as the SSOT for WIP tracking, work center capacity, routing, takt time, cycle time, throughput, OEE metrics, and batch control. Covers MTO, MTS, ETO, and ATO production strategies and MRP II resource planning.' .

ind:Customer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Customer' ;
    rdfs:comment 'Single source of truth for all customer identities, accounts, contacts, and segmentation across B2B industrial buyers, OEM partners, system integrators, distributors, and end-users. Manages customer hierarchies, credit profiles, corporate accounts, contract associations, and SLA agreements across CRM and ERP systems.' .

ind:Engineering rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Engineering' ;
    rdfs:comment 'Owns the complete product engineering lifecycle including CAD/CAM models, BOM (Bill of Materials), BoP (Bill of Process), PLM/PDM records, ECN/ECO change management, DFM/DFA analysis, DFMEA/PFMEA documentation, and prototype development. SSOT for product structure, technical specifications, drawings, and engineering change workflows for automation systems and electrification solutions.' .

ind:Order rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Order' ;
    rdfs:comment 'SSOT for all customer order transactions including RFQ/RFP processing, quotations, sales orders, ATP/CTP commitments, order configuration options, fulfillment scheduling, delivery confirmation, and order-to-cash workflows. Manages order lifecycle from quote to cash across MTO, MTS, ETO, and ATO fulfillment modes.' .

ind:Product rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Product' ;
    rdfs:comment 'SSOT for the commercial product catalog including finished goods, automation systems, electrification solutions, smart infrastructure offerings, and aftermarket parts. Manages product classifications, SKU master data, product hierarchies, configurations, pricing structures, lifecycle stages, and regulatory certifications (CE, UL, RoHS, REACH).' .

ind:Quality rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Quality' ;
    rdfs:comment 'Manages the Quality Management System (QMS) including inspection plans, FAI (First Article Inspection), AQL/SPC/Six Sigma controls, NCR processing, CAPA workflows, FMEA analyses, APQP, PPAP documentation, and quality audits. Tracks PPM, Cp/Cpk indices, scrap rate, and yield across all production stages. Ensures compliance with ISO 9001.' .

ind:Inventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Inventory' ;
    rdfs:comment 'SSOT for all inventory positions, SKU stock levels, inventory transactions, warehouse locations, and WMS operations. Manages raw materials, WIP, finished goods, and MRO stock across all plant and distribution center locations. Covers cycle counting, ABC classification, safety stock, reorder points, and inventory valuation.' .

ind:Asset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Asset' ;
    rdfs:comment 'Manages the full lifecycle of manufacturing equipment, plant assets, and capital infrastructure using EAM/CMMS. Covers preventive and predictive maintenance (TPM), work order management, MTBF/MTTR tracking, condition monitoring via IIoT/MindSphere, PLCs, CNC machines, SCADA systems, and CAPEX/OPEX asset accounting.' .

ind:Sales rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Sales' ;
    rdfs:comment 'Manages the commercial sales pipeline including opportunities, leads, accounts, territories, sales forecasting, commission tracking, contracts, pricing rules, discount structures, and CRM integration. Supports both direct and channel sales motions for industrial automation projects, electrification solutions, and system integration contracts.' .

ind:Logistics rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Logistics' ;
    rdfs:comment 'Manages inbound and outbound freight, transportation planning, carrier selection and management, freight optimization, TMS-driven route optimization, shipment tracking, customs/trade compliance documentation, and delivery performance across global distribution networks.' .

ind:Procurement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Procurement' ;
    rdfs:comment 'Governs end-to-end procurement and supply chain planning including supplier master data, MRP/MRP II planning, demand forecasting, strategic sourcing, purchase requisitions, PO lifecycle, GRN processing, supplier performance tracking, vendor qualification, spend analytics, category management, and procurement compliance for direct and indirect materials' .

ind:Finance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Finance' ;
    rdfs:comment 'SSOT for all financial data including general ledger, cost centers, cost accounting, COGS, EBITDA reporting, CAPEX/OPEX tracking, accounts payable/receivable, budgeting, multi-currency consolidation, and statutory reporting. Supports IFRS and GAAP compliance across all legal entities and geographies.' .

ind:Service rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Service' ;
    rdfs:comment 'Manages after-sales service and aftermarket operations including field service dispatch, warranty claims, spare parts management, service contracts, SLA tracking, installation, commissioning, technical support, and customer support cases. Tracks NPS and service KPIs for the installed base of automation and electrification products.' .

ind:Shared rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Shared' ;
    rdfs:comment 'Cross-domain shared entities referenced by many domains' .

# --- Data Product Classes (Tables) ---
ind:Contact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Contact' ;
    rdfs:comment 'Individual person records associated with customer accounts, including procurement managers, engineering leads, plant managers, and executive sponsors at B2B industrial buyer organizations. Captures full name, job title, department, phone, email, preferred language, LinkedIn profile, contact role (technical, commercial, executive), opt-in/opt-out flags, and GDPR/CCPA consent status. Sourced from Salesforce CRM Contact object.' .

ind:AccountHierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Account Hierarchy' ;
    rdfs:comment 'Defines parent-child corporate hierarchy relationships between customer accounts, enabling roll-up reporting across subsidiaries, regional entities, and global enterprise accounts. Captures parent account, child account, hierarchy level, relationship type (subsidiary, division, affiliate, joint venture), effective date, and hierarchy depth. Critical for global account management and consolidated credit exposure tracking.' .

ind:Address rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Address' ;
    rdfs:comment 'Authoritative repository of all physical and mailing addresses associated with customer accounts, including headquarters, billing address, shipping/delivery address, plant site address, and registered office. Captures address type, street lines, city, state/province, postal code, country ISO code, geocoordinates, validated flag, validation source, and effective date range. Supports multi-site industrial customers with dozens of plant locations.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Market segmentation classification records defining how customer accounts are grouped for commercial strategy, pricing, and go-to-market purposes. Captures segment code, segment name (e.g., Tier-1 OEM, Strategic Distributor, SME End-User, System Integrator), industry vertical, geographic region, revenue band, strategic priority flag, assigned segment manager, and review cycle. Used for targeted sales campaigns and SLA tier assignment.' .

ind:CreditProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Credit Profile' ;
    rdfs:comment 'Financial credit standing and risk assessment record for each customer account, managed in SAP S/4HANA FI/SD. Captures credit limit (in account currency and group currency), credit exposure, credit risk class, payment terms code, credit block status, credit check method, Dun & Bradstreet rating, internal credit score, last review date, next review date, credit analyst, and credit hold reason. Essential for order-to-cash risk management.' .

ind:SlaAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Sla Agreement' ;
    rdfs:comment 'Service Level Agreement records defining contractual performance commitments made to customer accounts, including delivery lead time SLAs, order fulfillment SLAs, technical support response SLAs, and field service SLAs. Captures SLA type, metric name, target value, measurement unit, measurement frequency, penalty clause flag, penalty rate, effective date, expiry date, and linked contract reference. Supports after-sales and order management SLA enforcement.' .

ind:PartnerFunction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Partner Function' ;
    rdfs:comment 'Defines the functional roles that customer accounts or contacts play in commercial transactions, such as Sold-To Party, Ship-To Party, Bill-To Party, Payer, and End-User. Captures partner function code, partner function description, account reference, contact reference, default flag, and validity period. Directly maps to SAP S/4HANA SD partner determination schema and is critical for order routing and invoice generation.' .

ind:AccountClassification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Account Classification' ;
    rdfs:comment 'Stores multi-dimensional classification attributes for customer accounts used in pricing, reporting, and compliance. Captures classification type (e.g., ABC classification, Nielsen classification, export control classification, industry sector), classification value, classification scheme, assigned date, and assigning user. Supports SAP S/4HANA customer classification and export control screening (ECCN, EAR99).' .

ind:SalesAreaAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Sales Area Assignment' ;
    rdfs:comment 'Maps customer accounts to specific SAP S/4HANA sales areas (Sales Organization, Distribution Channel, Division) defining which products and pricing conditions apply to each customer in each sales area. Captures sales organization code, distribution channel, division, customer group, price list type, incoterms, delivery priority, and order combination flag. Foundational for order management and pricing determination.' .

ind:PricingAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Pricing Agreement' ;
    rdfs:comment 'Customer-specific pricing agreements and special price arrangements negotiated with key accounts, OEM partners, and distributors. Captures agreement type (customer-specific price, volume rebate, special discount), product or product group scope, agreed price or discount percentage, minimum order quantity, validity period, approval status, approving authority, and linked commercial contract reference. Feeds SAP S/4HANA condition records.' .

ind:AccountContactRole rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Account Contact Role' ;
    rdfs:comment 'Association entity linking contacts to accounts with specific business roles, capturing the nature of the relationship between a person and an organization. Captures role type (primary commercial contact, technical decision maker, accounts payable contact, plant manager, executive sponsor), start date, end date, active flag, and communication preference. Enables targeted communication routing and relationship mapping across complex B2B accounts.' .

ind:InstalledBase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Installed Base' ;
    rdfs:comment 'Registry of Manufacturing products and automation systems installed and operating at customer sites, forming the foundation for after-sales service, warranty management, spare parts sales, and upgrade campaigns. Captures installed product SKU, serial number, installation site address, installation date, commissioning date, warranty expiry date, software version, firmware version, operational status, and assigned service territory. Links customer domain to asset and service domains.' .

ind:MrpRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Mrp Run' ;
    rdfs:comment 'Records each MRP (Material Requirements Planning) or MRP II planning run executed in SAP PP/MM. Captures planning scope (plant, MRP area, material range), run type (regenerative, net change, net change in planning horizon), run timestamp, planning horizon, and exception message counts. Provides audit trail for supply planning decisions and supports MRP controller review workflows.' .

ind:MrpPlannedOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Mrp Planned Order' ;
    rdfs:comment 'Planned orders generated by MRP/MRP II runs representing future procurement or production requirements. Captures material, plant, planned quantity, planned start date, planned finish date, order type (purchase requisition, production order, transfer order), and firming status. Supports MRP controller review, firming decisions, and conversion to purchase requisitions or production orders.' .

ind:DemandForecast rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Demand Forecast' ;
    rdfs:comment 'Forward-looking demand signals used to drive supply planning and MRP inputs. Captures forecast version, material, plant, forecast period (weekly/monthly), forecasted quantity, statistical forecast baseline, consensus forecast adjustments, and forecast accuracy metrics (MAPE, bias). Supports S&OP (Sales and Operations Planning), safety stock optimization, and supplier capacity reservation.' .

ind:SupplyAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Supply Agreement' ;
    rdfs:comment 'Long-term supply agreements and blanket purchase agreements negotiated with strategic suppliers. Captures agreement type (scheduling agreement, blanket order, framework contract), validity period, total committed volume, pricing conditions, release schedule, minimum call-off quantities, and penalty clauses. Aligned with SAP MM Outline Agreement (ME31L/ME31K). Distinct from individual POs which are releases against agreements.' .

ind:DeliverySchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Delivery Schedule' ;
    rdfs:comment 'Scheduled delivery lines released against a supply agreement or blanket PO specifying exact delivery dates, quantities, and delivery locations. Captures JIT (Just-In-Time) delivery windows, Kanban replenishment signals, cumulative quantities, and schedule adherence tracking. Supports lean manufacturing replenishment and supplier delivery performance monitoring.' .

ind:SourceList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Source List' ;
    rdfs:comment 'Defines the approved and preferred sources of supply for each material at each plant. Captures valid supplier sources, supply agreement references, fixed/preferred source indicators, MRP relevance flags, and validity periods. Controls which suppliers MRP can automatically generate purchase requisitions for. Aligned with SAP MM Source List (ME01/EORD).' .

ind:QuotaArrangement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Quota Arrangement' ;
    rdfs:comment 'Defines the split of procurement volume across multiple approved suppliers for a given material and plant. Captures quota percentages per supplier, quota base quantity, cumulative allocated quantities, and validity period. Supports multi-source supply strategies, risk diversification, and competitive supplier management. Aligned with SAP MM Quota Arrangement (MEQ1/EQUK).' .

ind:Class rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Class' ;
    rdfs:comment 'Reference classification taxonomy for manufacturing assets defining asset categories (e.g., CNC Machining Center, Industrial Robot, PLC Controller, HVAC System, Power Transformer), depreciation class, maintenance strategy class, and regulatory inspection requirements. Used for standardized asset categorization across EAM and ERP systems.' .

ind:MaintenancePlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Maintenance Plan' ;
    rdfs:comment 'Defines preventive and time-based maintenance strategies for equipment assets including TPM schedules, inspection intervals, lubrication cycles, calibration frequencies, and regulatory inspection plans. Captures maintenance strategy type (time-based, counter-based, condition-based), cycle parameters, lead times, and scheduling horizon. Sourced from SAP PM Maintenance Plans and Maximo EAM PM Programs.' .

ind:MaintenanceItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Maintenance Item' ;
    rdfs:comment 'Individual maintenance task items within a maintenance plan, defining the specific inspection, lubrication, replacement, or calibration activity to be performed on a piece of equipment at a defined interval. Captures task list reference, work center assignment, estimated duration, required materials, and safety instructions. Supports TPM task decomposition.' .

ind:AssetNotification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Asset Notification' ;
    rdfs:comment 'Maintenance notification records capturing equipment malfunction reports, damage notifications, activity requests, and operator-initiated fault reports from the shop floor. Serves as the upstream trigger for work order creation. Captures notification type (M1-malfunction, M2-activity, M3-inspection), reported damage, cause codes, and breakdown indicators. Sourced from SAP PM Notifications (QMEL) and Maximo EAM Service Requests.' .

ind:MeasurementPoint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Measurement Point' ;
    rdfs:comment 'Defines measurement points and counter positions on equipment for condition monitoring, counter-based maintenance triggering, and IIoT sensor data integration. Captures measurement point category (counter, characteristic), unit of measure, upper/lower limits, and MindSphere sensor binding. Enables condition-based maintenance and predictive analytics via Siemens MindSphere.' .

ind:MeasurementReading rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Measurement Reading' ;
    rdfs:comment 'Time-series transactional records of actual measurement readings and counter readings captured at defined measurement points on manufacturing equipment. Includes readings from manual inspections, automated IIoT sensors via MindSphere, and SCADA system integrations. Captures reading value, unit, reading timestamp, source system, and threshold breach indicators for condition-based maintenance triggering.' .

ind:FailureRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Failure Record' ;
    rdfs:comment 'Structured records of equipment failures, breakdowns, and fault events capturing failure mode, failure cause, failure effect, damage code, and MTBF/MTTR data points. Supports FMEA analysis, reliability engineering, and TPM loss tracking. Links to work orders and notifications to form a complete failure history for each asset. Enables OEE downtime categorization and Six Sigma reliability improvement programs.' .

ind:AssetBom rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Asset Bom' ;
    rdfs:comment 'Equipment Bill of Materials defining the hierarchical spare parts and sub-component structure of manufacturing assets. Captures parent-child component relationships, part numbers, quantities, installation positions, and criticality ratings. Enables MRO spare parts planning, maintenance task material requirements, and equipment configuration management. Distinct from the engineering product BOM managed in Teamcenter PLM.' .

ind:WorkOrderOperation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Work Order Operation' ;
    rdfs:comment 'Individual operation steps within a maintenance work order defining the sequence of maintenance tasks, craft/skill requirements, estimated and actual labor hours, work center assignments, and operation-level completion status. Enables detailed labor planning, multi-craft coordination, and operation-level progress tracking within complex maintenance work orders.' .

ind:CalibrationRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Calibration Record' ;
    rdfs:comment 'Calibration and metrology records for precision manufacturing equipment, measurement instruments, gauges, and test equipment. Captures calibration date, calibration standard used, as-found and as-left values, calibration result (pass/fail), next due date, calibration certificate reference, and accredited laboratory details. Supports ISO 9001 QMS calibration control requirements and regulatory compliance.' .

ind:AssetValuation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Asset Valuation' ;
    rdfs:comment 'Financial valuation records for capital assets capturing acquisition cost, current book value, accumulated depreciation, depreciation method, useful life, residual value, and asset capitalization date. Supports CAPEX/OPEX tracking, IFRS/GAAP fixed asset accounting, and asset impairment assessments. Sourced from SAP FI-AA (Fixed Asset Accounting) module and linked to the finance domain general ledger.' .

ind:Warranty rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Warranty' ;
    rdfs:comment 'Warranty coverage records for manufacturing equipment and components capturing OEM warranty terms, warranty start and expiration dates, covered components, warranty claim procedures, and warranty claim history. Tracks both original equipment warranties and extended service agreements. Enables warranty cost recovery, maintenance decision support (warranty vs. repair), and supplier warranty performance tracking.' .

ind:ServiceContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Service Contract' ;
    rdfs:comment 'OEM and third-party maintenance service contract records covering manufacturing equipment. Captures contract scope, covered assets, SLA terms (response time, uptime guarantees), contract value, billing frequency, included services (preventive maintenance, emergency response, spare parts), and contract performance metrics. Distinct from customer-facing service contracts managed in the service domain — this covers vendor-side maintenance contracts for owned assets.' .

ind:TaskList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Task List' ;
    rdfs:comment 'Standardized maintenance task list templates (general, equipment-specific, and functional location-specific) defining the sequence of operations, required materials, tools, safety instructions, and estimated durations for recurring maintenance activities. Serves as the reusable template library for work order generation and maintenance plan assignment. Supports SOP standardization and TPM task standardization across plants.' .

ind:StockPosition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Stock Position' ;
    rdfs:comment 'SSOT for current inventory positions across all SKUs, storage locations, plants, and distribution centers. Captures on-hand quantity, reserved quantity, available-to-promise (ATP) quantity, WIP stock, and in-transit stock for raw materials, finished goods, semi-finished goods, and MRO items. Aligned with SAP S/4HANA MM stock overview and Infor WMS inventory balance records.' .

ind:StorageLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Granular storage location master defining aisles, racks, bins, shelves, and zones within a warehouse or plant. Captures location code, warehouse association, zone type (bulk, pick, reserve, quarantine, hazmat), bin dimensions, weight capacity, temperature zone, and active status. Supports putaway and picking strategies in Infor WMS and SAP WM storage bin management.' .

ind:Transaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Transaction' ;
    rdfs:comment 'Transactional record of every inventory movement event including goods receipts (GRN), goods issues, stock transfers, returns, scrapping, production confirmations, and adjustments. Captures movement type, quantity, unit of measure, source and destination locations, reference document (PO, production order, sales order), posting date, batch number, and posting user. Aligned with SAP MM material document and Infor WMS transaction history.' .

ind:StockTransfer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Transfer' ;
    rdfs:comment 'Records inter-plant, inter-warehouse, and inter-location stock transfer orders and their execution. Captures transfer order number, transfer type (plant-to-plant, warehouse-to-warehouse, storage location transfer, STO), source plant/warehouse/location, destination plant/warehouse/location, SKU, quantity, transfer status, planned date, actual transfer date, and transport reference. Aligned with SAP MM STO and Infor WMS transfer order.' .

ind:CycleCount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Cycle Count' ;
    rdfs:comment 'Manages cycle counting programs for continuous physical inventory verification without full warehouse shutdowns. Captures count cycle ID, warehouse, count zone, SKU scope, count frequency (daily, weekly, monthly), ABC class trigger, scheduled count date, actual count date, count status (planned, in-progress, completed, reconciled), assigned counter, and variance threshold. Aligned with SAP MM cycle counting configuration and Infor WMS cycle count module.' .

ind:CycleCountResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Cycle Count Result' ;
    rdfs:comment 'Captures the detailed results of each cycle count event at the SKU and storage location level. Records counted quantity, system book quantity, variance quantity, variance percentage, count date and time, counter identity, recount flag, recount quantity, approval status, and adjustment posting reference. Drives inventory accuracy KPIs and triggers stock adjustment postings when variances exceed tolerance. Aligned with SAP MM physical inventory document items.' .

ind:StockAdjustment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Adjustment' ;
    rdfs:comment 'Records approved inventory adjustments made to correct book stock quantities following cycle counts, physical inventories, quality holds, or write-offs. Captures adjustment number, SKU, storage location, adjustment type (count variance, damage write-off, quality rejection, system correction), adjusted quantity, reason code, financial impact, approver, approval date, and reference document. Aligned with SAP MM inventory difference posting.' .

ind:LotBatch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Lot Batch' ;
    rdfs:comment 'Master record for material lots and production batches tracked through inventory. Captures batch number, SKU, manufacturing date, expiry date, shelf life remaining, supplier batch reference, country of origin, quality inspection status (unrestricted, quality hold, blocked, restricted), batch classification characteristics, and storage conditions. Supports FIFO/FEFO picking strategies and traceability requirements. Aligned with SAP MM batch master.' .

ind:ReorderPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Reorder Policy' ;
    rdfs:comment 'Defines reorder parameters and replenishment policies for each SKU at each plant or warehouse location. Captures reorder point (ROP), safety stock level, minimum order quantity (MOQ), maximum stock level, economic order quantity (EOQ), replenishment lead time, MRP type (reorder point, MRP, consumption-based), and review cycle. Drives automated replenishment triggers in SAP MRP and Infor WMS min/max replenishment.' .

ind:ReplenishmentOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Replenishment Order' ;
    rdfs:comment 'Tracks internal replenishment requests and warehouse replenishment orders generated to move stock from reserve storage to pick locations or from bulk storage to forward pick areas. Captures replenishment order number, trigger type (min/max, kanban, manual), source location, destination location, SKU, requested quantity, replenishment status (open, in-progress, completed), priority, and completion timestamp. Aligned with Infor WMS replenishment module.' .

ind:InventoryValuation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Inventory Valuation' ;
    rdfs:comment 'Captures the financial valuation of inventory positions by SKU, plant, and valuation class at period-end and on-demand. Records valuation method (standard cost, moving average price, FIFO, LIFO), standard price, moving average price, total stock value, currency, valuation date, price control indicator, and last price change date. Supports COGS calculation, balance sheet inventory reporting, and period-end closing. Aligned with SAP MM material valuation (MBEW).' .

ind:WipStock rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Wip Stock' ;
    rdfs:comment 'Tracks Work-In-Progress (WIP) inventory at the production order and operation level, capturing materials that have been issued to production but not yet confirmed as finished goods. Records production order reference, operation step, WIP quantity, WIP valuation, plant, cost center, WIP status (open, partially confirmed, fully confirmed), and expected completion date. Bridges the inventory and production domains for accurate WIP reporting. Aligned with SAP PP/CO WIP calculation.' .

ind:QuarantineHold rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Quarantine Hold' ;
    rdfs:comment 'Manages inventory items placed under quality hold, quarantine, or blocked stock status pending inspection, disposition, or regulatory clearance. Captures hold reference number, SKU, batch, quantity, storage location, hold type (quality inspection, customer return, regulatory hold, damage hold), hold reason, initiating document (NCR, GRN, customer complaint), hold start date, expected release date, disposition decision (accept, rework, scrap, return to vendor), and release authorization. Aligned with SAP QM usage decision and Infor WMS hold management.' .

ind:SerializedUnit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Serialized Unit' ;
    rdfs:comment 'Master record for individually serialized inventory items tracked at the unit level rather than quantity level. Captures serial number, SKU, batch, current storage location, plant, serial number status (in stock, issued to production, shipped, returned, scrapped), manufacturing date, warranty start date, and last movement date. Supports traceability for high-value components, electrification equipment, and automation systems. Aligned with SAP MM serial number management.' .

ind:PhysicalInventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Physical Inventory' ;
    rdfs:comment 'Manages full physical inventory count events (annual or periodic wall-to-wall counts) at the warehouse or plant level. Captures physical inventory document number, warehouse/plant scope, count type (full count, partial count, spot check), planned count date, actual count date, count status (created, counting, completed, posted), total SKUs in scope, counted SKUs, variance count, total variance value, and approval status. Distinct from cycle_count which manages continuous rolling counts. Aligned with SAP MM physical inventory document.' .

ind:EngineeringBom rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Engineering Bom' ;
    rdfs:comment 'Bill of Materials header record defining the structured product assembly hierarchy for each finished good, sub-assembly, or configurable automation system. Captures BOM type (engineering BOM, manufacturing BOM, service BOM), effectivity dates, revision level, BOM status, and the owning product or assembly. Links to Siemens Teamcenter BOM Management and SAP PP BOM. SSOT for product structure definitions.' .

ind:BomLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Bom Line' ;
    rdfs:comment 'Individual line-item within a Bill of Materials defining each child component, quantity, unit of measure, reference designator, find number, item category (stock, non-stock, document), scrap factor, and effectivity date range. Supports multi-level BOM explosion for MRP and production planning. Sourced from Siemens Teamcenter BOM line items and SAP PP BOM item records.' .

ind:Bop rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Bop' ;
    rdfs:comment 'Bill of Process header record defining the sequence of manufacturing operations, work centers, and process steps required to produce a finished assembly or sub-assembly. Captures process type (standard, alternate), revision level, effectivity dates, cycle time, takt time, and linkage to the corresponding engineering BOM. SSOT for process structure feeding Siemens Opcenter MES and SAP PP routing.' .

ind:BopOperation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Bop Operation' ;
    rdfs:comment 'Individual operation step within a Bill of Process defining the work center, operation description, standard values (setup time, machine time, labor time), control key, inspection characteristics, tooling requirements, and SOP reference. Supports PFMEA linkage and shop floor instruction generation. Sourced from SAP PP routing operations and Teamcenter manufacturing process steps.' .

ind:CadModel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Cad Model' ;
    rdfs:comment 'Master record for CAD/CAM design models and 3D geometry files managed within the PLM/PDM system. Captures model number, CAD tool (e.g., NX, CATIA, SolidWorks), file format, revision, lifecycle state (in-work, released, frozen), design owner, associated component or assembly, model type (3D solid, 2D drawing, simulation), and digital twin linkage. Sourced from Siemens Teamcenter Document Management.' .

ind:Drawing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Drawing' ;
    rdfs:comment 'Master record for formal engineering drawings and technical documents including assembly drawings, detail drawings, wiring diagrams, and schematics. Captures drawing number, title, revision level, drawing type, sheet count, scale, tolerance standard, approval status, release date, and associated component or assembly. Managed in Siemens Teamcenter Document Management and linked to SAP DMS.' .

ind:Ecn rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Ecn' ;
    rdfs:comment 'Engineering Change Notice header record capturing the formal initiation and approval of a proposed change to a component, BOM, drawing, or process. Records ECN number, change title, change type (design, process, material, regulatory), initiator, priority, affected items, reason for change (e.g., CAPA-driven, cost reduction, obsolescence), estimated implementation cost, and current workflow state (draft, review, approved, rejected, implemented). SSOT for engineering change governance in Teamcenter Change Management.' .

ind:Eco rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Eco' ;
    rdfs:comment 'Engineering Change Order record representing the formal authorization and implementation instruction derived from an approved ECN. Captures ECO number, linked ECN, implementation scope (affected BOM revisions, drawing revisions, routing revisions), effectivity type (date-based, serial number-based, lot-based), implementation deadline, responsible engineer, and completion status. Drives BOM and routing updates in SAP PP and Teamcenter.' .

ind:ChangeAffectedItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Change Affected Item' ;
    rdfs:comment 'Association record linking an ECN or ECO to each specific item (component, BOM, drawing, routing, document) affected by the engineering change. Captures the affected item type, item identifier, old revision, new revision, change action (revise, obsolete, create), and implementation status. Enables full traceability of what changed, when, and why across the product structure.' .

ind:Dfmea rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Dfmea' ;
    rdfs:comment 'Design Failure Mode and Effects Analysis record capturing the structured risk assessment of potential design failures for a component or assembly. Records DFMEA number, revision, scope (component or system level), each failure mode, potential effect, severity rating, potential cause, occurrence rating, current design controls, detection rating, RPN (Risk Priority Number), recommended actions, and responsible engineer. Supports APQP and PPAP deliverables. Managed in Teamcenter and linked to quality domain.' .

ind:Pfmea rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Pfmea' ;
    rdfs:comment 'Process Failure Mode and Effects Analysis record capturing the structured risk assessment of potential process failures for each manufacturing operation in the Bill of Process. Records PFMEA number, revision, linked BOP operation, failure mode, potential effect on product quality, severity, potential cause, occurrence, current process controls, detection rating, RPN, recommended actions, and CAPA linkage. Feeds SPC control plans and Opcenter quality inspection plans.' .

ind:ProductSpecification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Product Specification' ;
    rdfs:comment 'Master record for formal product technical specifications defining the functional, performance, environmental, and regulatory requirements for a product or component. Captures specification number, revision, specification type (functional, interface, material, environmental), applicable standards (IEC 61131, CE, RoHS, REACH), parameter name, nominal value, tolerance, unit of measure, and approval status. SSOT for design requirements traceability.' .

ind:MaterialSpecification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Material Specification' ;
    rdfs:comment 'Master record defining approved material standards and chemical composition requirements for raw materials and purchased components used in manufacturing. Captures material specification number, material type, applicable standard (ASTM, DIN, EN), chemical composition limits, mechanical property requirements, surface treatment, RoHS/REACH compliance status, and approved supplier list reference. Feeds procurement qualification and incoming inspection.' .

ind:ApprovedManufacturer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Approved Manufacturer' ;
    rdfs:comment 'Association record defining the Approved Manufacturer List (AML) and Approved Vendor List (AVL) entries for each component, specifying which manufacturers and their specific part numbers are approved for use in production. Captures component reference, manufacturer name, manufacturer part number, approval status, approval date, qualification test reference, and any use restrictions. Critical for procurement qualification and supply chain risk management.' .

ind:PlmLifecycleState rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Plm Lifecycle State' ;
    rdfs:comment 'Reference record defining the authorized lifecycle states and state transition rules for PLM-managed objects (components, BOMs, drawings, CAD models) within the Teamcenter PLM workflow. Captures state code, state name, allowed transitions, required approvals, and applicable object types. Provides the governance framework for product data maturity progression from concept through obsolescence.' .

ind:ProductVariant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Product Variant' ;
    rdfs:comment 'Master record defining configurable product variants and option combinations for automation systems and electrification solutions offered in multiple configurations. Captures variant code, variant description, base product reference, configuration options (voltage, power rating, communication protocol, enclosure class), variant-specific BOM reference, and market applicability. Supports ATO (Assemble to Order) and ETO (Engineer to Order) fulfillment models.' .

ind:SubstituteComponent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Substitute Component' ;
    rdfs:comment 'Association record defining approved substitute or alternate components that can replace a primary component in a BOM when the primary is unavailable or obsolete. Captures the primary component reference, substitute component reference, substitution type (full, conditional, temporary), applicable BOM context, approval status, and any use restrictions or quantity adjustments. Supports MRP exception handling and supply chain resilience.' .

ind:ToolingEquipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Tooling Equipment' ;
    rdfs:comment 'Master record for specialized manufacturing tooling, jigs, fixtures, molds, and test equipment designed or managed by the engineering function. Captures tool number, tool type, associated process operation, design revision, tool material, tool life (shots or cycles), current status (active, under repair, retired), storage location, and calibration requirement flag. Distinct from production asset records owned by the asset domain.' .

ind:LineItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Line Item' ;
    rdfs:comment 'Individual line item within a sales order representing a specific product, automation system, electrification solution, or smart infrastructure component being ordered. Captures line item number, material/SKU number, ordered quantity, confirmed quantity, unit of measure, requested delivery date per line, confirmed delivery date, line item status, net price, gross price, discount, plant assignment, storage location, batch number, ATP/CTP confirmation flag, and schedule line details. Sourced from SAP S/4HANA SD line item tables.' .

ind:Quotation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Quotation' ;
    rdfs:comment 'Commercial quotation issued to a customer or prospect in response to an RFQ/RFP. Captures quotation number, validity start and end dates, customer reference, quoted products and configurations, pricing conditions, discount structures, delivery lead times, payment terms, incoterms, quotation status (draft, submitted, accepted, rejected, expired), win/loss reason, linked opportunity reference, and sales representative. Supports MTO, ETO, and ATO quoting workflows. Sourced from SAP S/4HANA SD quotation module.' .

ind:QuotationLineItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Quotation Line Item' ;
    rdfs:comment 'Individual line item within a commercial quotation detailing a specific product, system, or component being quoted. Captures line number, material/SKU, quoted quantity, unit of measure, list price, quoted net price, discount percentage, delivery lead time, configuration options, technical specifications summary, and line item status. Enables granular pricing and configuration tracking at the item level for complex industrial manufacturing quotations.' .

ind:RfqRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Rfq Request' ;
    rdfs:comment 'Inbound Request for Quotation (RFQ) or Request for Proposal (RFP) received from a customer or prospect. Captures RFQ/RFP number, customer identity, submission date, response due date, project name, application type (factory automation, building electrification, transportation infrastructure), required delivery date, technical requirements summary, quantity requirements, budget indication, evaluation criteria, RFQ status (received, under review, responded, awarded, declined), and assigned sales/application engineer. SSOT for inbound customer RFQ/RFP records.' .

ind:ScheduleLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Schedule Line' ;
    rdfs:comment 'Delivery schedule lines associated with a sales order line item, representing ATP/CTP-confirmed delivery commitments broken into specific dates and quantities. Captures schedule line number, confirmed delivery date, confirmed quantity, delivery block status, goods issue date, transportation planning date, loading date, route, shipping point, and MRP-driven availability confirmation details. Critical for fulfillment scheduling and delivery promise management in multi-plant manufacturing environments. Sourced from SAP S/4HANA SD schedule lines.' .

ind:StatusHistory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Status History' ;
    rdfs:comment 'Chronological audit trail of all status transitions for a sales order throughout its lifecycle from creation to cash. Captures order reference, previous status, new status, status change timestamp, changed by user, change reason code, system of origin (SAP SD, MES, manual), and any associated blocking or release actions. Supports order lifecycle visibility, SLA compliance tracking, and order-to-cash process analytics. Enables full traceability of order progression.' .

ind:OrderConfirmation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Order Confirmation' ;
    rdfs:comment 'Formal order acknowledgment and confirmation document sent to the customer after a sales order is validated, ATP/CTP-checked, and accepted. Captures confirmation number, confirmation date, confirmed delivery dates per line, confirmed quantities, confirmed pricing, any deviations from original order request, confirmation method (email, EDI, portal), customer acknowledgment status, and linked sales order reference. Serves as the contractual commitment record between manufacturer and customer.' .

ind:AtpCommitment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Atp Commitment' ;
    rdfs:comment 'Available-to-Promise (ATP) and Capable-to-Promise (CTP) commitment records generated during order entry to confirm product availability and delivery feasibility. Captures commitment type (ATP or CTP), requested quantity, confirmed quantity, requested delivery date, confirmed delivery date, plant, storage location, MRP area, checking rule applied, backorder quantity, replenishment lead time, and commitment status. Critical for delivery promise accuracy in MTO, MTS, and ATO fulfillment modes. Sourced from SAP S/4HANA ATP/CTP engine.' .

ind:OrderConfiguration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Order Configuration' ;
    rdfs:comment 'Product configuration options and variant selections captured at the order line item level for configurable products such as automation systems, drive systems, and switchgear. Captures configuration ID, linked order line item, product model/base material, selected variant characteristics (voltage rating, enclosure type, communication protocol, motor size, control type), configuration validity, BOM explosion reference, and configuration status. Supports ETO and ATO fulfillment modes where customer-specific configurations drive production. Sourced from SAP S/4HANA variant configuration (VC).' .

ind:PricingCondition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Pricing Condition' ;
    rdfs:comment 'Pricing condition records applied to sales orders and quotations capturing the detailed pricing determination logic. Captures condition type (price list, customer-specific price, discount, surcharge, freight, tax), condition value, currency, calculation type, scale basis, validity period, pricing procedure step, and condition origin (manual, automatic, contract-based). Enables full price transparency and audit trail for industrial manufacturing commercial transactions. Sourced from SAP S/4HANA SD pricing (KONV/KONP).' .

ind:ReturnsOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Returns Order' ;
    rdfs:comment 'Customer returns order (RMA - Return Material Authorization) capturing the reverse logistics and credit process for returned industrial products, components, or systems. Captures return order number, original sales order reference, return reason code (defective, wrong item, over-delivery, warranty return), return quantity, material condition, return plant, credit memo request flag, inspection requirement flag, restocking fee, return status, and customer return authorization number. Sourced from SAP S/4HANA SD returns processing (VA01 - RE order type).' .

ind:BlanketOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Blanket Order' ;
    rdfs:comment 'Long-term blanket or framework order agreement with industrial customers defining committed volumes, pricing, and delivery terms over a contract period. Captures blanket order number, customer identity, validity start and end dates, total committed value, total committed quantity per material, release schedule, consumed quantity to date, remaining open quantity, pricing conditions, delivery plant, and blanket order status. Supports MTS and Kanban-driven replenishment for high-volume industrial customers. Sourced from SAP S/4HANA SD scheduling agreements.' .

ind:FulfillmentPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Fulfillment Plan' ;
    rdfs:comment 'Fulfillment execution plan associated with a sales order or order line item, linking the commercial order to the production, procurement, and logistics actions required to fulfill it. Captures fulfillment plan ID, linked sales order, fulfillment mode (MTO, MTS, ETO, ATO), planned production order reference, planned procurement reference, planned delivery date, actual fulfillment date, fulfillment status, bottleneck flags, and exception alerts. Bridges the order domain with production and supply chain execution.' .

ind:GoodsIssue rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Goods Issue' ;
    rdfs:comment 'Goods issue event record capturing the physical departure of finished goods or components from the manufacturing plant or warehouse against a delivery order. Captures goods issue document number, posting date, delivery reference, material/SKU, issued quantity, unit of measure, storage location, batch number, movement type, plant, cost center, and goods issue status. Represents the inventory reduction event and triggers revenue recognition eligibility in the order-to-cash process. Sourced from SAP S/4HANA MM/SD goods issue posting.' .

ind:Channel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Reference classification of the channels through which industrial manufacturing orders are received and processed. Captures channel code, channel name (direct sales, distributor, OEM partner, e-commerce portal, EDI, field sales, inside sales, agent/rep), channel type, applicable sales organization, commission eligibility flag, EDI standard (EDIFACT, ANSI X12), portal integration reference, and channel status. Used for order routing, commission calculation, and channel performance reporting.' .

ind:Priority rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Reference classification of order priority levels used to manage fulfillment sequencing and resource allocation in industrial manufacturing operations. Captures priority code, priority name (standard, expedite, critical, emergency, strategic account), priority description, target order-to-ship lead time, escalation threshold days, production scheduling weight, warehouse pick priority, and approval required flag for priority upgrades. Supports shop floor scheduling and customer SLA management.' .

ind:CreditCheck rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Credit Check' ;
    rdfs:comment 'Credit check evaluation record performed on a customer sales order to assess credit exposure against approved credit limits. Captures check ID, linked sales order, customer credit account reference, credit check date, credit check type (static, dynamic), current credit exposure, credit limit, available credit, check result (approved, blocked, warning), risk category, credit control area, and release authorization. Supports order-to-cash risk management and financial controls. Sourced from SAP S/4HANA FI credit management.' .

ind:Hierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Hierarchy' ;
    rdfs:comment 'Defines the multi-level commercial product classification tree used across the enterprise — from top-level product division (e.g., Automation Systems, Electrification Solutions, Smart Infrastructure) down through product family, product group, and product line. Each node carries a hierarchy level code, parent node reference, short name, long name, and effective date range. Supports OLAP drill-down, revenue reporting by product line, and catalog navigation. Aligned with SAP S/4HANA product hierarchy configuration.' .

ind:ProductConfiguration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Product Configuration' ;
    rdfs:comment 'Defines valid configurable options and variant rules for engineer-to-order (ETO) and assemble-to-order (ATO) products. Captures configuration model ID, option classes (e.g., voltage, enclosure rating, communication protocol), selectable feature codes, constraint rules (incompatible combinations, mandatory selections), and default values. Supports CPQ (Configure-Price-Quote) processes and links to SAP S/4HANA variant configuration (VC) models and Teamcenter product configurator.' .

ind:Lifecycle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Lifecycle' ;
    rdfs:comment 'Tracks the commercial lifecycle stage of each catalog item over time — from concept and introduction through growth, maturity, decline, end-of-sale, and end-of-life (EOL). Records the lifecycle stage code, effective start and end dates, reason for stage transition, responsible product manager, and planned EOL date. Enables proactive customer communication, inventory wind-down planning, and aftermarket parts availability commitments. Aligned with PLM lifecycle management in Siemens Teamcenter.' .

ind:ProductPriceList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Product Price List' ;
    rdfs:comment 'Master price list entity defining the commercial pricing structure for catalog items. Captures price list name, currency, validity period (effective and expiry dates), price list type (standard list price, distributor price, OEM price, intercompany transfer price), applicable sales organization, and distribution channel. Each price list is the parent container for individual price list items. Supports multi-currency and multi-channel pricing strategies aligned with SAP S/4HANA SD pricing.' .

ind:PriceListItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Price List Item' ;
    rdfs:comment 'Individual line-level pricing record within a price list, associating a specific SKU or catalog item to a unit price, pricing unit of measure, minimum quantity, and scale/tiered pricing breaks. Captures list price, floor price, recommended retail price (RRP), and any surcharge or discount conditions. Supports volume-based pricing tiers (e.g., 1-9 units at $X, 10-99 units at $Y). The authoritative source for base product pricing consumed by order management and CPQ.' .

ind:Category rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Category' ;
    rdfs:comment 'Reference classification taxonomy for grouping catalog items into commercial and operational categories — such as Drive Technology, Motion Control, Industrial Automation, Power Distribution, Building Technologies, and Aftermarket Spare Parts. Each category carries a category code, parent category (supporting multi-level hierarchy), description, applicable industry segment, and whether the category is active for ordering. Used for catalog navigation, spend analytics, and regulatory grouping.' .

ind:RegulatoryCertification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Regulatory Certification' ;
    rdfs:comment 'Records all product-level regulatory certifications and compliance approvals required for market access — including CE Marking, UL Listing, RoHS compliance, REACH substance declarations, CSA, CCC, and EAC certifications. Captures certification type, issuing body, certificate number, scope (product or product family), issue date, expiry date, applicable markets/regions, certification status (valid, expired, under renewal), and the responsible compliance owner. Critical for export control and customer compliance documentation.' .

ind:HazardousSubstance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Hazardous Substance' ;
    rdfs:comment 'Tracks restricted and declarable substances present in catalog items for RoHS, REACH, and other chemical compliance programs. Captures substance name, CAS number, substance concentration (ppm), threshold limit per regulation, applicable regulation (RoHS, REACH SVHC, California Prop 65), declaration type (exemption, substitution, declaration of conformity), and the associated catalog item or component. Supports product compliance documentation and customer material declarations (e.g., IPC-1752A).' .

ind:Document rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Document' ;
    rdfs:comment 'Manages the library of commercial and technical documents associated with catalog items — including datasheets, installation manuals, user guides, safety data sheets (SDS), declaration of conformity (DoC), test reports, and marketing collateral. Captures document type, document number, revision level, language, file format, publication date, applicable product scope, and document status (draft, released, obsolete). Linked to Siemens Teamcenter document management and SAP DMS.' .

ind:Substitution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Substitution' ;
    rdfs:comment 'Defines approved product substitution and supersession relationships between catalog items — capturing when a product is replaced by a newer model, a cross-reference to a competitor equivalent, or an approved alternate SKU for supply continuity. Records substitution type (superseded-by, equivalent, preferred-alternate, cross-reference), effective date, substitution direction (one-way or bidirectional), and the reason code (EOL replacement, cost reduction, performance upgrade). Used by order management for ATP/CTP fallback and by service for spare parts cross-referencing.' .

ind:AftermarketPart rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Aftermarket Part' ;
    rdfs:comment 'Master record for spare parts, replacement components, and MRO items offered through the aftermarket and service channel. Captures aftermarket part number, description, part type (OEM spare, consumable, wear part, repair kit), compatibility scope (applicable equipment models and serial number ranges), supersession chain, average replacement interval (MTBF-based), and stocking classification (critical spare, standard, non-stock). Distinct from the main catalog_item as aftermarket parts follow a separate commercial and logistics channel.' .

ind:SalesOrg rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Sales Org' ;
    rdfs:comment 'Association entity defining which catalog items and SKUs are authorized for sale within specific sales organizations, distribution channels, and divisions — the SAP SD sales org/distribution channel/division (Org/DC/Div) assignment. Captures sales status (active, blocked, phasing-out), minimum order value, delivery plant assignment, item category group, and account assignment group. Governs which products are orderable in which commercial channels and geographies.' .

ind:Plant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Plant' ;
    rdfs:comment 'Defines the manufacturing and storage plant-level attributes for each catalog item — capturing the producing plant, MRP type, MRP controller, lot sizing procedure, safety stock level, reorder point, planned delivery time, in-house production time, and storage conditions. This is the SAP MM plant-level material master view, governing how each product is planned, produced, and stored at each manufacturing facility. Essential for MRP/MRP II planning and production scheduling.' .

ind:Uom rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Uom' ;
    rdfs:comment 'Defines all valid units of measure (UoM) for a catalog item and the conversion factors between them — base unit, order unit, sales unit, delivery unit, and storage unit. Captures the UoM code (ISO 80000), conversion numerator and denominator, and whether the UoM is the base, order, or sales unit. Supports multi-UoM transactions across procurement, production, sales, and logistics. Aligned with SAP S/4HANA UoM conversion configuration.' .

ind:Classification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Stores the assignment of catalog items to industry-standard classification systems and internal classification schemas — including eCl@ss, UNSPSC, ETIM (Electrotechnical Information Model), and custom internal product class codes. Captures classification system name, class code, class version, characteristic assignments (key-value pairs for technical attributes like rated voltage, IP protection class, power rating), and classification date. Enables structured product search, cross-catalog comparison, and EDI/punchout catalog integration.' .

ind:WarrantyPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Warranty Policy' ;
    rdfs:comment 'Defines the standard warranty terms and conditions applicable to catalog items and product families — capturing warranty type (standard, extended, performance guarantee), warranty duration (months), coverage scope (parts only, parts and labor, full replacement), exclusion conditions, warranty registration requirement flag, and applicable geographic markets. Serves as the reference policy for warranty claims processed in the service domain and for customer-facing warranty documentation.' .

ind:WorkCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Work Center' ;
    rdfs:comment 'Master data for manufacturing work centers (SAP PP Work Center / Opcenter Resource). Represents a physical or logical production unit on the shop floor — a machine, assembly cell, production line, or labor group. Stores work center code, description, plant, cost center linkage, capacity category, available capacity (shifts, hours), efficiency rate, utilization rate, setup time, teardown time, queue time, move time, work center type (machine, labor, process), and responsible supervisor. SSOT for work center capacity and routing assignments used in MRP II planning and shop floor scheduling.' .

ind:Routing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Routing' ;
    rdfs:comment 'Master data for manufacturing routings (SAP PP Routing / BoP — Bill of Process). Defines the sequence of operations required to manufacture a product, including operation numbers, work center assignments, standard values (setup time, machine time, labor time), control keys, and inspection characteristics. Supports multiple routing variants (standard, rework, alternate). Links to the engineering BOM and drives MRP II capacity planning, shop floor scheduling, and costing. SSOT for the manufacturing process sequence and standard times.' .

ind:RoutingOperation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Routing Operation' ;
    rdfs:comment 'Individual operation steps within a manufacturing routing. Each record represents a single operation in the production sequence — e.g., machining, welding, assembly, inspection, painting. Stores operation number, operation short text, work center, control key, standard setup time, standard machine time, standard labor time, operation unit, scrap percentage, inspection flag, and long-text instructions. Enables granular shop floor scheduling, capacity loading per operation, and operation-level cost rollup. Child entity of routing.' .

ind:Schedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Schedule' ;
    rdfs:comment 'Planned production schedule generated by MRP II / capacity planning for a planning horizon. Captures planned production quantities per finished good or semi-finished material, per work center, per time bucket (daily/weekly). Stores schedule version, planning horizon start/end, planned order references, capacity load percentage, scheduling strategy (forward/backward), takt time targets, and schedule status (draft, released, frozen). Drives shop floor execution sequencing and feeds ATP/CTP commitments to the order domain. SSOT for the production plan.' .

ind:PlannedOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Planned Order' ;
    rdfs:comment 'MRP/MPS-generated planned order representing a future production requirement before conversion to a production order (SAP PP Planned Order). Stores planned order number, material number, plant, planned quantity, scheduled start date, scheduled finish date, order type (planned order for in-house production vs. purchase requisition), MRP run reference, firming indicator, and conversion status. Acts as the bridge between demand planning and shop floor execution. Converted to production orders upon release.' .

ind:ShopOrderOperation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Shop Order Operation' ;
    rdfs:comment 'Execution-level record for each operation performed against a production order on the shop floor (Opcenter MES Operation / SAP PP Confirmation at operation level). Tracks actual start/finish timestamps, operator ID, work center, machine ID, actual setup time, actual run time, actual labor time, yield quantity, scrap quantity, rework quantity, operation status (queued, active, completed, held), and NC (non-conformance) flag. Provides granular WIP tracking and feeds OEE calculations and actual cost confirmations.' .

ind:ProductionConfirmation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Production Confirmation' ;
    rdfs:comment 'Goods confirmation record posted against a production order upon completion of production activities (SAP PP Goods Receipt / Order Confirmation). Captures confirmed quantity (yield), scrap quantity, rework quantity, confirmation timestamp, confirming operator, work center, movement type, storage location, batch number, and variance reason codes. Triggers inventory postings (WIP to finished goods), actual cost settlement, and order status updates. SSOT for production output quantities and completion events.' .

ind:MaterialStaging rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Material Staging' ;
    rdfs:comment 'Records the staging and issuance of raw materials and components from inventory to the shop floor for a production order (SAP PP Goods Issue / Material Staging). Stores production order reference, component material number, required quantity, issued quantity, staging date/time, storage location, batch number, issuing warehouse, and staging status (planned, staged, issued, short). Tracks material availability on the shop floor and feeds WIP costing. Supports JIT and Kanban material replenishment workflows.' .

ind:OrderStatus rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Lifecycle status history of production orders, capturing every status transition event from creation through closure (SAP PP Order Status / Opcenter Work Order Status History). Stores production order reference, from-status, to-status, transition timestamp, triggered-by user, triggering event (MRP run, manual release, system confirmation, QM hold), and status reason code. Enables full audit trail of order lifecycle, supports SLA tracking for order lead times, and feeds production performance reporting.' .

ind:CapacityRequirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Capacity Requirement' ;
    rdfs:comment 'Capacity requirement records generated by MRP II capacity planning for each work center and time period (SAP PP Capacity Requirements / CM01). Stores work center, planning period (date/shift), required capacity (hours), available capacity (hours), load percentage, order references contributing to the load, capacity category (machine, labor), and overload indicator. Enables capacity leveling, bottleneck identification, and what-if scheduling scenarios. SSOT for work center capacity load visibility.' .

ind:Version rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Version' ;
    rdfs:comment 'Production version master data defining the valid combination of BOM and routing for manufacturing a specific material at a specific plant (SAP PP Production Version). Stores material number, plant, production version code, description, valid-from/valid-to dates, BOM alternative, routing group/counter, lot size range (minimum/maximum), production line, and status (active, inactive). Enables multiple manufacturing methods for the same product and drives MRP II planning with the correct BOM/routing combination.' .

ind:Batch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Batch' ;
    rdfs:comment 'Batch master record for lot-controlled materials produced or consumed in manufacturing (SAP MM/PP Batch Master). Stores batch number, material number, plant, storage location, batch status (unrestricted, quality inspection, blocked, restricted), manufacturing date, expiry date, shelf life, batch classification values (e.g., purity, viscosity, tensile strength), batch origin (internal production vs. external procurement), and certificate of analysis reference. SSOT for batch traceability and genealogy across the production and quality domains.' .

ind:BatchGenealogy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Batch Genealogy' ;
    rdfs:comment 'Tracks parent-child relationships between batches consumed and produced during manufacturing operations, enabling full forward and backward batch traceability (SAP PP Batch Where-Used / Batch Genealogy). Stores parent batch reference, child batch reference, production order reference, operation reference, consumed quantity, produced quantity, relationship type (component-to-assembly, rework, split, merge), and traceability timestamp. Critical for product recall management, quality investigations, and regulatory compliance (ISO 9001, FDA, automotive IATF 16949).' .

ind:DowntimeEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Downtime Event' ;
    rdfs:comment 'Detailed record of unplanned and planned downtime events on the shop floor (Opcenter MES Downtime / MindSphere Asset Downtime). Stores work center/machine, downtime start/end timestamp, total duration (minutes), downtime category (breakdown, planned maintenance, changeover, material shortage, quality hold, operator absence), downtime reason code, responsible department, production order impacted, lost production quantity, and corrective action taken. Feeds TPM programs, MTBF/MTTR calculations, and OEE availability component. Distinct from OEE events in that it captures the full downtime record with root cause.' .

ind:Shift rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Shift' ;
    rdfs:comment 'Reference master for production shift definitions used in shop floor scheduling and OEE calculations. Stores shift code, shift name (e.g., Day Shift, Night Shift, Swing Shift), plant, shift start time, shift end time, shift duration (hours), break schedule, days of week applicability, and effective date range. Used to calculate available production time, assign production orders to shifts, and segment OEE metrics by shift. Distinct from workforce shift scheduling (owned by workforce domain) — this is the production-context shift reference.' .

ind:ScrapRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Scrap Record' ;
    rdfs:comment 'Records of scrap and rework generated during production operations (SAP PP Scrap / Opcenter MES Scrap Reporting). Stores production order reference, operation reference, work center, scrap quantity, scrap reason code, scrap category (process scrap, machine scrap, material defect, operator error), material number, scrap cost, rework flag, rework order reference, and reporting timestamp. Feeds scrap rate KPIs, COGS variance analysis, and quality improvement programs (Six Sigma, CAPA). Distinct from quality NCR records — this captures the production-side scrap event.' .

ind:OrderType rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Reference data defining the types of production orders used in manufacturing operations (SAP PP Order Type). Stores order type code, order type description, production strategy (MTO, MTS, ETO, ATO), settlement rule, costing variant, scheduling type (forward, backward, current date), availability check rule, goods receipt indicator, and applicable plant. Drives default behavior for production order creation and processing. Enables differentiated handling of standard production, rework orders, prototype orders, and co-product orders.' .

ind:Lead rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Lead' ;
    rdfs:comment 'Represents an unqualified prospect or inbound inquiry for industrial automation systems, electrification solutions, or system integration projects. Captures lead source, industry segment, product interest area, qualification status, and conversion tracking. Sourced from Salesforce Sales Cloud. Precursor to a qualified opportunity.' .

ind:AccountPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Account Plan' ;
    rdfs:comment 'Strategic account planning record for key industrial B2B accounts including OEM partners, system integrators, and enterprise end-users. Captures annual revenue targets, strategic objectives, whitespace analysis, competitive positioning, and planned engagement activities per account. Supports direct and channel sales planning cycles.' .

ind:SalesTerritory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Sales Territory' ;
    rdfs:comment 'Defines the geographic, industry-vertical, or named-account sales territory assignments used to organize the field sales force for industrial automation and electrification solutions. Captures territory hierarchy (region, district, area), assigned revenue quota, territory type (geographic/vertical/named), and effective date ranges.' .

ind:TerritoryAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Territory Assignment' ;
    rdfs:comment 'Association entity linking sales representatives or channel partners to specific territories with defined roles, effective periods, and quota allocations. Supports split-territory scenarios common in large industrial project sales where multiple reps collaborate on a single account or geography.' .

ind:Quota rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Quota' ;
    rdfs:comment 'Defines periodic revenue, margin, and unit sales quotas assigned to individual sales representatives, channel partners, or territory teams for industrial product lines and solution categories. Tracks quota type (revenue/units/margin), period (monthly/quarterly/annual), product family scope, and attainment basis.' .

ind:SalesPriceList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Sales Price List' ;
    rdfs:comment 'Master price list defining standard list prices for industrial automation products, electrification solutions, and aftermarket parts — consolidated with product domain as SSOT owner' .

ind:DiscountStructure rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Discount Structure' ;
    rdfs:comment 'Defines approved discount frameworks applicable to industrial product lines, customer segments, and sales channels. Captures discount type (trade/volume/project/promotional), maximum discount percentage, approval authority level, applicable product families, and validity period. Governs discount authorization in the sales process.' .

ind:Forecast rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Forecast' ;
    rdfs:comment 'Periodic sales forecast record capturing projected revenue, units, and margin by product family, territory, and time period. Supports rolling forecast cycles (monthly/quarterly) for industrial automation and electrification product lines. Tracks forecast version, submission date, confidence level, and variance to quota. Feeds S&OP and financial planning.' .

ind:Activity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Activity' ;
    rdfs:comment 'Transactional record of sales engagement activities including customer visits, product demonstrations, technical presentations, RFQ/RFP responses, and follow-up actions associated with an opportunity or account. Captures activity type, date, participants, outcome, and next steps. Sourced from Salesforce Activity Management.' .

ind:Competitor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Competitor' ;
    rdfs:comment 'Master reference record for competitors tracked in the industrial automation and electrification market. Captures competitor name, product lines, market segments, geographic presence, known strengths and weaknesses, and win/loss context. Used in opportunity competitive analysis and sales strategy planning.' .

ind:OpportunityCompetitor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Opportunity Competitor' ;
    rdfs:comment 'Association entity linking a specific competitor to a sales opportunity, capturing the competitive scenario details including competitor product proposed, win/loss outcome, loss reason, and competitive displacement strategy. Enables win/loss analysis across the industrial sales pipeline.' .

ind:Team rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Team' ;
    rdfs:comment 'Defines the composition of a sales team assigned to a major industrial project opportunity or key account, capturing team member roles (account executive, application engineer, solution architect, commercial manager), contribution percentages for commission splits, and team lead designation.' .

ind:Campaign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Campaign' ;
    rdfs:comment 'Defines targeted sales campaigns for industrial product launches, end-of-life promotions, solution bundles, or vertical market initiatives. Captures campaign type, target segment, associated product families, campaign period, revenue target, and assigned budget. Links to leads and opportunities generated through the campaign.' .

ind:Supplier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Supplier' ;
    rdfs:comment 'Master record for all suppliers, vendors, and sub-contractors engaged in sourcing raw materials, components, subassemblies, and MRO supplies. Captures supplier identity, classification, qualification status, risk tier, payment terms, diversity classification, and global registration details as managed in SAP Ariba Supplier Management. Serves as the SSOT for supplier identity within the procurement domain.' .

ind:Contract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Contract' ;
    rdfs:comment 'Master record for all procurement contracts and supplier agreements including blanket purchase agreements, long-term supply agreements, frame contracts, and spot buy contracts. Captures contract type, spend category, contracted value, validity period, payment terms, Incoterms, penalty clauses, renewal options, and compliance obligations. Managed via SAP Ariba Contract Management.' .

ind:PurchaseRequisition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Purchase Requisition' ;
    rdfs:comment 'Internal procurement request generated by production planning (MRP), maintenance (MRO), or business units requesting materials, components, or services. Captures requestor, cost center, material/service description, required quantity, required delivery date, preferred supplier, and approval workflow status. Sourced from SAP S/4HANA MM module (ME51N).' .

ind:PurchaseOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Purchase Order' ;
    rdfs:comment 'Formal PO issued to a supplier authorizing the supply of materials, components, subassemblies, or MRO items at agreed terms. Captures PO type (standard, blanket release, subcontracting), supplier, plant, delivery address, payment terms, Incoterms, total PO value, currency, and approval status. Core transactional entity in SAP S/4HANA MM (ME21N).' .

ind:GoodsReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Goods Receipt' ;
    rdfs:comment 'Records the physical receipt of goods against a purchase order at a plant or warehouse location. Captures GRN (Goods Receipt Note) number, received quantity, receiving plant, storage location, batch number, quality inspection flag, and posting date. Triggers inventory update and initiates three-way match for invoice verification in SAP S/4HANA MM (MIGO).' .

ind:SupplierInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Supplier Invoice' ;
    rdfs:comment 'Supplier-submitted invoice for goods or services delivered against a PO. Captures invoice number, invoice date, invoiced amount, tax amount, currency, payment due date, three-way match status (PO-GRN-Invoice), discrepancy flags, and payment block reasons. Processed via SAP S/4HANA MM Invoice Verification (MIRO) and linked to accounts payable in Finance.' .

ind:SpendCategory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Spend Category' ;
    rdfs:comment 'Hierarchical classification taxonomy for all procurement spend categories including direct materials (raw materials, components, subassemblies), indirect materials (MRO, facilities), and services (contract manufacturing, logistics). Captures category code, category level, parent category, commodity code (UNSPSC), responsible category manager, and strategic sourcing strategy. Supports category management and spend analytics.' .

ind:PreferredSupplierList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Preferred Supplier List' ;
    rdfs:comment 'Maintains the approved and preferred supplier registry per spend category, plant, and region. Captures supplier preference tier (preferred, approved, conditional, restricted), valid period, category scope, sourcing strategy alignment, and the business rationale for preference designation. Enforces procurement policy by directing buyers to qualified, strategically aligned suppliers.' .

ind:InspectionPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Inspection Plan' ;
    rdfs:comment 'Master definition of quality inspection plans specifying inspection characteristics, sampling methods, AQL levels, measurement techniques, and acceptance criteria for a given part, operation, or process stage. Sourced from SAP QM inspection plan master data. Serves as the template governing all inspection lot execution.' .

ind:InspectionLot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Inspection Lot' ;
    rdfs:comment 'Transactional record of a quality inspection event triggered by a production order, goods receipt, or delivery. Captures lot origin, inspection type, quantity, status, usage decision, and results summary. Core operational entity in SAP QM representing each discrete inspection execution instance.' .

ind:InspectionResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Inspection Result' ;
    rdfs:comment 'Detailed measurement and characteristic result records captured during inspection lot execution. Stores individual measured values, attribute conformance decisions, SPC data points, Cp/Cpk indices per characteristic, and inspector sign-off. Enables traceability from lot to individual measurement.' .

ind:UsageDecision rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Usage Decision' ;
    rdfs:comment 'Records the formal quality usage decision made at the conclusion of an inspection lot — accept, reject, conditional release, or scrap. Captures decision code, decision date, responsible quality engineer, stock posting instruction, and any associated NCR reference. Drives downstream inventory posting in SAP QM.' .

ind:Capa rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Capa' ;
    rdfs:comment 'Corrective and Preventive Action (CAPA) record managing the full workflow from root cause analysis through action implementation and effectiveness verification. Tracks problem statement, root cause method (5-Why, Ishikawa), assigned owner, target closure date, verification evidence, and recurrence status. Supports ISO 9001 Clause 10.2 compliance.' .

ind:Fmea rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Fmea' ;
    rdfs:comment 'Failure Mode and Effects Analysis (FMEA) master record capturing design or process risk assessments. Stores function, potential failure mode, effect, severity (S), occurrence (O), detection (D), RPN score, recommended actions, and revised RPN after mitigation. Supports both DFMEA and PFMEA per AIAG/VDA methodology.' .

ind:ControlPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Control Plan' ;
    rdfs:comment 'Quality Control Plan master record defining the process controls, inspection frequency, reaction plans, and measurement systems for each manufacturing process step. Links to PFMEA, process flow, and inspection plan. Core APQP deliverable used in PPAP submissions and ongoing production quality governance.' .

ind:PpapSubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Ppap Submission' ;
    rdfs:comment 'Production Part Approval Process (PPAP) submission package record tracking the status and completeness of all required PPAP elements (design records, PFMEA, control plan, MSA, capability studies, FAI, etc.) for a given part and supplier. Captures submission level, customer approval status, and PSW (Part Submission Warrant) details.' .

ind:FaiRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Fai Record' ;
    rdfs:comment 'First Article Inspection (FAI) record documenting the dimensional, material, and functional verification of the first production part against engineering drawings and specifications. Captures balloon drawing reference, measured vs. nominal values, AS9102 / customer-specific form completion status, and approval disposition.' .

ind:SpcChart rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Spc Chart' ;
    rdfs:comment 'Statistical Process Control (SPC) chart master record defining the control chart configuration for a monitored process characteristic — chart type (Xbar-R, Xbar-S, p-chart, c-chart), subgroup size, sampling frequency, UCL/LCL control limits, and Cp/Cpk targets. Governs ongoing SPC monitoring in Siemens Opcenter MES Quality module.' .

ind:SpcSample rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Spc Sample' ;
    rdfs:comment 'Individual SPC data point record capturing a subgroup sample measurement collected during production for a monitored characteristic. Stores sample timestamp, measured values, subgroup mean, range/standard deviation, control limit violations, out-of-control signal flags (Western Electric rules), and operator ID. Feeds real-time SPC monitoring.' .

ind:DefectCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Defect Code' ;
    rdfs:comment 'Reference master for standardized defect classification codes used across NCRs, inspection results, and scrap/rework transactions. Captures defect code, defect category (dimensional, surface, functional, material, assembly), defect family, applicable process stage, and ISO/customer standard mapping. Ensures consistent defect taxonomy enterprise-wide.' .

ind:Characteristic rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Characteristic' ;
    rdfs:comment 'Master record for quality characteristics (CTQ — Critical to Quality features) defined for parts, assemblies, or processes. Captures characteristic name, type (dimensional, functional, visual, material), nominal value, tolerance limits, measurement unit, gauge type, and classification (critical, major, minor). Referenced by inspection plans, control plans, and SPC charts.' .

ind:Gauge rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Gauge' ;
    rdfs:comment 'Gauge and measurement instrument master record for all measuring equipment used in quality inspection. Captures gauge ID, description, gauge type (CMM, caliper, micrometer, go/no-go, torque wrench), calibration interval, last calibration date, next due date, calibration status, and assigned location. Supports ISO 9001 Clause 7.1.5 measurement resource management.' .

ind:GaugeCalibration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Gauge Calibration' ;
    rdfs:comment 'Calibration event record for each gauge or measurement instrument calibration activity. Captures calibration date, calibration lab (internal/external), calibration standard used, as-found and as-left condition, pass/fail result, calibration certificate number, and next scheduled calibration date. Provides full MSA and traceability audit trail.' .

ind:CustomerComplaint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Customer Complaint' ;
    rdfs:comment 'Customer quality complaint record capturing field quality issues reported by customers or OEM partners. Stores complaint reference, customer ID, affected product/serial number, failure description, warranty status, 8D problem-solving workflow status, containment actions, root cause, corrective action, and customer satisfaction closure. Links to CAPA and NCR.' .

ind:QualityNotification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Quality Notification' ;
    rdfs:comment 'SAP QM Quality Notification record used to formally document and manage quality problems, complaints, and improvement requests within the enterprise. Captures notification type (internal defect, customer complaint, supplier defect), priority, affected object (material, equipment, order), task list, and processing status. Central workflow trigger in SAP QM.' .

ind:Certificate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Certificate' ;
    rdfs:comment 'Quality certificate (Certificate of Conformance / Certificate of Analysis) record issued for a manufactured batch, lot, or shipment. Captures certificate type (CoC, CoA, material test report), issuing plant, part number, batch/lot number, test results summary, applicable standards met, authorized signatory, and customer-specific certificate requirements.' .

ind:ShipmentItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Shipment Item' ;
    rdfs:comment 'Line-level detail for each SKU or material included within a shipment. Records part number, quantity shipped, unit of measure, net/gross weight, package count, hazardous classification (REACH/RoHS flags), country of origin, and customs tariff code (HS code). Enables item-level traceability from sales order line to physical delivery.' .

ind:Carrier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Carrier' ;
    rdfs:comment 'Master record for all approved freight carriers and logistics service providers (LSPs) used across road, rail, air, and ocean modes. Stores carrier SCAC code, IATA/IATA code, DOT/MC number, carrier type, service modes offered, insurance certificate details, contract reference, performance tier, and active/inactive status. SSOT for carrier identity used in TMS route planning and freight audit.' .

ind:CarrierService rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Carrier Service' ;
    rdfs:comment 'Defines the specific service offerings provided by each carrier, such as LTL, FTL, express parcel, ocean FCL/LCL, air freight, and intermodal. Captures service code, transit time commitments, service lane coverage (origin-destination pairs), cut-off times, dimensional weight rules, and applicable surcharge types. Used in TMS carrier selection and rate shopping.' .

ind:FreightOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Freight Order' ;
    rdfs:comment 'Operational freight order issued to a carrier for execution of one or more shipments. Represents the contractual transport instruction including pickup/delivery windows, load instructions, special handling requirements, freight cost estimate, confirmed freight charges, and carrier booking reference. Maps to SAP TM Freight Order and is the primary operational document for carrier execution.' .

ind:TransportPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Transport Plan' ;
    rdfs:comment 'TMS-generated transportation plan that consolidates shipment demands into optimized load plans and route assignments. Captures planning horizon, optimization objective (cost, time, CO2), total planned loads, planned carrier mix, planned freight spend, and plan status (draft, confirmed, executed). Supports MRP II-aligned distribution requirements planning (DRP) and freight budget management.' .

ind:Route rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Route' ;
    rdfs:comment 'Master definition of a transportation lane or route between an origin location and a destination location. Stores origin/destination location codes, transport mode, distance (km/miles), standard transit days, preferred carrier, route type (direct, hub-and-spoke, multimodal), and active status. Used as the reference backbone for TMS route optimization and freight rate assignment.' .

ind:RouteStop rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Route Stop' ;
    rdfs:comment 'Individual stop or waypoint within a multi-leg or milk-run route. Records stop sequence, location code, planned arrival/departure timestamps, dwell time, stop type (pickup, delivery, cross-dock, customs), and actual arrival/departure for on-time performance tracking. Enables granular visibility into multi-stop freight movements.' .

ind:Delivery rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Delivery' ;
    rdfs:comment 'Outbound delivery document confirming physical dispatch of goods to a customer, distribution center, or interplant transfer destination. Captures delivery date, actual ship date, proof-of-delivery (POD) reference, delivery status, goods issue posting date, packing list reference, and any short-ship or over-ship variances. SSOT for delivery confirmation linked to SAP SD outbound delivery.' .

ind:InboundDelivery rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Inbound Delivery' ;
    rdfs:comment 'Inbound delivery document tracking the receipt of purchased materials, components, or MRO goods from suppliers. Records expected arrival date, actual GRN date, supplier reference, purchase order reference, receiving location, quantity received vs. ordered, and discrepancy flags. Feeds SAP MM GRN processing and inventory replenishment in Infor WMS.' .

ind:TrackingEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Tracking Event' ;
    rdfs:comment 'Real-time and milestone-based shipment tracking events captured from carrier EDI feeds, IIoT telematics, GPS, and TMS integrations. Records event type (departed, in-transit, customs-cleared, out-for-delivery, delivered, exception), event timestamp, location (GPS coordinates or location code), carrier event code, and exception description. Enables end-to-end shipment visibility and OTIF performance measurement.' .

ind:FreightRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Freight Rate' ;
    rdfs:comment 'Contracted and spot freight rate records negotiated with carriers for specific lanes, service levels, and commodity types. Stores rate type (base rate, fuel surcharge, accessorial), rate basis (per kg, per pallet, per container, per mile), currency, effective/expiry dates, minimum charge, and rate source (contract, spot, benchmark). Used in TMS freight cost estimation and freight audit.' .

ind:FreightInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Freight Invoice' ;
    rdfs:comment 'Carrier-issued freight invoice submitted for payment of transportation services rendered. Captures invoice number, carrier reference, invoice date, billing period, total invoiced amount, currency, line-level charge breakdown (base freight, fuel surcharge, accessorials), and payment status. Subject to freight audit and match against contracted freight rates before approval for payment.' .

ind:Packaging rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Packaging' ;
    rdfs:comment 'Master record for packaging configurations and container types used in freight operations, including pallets, cartons, crates, drums, IBCs, and ISO containers. Stores packaging type code, dimensions (L×W×H), tare weight, max payload, stackability flag, hazmat compatibility, returnable/disposable flag, and unit cost. Used in load planning, dimensional weight calculation, and packaging compliance.' .

ind:Location rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Location' ;
    rdfs:comment 'Master record for all physical locations participating in the logistics network, including manufacturing plants, distribution centers, cross-dock facilities, customer delivery points, supplier pickup points, ports of entry, and customs bonded warehouses. Stores location code, location type, address, GPS coordinates, operating hours, dock capacity, and customs bonded status. SSOT for logistics network node identity.' .

ind:FreightContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Freight Contract' ;
    rdfs:comment 'Master freight contract negotiated with a carrier or LSP defining the commercial terms, rate structures, service commitments, SLA penalties, volume commitments, and contract duration. Stores contract number, contract type (spot, annual, multi-year), effective/expiry dates, minimum volume commitment, rate escalation clauses, and contract status. Distinct from individual freight rates — this is the governing commercial agreement.' .

ind:ChartOfAccounts rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Chart Of Accounts' ;
    rdfs:comment 'Authoritative master list of all general ledger account codes used across Manufacturing legal entities. Defines account number, account name, account type (asset, liability, equity, revenue, expense), financial statement line mapping, IFRS/GAAP classification, cost element linkage, and consolidation group assignment. Supports multi-chart configurations for local statutory versus group IFRS reporting.' .

ind:ControllingArea rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'Master configuration entity defining the controlling area scope within SAP CO, representing the organizational unit within which cost accounting is performed. Captures controlling area code, name, assigned company codes, fiscal year variant, currency type, cost center standard hierarchy, and CO version settings. Governs the boundaries for internal cost allocation, profitability analysis, and management reporting.' .

ind:FiscalPeriod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Reference master defining the fiscal calendar periods used for financial posting and reporting across all legal entities. Captures fiscal year, period number, period name, calendar start and end dates, period status (open/closed), posting period variant, and special period indicators for year-end adjustments. Controls which periods are open for journal entry posting and drives period-end close workflows.' .

ind:JournalEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry' ;
    rdfs:comment 'Core transactional record capturing every financial posting made to the general ledger across all Manufacturing legal entities. Records document number, document type, posting date, document date, fiscal year, fiscal period, reference document, posting key, reversal indicator, source system, currency, exchange rate, and posting user. The atomic unit of the double-entry bookkeeping system and the foundation for all financial statements. Sourced from SAP S/4HANA FI.' .

ind:JournalEntryLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry Line' ;
    rdfs:comment 'Individual line item within a journal entry document, representing a single debit or credit posting to a GL account. Captures line item number, GL account, debit/credit indicator, amount in transaction currency, amount in local currency, amount in group currency, cost center, profit center, WBS element, business area, tax code, assignment field, and line item text. Provides the granular detail required for account analysis, cost allocation, and audit trails.' .

ind:ApInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Ap Invoice' ;
    rdfs:comment 'Transactional record for vendor/supplier invoices received and processed through the accounts payable function. Captures invoice number, vendor reference, invoice date, posting date, payment due date, gross amount, tax amount, net amount, payment terms, payment block indicator, discount terms, three-way match status (PO/GRN/invoice), withholding tax details, and payment method. Sourced from SAP S/4HANA MM-FI integration and SAP Ariba.' .

ind:ArInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Ar Invoice' ;
    rdfs:comment 'Transactional record for customer invoices issued by Manufacturing for goods and services delivered. Captures invoice number, billing document reference, customer account, invoice date, due date, payment terms, gross amount, tax amount, net amount, revenue recognition status, dunning level, clearing status, and dispute indicator. Sourced from SAP S/4HANA SD-FI billing integration. Distinct from billing.invoice which manages the billing generation process; this record represents the AR open item and cash collection lifecycle.' .

ind:Payment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Payment' ;
    rdfs:comment 'Transactional record capturing outgoing and incoming payment transactions processed through the finance function. Records payment document number, payment date, payment method (bank transfer, check, ACH, SEPA), payment amount, currency, exchange rate, bank account used, clearing document references, payment run identifier, and payment status. Covers both AP payment runs to suppliers and AR cash receipts from customers. Sourced from SAP S/4HANA FI payment program.' .

ind:BankAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Bank Account' ;
    rdfs:comment 'Master record for all corporate bank accounts held by Manufacturing legal entities across global banking institutions. Captures bank account number, IBAN, SWIFT/BIC code, bank name, bank country, account currency, account type (current, deposit, payroll), house bank identifier, cash pool membership, signatory details, and account status. Used for payment processing, cash positioning, and treasury operations.' .

ind:AssetTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Asset Transaction' ;
    rdfs:comment 'Transactional record capturing all financial movements on fixed assets including acquisitions, retirements, transfers, write-downs, and depreciation postings. Records transaction type, posting date, amount, depreciation area, document reference, and asset value date. Provides the complete financial history of each capitalized asset for CAPEX reporting, impairment testing, and audit compliance.' .

ind:CostAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Cost Allocation' ;
    rdfs:comment 'Transactional record capturing internal cost allocation and assessment cycles executed during period-end close. Records allocation cycle name, sender cost center or cost element group, receiver cost center or profit center, allocation method (percentage, equivalence numbers, statistical key figures), allocated amount, allocation date, and fiscal period. Supports overhead absorption, shared service cost distribution, and management reporting accuracy.' .

ind:ProductCostEstimate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Product Cost Estimate' ;
    rdfs:comment 'Standard cost estimate records for manufactured products and assemblies, capturing the planned cost of goods manufactured (COGM) broken down by cost components (material, labor, machine, overhead). Records costing variant, costing version, base quantity, material cost, activity cost, overhead cost, total standard cost, costing status, and validity dates. Feeds standard cost rolls into inventory valuation and COGS calculation. Sourced from SAP S/4HANA CO-PC.' .

ind:ProductionOrderCost rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Production Order Cost' ;
    rdfs:comment 'Actual cost collection record for manufacturing production orders, capturing the real costs incurred during shop floor execution versus the standard cost estimate. Records planned cost, actual material cost, actual labor cost, actual machine cost, actual overhead cost, variance amount, variance category, settlement status, and WIP value. Enables manufacturing cost variance analysis, COGS accuracy, and production efficiency reporting. Sourced from SAP S/4HANA CO-PC-OBJ.' .

ind:ProfitabilitySegment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Profitability Segment' ;
    rdfs:comment 'Master record defining the profitability analysis (CO-PA) segments used for contribution margin and EBITDA reporting. Captures segment characteristics including customer, product, sales organization, distribution channel, region, industry, and business area combinations. Enables multi-dimensional profitability analysis by product line, customer segment, geography, and sales channel in alignment with IFRS 8 segment reporting requirements.' .

ind:CurrencyExchangeRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Currency Exchange Rate' ;
    rdfs:comment 'Reference master for foreign currency exchange rates used across all financial transactions and consolidation processes. Captures currency pair (from/to currency), exchange rate type (spot, average, closing, budget), valid-from date, exchange rate value, rate source (ECB, Reuters, internal), and rate status. Supports multi-currency transaction recording, foreign currency revaluation, and group consolidation translation under IAS 21.' .

ind:TaxCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shared ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Reference master defining tax codes and tax rates applicable to financial transactions across all Manufacturing jurisdictions. Captures tax code, tax type (input/output VAT, withholding tax, sales tax), tax rate percentage, tax jurisdiction, validity dates, GL account assignment for tax postings, and reporting category. Supports VAT compliance, tax return preparation, and cross-border transaction tax determination.' .

ind:Request rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Request' ;
    rdfs:comment 'Customer-initiated service and support case records capturing post-sale technical issues, complaints, warranty claims, product defects, and general after-sales inquiries for automation systems, electrification solutions, and smart infrastructure components. Tracks case origin channel (phone, email, portal, field), severity classification, case category, assigned support engineer, escalation history, resolution steps, root cause, and closure details. Sourced from Salesforce Service Cloud. Serves as the primary SSOT for customer support interactions in the aftermarket domain.' .

ind:WarrantyClaim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Warranty Claim' ;
    rdfs:comment 'Transactional records for warranty claims submitted against Manufacturing products including automation systems, PLCs, drives, switchgear, and electrification components. Captures claim submission date, product serial number, failure description, failure mode, defect code, claim type (repair, replacement, credit), claim status, approved/rejected decision, warranty coverage validation, repair cost, replacement part details, and claim settlement amount. Linked to the installed base and product catalog. Managed in SAP S/4HANA QM and Salesforce Service Cloud.' .

ind:ContractLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Contract Line' ;
    rdfs:comment 'Individual line items within a customer service contract defining the specific covered equipment, service scope, and pricing for each covered asset or service bundle. Captures line item number, covered equipment serial number or installed base reference, service type, unit price, quantity, discount, line value, coverage start and end dates, and SLA parameters applicable to that line. Enables granular tracking of multi-equipment service contracts and supports contract profitability analysis at the line level.' .

ind:SlaCommitment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Sla Commitment' ;
    rdfs:comment 'Defines the specific SLA performance commitments and thresholds applicable to service contracts, service request categories, and customer tiers. Captures SLA name, SLA type (response time, resolution time, uptime guarantee, first-time fix rate), target metric value, measurement unit, breach threshold, escalation trigger, applicable customer segment, applicable product category, and penalty terms for breach. Serves as the reference standard against which actual service performance is measured. Distinct from customer.sla_agreement which records the contractual SLA agreement at the customer account level.' .

ind:SlaTracking rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Sla Tracking' ;
    rdfs:comment 'Transactional records tracking real-time SLA compliance status for individual service requests and field service orders against their committed SLA targets. Captures the associated service request or field service order reference, SLA commitment reference, SLA start timestamp, response due timestamp, resolution due timestamp, actual response timestamp, actual resolution timestamp, current SLA status (on-track, at-risk, breached), breach duration, breach reason code, and escalation flag. Enables proactive SLA management and breach prevention workflows in Salesforce Service Cloud.' .

ind:Technician rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Technician' ;
    rdfs:comment 'Master records for field service technicians and service engineers deployed to customer sites for installation, commissioning, repair, and maintenance of automation and electrification products. Captures technician employee ID, name, skill certifications (PLC programming, drive commissioning, HMI configuration, electrical safety), product line competencies, geographic service territory, current availability status, base location, vehicle assignment, and active work order count. Distinct from workforce.employee which is the HR master — this entity captures service-domain-specific competency and dispatch attributes not held in the HR system.' .

ind:ServiceTerritory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Service Territory' ;
    rdfs:comment 'Geographic service territory definitions used to assign field service orders and technicians to customer sites based on location. Captures territory name, territory code, geographic boundaries (country, region, state, city, postal code ranges), assigned service center, territory manager, active technician count, and coverage hours. Supports optimal dispatch routing and workload balancing across the field service network. Used in Salesforce Field Service for territory-based scheduling and capacity planning.' .

ind:DispatchSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Dispatch Schedule' ;
    rdfs:comment 'Scheduling and dispatch records assigning field service technicians to field service orders within defined time windows. Captures the assigned technician, field service order reference, scheduled start datetime, scheduled end datetime, estimated travel time, actual arrival datetime, actual departure datetime, dispatch status (scheduled, en-route, on-site, completed, cancelled), scheduling method (manual, auto-optimized), and dispatcher notes. Sourced from Salesforce Field Service scheduling engine. Enables real-time visibility into technician deployment and field workforce utilization.' .

ind:SparePartsRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Spare Parts Request' ;
    rdfs:comment 'Transactional records for spare parts and MRO materials requested to fulfill field service orders and warranty repairs for customer-installed automation and electrification equipment. Captures the originating field service order or warranty claim, requested part number, part description, quantity requested, urgency level, requested delivery date, source warehouse, fulfillment status, actual quantity issued, and shipment reference. Distinct from inventory domain stock management — this entity captures the service-driven demand signal and fulfillment tracking specific to aftermarket operations.' .

ind:SparePartsCatalog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Spare Parts Catalog' ;
    rdfs:comment 'Master catalog of spare parts and aftermarket components available for service and repair of Manufacturing\'s automation systems, electrification solutions, and smart infrastructure products. Captures part number, part description, compatible product families, supersession chain (old part to new part), list price, lead time, minimum order quantity, hazardous material flag, shelf life, storage conditions, and availability status. Serves as the aftermarket parts reference for field service engineers and customer self-service portals. Complements inventory.sku which manages stock positions — this entity manages the commercial aftermarket catalog definition.' .

ind:InstallationRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Installation Record' ;
    rdfs:comment 'Records of product installation and commissioning activities performed at customer sites for automation systems, electrification solutions, PLC panels, drives, switchgear, and smart infrastructure components. Captures installation date, site address, installed product serial number, installation type (new installation, upgrade, replacement), commissioning engineer, commissioning checklist completion status, FAI (First Article Inspection) result, customer sign-off status, handover documentation reference, and warranty activation date. Feeds the installed base registry and triggers warranty start.' .

ind:Report rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Report' ;
    rdfs:comment 'Field service completion reports generated by technicians upon completing a field service order at a customer site. Captures the associated field service order, work performed narrative, equipment condition found, parts replaced (part numbers and quantities), labor hours by activity type, test results and measurements, safety observations, customer signature and acceptance, and recommendations for follow-up work. Serves as the official record of service delivery and is shared with the customer as proof of service. Required for warranty claim substantiation and service billing.' .

ind:Entitlement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Entitlement' ;
    rdfs:comment 'Defines the specific service entitlements granted to customer accounts based on their active service contracts, product warranties, or support tier subscriptions. Captures entitlement name, entitlement type (warranty, contract, support tier), covered product or product family, number of service incidents included, remaining incident balance, entitlement start and end dates, SLA tier reference, and entitlement status. Used in Salesforce Service Cloud to automatically validate whether a customer is entitled to service before a case is accepted, preventing unauthorized service consumption.' .

ind:KnowledgeArticle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Knowledge Article' ;
    rdfs:comment 'Technical knowledge base articles authored by service engineers and product specialists to document solutions to common field issues, troubleshooting procedures, product-specific repair guides, and best practices for automation and electrification products. Captures article title, article type (troubleshooting guide, repair procedure, product bulletin, FAQ), applicable product family, symptom description, root cause, resolution steps, related part numbers, author, review status, publication date, and usage count. Enables first-call resolution improvement and supports self-service customer portals.' .

ind:ContractCoverage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Contract Coverage' ;
    rdfs:comment 'This association product represents the Contract (coverage assignment) between service_contract and maintenance_plan. It captures the formal scope definition of which maintenance plans are covered under a given vendor service contract, including the specific terms, visit allocations, and priority levels that apply to each plan-contract pairing. Each record links one service_contract to one maintenance_plan with attributes that exist only in the context of this coverage relationship — such as how many PM visits are allocated to that plan under that contract, and the effective coverage dates for that specific pairing.. Existence Justification: In industrial manufacturing EAM, a single service contract (e.g., a vendor OEM agreement) explicitly covers multiple maintenance plans — for example, Contract SC-2024-001 covers PM Plan MP-CNC-001, MP-CNC-002, and MP-HVAC-003 at Plant A. Conversely, a single maintenance plan (e.g., a quarterly lubrication cycle for a CNC machine) can be covered by multiple service contracts over its lifetime, or simultaneously by overlapping contracts (e.g., an OEM contract for parts and a third-party contract for labor). The business actively manages this coverage scope as a formal assignment — procurement and maintenance teams create, update, and terminate these coverage records as contracts are negotiated and plans are revised.' .

ind:ComponentToolingAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Component Tooling Assignment' ;
    rdfs:comment 'This association product represents the Assignment relationship between a BOM line item (component) and a tooling/equipment master record. It captures which specific tools are required to manufacture a given component, including the role of each tool, its setup sequence, effectivity window, and the plant where the assignment applies. Each record links one bom_line to one tooling_equipment with attributes that exist only in the context of this component-tool pairing. Supports PPAP qualification, tooling planning, and MRP tooling requirement explosion.. Existence Justification: In industrial manufacturing, a BOM line item (component) genuinely requires multiple specialized tools simultaneously — e.g., a machined part needs a fixture, a cutting tool, and a gauge — while each tool is shared across many different BOM components across different assemblies and plants. This is an operationally managed relationship: engineering teams actively create, update, and retire component-tooling assignments as part of PPAP qualification, tooling planning, and production readiness. The relationship carries its own data (usage type, setup sequence, effectivity dates, plant scope) that belongs to neither the BOM line nor the tool master alone.' .

ind:PricingCoverageAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Pricing Coverage Assignment' ;
    rdfs:comment 'This association product represents the Contract between account_hierarchy and pricing_agreement. It captures the formal assignment of a negotiated pricing agreement to a specific account hierarchy node (subsidiary, division, or affiliate), defining the scope, validity period, approval status, and exclusivity of that coverage. Each record links one account_hierarchy node to one pricing_agreement with attributes that exist only in the context of this specific node-agreement assignment. Feeds SAP S/4HANA condition record scoping and global account management workflows.. Existence Justification: In industrial manufacturing, global pricing agreements are negotiated at the corporate parent level but must be explicitly applied to specific entities within the account hierarchy (subsidiaries, divisions, affiliates). A single pricing agreement covers multiple hierarchy nodes (e.g., all EMEA subsidiaries of a global OEM), and a given hierarchy node may be covered by multiple pricing agreements for different product lines or agreement types. This is an operationally managed relationship — commercial teams actively create, maintain, and expire these assignments as part of account management and SAP S/4HANA condition record management.' .

ind:PreferredSupplier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Preferred Supplier' ;
    rdfs:comment 'This association product represents the Contract/Approval between a supplier and a spend category within the Preferred Supplier List (PSL) governance process. It captures which suppliers are approved and preferred for each spend category, along with the tier ranking, spend allocation percentage, validity period, and strategic designation. Each record links one supplier to one spend category and carries attributes that exist only in the context of this sourcing preference relationship — they cannot reside on the supplier or spend_category master records alone.. Existence Justification: In industrial manufacturing procurement, a supplier is approved and preferred for multiple spend categories (e.g., a fastener supplier may be preferred for both raw materials and MRO), and each spend category has multiple approved/preferred suppliers with different tiers, allocation percentages, and validity periods. The Preferred Supplier List (PSL) is a formally governed business concept in strategic sourcing — procurement teams actively create, review, and expire PSL entries as part of category management. This is not an analytical correlation; it is an operational record that procurement managers maintain in systems like SAP Ariba.' .

ind:CashApplication rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cash Application' ;
    rdfs:comment 'This association product represents the Cash Application event between payment and ar_invoice. It captures the operational record of how a specific payment amount is applied to a specific AR invoice during the AR clearing process. Each record links one payment to one ar_invoice and carries the cleared amount, discount taken, and remittance reference that exist only in the context of this payment-to-invoice matching event. Sourced from SAP S/4HANA FI-AR open item clearing (BSAD/BSID tables).. Existence Justification: In manufacturing AR operations, cash application (payment-to-invoice matching) is a genuine operational M:N business process. A single customer remittance payment covers multiple invoices simultaneously, and a single invoice can receive partial payments across multiple payment runs over its lifecycle. This is not an analytical correlation — AR teams actively create, manage, and reconcile these clearing records as part of daily collections operations.' .

# --- Attribute Properties ---
ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual contact record in the silver layer, serving as the primary key for the contact data product.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:mailingAddressId rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Id' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: contact stores mailing_city and mailing_state_province as denormalized address fields. The address product is the authoritative repository for all physical and mailing addresses. Adding mailing_addres' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:ccpaOptOut rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out' ;
    rdfs:comment 'Indicates whether the contact has exercised their CCPA right to opt out of the sale or sharing of their personal information. Applicable to contacts who are California residents.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country where the contact is primarily located or operates. Used for regional segmentation, compliance jurisdiction determination, and territory assignment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when the contact record was first created in the source system (Salesforce CRM). Used for data lineage, audit trails, and measuring time-to-contact from lead acquisition.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:crmContactCode rdf:type rdf:Property ;
    rdfs:label 'Crm Contact Code' ;
    rdfs:comment 'Native record identifier from Salesforce CRM (Contact object ID, e.g., 003XXXXXXXXXXXXXXX), used for cross-system traceability and lineage back to the source system of record.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectRequestStatus rdf:type rdf:Property ;
    rdfs:label 'Data Subject Request Status' ;
    rdfs:comment 'Tracks the status of any active data subject rights request (access, deletion, portability, rectification) submitted by this contact under GDPR or CCPA. Supports privacy compliance workflows.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Organizational department or functional unit the contact belongs to within their company (e.g., Engineering, Procurement, Operations, Finance, Quality). Supports targeted communication and account mapping.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary business email address of the contact, used for commercial communications, order notifications, service updates, and marketing campaigns. Sourced from Salesforce CRM Contact object.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailOptIn rdf:type rdf:Property ;
    rdfs:label 'Email Opt In' ;
    rdfs:comment 'Indicates whether the contact has opted in to receive marketing and commercial email communications. Must be true before any marketing emails are sent. Supports GDPR and CCPA compliance.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailOptOut rdf:type rdf:Property ;
    rdfs:label 'Email Opt Out' ;
    rdfs:comment 'Indicates whether the contact has explicitly opted out of all marketing email communications. When true, the contact must be excluded from all commercial email campaigns regardless of opt-in status.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given name of the individual contact as recorded in Salesforce CRM. Used for personalized communication and salutation in customer-facing correspondence.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentDate rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Date' ;
    rdfs:comment 'Date on which the contact granted or last updated their GDPR consent. Required for audit and compliance purposes to demonstrate lawful basis for data processing under GDPR.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Status' ;
    rdfs:comment 'Current GDPR consent status for processing this contact\'s personal data. Tracks whether consent has been granted, withdrawn, is pending collection, or is not applicable (e.g., for contacts outside GDPR jurisdiction).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDecisionMaker rdf:type rdf:Property ;
    rdfs:label 'Is Decision Maker' ;
    rdfs:comment 'Indicates whether this contact holds decision-making authority for purchasing, contracting, or technical approvals within their organization. Critical for sales qualification and opportunity management in B2B industrial sales cycles.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInfluencer rdf:type rdf:Property ;
    rdfs:label 'Is Influencer' ;
    rdfs:comment 'Indicates whether this contact is identified as a key influencer in the purchasing or technical evaluation process, even if they do not hold final decision-making authority. Supports multi-stakeholder account management strategies.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this contact is designated as the primary point of contact for the associated customer account. Only one contact per account should be flagged as primary for a given role.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Official job title or position of the contact within their organization (e.g., Plant Manager, Procurement Manager, Engineering Lead, VP of Operations). Used for segmentation, routing, and persona-based engagement.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent logged activity (call, email, meeting, task) associated with this contact in Salesforce CRM. Used to measure contact engagement recency and identify dormant contacts for re-engagement.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastContactedDate rdf:type rdf:Property ;
    rdfs:label 'Last Contacted Date' ;
    rdfs:comment 'Date on which a sales or service representative last made direct contact with this individual (distinct from last_activity_date which includes all logged activities). Supports contact cadence management and SLA tracking.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the contact record in the source system (Salesforce CRM). Used for change data capture (CDC), incremental data loads, and audit compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family name or surname of the individual contact. Combined with first_name to form the full display name for reporting, CRM, and correspondence.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'Channel or origin through which this contact was first acquired or entered the CRM system. Used for marketing attribution, pipeline analysis, and ROI measurement of demand generation activities.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinProfileUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile Url' ;
    rdfs:comment 'URL of the contact\'s LinkedIn professional profile. Used by sales and account management teams for social selling, relationship intelligence, and contact verification in B2B industrial markets.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile or cell phone number for the contact, used for urgent communications, field service coordination, and SMS notifications. Distinct from the primary office phone.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Most recent Net Promoter Score (NPS) survey response from this contact, on a scale of 0-10. Used to measure individual contact loyalty and satisfaction, and to identify promoters, passives, and detractors within key accounts.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary business phone number for the contact, typically a direct office line or switchboard extension. Used for sales outreach, service escalations, and account management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneOptOut rdf:type rdf:Property ;
    rdfs:label 'Phone Opt Out' ;
    rdfs:comment 'Indicates whether the contact has opted out of phone-based outreach including sales calls and telemarketing. Supports compliance with do-not-call regulations and GDPR consent requirements.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-1 language code (optionally with ISO 3166-1 country subtag) representing the contact\'s preferred language for communications, documentation, and support (e.g., en-US, de-DE, fr-FR, zh-CN).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Record Effective Date' ;
    rdfs:comment 'Date from which the current version of the contact record is considered valid in the silver layer. Supports slowly changing dimension (SCD) type 2 history tracking and point-in-time reporting for analytics and compliance.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportsToName rdf:type rdf:Property ;
    rdfs:label 'Reports To Name' ;
    rdfs:comment 'Full name of the contact\'s direct manager or superior within the customer organization. Used to understand organizational hierarchy and identify escalation paths within the account.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:role rdf:type rdf:Property ;
    rdfs:label 'Role' ;
    rdfs:comment 'Business role classification of the contact within the customer engagement model. Identifies whether the contact is a technical evaluator, commercial decision-maker, executive sponsor, or operational user. Drives sales strategy and communication routing.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salutation rdf:type rdf:Property ;
    rdfs:label 'Salutation' ;
    rdfs:comment 'Formal honorific or title prefix used when addressing the contact in written or verbal communication (e.g., Mr., Dr., Eng.). Supports professional etiquette in B2B industrial contexts.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapBusinessPartnerNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Business Partner Number' ;
    rdfs:comment 'SAP S/4HANA Business Partner identifier corresponding to this contact, enabling cross-system linkage between Salesforce CRM contact records and SAP ERP business partner master data for order management and billing.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this contact record was originally sourced or created. Supports data lineage, master data management, and deduplication workflows.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:status rdf:type rdf:Property ;
    rdfs:label 'Status' ;
    rdfs:comment 'Current lifecycle status of the contact record. Indicates whether the contact is actively engaged, inactive, flagged as do-not-contact, or has been merged into another record.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Id' ;
    rdfs:comment 'Unique surrogate identifier for each parent-child account hierarchy relationship record in the Databricks Silver Layer. Serves as the primary key for the account_hierarchy data product.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountHierarchy .

ind:accountClassificationId rdf:type rdf:Property ;
    rdfs:label 'Account Classification Id' ;
    rdfs:comment 'Foreign key linking to customer.account_classification. Business justification: account_hierarchy carries customer_classification and industry_sector_code as denormalized STRING attributes. account_classification is the authoritative multi-dimensional classification record for cu' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountClassification .

ind:salesAreaAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Sales Area Assignment Id' ;
    rdfs:comment 'Foreign key linking to customer.sales_area_assignment. Business justification: account_hierarchy stores sales_organization_code as a STRING, which is a denormalized reference to the SAP sales area configuration. Adding sales_area_assignment_id links the corporate hierarchy node ' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesAreaAssignment .

ind:slaAgreementId rdf:type rdf:Property ;
    rdfs:label 'Sla Agreement Id' ;
    rdfs:comment 'Foreign key linking to customer.sla_agreement. Business justification: account_hierarchy carries a denormalized sla_tier STRING that references the governing SLA tier for the corporate hierarchy. Adding sla_agreement_id as a FK to sla_agreement normalizes this relationsh' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaAgreement .

ind:accountGroupCode rdf:type rdf:Property ;
    rdfs:label 'Account Group Code' ;
    rdfs:comment 'SAP S/4HANA account group classification code assigned to the child account within this hierarchy, controlling field selection, number ranges, and partner functions. Examples include KUNA (one-time customer), DEBI (domestic customer), EXPO (export customer).' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date on which this hierarchy relationship was formally approved by the designated authority. Used for audit trail, compliance reporting, and governance of corporate account structure changes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or employee identifier of the business authority (e.g., Global Account Director, Credit Manager) who approved the establishment or modification of this hierarchy relationship. Supports governance, audit trail, and segregation of duties requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childAccountCode rdf:type rdf:Property ;
    rdfs:label 'Child Account Code' ;
    rdfs:comment 'Business identifier of the child (subordinate) account in the hierarchy relationship, sourced from SAP S/4HANA or Salesforce CRM. Represents the subsidiary, division, affiliate, or regional entity reporting up to the parent.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidatedCreditLimit rdf:type rdf:Property ;
    rdfs:label 'Consolidated Credit Limit' ;
    rdfs:comment 'Maximum credit exposure amount approved for the child account within the context of this hierarchy relationship, expressed in the credit_limit_currency. Used for consolidated credit exposure tracking across subsidiaries and global account credit risk management in SAP S/4HANA FI Credit Management.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consolidationMethod rdf:type rdf:Property ;
    rdfs:label 'Consolidation Method' ;
    rdfs:comment 'Accounting method applied to consolidate the child account\'s financials into the parent\'s financial statements. Determined by ownership percentage and control assessment per IFRS 10 and GAAP ASC 810. Drives credit exposure aggregation and financial reporting roll-up logic.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference number of the master contract or framework agreement governing the commercial relationship between the parent and child accounts within this hierarchy. Links to the contract management system for terms, pricing, and SLA enforcement.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the consolidated credit limit assigned to this hierarchy node. Supports multi-currency credit exposure management across global enterprise accounts.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The date from which this parent-child hierarchy relationship is valid and active. Used for time-based hierarchy queries, historical roll-up reporting, and compliance with IFRS/GAAP consolidation period requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'The date on which this parent-child hierarchy relationship ceases to be valid, typically due to corporate restructuring, divestiture, merger, or acquisition. A null value indicates the relationship is currently active with no planned end date.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:globalAccountManager rdf:type rdf:Property ;
    rdfs:label 'Global Account Manager' ;
    rdfs:comment 'Name or employee identifier of the global account manager responsible for managing the parent-level account relationship. Used for accountability tracking, escalation routing, and global account management reporting in Salesforce CRM.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Code' ;
    rdfs:comment 'Business-assigned alphanumeric code uniquely identifying this hierarchy relationship, used for cross-system referencing in SAP S/4HANA SD and Salesforce CRM account hierarchy structures.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyDepth rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Depth' ;
    rdfs:comment 'Total number of levels in the hierarchy tree rooted at the ultimate parent account. Indicates the structural complexity of the corporate group. Distinct from hierarchy_level which represents the position of the child; this represents the full tree depth.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric depth level of the child account within the corporate hierarchy tree, where level 1 represents the ultimate parent (global headquarters). Used for roll-up reporting, credit exposure aggregation, and global account management analytics.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Delimited string representing the full ancestry path from the root (ultimate parent) to the current child account, e.g., \'ROOT_CODE/REGION_CODE/COUNTRY_CODE/CHILD_CODE\'. Enables efficient tree traversal and ancestor lookups in analytics and reporting.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyType rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Type' ;
    rdfs:comment 'Classifies the purpose or dimension of the hierarchy relationship. \'Corporate\' reflects legal ownership structure; \'sales\' reflects sales territory or account management grouping; \'credit\' reflects credit consolidation grouping; \'reporting\' reflects management reporting roll-up; \'legal\' reflects legal entity structure; \'operational\' reflects operational management grouping.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDirectRelationship rdf:type rdf:Property ;
    rdfs:label 'Is Direct Relationship' ;
    rdfs:comment 'Indicates whether the parent-child relationship in this record is a direct (immediate) relationship (true) or an indirect/derived relationship representing a non-adjacent ancestor-descendant link in the hierarchy (false). Enables distinction between direct and transitive hierarchy edges for graph traversal and reporting.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryHierarchy rdf:type rdf:Property ;
    rdfs:label 'Is Primary Hierarchy' ;
    rdfs:comment 'Indicates whether this hierarchy relationship is the primary (authoritative) hierarchy for the child account when multiple hierarchy types exist (e.g., corporate vs. sales vs. credit). Ensures unambiguous roll-up path selection for consolidated reporting.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for capturing additional context, business rationale, or special instructions related to this hierarchy relationship. May include details about corporate restructuring events, exceptions to standard hierarchy rules, or account management notes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of ownership or equity stake held by the parent account in the child account entity. Critical for IFRS 10/GAAP ASC 810 consolidation determination (>50% typically triggers full consolidation), credit exposure weighting, and financial risk assessment.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentAccountCode rdf:type rdf:Property ;
    rdfs:label 'Parent Account Code' ;
    rdfs:comment 'Business identifier of the parent account in the hierarchy relationship, sourced from SAP S/4HANA customer master (SD) or Salesforce CRM. Represents the superior entity (e.g., global headquarters, holding company) in the corporate structure.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Internal regional classification code (e.g., EMEA, APAC, AMER, LATAM) assigned to the child account for geographic segmentation, regional reporting, and global account management analytics.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Classifies the nature of the corporate relationship between the parent and child accounts. Drives legal, financial, and credit consolidation rules. Examples include subsidiary (majority-owned), division (internal business unit), affiliate (minority-owned), joint venture, branch, or distributor.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restructuringReason rdf:type rdf:Property ;
    rdfs:label 'Restructuring Reason' ;
    rdfs:comment 'Reason code explaining why this hierarchy relationship was created, modified, or terminated. Captures corporate events such as mergers, acquisitions, divestitures, spin-offs, or internal reorganizations. Critical for audit trail and financial consolidation history.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootAccountCode rdf:type rdf:Property ;
    rdfs:label 'Root Account Code' ;
    rdfs:comment 'Business identifier of the ultimate parent account at the top of the corporate hierarchy (level 1). Used for consolidated credit exposure tracking, global account management, and enterprise-wide roll-up reporting across all subsidiaries and affiliates.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'Native record identifier of this hierarchy relationship in the originating source system (e.g., SAP S/4HANA account hierarchy node ID or Salesforce CRM account relationship ID). Enables traceability and reconciliation between the Silver Layer and operational systems.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying each address record in the customer address repository.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:accessRestriction rdf:type rdf:Property ;
    rdfs:label 'Access Restriction' ;
    rdfs:comment 'Indicates any access restrictions applicable to this address for deliveries or service visits. Common in industrial manufacturing environments where plant sites require security clearance, scheduled appointments, or certified personnel.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attentionLine rdf:type rdf:Property ;
    rdfs:label 'Attention Line' ;
    rdfs:comment 'Attention or care-of line specifying the department, role, or individual to whom correspondence or shipments should be directed at this address (e.g., \'Attn: Procurement Department\', \'c/o Plant Manager\').' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'Name of the city, municipality, or locality where the address is located. Used for logistics routing, tax jurisdiction determination, and regional reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countyDistrict rdf:type rdf:Property ;
    rdfs:label 'County District' ;
    rdfs:comment 'County, district, or sub-regional administrative division of the address. Used for local tax jurisdiction determination and regulatory compliance reporting in jurisdictions where county-level data is required.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsRegionCode rdf:type rdf:Property ;
    rdfs:label 'Customs Region Code' ;
    rdfs:comment 'Customs or trade region code associated with the address, used for export/import compliance, customs duty calculation, and trade zone classification (e.g., free trade zone, bonded warehouse zone).' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Numeric score (0.00–100.00) representing the overall data quality and completeness of the address record, calculated based on validation status, geocoding accuracy, and field completeness. Supports master data governance and data stewardship workflows.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryInstruction rdf:type rdf:Property ;
    rdfs:label 'Delivery Instruction' ;
    rdfs:comment 'Free-text field capturing special delivery instructions for this address, such as dock door numbers, security gate procedures, receiving hours, or hazardous material handling requirements specific to industrial plant sites.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date after which this address record is no longer valid for business use. A null value indicates the address is currently active with no planned expiry. Used for historical address retention and compliance record-keeping.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date from which this address record is valid and active for business use. Supports temporal address management for customers who relocate facilities or open new plant sites.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geocodingAccuracy rdf:type rdf:Property ;
    rdfs:label 'Geocoding Accuracy' ;
    rdfs:comment 'Indicates the precision level of the geocoordinates assigned to the address. Rooftop indicates exact match; range_interpolated and approximate indicate lower precision. Used to assess reliability of location-based analytics.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultBilling rdf:type rdf:Property ;
    rdfs:label 'Is Default Billing' ;
    rdfs:comment 'Indicates whether this address is the default billing address for invoice delivery. Used by accounts receivable and ERP invoicing processes to route financial documents to the correct address.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultShipping rdf:type rdf:Property ;
    rdfs:label 'Is Default Shipping' ;
    rdfs:comment 'Indicates whether this address is the default shipping/delivery destination for the customer. Used by order management and warehouse management systems to pre-populate delivery addresses on sales orders.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Indicates whether this address is the primary/default address for the associated customer account and address type. Only one address per customer per address type should be flagged as primary.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isValidated rdf:type rdf:Property ;
    rdfs:label 'Is Validated' ;
    rdfs:comment 'Indicates whether the address has been validated against a postal authority or address verification service. Validated addresses reduce shipping errors and returned mail for industrial shipments.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'ISO 639-1 language code for the preferred communication language at this address (e.g., en, de, zh-CN, fr). Used to localize shipping documents, invoices, and correspondence for multinational customers.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the address in decimal degrees (WGS 84 datum). Enables geocoding, proximity analysis, logistics route optimization, and plant site mapping for multi-site industrial customers.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line 1' ;
    rdfs:comment 'Primary street address line including building number, street name, and directional indicators. Represents the first line of the physical or mailing address.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line 2' ;
    rdfs:comment 'Secondary address line for suite, floor, unit, building name, or additional location detail supplementing the primary street address.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line3 rdf:type rdf:Property ;
    rdfs:label 'Line 3' ;
    rdfs:comment 'Tertiary address line used for additional location identifiers such as industrial park name, zone designation, or campus building reference, common in large multi-site industrial facilities.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the address in decimal degrees (WGS 84 datum). Used in conjunction with latitude for geocoding, delivery zone assignment, and spatial analytics.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'SAP plant code or equivalent ERP facility identifier associated with this address when the address represents a manufacturing plant or production site. Links the address to production planning and materials management operations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poBox rdf:type rdf:Property ;
    rdfs:label 'Po Box' ;
    rdfs:comment 'Post Office (PO) Box number for mailing addresses where physical delivery is not applicable. Common for billing and remittance addresses of corporate customers.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the address. Supports variable formats across countries (e.g., 5-digit US ZIP, alphanumeric UK postcode). Used for shipping rate calculation, tax zone assignment, and geographic analytics.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'Business name or descriptive label for the physical site at this address (e.g., \'Chicago Assembly Plant\', \'Frankfurt Distribution Center\'). Supports multi-site industrial customers with dozens of named plant locations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemAddressCode rdf:type rdf:Property ;
    rdfs:label 'Source System Address Code' ;
    rdfs:comment 'The native address identifier from the originating source system (e.g., SAP Business Partner Address GUID, Salesforce Account Address ID). Enables cross-system reconciliation and traceability back to the system of record.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or administrative region of the address. Stored as ISO 3166-2 subdivision code (e.g., US-CA, DE-BY) to support global multi-country operations and tax jurisdiction mapping.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Tax jurisdiction identifier assigned to the address for sales tax, VAT, or GST determination. Used by ERP tax engines to calculate applicable tax rates for orders shipped to or billed at this address.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the address location (e.g., America/Chicago, Europe/Berlin). Used for scheduling deliveries, service appointments, and coordinating operations across global plant sites.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:type rdf:type rdf:Property ;
    rdfs:label 'Type' ;
    rdfs:comment 'Classifies the functional purpose of the address (e.g., headquarters, billing, shipping/delivery, plant site, registered office). A single customer account may have multiple address types across its global operations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationSource rdf:type rdf:Property ;
    rdfs:label 'Validation Source' ;
    rdfs:comment 'Identifies the system or service used to validate the address (e.g., USPS CASS, Loqate, Google Maps, manual review). Supports data quality auditing and validation process governance.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'Date and time when the address was last validated against a postal authority or address verification service. Used to schedule re-validation cycles and assess address data freshness.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'Value Added Tax (VAT) or GST registration number associated with this address, particularly for EU and international billing addresses. Required for cross-border B2B invoicing and tax compliance in industrial manufacturing.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Unique system-generated identifier for each customer segment record within the industrial manufacturing CRM and ERP ecosystem.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:campaignEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Campaign Eligibility Flag' ;
    rdfs:comment 'Boolean indicator specifying whether customers classified in this segment are eligible to receive targeted marketing campaigns, promotional offers, and sales outreach programs.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:code rdf:type rdf:Property ;
    rdfs:label 'Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the customer segment, used for cross-system referencing across SAP S/4HANA SD and Salesforce CRM (e.g., TIER1_OEM, STRAT_DIST, SME_END).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractFrameworkRequired rdf:type rdf:Property ;
    rdfs:label 'Contract Framework Required' ;
    rdfs:comment 'Boolean indicator specifying whether customers in this segment must have a formal framework contract or master agreement in place before transacting, as required by commercial policy.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditRiskCategory rdf:type rdf:Property ;
    rdfs:label 'Credit Risk Category' ;
    rdfs:comment 'Credit risk classification assigned to the segment, used to set default credit limits and approval workflows for customer accounts within this segment in SAP S/4HANA FI credit management.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Crm Segment Code' ;
    rdfs:comment 'External identifier for this customer segment as recorded in Salesforce CRM, enabling cross-system reconciliation between the lakehouse silver layer and the CRM system of record.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Consent Required' ;
    rdfs:comment 'Boolean indicator specifying whether explicit data privacy consent must be obtained from customer contacts within this segment before processing their personal data for marketing or analytics purposes.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Detailed narrative describing the business rationale, characteristics, and commercial intent of the customer segment for use in sales strategy documentation and go-to-market planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountRatePercent rdf:type rdf:Property ;
    rdfs:label 'Discount Rate Percent' ;
    rdfs:comment 'Standard percentage discount applied to list prices for customers within this segment as part of the commercial pricing strategy, expressed as a percentage value between 0 and 100.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:erpCustomerGroupCode rdf:type rdf:Property ;
    rdfs:label 'Erp Customer Group Code' ;
    rdfs:comment 'SAP S/4HANA customer group code mapped to this segment, used for pricing condition determination, output determination, and statistical grouping in SD and FI modules.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportControlClassification rdf:type rdf:Property ;
    rdfs:label 'Export Control Classification' ;
    rdfs:comment 'Export control classification applicable to this customer segment, determining whether customers require export licenses or are subject to trade compliance restrictions under US EAR, ITAR, or EU dual-use regulations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Primary geographic region associated with the customer segment using ISO 3166-1 alpha-3 country codes, supporting regional go-to-market strategies and territory management across multinational operations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goToMarketChannel rdf:type rdf:Property ;
    rdfs:label 'Go To Market Channel' ;
    rdfs:comment 'Primary sales and distribution channel through which customers in this segment are engaged and served, informing channel strategy, partner management, and revenue attribution.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryVertical rdf:type rdf:Property ;
    rdfs:label 'Industry Vertical' ;
    rdfs:comment 'The primary industry sector served by customers within this segment, enabling vertical-specific go-to-market strategies, product positioning, and regulatory compliance alignment (e.g., Automotive, Aerospace and Defense, Energy and Utilities).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date on which the most recent formal review of this customer segment was completed, used to track compliance with the defined review cycle and governance obligations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managerEmail rdf:type rdf:Property ;
    rdfs:label 'Manager Email' ;
    rdfs:comment 'Corporate email address of the segment manager responsible for this customer segment, used for escalation routing, review notifications, and campaign coordination.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Full name of the business owner or commercial manager responsible for the strategy, performance, and review of this customer segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'System timestamp recording the most recent update to this customer segment record, used for change tracking, incremental data loads, and audit compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:name rdf:type rdf:Property ;
    rdfs:label 'Name' ;
    rdfs:comment 'Full descriptive name of the customer segment as used in commercial strategy and go-to-market planning (e.g., Tier-1 OEM, Strategic Distributor, SME End-User, System Integrator).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next formal review of this customer segment, enabling proactive governance and ensuring segment definitions remain aligned with current commercial strategy.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Standard payment terms applicable to customers within this segment, defining the expected payment timeline and any early payment discount conditions as configured in SAP S/4HANA FI.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy' ;
    rdfs:comment 'Commercial pricing approach applied to customers within this segment, determining how product and service prices are structured, discounted, or contracted in SAP S/4HANA SD pricing conditions.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceScope rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Scope' ;
    rdfs:comment 'Comma-separated list of applicable regulatory frameworks and compliance obligations relevant to customers in this segment (e.g., REACH, RoHS, CE Marking, ITAR, Export Control), informing compliance checks during order processing.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueBandCurrency rdf:type rdf:Property ;
    rdfs:label 'Revenue Band Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the revenue band minimum and maximum thresholds are denominated, supporting multi-currency global segment definitions.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueBandMax rdf:type rdf:Property ;
    rdfs:label 'Revenue Band Max' ;
    rdfs:comment 'Maximum annual revenue threshold (in segment currency) defining the upper boundary of the revenue band used to classify customers into this segment for pricing and SLA tier assignment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueBandMin rdf:type rdf:Property ;
    rdfs:label 'Revenue Band Min' ;
    rdfs:comment 'Minimum annual revenue threshold (in segment currency) defining the lower boundary of the revenue band used to classify customers into this segment for pricing and SLA tier assignment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewCycle rdf:type rdf:Property ;
    rdfs:label 'Review Cycle' ;
    rdfs:comment 'Frequency at which this customer segment definition, criteria, and performance are formally reviewed and updated by the segment manager and commercial leadership.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrganization rdf:type rdf:Property ;
    rdfs:label 'Sales Organization' ;
    rdfs:comment 'SAP S/4HANA sales organization code responsible for managing and owning this customer segment, aligning the segment to the correct legal entity, region, and revenue reporting structure.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'Service Level Agreement tier assigned to this customer segment, governing response times, support entitlements, and delivery commitments for all customers classified within the segment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicPriorityFlag rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority Flag' ;
    rdfs:comment 'Boolean indicator designating whether this customer segment is classified as a strategic priority for executive-level attention, dedicated account management, and preferential resource allocation.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subRegion rdf:type rdf:Property ;
    rdfs:label 'Sub Region' ;
    rdfs:comment 'Secondary geographic sub-region or sales territory within the primary geographic region, enabling finer-grained territory management and regional commercial strategy alignment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCustomerCount rdf:type rdf:Property ;
    rdfs:label 'Target Customer Count' ;
    rdfs:comment 'Planned number of customer accounts targeted for classification within this segment as part of the commercial go-to-market strategy and sales planning cycle.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tier rdf:type rdf:Property ;
    rdfs:label 'Tier' ;
    rdfs:comment 'Commercial tier classification indicating the strategic importance and priority level of the segment, used to differentiate service levels, pricing, and SLA assignments (e.g., Tier-1 OEM receives premium SLA).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditProfileId rdf:type rdf:Property ;
    rdfs:label 'Credit Profile Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer credit profile record in the Databricks Silver Layer. Serves as the primary key for all credit risk and order-to-cash processes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditProfile .

ind:controllingAreaId rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Id' ;
    rdfs:comment 'Foreign key linking to finance.controlling_area. Business justification: Credit profiles are managed within controlling areas for credit risk monitoring and exposure analysis. Credit management teams track customer credit limits by controlling area for financial control.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControllingArea .

ind:creditAccountCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Account Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code representing the local account currency in which the credit limit and exposure are denominated for this customer (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditBlockStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Block Status' ;
    rdfs:comment 'Indicates whether the customer account is currently subject to a credit block (True) or not (False). When True, new sales orders for this customer are blocked in SAP S/4HANA SD pending credit review and release by an authorized credit analyst.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditCheckMethod rdf:type rdf:Property ;
    rdfs:label 'Credit Check Method' ;
    rdfs:comment 'SAP credit check method code controlling how credit checks are performed for this customer during order-to-cash processing (e.g., A=Static Credit Check, B=Dynamic Credit Check, C=Maximum Document Value, D=No Check). Determines the credit verification logic applied at sales order creation.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditControlArea rdf:type rdf:Property ;
    rdfs:label 'Credit Control Area' ;
    rdfs:comment 'SAP organizational unit (credit control area code) responsible for managing and monitoring the customer\'s credit. Defines the currency, fiscal year variant, and credit management rules applicable to this customer\'s credit profile.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Exposure Amount' ;
    rdfs:comment 'Current total credit exposure for the customer in account currency, comprising open sales orders, open deliveries, open billing documents, and outstanding accounts receivable. Compared against credit limit to determine credit availability.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditHoldReason rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Reason' ;
    rdfs:comment 'Reason code explaining why the customer account has been placed on credit hold. Used by credit analysts and order management teams to prioritize resolution actions and communicate hold rationale to sales teams.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldReasonText rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Reason Text' ;
    rdfs:comment 'Free-text narrative providing additional context or detail for the credit hold reason beyond the structured reason code. Entered by the credit analyst to document specific circumstances such as dispute details or negotiation status.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditInsuranceLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Limit' ;
    rdfs:comment 'Maximum insured amount covered by the trade credit insurance policy for this customer, expressed in account currency. Represents the insurer\'s approved exposure ceiling and is a key input to the internal credit limit approval process.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditInsurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Policy Number' ;
    rdfs:comment 'Reference number of the trade credit insurance policy covering this customer account, if applicable. Credit insurance mitigates the financial risk of customer default and may allow higher credit limits to be extended to insured customers.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitAccountCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Account Currency' ;
    rdfs:comment 'Maximum credit amount extended to the customer expressed in the account\'s local currency. Defines the upper boundary of outstanding receivables permitted before credit block is triggered in SAP S/4HANA SD order processing.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimitApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Approved Date' ;
    rdfs:comment 'Date on which the current credit limit was formally approved by the authorized credit analyst or credit committee. Provides an audit trail for credit limit changes and supports SOX compliance for financial controls.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditLimitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Expiry Date' ;
    rdfs:comment 'Date on which the currently approved credit limit expires and requires renewal or re-approval. After this date, the credit limit may be automatically reduced or the account placed on hold pending review.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditLimitGroupCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Group Currency' ;
    rdfs:comment 'Maximum credit amount extended to the customer expressed in the corporate group currency (e.g., USD for a US-headquartered multinational). Enables consolidated credit exposure reporting across all subsidiaries and legal entities.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRiskClass rdf:type rdf:Property ;
    rdfs:label 'Credit Risk Class' ;
    rdfs:comment 'SAP credit risk class code assigned to the customer, representing the internal risk tier (e.g., 001=Very Low Risk, 002=Low Risk, 003=Medium Risk, 004=High Risk, 005=Very High Risk). Drives credit check rules and automatic credit limit proposals.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRiskClassDescription rdf:type rdf:Property ;
    rdfs:label 'Credit Risk Class Description' ;
    rdfs:comment 'Human-readable description of the credit risk class assigned to the customer (e.g., \'Very Low Risk\', \'Medium Risk\', \'High Risk\'). Supports reporting and business user interpretation without requiring code lookups.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditSegment rdf:type rdf:Property ;
    rdfs:label 'Credit Segment' ;
    rdfs:comment 'SAP credit segment identifier grouping customers for credit management purposes, enabling separate credit limit management per business unit, sales organization, or geographic region within a single customer account.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Credit Utilization Pct' ;
    rdfs:comment 'Percentage of the credit limit currently utilized, calculated as (credit_exposure_amount / credit_limit_account_currency) * 100. Used for credit risk monitoring dashboards and automated alert thresholds.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysSalesOutstanding rdf:type rdf:Property ;
    rdfs:label 'Days Sales Outstanding' ;
    rdfs:comment 'Average number of days the customer takes to pay invoices, calculated from invoice date to payment receipt date over a rolling period. A key KPI for accounts receivable management and credit risk assessment in the order-to-cash process.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dunningBradstreetRating rdf:type rdf:Property ;
    rdfs:label 'Dunning Bradstreet Rating' ;
    rdfs:comment 'External credit rating assigned by Dun & Bradstreet (D&B) for the customer organization, such as the D&B PAYDEX score or Financial Stress Score. Used as an external benchmark to validate and calibrate internal credit risk assessments.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningBradstreetScore rdf:type rdf:Property ;
    rdfs:label 'Dunning Bradstreet Score' ;
    rdfs:comment 'Numeric D&B PAYDEX score (1–100) reflecting the customer\'s payment performance history based on trade references reported to Dun & Bradstreet. Higher scores indicate better payment behavior. Used alongside internal scoring for credit limit decisions.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning level (0–4) assigned to the customer in SAP S/4HANA FI-AR, reflecting the escalation stage of the collections process. Level 0 = no dunning; Level 4 = final notice / legal action. Drives automated dunning letter generation and collections escalation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:groupCurrency rdf:type rdf:Property ;
    rdfs:label 'Group Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the corporate group reporting currency used to express the group-currency credit limit and exposure (e.g., USD, EUR).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalCreditScore rdf:type rdf:Property ;
    rdfs:label 'Internal Credit Score' ;
    rdfs:comment 'Proprietary internal credit score assigned to the customer based on payment history, financial statements, order behavior, and risk class. Used by credit analysts to make credit limit recommendations and risk classification decisions.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'Date on which the most recent dunning notice was issued to the customer. Used to enforce dunning interval rules and prevent premature re-dunning in SAP S/4HANA FI-AR collections management.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oldestOpenItemDays rdf:type rdf:Property ;
    rdfs:label 'Oldest Open Item Days' ;
    rdfs:comment 'Number of days since the oldest unpaid open invoice item was due for this customer. Used in credit risk assessment and dunning level determination — a high value indicates chronic payment delays requiring escalation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overdueAmount rdf:type rdf:Property ;
    rdfs:label 'Overdue Amount' ;
    rdfs:comment 'Total value of outstanding invoices that have exceeded their payment due date, expressed in account currency. A primary trigger for credit block activation and dunning process initiation in SAP S/4HANA FI-AR.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBehaviorCode rdf:type rdf:Property ;
    rdfs:label 'Payment Behavior Code' ;
    rdfs:comment 'Internal classification of the customer\'s historical payment behavior based on analysis of invoice payment patterns, average days past due, and frequency of late payments. Informs credit risk class assignment and credit limit decisions.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'SAP payment terms key (e.g., NT30, NT60, 2/10NET30) assigned to the customer, defining the agreed payment due dates, early payment discount percentages, and baseline date calculation. Directly impacts days sales outstanding (DSO) and credit exposure calculations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when the credit profile record was first created in the source system (SAP S/4HANA). Provides the creation audit trail for compliance, data lineage, and historical analysis in the Databricks Silver Layer.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the credit profile record in the source system. Used for incremental data loading, change detection, and audit trail maintenance in the Databricks Silver Layer.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Frequency at which the customer\'s credit profile is formally reviewed and updated. Typically determined by the customer\'s risk class — high-risk customers are reviewed more frequently than low-risk customers.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialCreditTerms rdf:type rdf:Property ;
    rdfs:label 'Special Credit Terms' ;
    rdfs:comment 'Description of any special or negotiated credit terms applicable to this customer that deviate from standard payment terms, such as extended payment windows, consignment arrangements, or letter of credit requirements. Documented for order management and finance reference.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Product Specification Id' ;
    rdfs:comment 'Foreign key linking to engineering.product_specification. Business justification: SLA agreements in industrial manufacturing are scoped to specific product specifications — defining performance thresholds, uptime guarantees, and response times tied to a product\'s engineering spec. ' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductSpecification .

ind:warrantyPolicyId rdf:type rdf:Property ;
    rdfs:label 'Warranty Policy Id' ;
    rdfs:comment 'Foreign key linking to product.warranty_policy. Business justification: Service level agreements often extend or customize standard product warranty policies. Service operations use this to determine coverage, response times, and entitlements for customer support requests' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarrantyPolicy .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Human-readable, business-facing unique identifier for the SLA agreement, used in customer communications, contract documents, and ERP/CRM cross-referencing. Typically generated by Salesforce CRM or SAP SD.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'The internal approval workflow status of the SLA agreement. Tracks whether the SLA has been reviewed and approved by authorized stakeholders (e.g., legal, finance, operations) before becoming active. Supports governance and audit trail requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'The date on which the SLA agreement received final internal approval and was authorized for activation. Used for audit trail, compliance reporting, and tracking the time from SLA creation to activation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the SLA agreement is configured to automatically renew upon expiry without requiring explicit customer or sales action. When True, the SLA renews under the same terms unless cancelled before the renewal date. Drives automated renewal workflows in SAP SD and Salesforce CRM.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'The internal business unit or division responsible for fulfilling and managing this SLA. For example, \'Automation Systems\', \'Electrification Solutions\', or \'Smart Infrastructure\'. Enables SLA performance reporting and accountability at the business unit level.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:category rdf:type rdf:Property ;
    rdfs:label 'Category' ;
    rdfs:comment 'Categorizes the SLA by its scope of applicability — whether it applies to a specific customer account, a master contract, a product line, a regional operation, or globally across the enterprise. Supports hierarchical SLA management and reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'The reference number of the master contract or service agreement to which this SLA is linked. Enables traceability between SLA commitments and the underlying contractual documents in SAP SD or Salesforce CRM. A single contract may have multiple SLA records.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'The ISO 4217 three-letter currency code in which penalty amounts, cap values, and any financial terms of the SLA are denominated. Supports multi-currency operations across global manufacturing entities. Examples: USD, EUR, GBP, JPY, CNY.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationProcedure rdf:type rdf:Property ;
    rdfs:label 'Escalation Procedure' ;
    rdfs:comment 'Describes the escalation path and procedure to be followed when an SLA is at risk of breach or has been breached. May reference an escalation matrix, named contacts, or a defined process code. Supports Salesforce Service Cloud escalation rule configuration and customer communication workflows.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Percent' ;
    rdfs:comment 'The percentage of the SLA target value at which an escalation warning is triggered before an actual breach occurs. For example, 80% means an alert is raised when 80% of the allowed response time has elapsed. Enables proactive SLA management and breach prevention.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governingLawCountry rdf:type rdf:Property ;
    rdfs:label 'Governing Law Country' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code of the jurisdiction whose laws govern the SLA agreement in case of disputes. Critical for multinational operations where SLAs may be subject to different legal frameworks. Examples: USA, DEU, GBR, CHN, BRA.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'Defines how often the SLA metric is measured and evaluated for compliance. For example, \'monthly\' for delivery performance SLAs, \'per_incident\' for support response SLAs, or \'real_time\' for uptime SLAs. Drives the cadence of SLA reporting and review cycles.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementWindow rdf:type rdf:Property ;
    rdfs:label 'Measurement Window' ;
    rdfs:comment 'Specifies the time window within which SLA performance is measured. Distinguishes between calendar hours (24x7), business hours only, or business days only. Critical for support and field service SLAs where response time commitments differ based on operating hours.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricName rdf:type rdf:Property ;
    rdfs:label 'Metric Name' ;
    rdfs:comment 'The specific performance metric being measured under this SLA, such as \'First Response Time\', \'Order-to-Ship Lead Time\', \'Mean Time To Repair (MTTR)\', \'On-Time Delivery Rate\', or \'Defect Resolution Time\'. Defines what is being tracked and enforced.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Threshold Value' ;
    rdfs:comment 'The minimum acceptable performance level below which penalty clauses are triggered. Distinct from the target value — the target is the goal, while the minimum threshold is the contractual floor. For example, target may be 95% on-time delivery, with a minimum threshold of 90% before penalties apply.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'The name of the internal account manager, service manager, or contract owner responsible for managing and enforcing this SLA. Used for accountability, escalation routing, and customer relationship management in Salesforce CRM.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCapValue rdf:type rdf:Property ;
    rdfs:label 'Penalty Cap Value' ;
    rdfs:comment 'The maximum cumulative financial penalty that can be applied under this SLA agreement, regardless of the number or severity of breaches. Expressed in the agreement currency. Protects both parties from unlimited liability and is a standard clause in enterprise manufacturing contracts.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Flag' ;
    rdfs:comment 'Indicates whether this SLA agreement includes a contractual penalty clause that is triggered upon SLA breach. When True, the penalty_rate and penalty_type fields define the financial consequences of non-compliance. Critical for financial risk management and contract compliance reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyRate rdf:type rdf:Property ;
    rdfs:label 'Penalty Rate' ;
    rdfs:comment 'The rate or amount applied as a financial penalty when the SLA is breached. Interpretation depends on penalty_type: for \'percentage_of_invoice\', this is a percentage (e.g., 2.5 = 2.5%); for \'fixed_amount\', this is a monetary value in the agreement currency. Used in SAP FI/CO for penalty invoice generation.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyType rdf:type rdf:Property ;
    rdfs:label 'Penalty Type' ;
    rdfs:comment 'Defines the mechanism by which financial penalties are applied upon SLA breach. \'percentage_of_invoice\' applies a percentage deduction to the invoice value; \'fixed_amount\' applies a flat fee; \'service_credit\' issues a credit note; \'rebate\' reduces future billing. Drives penalty calculation logic in SAP FI/CO.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'The priority tier assigned to this SLA, reflecting the urgency and criticality of the performance commitment. Critical and high-priority SLAs typically have tighter targets, stricter penalties, and escalation paths. Used in Salesforce Service Cloud for case routing and escalation rule configuration.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'The date on which the SLA agreement is scheduled for renewal review or automatic renewal. Supports proactive contract management, customer retention workflows, and renewal pipeline reporting in Salesforce CRM.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialConditions rdf:type rdf:Property ;
    rdfs:label 'Special Conditions' ;
    rdfs:comment 'Documents any special contractual conditions, exclusions, or exceptions that modify the standard SLA terms. For example, force majeure clauses, seasonal exclusions, or product-specific carve-outs. Critical for accurate SLA compliance assessment and dispute resolution.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The contractually committed performance target for the SLA metric. For example, a target value of 4 with unit \'hours\' means the SLA commits to a 4-hour response time. This is the threshold against which actual performance is measured for compliance and penalty assessment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'The date on which the SLA agreement was early-terminated before its scheduled expiry date. Distinct from expiry_date, which represents the planned end. Populated only when the SLA is terminated early due to contract cancellation, customer churn, or mutual agreement.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'The reason code explaining why the SLA agreement was terminated before its scheduled expiry. Used for root cause analysis, customer churn reporting, and contract performance analytics. Populated only when termination_date is set.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'The unit in which the SLA metric target value is expressed. For example, \'hours\' for response time SLAs, \'percentage\' for on-time delivery rate SLAs, \'days\' for lead time SLAs, or \'count\' for defect occurrence SLAs. Essential for correct interpretation and measurement of the target value.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'The version number of the SLA agreement, incremented each time the SLA terms are formally revised and a new version is issued. Supports SLA change history tracking, audit compliance, and ensures the correct version is enforced at any point in time.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerFunctionId rdf:type rdf:Property ;
    rdfs:label 'Partner Function Id' ;
    rdfs:comment 'Unique surrogate identifier for each partner function assignment record in the silver layer lakehouse. Serves as the primary key for this entity.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerFunction .

ind:assignmentLevel rdf:type rdf:Property ;
    rdfs:label 'Assignment Level' ;
    rdfs:comment 'Indicates the level at which this partner function is assigned — at the customer master level (default for all transactions), sales area level, document header level, or document item level. Determines the scope of applicability.' ;
    rdfs:domain ind:PartnerFunction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationGroup rdf:type rdf:Property ;
    rdfs:label 'Authorization Group' ;
    rdfs:comment 'SAP authorization group code controlling which users or roles are permitted to view or modify this partner function assignment. Supports role-based access control and data security governance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Business reason or justification for the most recent change to this partner function assignment (e.g., \'Contract renewal\', \'Organizational restructuring\', \'Customer request\', \'Merger/acquisition\'). Supports audit trail and change management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'The user ID or username of the person who created this partner function assignment in the source system. Supports audit trail and accountability tracking per quality management requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:determinationProcedure rdf:type rdf:Property ;
    rdfs:label 'Determination Procedure' ;
    rdfs:comment 'The SAP partner determination procedure code that governs how this partner function is resolved in sales documents. Defines the sequence and rules for automatic partner determination.' ;
    rdfs:domain ind:PartnerFunction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'The SAP sales document type (e.g., OR=Standard Order, QT=Quotation, CR=Credit Memo Request) for which this partner function assignment applies. Null indicates applicability across all document types.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpPartnerNumber rdf:type rdf:Property ;
    rdfs:label 'Erp Partner Number' ;
    rdfs:comment 'The source ERP system\'s native partner/customer number for this partner function assignment. Used for traceability back to the SAP S/4HANA source record and cross-system reconciliation.' ;
    rdfs:domain ind:PartnerFunction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionCategory rdf:type rdf:Property ;
    rdfs:label 'Function Category' ;
    rdfs:comment 'Standardized business category classifying the partner function into a canonical role type for cross-system analytics and reporting, independent of source system codes.' ;
    rdfs:domain ind:PartnerFunction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionCode rdf:type rdf:Property ;
    rdfs:label 'Function Code' ;
    rdfs:comment 'SAP SD partner function code identifying the role of the partner in a commercial transaction (e.g., SP=Sold-To Party, SH=Ship-To Party, BP=Bill-To Party, PY=Payer, EU=End User, AG=Ordering Party). Directly maps to SAP VBPA-PARVW field.' ;
    rdfs:domain ind:PartnerFunction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionDescription rdf:type rdf:Property ;
    rdfs:label 'Function Description' ;
    rdfs:comment 'Human-readable description of the partner function role (e.g., \'Sold-To Party\', \'Ship-To Party\', \'Bill-To Party\', \'Payer\', \'End User\', \'Forwarding Agent\'). Used for display in reports and order documents.' ;
    rdfs:domain ind:PartnerFunction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Flag' ;
    rdfs:comment 'Indicates whether this partner function assignment represents an intercompany relationship (i.e., the partner belongs to the same corporate group). Used for intercompany billing and transfer pricing processes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Indicates whether this partner function assignment is the default for the given function code within the sales area. When true, this partner is automatically proposed in new sales documents without manual selection.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether this partner function is mandatory for order processing. When true, the system requires this function to be populated before a sales document can be saved or processed.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'The SAP sales document item category for which this partner function is applicable at the item level. Used when partner functions are assigned at document item granularity rather than header level.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'The user ID or username of the person who last modified this partner function assignment in the source system. Supports audit trail and change accountability.' ;
    rdfs:domain ind:PartnerFunction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerName rdf:type rdf:Property ;
    rdfs:label 'Partner Name' ;
    rdfs:comment 'The name of the business partner (company or individual) fulfilling this partner function. Used for display on order confirmations, shipping documents, and invoices.' ;
    rdfs:domain ind:PartnerFunction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerType rdf:type rdf:Property ;
    rdfs:label 'Partner Type' ;
    rdfs:comment 'Indicates the type of business partner fulfilling this function — whether it is a customer account, an individual contact person, a vendor, an employee, or an organizational unit. Maps to SAP partner type (KU, AP, LI, PE).' ;
    rdfs:domain ind:PartnerFunction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Numeric sequence number used when multiple partners fulfill the same function code for a given account and sales area. Determines the priority order for partner selection in document processing.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemKey rdf:type rdf:Property ;
    rdfs:label 'Source System Key' ;
    rdfs:comment 'The natural/composite key from the source system uniquely identifying this partner function record (e.g., SAP KNVP composite key: KUNNR+VKORG+VTWEG+SPART+PARVW). Enables idempotent upserts and lineage tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The date from which this partner function assignment becomes effective. Used to manage time-bound partner relationships and contractual validity periods.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The date on which this partner function assignment expires. After this date, the partner function is no longer valid for new transactions. Used for contract expiry and partner relationship lifecycle management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:abcClass rdf:type rdf:Property ;
    rdfs:label 'Abc Class' ;
    rdfs:comment 'The ABC classification assigned to the customer account based on revenue contribution and strategic importance. \'A\' represents the highest-value accounts (typically top 20% generating ~80% of revenue), \'B\' represents mid-tier accounts, and \'C\' represents lower-value accounts. Used in sales prioritization and resource allocation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'The username or user ID of the individual who approved the classification assignment. Required for export control classifications (ECCN) and high-risk credit classifications where dual-control approval is mandated.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedByUser rdf:type rdf:Property ;
    rdfs:label 'Assigned By User' ;
    rdfs:comment 'The username or user ID of the individual who assigned the classification to the customer account. Supports audit trail requirements and accountability for classification decisions.' ;
    rdfs:domain ind:AccountClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'The calendar date on which the classification was formally assigned to the customer account. Used for audit trails, compliance reporting, and tracking classification history.' ;
    rdfs:domain ind:AccountClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:classificationCode rdf:type rdf:Property ;
    rdfs:label 'Classification Code' ;
    rdfs:comment 'The standardized short code representing the classification value within the classification scheme. Used for system-to-system integration, SAP S/4HANA customer classification fields, and export control screening lookups.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationDescription rdf:type rdf:Property ;
    rdfs:label 'Classification Description' ;
    rdfs:comment 'Human-readable description of the classification value, providing business context for the assigned classification. For example, \'High-value strategic account\' for ABC-A, or \'Dual-use item requiring export license\' for an ECCN code.' ;
    rdfs:domain ind:AccountClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationLanguage rdf:type rdf:Property ;
    rdfs:label 'Classification Language' ;
    rdfs:comment 'The ISO 639-1 two-letter language code in which the classification description and value are maintained. Supports multi-language classification management for multinational operations.' ;
    rdfs:domain ind:AccountClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationPriority rdf:type rdf:Property ;
    rdfs:label 'Classification Priority' ;
    rdfs:comment 'A numeric priority rank assigned to the classification record when multiple classifications of the same type exist for a customer account. Lower numbers indicate higher priority. Used to resolve conflicts when multiple classifications apply simultaneously.' ;
    rdfs:domain ind:AccountClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:classificationScheme rdf:type rdf:Property ;
    rdfs:label 'Classification Scheme' ;
    rdfs:comment 'The formal scheme, standard, or framework under which the classification value is defined. Examples include \'SAP ABC Analysis\', \'Nielsen Global Segment Framework\', \'US EAR Export Control\', \'EU Dual-Use Regulation\', or a company-defined internal scheme.' ;
    rdfs:domain ind:AccountClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationType rdf:type rdf:Property ;
    rdfs:label 'Classification Type' ;
    rdfs:comment 'The category or scheme of classification applied to the customer account. Examples include ABC classification (revenue-based segmentation), Nielsen classification (market research segmentation), ECCN (Export Control Classification Number), EAR99 (Export Administration Regulations catch-all), industry sector, credit risk tier, and strategic account classification.' ;
    rdfs:domain ind:AccountClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationValue rdf:type rdf:Property ;
    rdfs:label 'Classification Value' ;
    rdfs:comment 'The specific classification value or code assigned to the customer account under the given classification type. For example, \'A\', \'B\', or \'C\' for ABC classification; an ECCN code such as \'3A001\' for export control; or a Nielsen segment code.' ;
    rdfs:domain ind:AccountClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfApplication rdf:type rdf:Property ;
    rdfs:label 'Country Of Application' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code indicating the country or jurisdiction in which this classification is applicable. Supports country-specific classification rules, export control by destination, and regional compliance requirements.' ;
    rdfs:domain ind:AccountClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerAccountGroup rdf:type rdf:Property ;
    rdfs:label 'Customer Account Group' ;
    rdfs:comment 'The SAP S/4HANA customer account group code that determines the number range, field selection, and partner functions applicable to the customer master record. Examples include KUNA (domestic customers), KUNE (export customers), CPDL (one-time customers).' ;
    rdfs:domain ind:AccountClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deniedPartyScreenDate rdf:type rdf:Property ;
    rdfs:label 'Denied Party Screen Date' ;
    rdfs:comment 'The most recent date on which the customer account was screened against denied party and sanctions lists. Used to ensure screening is current and to schedule re-screening at required intervals.' ;
    rdfs:domain ind:AccountClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deniedPartyScreenResult rdf:type rdf:Property ;
    rdfs:label 'Denied Party Screen Result' ;
    rdfs:comment 'The outcome of the most recent denied party and sanctions screening for the customer account. \'clear\' indicates no match found; \'match_found\' triggers a compliance hold; \'potential_match\' requires manual review.' ;
    rdfs:domain ind:AccountClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deniedPartyScreened rdf:type rdf:Property ;
    rdfs:label 'Denied Party Screened' ;
    rdfs:comment 'Indicates whether the customer account has been screened against denied party, debarred, and sanctioned entity lists (e.g., US BIS Denied Persons List, OFAC SDN List, EU Consolidated Sanctions List). True = screening has been performed.' ;
    rdfs:domain ind:AccountClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ear99Flag rdf:type rdf:Property ;
    rdfs:label 'Ear99 Flag' ;
    rdfs:comment 'Indicates whether the customer account has been classified as EAR99 under the US Export Administration Regulations, meaning the associated goods or transactions do not require a specific export license for most destinations. True = EAR99 classification applies.' ;
    rdfs:domain ind:AccountClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eccnCode rdf:type rdf:Property ;
    rdfs:label 'Eccn Code' ;
    rdfs:comment 'The Export Control Classification Number (ECCN) assigned to the customer account for export control screening purposes. Identifies whether the customer or their end-use requires an export license under the US Export Administration Regulations (EAR). Applicable for industrial manufacturing customers dealing in dual-use goods.' ;
    rdfs:domain ind:AccountClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportLicenseRequired rdf:type rdf:Property ;
    rdfs:label 'Export License Required' ;
    rdfs:comment 'Indicates whether an export license is required for transactions with this customer account based on their export control classification, destination country, and end-use. Drives export compliance screening workflows.' ;
    rdfs:domain ind:AccountClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:industrySectorCode rdf:type rdf:Property ;
    rdfs:label 'Industry Sector Code' ;
    rdfs:comment 'The industry sector classification code assigned to the customer account, aligned with standard industry classification systems such as NAICS, SIC, or NACE. Used for market segmentation, reporting, and targeted sales strategies.' ;
    rdfs:domain ind:AccountClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySectorName rdf:type rdf:Property ;
    rdfs:label 'Industry Sector Name' ;
    rdfs:comment 'The human-readable name of the industry sector assigned to the customer account. Complements the industry sector code for reporting and analytics purposes.' ;
    rdfs:domain ind:AccountClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingGroup rdf:type rdf:Property ;
    rdfs:label 'Pricing Group' ;
    rdfs:comment 'The pricing group code assigned to the customer account in SAP S/4HANA SD, used to determine applicable pricing conditions, discount schedules, and surcharges. Links the customer to a specific pricing strategy.' ;
    rdfs:domain ind:AccountClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachRohsCompliant rdf:type rdf:Property ;
    rdfs:label 'Reach Rohs Compliant' ;
    rdfs:comment 'Indicates whether the customer account has confirmed compliance with EU REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals) and RoHS (Restriction of Hazardous Substances) regulations. Relevant for industrial manufacturing customers in the EU market.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueTier rdf:type rdf:Property ;
    rdfs:label 'Revenue Tier' ;
    rdfs:comment 'The revenue-based tier assigned to the customer account, used for pricing, discount eligibility, and service level differentiation. Platinum and Gold tiers typically receive preferential pricing and dedicated account management.' ;
    rdfs:domain ind:AccountClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'The scheduled date for the next periodic review of the classification. Ensures classifications remain current and accurate, particularly for credit risk, export control, and strategic account tiers.' ;
    rdfs:domain ind:AccountClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxClassification rdf:type rdf:Property ;
    rdfs:label 'Tax Classification' ;
    rdfs:comment 'The tax classification assigned to the customer account, determining the applicable tax treatment for sales transactions. Drives VAT/GST determination in SAP S/4HANA SD and ensures compliance with local tax regulations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Number' ;
    rdfs:comment 'The official tax exemption certificate number issued by the relevant tax authority, confirming the customer account\'s exemption from applicable taxes. Required for compliance and audit purposes.' ;
    rdfs:domain ind:AccountClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Pricing Agreement Id' ;
    rdfs:comment 'Foreign key linking to customer.pricing_agreement. Business justification: sales_area_assignment stores pricing_procedure and price_list_type as STRING attributes that reference the pricing configuration applicable to the sales area. pricing_agreement is the authoritative re' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingAgreement .

ind:salesOrgId rdf:type rdf:Property ;
    rdfs:label 'Sales Org Id' ;
    rdfs:comment 'Foreign key linking to product.sales_org. Business justification: A customer\'s sales area assignment maps directly to a sales organization that owns the customer relationship and product catalog access. This is a foundational ERP relationship in manufacturing — sale' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesOrg .

ind:accountAssignmentGroup rdf:type rdf:Property ;
    rdfs:label 'Account Assignment Group' ;
    rdfs:comment 'SAP Account Assignment Group for the customer, used in revenue account determination to map sales transactions to the correct general ledger (GL) revenue accounts during billing (e.g., 01=Domestic Revenue, 02=Export Revenue, 03=Service Revenue).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingBlockCode rdf:type rdf:Property ;
    rdfs:label 'Billing Block Code' ;
    rdfs:comment 'SAP Billing Block code indicating whether billing is currently blocked for this customer in this sales area and the reason (e.g., 01=Credit Block, 02=Dispute, 03=Audit Hold). A blank value indicates no billing block is active.' ;
    rdfs:domain ind:SalesAreaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerClassification rdf:type rdf:Property ;
    rdfs:label 'Customer Classification' ;
    rdfs:comment 'SAP Customer Classification code used for statistical analysis and ABC segmentation of customers by revenue contribution within this sales area (e.g., A=High Value, B=Medium Value, C=Low Value). Supports strategic account management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerGroupCode rdf:type rdf:Property ;
    rdfs:label 'Customer Group Code' ;
    rdfs:comment 'SAP Customer Group code classifying the customer for pricing, reporting, and statistical purposes within this sales area (e.g., 01=OEM, 02=System Integrator, 03=Distributor, 04=End User, 05=Government). Used in pricing condition determination.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerGroupName rdf:type rdf:Property ;
    rdfs:label 'Customer Group Name' ;
    rdfs:comment 'Descriptive name of the customer group classification (e.g., \'OEM Partner\', \'System Integrator\', \'Distributor\', \'End User\') for business reporting and segmentation analysis.' ;
    rdfs:domain ind:SalesAreaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryBlockCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Block Code' ;
    rdfs:comment 'SAP Delivery Block code indicating whether outbound deliveries are currently blocked for this customer in this sales area and the reason (e.g., 01=Credit Limit Exceeded, 02=Export License Pending). A blank value indicates no delivery block.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPriority rdf:type rdf:Property ;
    rdfs:label 'Delivery Priority' ;
    rdfs:comment 'SAP Delivery Priority code assigned to this customer in this sales area, controlling the sequence in which deliveries are processed during outbound logistics (e.g., 01=Urgent, 02=Normal, 03=Low). Impacts warehouse scheduling and shipping lead times.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannelName rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Name' ;
    rdfs:comment 'Descriptive name of the distribution channel (e.g., \'Direct Sales\', \'Distributor\', \'OEM Partner\', \'E-Commerce\') for reporting and business user clarity.' ;
    rdfs:domain ind:SalesAreaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionCode rdf:type rdf:Property ;
    rdfs:label 'Division Code' ;
    rdfs:comment 'SAP Division code representing the product line or business segment assigned to this customer in this sales area (e.g., 01=Automation Systems, 02=Electrification, 03=Smart Infrastructure). Determines which product catalog and pricing conditions apply.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionName rdf:type rdf:Property ;
    rdfs:label 'Division Name' ;
    rdfs:comment 'Descriptive name of the division (product line or business segment) for reporting and analytics (e.g., \'Automation Systems\', \'Electrification Solutions\', \'Smart Infrastructure\').' ;
    rdfs:domain ind:SalesAreaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'International Commercial Terms (Incoterms) code defining the default delivery terms and risk transfer point for orders placed by this customer in this sales area (e.g., EXW, FCA, DAP, DDP). Governs freight cost allocation and export documentation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'Named place or port associated with the Incoterms code specifying the exact point of delivery or risk transfer (e.g., \'Chicago Port\', \'Customer Warehouse Frankfurt\'). Required for complete Incoterms specification per ICC 2020 rules.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDatesCode rdf:type rdf:Property ;
    rdfs:label 'Invoice Dates Code' ;
    rdfs:comment 'SAP Invoice Dates (billing schedule) code defining the default billing frequency or calendar for this customer in this sales area (e.g., monthly billing, weekly billing, milestone billing). Controls when billing documents are created.' ;
    rdfs:domain ind:SalesAreaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxPartialDeliveries rdf:type rdf:Property ;
    rdfs:label 'Max Partial Deliveries' ;
    rdfs:comment 'Maximum number of partial deliveries allowed per sales order for this customer in this sales area. Limits the number of shipment splits permitted, balancing customer flexibility with logistics cost control.' ;
    rdfs:domain ind:SalesAreaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderBlockCode rdf:type rdf:Property ;
    rdfs:label 'Order Block Code' ;
    rdfs:comment 'SAP Order Block code indicating whether new sales orders are currently blocked for this customer in this sales area and the reason (e.g., 01=Credit Hold, 02=Sanctions Review, 03=Contract Expired). A blank value indicates no order block is active.' ;
    rdfs:domain ind:SalesAreaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderCombinationFlag rdf:type rdf:Property ;
    rdfs:label 'Order Combination Flag' ;
    rdfs:comment 'Indicates whether multiple open sales orders for this customer in this sales area can be combined into a single delivery document. When True, SAP SD will attempt to consolidate orders into one shipment to reduce freight costs and improve logistics efficiency.' ;
    rdfs:domain ind:SalesAreaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderProbabilityPct rdf:type rdf:Property ;
    rdfs:label 'Order Probability Pct' ;
    rdfs:comment 'Default probability percentage (0-100%) that a sales quotation or inquiry from this customer in this sales area will convert to a confirmed sales order. Used in sales pipeline forecasting and opportunity management.' ;
    rdfs:domain ind:SalesAreaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partialDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Delivery Flag' ;
    rdfs:comment 'SAP Partial Delivery indicator controlling whether partial deliveries are permitted for this customer in this sales area (e.g., A=Partial delivery allowed, B=Only complete delivery, C=Partial delivery per item). Governs order fulfillment behavior.' ;
    rdfs:domain ind:SalesAreaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Rebate Eligible Flag' ;
    rdfs:comment 'Indicates whether this customer is eligible to participate in rebate agreements within this sales area. When True, SAP SD will process rebate accruals and settlements for qualifying transactions per the applicable rebate agreement.' ;
    rdfs:domain ind:SalesAreaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesDistrictCode rdf:type rdf:Property ;
    rdfs:label 'Sales District Code' ;
    rdfs:comment 'SAP Sales District code grouping customers into geographic or market-based territories within the sales organization for territory management, sales rep assignment, and regional performance reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesGroupCode rdf:type rdf:Property ;
    rdfs:label 'Sales Group Code' ;
    rdfs:comment 'SAP Sales Group code identifying the team or group of sales representatives within the sales office responsible for this customer account. Enables granular sales performance tracking at team level.' ;
    rdfs:domain ind:SalesAreaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOfficeCode rdf:type rdf:Property ;
    rdfs:label 'Sales Office Code' ;
    rdfs:comment 'SAP Sales Office code identifying the regional sales office responsible for managing this customer account within the sales organization. Used for organizational reporting and sales performance analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCondition rdf:type rdf:Property ;
    rdfs:label 'Shipping Condition' ;
    rdfs:comment 'SAP Shipping Condition code defining the default mode and urgency of shipment for this customer in this sales area (e.g., 01=Standard Ground, 02=Express Air, 03=Sea Freight, 04=Customer Pickup). Used in route and shipping point determination.' ;
    rdfs:domain ind:SalesAreaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordKey rdf:type rdf:Property ;
    rdfs:label 'Source Record Key' ;
    rdfs:comment 'Natural composite key from the source SAP S/4HANA system uniquely identifying this record in the originating system (typically concatenation of Customer Number + Sales Org + Distribution Channel + Division, e.g., \'C0001234-US01-10-01\'). Enables traceability back to the source system.' ;
    rdfs:domain ind:SalesAreaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Identifier of the operational source system from which this sales area assignment record originated (e.g., \'SAP_S4H_PROD\', \'SAP_S4H_EU\'). Supports multi-system data lineage tracking in the Databricks Lakehouse Silver Layer for multinational deployments.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productPriceListId rdf:type rdf:Property ;
    rdfs:label 'Product Price List Id' ;
    rdfs:comment 'Foreign key linking to product.price_list. Business justification: Customer-specific pricing agreements reference standard or custom price lists. Order management systems use this to apply correct negotiated pricing when customers place orders.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductPriceList .

ind:productVariantId rdf:type rdf:Property ;
    rdfs:label 'Product Variant Id' ;
    rdfs:comment 'Foreign key linking to engineering.product_variant. Business justification: Customer pricing agreements in manufacturing are negotiated at the product variant level — specific configurations carry distinct pricing. Sales and commercial teams link pricing agreements to exact v' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductVariant .

ind:taxCodeId rdf:type rdf:Property ;
    rdfs:label 'Tax Code Id' ;
    rdfs:comment 'Foreign key linking to finance.tax_code. Business justification: Pricing agreements reference specific tax codes to calculate correct tax amounts during order processing and invoicing. Sales and billing teams use this for every customer transaction.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxCode .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Descriptive name or title of the pricing agreement as referenced in commercial negotiations, e.g., \'OEM Partner Annual Volume Discount 2024\' or \'Key Account Special Price – Automation Division\'.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the pricing arrangement. Determines the pricing logic applied in SAP S/4HANA condition records: customer-specific price (fixed net price), volume rebate (retroactive rebate based on cumulative spend), special discount (percentage or absolute deduction), or other commercial pricing constructs.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'The date and time when the pricing agreement was formally approved by the authorized approver. Used for audit trail, compliance reporting, and SLA tracking of the pricing approval process.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvingAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Approving Authority Level' ;
    rdfs:comment 'The organizational authority level required to approve this pricing agreement, determined by the discount depth or deal value. Enforces the pricing governance matrix — e.g., discounts above 20% require VP Sales approval, above 30% require CFO sign-off.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialContractReference rdf:type rdf:Property ;
    rdfs:label 'Commercial Contract Reference' ;
    rdfs:comment 'Reference number or identifier of the overarching commercial contract, master service agreement, or framework agreement to which this pricing agreement is linked. Enables traceability between pricing conditions and legal contract documents.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionTypeCode rdf:type rdf:Property ;
    rdfs:label 'Condition Type Code' ;
    rdfs:comment 'The SAP S/4HANA SD condition type code (e.g., PR00 for base price, K007 for customer discount, BO01 for rebate) that this pricing agreement maps to in the condition record. Essential for ERP integration and pricing procedure determination.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'The negotiated percentage discount to be applied off the standard list price or base price. Applicable when agreement_type is \'special_discount\' or \'volume_rebate\'. Expressed as a percentage value (e.g., 12.5 = 12.5%). Null when the agreement is fixed-price based.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'The SAP S/4HANA distribution channel through which the products covered by this pricing agreement are sold. Determines the applicable pricing condition table and access sequence. Examples: direct sales, distributor, OEM, export.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:division rdf:type rdf:Property ;
    rdfs:label 'Division' ;
    rdfs:comment 'The SAP S/4HANA division (product line or business unit) to which this pricing agreement applies. Used in condition record key determination and supports divisional P&L reporting for pricing analytics.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'International Commercial Terms (Incoterms 2020) defining the delivery obligations, risk transfer point, and cost responsibilities between seller and buyer under this pricing agreement. Affects the net price calculation and logistics cost allocation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive' ;
    rdfs:comment 'Indicates whether this pricing agreement grants the customer exclusive pricing rights for the covered product or product group within a defined territory or channel. Exclusive agreements restrict the same pricing from being offered to competing customers.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRetroactive rdf:type rdf:Property ;
    rdfs:label 'Is Retroactive' ;
    rdfs:comment 'Indicates whether the pricing agreement terms apply retroactively to orders placed before the agreement was formally activated. Relevant for volume rebate agreements where retroactive settlement is triggered upon reaching the target volume.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'The minimum quantity the customer must order per transaction or within the agreement period to qualify for the agreed pricing. Expressed in the price_unit. A key commercial condition for volume-based and OEM pricing agreements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Value' ;
    rdfs:comment 'The minimum monetary value of an order or cumulative period spend required to activate or maintain the pricing agreement. Expressed in currency_code. Used for value-based volume rebate thresholds and key account agreements.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceListType rdf:type rdf:Property ;
    rdfs:label 'Price List Type' ;
    rdfs:comment 'The price list category from which the base price is derived before applying the agreed discount or special price. Determines the reference price point for discount calculation in SAP S/4HANA condition records.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePerQuantity rdf:type rdf:Property ;
    rdfs:label 'Price Per Quantity' ;
    rdfs:comment 'The quantity denominator for the agreed price, i.e., the number of units to which the agreed_price applies. For example, a price of $500 per 100 pieces would have price_per_quantity = 100. Aligns with SAP S/4HANA condition record pricing quantity (KPEIN).' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebatePercentage rdf:type rdf:Property ;
    rdfs:label 'Rebate Percentage' ;
    rdfs:comment 'The retroactive rebate percentage applied to cumulative purchases once the minimum order quantity or revenue threshold is met within the agreement validity period. Applicable for volume_rebate agreement types. Expressed as a percentage (e.g., 3.0 = 3%).' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalType rdf:type rdf:Property ;
    rdfs:label 'Renewal Type' ;
    rdfs:comment 'Defines the renewal behavior of the pricing agreement upon expiry. \'auto_renew\' triggers automatic extension under the same terms; \'manual_renew\' requires explicit renegotiation; \'no_renewal\' means the agreement terminates at valid_to.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeType rdf:type rdf:Property ;
    rdfs:label 'Scope Type' ;
    rdfs:comment 'Defines whether the pricing agreement applies to a single product (SKU), a product group, a material group, a product hierarchy node, or all products. Determines the granularity of condition record creation in SAP S/4HANA.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByAgreement rdf:type rdf:Property ;
    rdfs:label 'Superseded By Agreement' ;
    rdfs:comment 'The agreement_number of the newer pricing agreement that has replaced this one when status is \'superseded\'. Provides forward linkage for agreement lineage tracking and ensures sales teams reference the current active agreement.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetVolume rdf:type rdf:Property ;
    rdfs:label 'Target Volume' ;
    rdfs:comment 'The agreed annual or period target purchase volume (in price_unit) that the customer commits to purchasing under this pricing agreement. Used for volume rebate tracking and commercial performance monitoring.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validFrom rdf:type rdf:Property ;
    rdfs:label 'Valid From' ;
    rdfs:comment 'The start date from which the pricing agreement becomes effective and eligible to be applied to sales orders. Aligns with SAP S/4HANA condition record validity start date (DATAB). Inclusive boundary.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validTo rdf:type rdf:Property ;
    rdfs:label 'Valid To' ;
    rdfs:comment 'The end date after which the pricing agreement is no longer effective. Aligns with SAP S/4HANA condition record validity end date (DATBI). Inclusive boundary. Agreements with no end date may use 9999-12-31 as a convention.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountContactRoleId rdf:type rdf:Property ;
    rdfs:label 'Account Contact Role Id' ;
    rdfs:comment 'Unique surrogate identifier for each account-contact role association record in the silver layer lakehouse. Serves as the primary key for this entity.' ;
    rdfs:domain ind:AccountContactRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorityLimitCurrency rdf:type rdf:Property ;
    rdfs:label 'Authority Limit Currency' ;
    rdfs:comment 'The ISO 4217 three-letter currency code in which the purchase order authority limit is denominated. Supports multi-currency operations across global accounts.' ;
    rdfs:domain ind:AccountContactRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationLanguage rdf:type rdf:Property ;
    rdfs:label 'Communication Language' ;
    rdfs:comment 'The preferred language for communications directed to this contact in this role, expressed as an IETF BCP 47 language tag (e.g., en-US, de-DE, fr-FR). Supports multilingual B2B engagement across global accounts.' ;
    rdfs:domain ind:AccountContactRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationPreference rdf:type rdf:Property ;
    rdfs:label 'Communication Preference' ;
    rdfs:comment 'The preferred channel through which this contact wishes to receive communications in the context of this role. Governs outbound communication routing for commercial, technical, and service interactions.' ;
    rdfs:domain ind:AccountContactRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Contract Authority Level' ;
    rdfs:comment 'Defines the level of contractual signing authority held by this contact in the context of this role. Critical for order management, procurement, and legal compliance workflows requiring authorized signatories.' ;
    rdfs:domain ind:AccountContactRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmRoleCode rdf:type rdf:Property ;
    rdfs:label 'Crm Role Code' ;
    rdfs:comment 'The native identifier for this account-contact role record in the Salesforce CRM system. Enables cross-system traceability and reconciliation between the lakehouse silver layer and the CRM source of record.' ;
    rdfs:domain ind:AccountContactRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'The date on which the contact\'s role within the account was terminated or expired. A null value indicates the role is currently active. Used for historical role tracking and succession planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationPriority rdf:type rdf:Property ;
    rdfs:label 'Escalation Priority' ;
    rdfs:comment 'Numeric priority rank (1 = highest) assigned to this contact role for escalation routing in service, quality, or commercial dispute scenarios. Ensures critical contacts are engaged first during incident management.' ;
    rdfs:domain ind:AccountContactRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:influenceLevel rdf:type rdf:Property ;
    rdfs:label 'Influence Level' ;
    rdfs:comment 'Characterizes the degree of influence this contact exercises over purchasing, technical, or operational decisions within the account. Used in sales strategy, opportunity management, and stakeholder mapping.' ;
    rdfs:domain ind:AccountContactRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Last Interaction Date' ;
    rdfs:comment 'The date of the most recent recorded business interaction (call, meeting, email, site visit) with this contact in the context of this role. Used for relationship health monitoring and account engagement analytics.' ;
    rdfs:domain ind:AccountContactRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationOptIn rdf:type rdf:Property ;
    rdfs:label 'Notification Opt In' ;
    rdfs:comment 'Indicates whether the contact has opted in to receive automated notifications (e.g., order status updates, shipment alerts, quality notifications) in the context of this role. Supports GDPR and CCPA compliant communication.' ;
    rdfs:domain ind:AccountContactRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purchaseOrderAuthorityLimit rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Authority Limit' ;
    rdfs:comment 'The maximum monetary value (in the account\'s base currency) up to which this contact is authorized to approve or issue Purchase Orders (POs) in this role. Used in procurement workflow routing and approval chain configuration.' ;
    rdfs:domain ind:AccountContactRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipStrength rdf:type rdf:Property ;
    rdfs:label 'Relationship Strength' ;
    rdfs:comment 'Qualitative assessment of the strength of the business relationship between the contact and the account in this role. Informs account management strategy and customer retention efforts.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleCategory rdf:type rdf:Property ;
    rdfs:label 'Role Category' ;
    rdfs:comment 'Broad grouping of the contact role used for segmentation and targeted communication strategies. Enables filtering of contacts by functional area across the account portfolio.' ;
    rdfs:domain ind:AccountContactRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleDescription rdf:type rdf:Property ;
    rdfs:label 'Role Description' ;
    rdfs:comment 'Free-text description providing additional context about the contact\'s specific responsibilities or scope within this role at the account. Captures nuances not covered by the standardized role type enumeration.' ;
    rdfs:domain ind:AccountContactRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'Classifies the specific business function or responsibility the contact holds within the account. Drives communication routing, escalation paths, and relationship mapping across complex B2B accounts in CRM and ERP systems.' ;
    rdfs:domain ind:AccountContactRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'The date on which the contact assumed the specified role within the account. Used for tenure tracking, historical analysis, and SLA (Service Level Agreement) assignment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The date on which the contact\'s role assignment was last verified or confirmed. Used for data quality audits and to identify stale or unverified role assignments requiring refresh.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Verified Flag' ;
    rdfs:comment 'Indicates whether the contact\'s role assignment has been formally verified and confirmed by the account management team or the contact themselves. Supports data quality governance and master data management.' ;
    rdfs:domain ind:AccountContactRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:installedBaseId rdf:type rdf:Property ;
    rdfs:label 'Installed Base Id' ;
    rdfs:comment 'Unique surrogate identifier for each installed base record representing a single product or automation system installed at a customer site.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InstalledBase .

ind:aftermarketPartId rdf:type rdf:Property ;
    rdfs:label 'Aftermarket Part Id' ;
    rdfs:comment 'Foreign key linking to product.aftermarket_part. Business justification: Installed base records for industrial automation equipment often represent a specific aftermarket or spare part unit installed at a customer site. Aftermarket sales and service teams use this link to ' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AftermarketPart .

ind:engineeringBomId rdf:type rdf:Property ;
    rdfs:label 'Engineering Bom Id' ;
    rdfs:comment 'Foreign key linking to engineering.engineering_bom. Business justification: The installed base must reference the exact BOM revision used to manufacture the customer\'s unit. After-sales engineering and spare parts teams use this to identify correct components for maintenance,' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EngineeringBom .

ind:lifecycleId rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Id' ;
    rdfs:comment 'Foreign key linking to product.lifecycle. Business justification: The lifecycle status of a product in the installed base determines whether spare parts, firmware updates, and support are still available. Account managers and service teams check lifecycle status on ' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lifecycle .

ind:lotBatchId rdf:type rdf:Property ;
    rdfs:label 'Lot Batch Id' ;
    rdfs:comment 'Foreign key linking to inventory.lot_batch. Business justification: Installed equipment at customer sites must trace back to the manufacturing lot/batch for quality recalls, compliance audits, and traceability. Quality and regulatory teams use this link to identify al' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LotBatch .

ind:productConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Product Configuration Id' ;
    rdfs:comment 'Foreign key linking to product.product_configuration. Business justification: An installed base record tracks the exact configured product installed at a customer site. Field service and aftermarket teams reference the product configuration daily to identify spare parts, firmwa' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductConfiguration .

ind:serializedUnitId rdf:type rdf:Property ;
    rdfs:label 'Serialized Unit Id' ;
    rdfs:comment 'Foreign key linking to inventory.serialized_unit. Business justification: Installed base records track which specific serialized equipment (automation systems, drives) is deployed at customer sites. Essential for service contracts, maintenance scheduling, and spare parts pl' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SerializedUnit .

ind:siteAddressId rdf:type rdf:Property ;
    rdfs:label 'Site Address Id' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: Installed base records contain embedded site address fields (site_address_line_1, site_city, site_country_code). Normalizing to the authoritative address repository eliminates duplication and enables ' ;
    rdfs:domain ind:InstalledBase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: Installed base records reference the originating storage/dispatch location from which the equipment was shipped to the customer. Logistics and after-sales teams use this to coordinate spare parts sour' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date on which the installed product was formally commissioned and handed over to the customer for operational use, marking the start of the warranty period and SLA obligations.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:connectivityStatus rdf:type rdf:Property ;
    rdfs:label 'Connectivity Status' ;
    rdfs:comment 'Current connectivity status of the installed product to the IIoT platform, indicating whether remote monitoring and telemetry data collection is active, used for proactive service and digital service upsell.' ;
    rdfs:domain ind:InstalledBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOriginCode rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code indicating where the installed product was manufactured, required for customs declarations, export control compliance, and REACH/RoHS regulatory reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmAssetCode rdf:type rdf:Property ;
    rdfs:label 'Crm Asset Code' ;
    rdfs:comment 'Identifier of the installed asset record in Salesforce CRM Service Cloud, enabling traceability between the lakehouse silver layer and the CRM system of record.' ;
    rdfs:domain ind:InstalledBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endCustomerAccountNumber rdf:type rdf:Property ;
    rdfs:label 'End Customer Account Number' ;
    rdfs:comment 'Account number of the end-user customer operating the installed product when the direct customer is a distributor, OEM partner, or system integrator, enabling end-customer service and upgrade targeting.' ;
    rdfs:domain ind:InstalledBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endOfSupportDate rdf:type rdf:Property ;
    rdfs:label 'End Of Support Date' ;
    rdfs:comment 'Date after which the manufacturer will no longer provide software updates, spare parts, or technical support for this product version, used to drive upgrade and migration campaigns.' ;
    rdfs:domain ind:InstalledBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:erpEquipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Erp Equipment Number' ;
    rdfs:comment 'Equipment master number from SAP S/4HANA Plant Maintenance (PM) module, uniquely identifying the physical asset in the ERP system for maintenance and cost tracking.' ;
    rdfs:domain ind:InstalledBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmwareVersion rdf:type rdf:Property ;
    rdfs:label 'Firmware Version' ;
    rdfs:comment 'Version identifier of the firmware currently installed on the product hardware, critical for cybersecurity vulnerability management, field update campaigns, and technical support.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardwareRevision rdf:type rdf:Property ;
    rdfs:label 'Hardware Revision' ;
    rdfs:comment 'Hardware revision or board revision level of the installed product unit, used to determine spare parts compatibility, field upgrade feasibility, and technical support scope.' ;
    rdfs:domain ind:InstalledBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iiotDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Iiot Device Code' ;
    rdfs:comment 'Unique device identifier registered in the Siemens MindSphere IIoT platform for this installed product, enabling remote monitoring, predictive maintenance, and telemetry data correlation.' ;
    rdfs:domain ind:InstalledBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date on which the product was physically installed at the customer site, used as the baseline for warranty period calculation and service history tracking.' ;
    rdfs:domain ind:InstalledBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastServiceDate rdf:type rdf:Property ;
    rdfs:label 'Last Service Date' ;
    rdfs:comment 'Date of the most recent completed service or maintenance activity performed on the installed product, used for preventive maintenance scheduling and service history reporting.' ;
    rdfs:domain ind:InstalledBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextPlannedServiceDate rdf:type rdf:Property ;
    rdfs:label 'Next Planned Service Date' ;
    rdfs:comment 'Scheduled date for the next preventive maintenance or planned service visit for the installed product, supporting field service capacity planning and customer communication.' ;
    rdfs:domain ind:InstalledBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Real-time or last-known operational condition of the installed product as reported by the IIoT platform or field service, distinct from the lifecycle status. Used for proactive maintenance and service dispatch prioritization.' ;
    rdfs:domain ind:InstalledBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'High-level category classifying the type of installed product, used for service routing, spare parts planning, and installed base segmentation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordNumber rdf:type rdf:Property ;
    rdfs:label 'Record Number' ;
    rdfs:comment 'Human-readable business key uniquely identifying the installed base record across CRM and ERP systems, used for cross-system referencing and customer communications.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTerritory rdf:type rdf:Property ;
    rdfs:label 'Service Territory' ;
    rdfs:comment 'Assigned service territory or region responsible for field service delivery to the installation site, used for field engineer dispatch, SLA management, and service capacity planning.' ;
    rdfs:domain ind:InstalledBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sku rdf:type rdf:Property ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Stock Keeping Unit code identifying the specific product variant installed at the customer site, linking to the product catalog for spare parts, upgrades, and service planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softwareVersion rdf:type rdf:Property ;
    rdfs:label 'Software Version' ;
    rdfs:comment 'Version identifier of the application software currently running on the installed product, used for compatibility checks, patch management, and upgrade eligibility assessment.' ;
    rdfs:domain ind:InstalledBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Upgrade Eligibility Flag' ;
    rdfs:comment 'Indicates whether the installed product is eligible for a hardware or software upgrade based on its current version, hardware revision, and product lifecycle phase, used to target upgrade campaigns.' ;
    rdfs:domain ind:InstalledBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyStartDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Start Date' ;
    rdfs:comment 'Date from which the product warranty coverage becomes effective, typically aligned with the commissioning date or first use date as defined in the sales contract.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyType rdf:type rdf:Property ;
    rdfs:label 'Warranty Type' ;
    rdfs:comment 'Classification of the warranty coverage applicable to the installed product, determining the scope of repair, replacement, and labor obligations under the warranty agreement.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpRunId rdf:type rdf:Property ;
    rdfs:label 'Mrp Run Id' ;
    rdfs:comment 'Unique system-generated identifier for each MRP or MRP II planning run execution record in the Silver Layer lakehouse.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MrpRun .

ind:physicalInventoryId rdf:type rdf:Property ;
    rdfs:label 'Physical Inventory Id' ;
    rdfs:comment 'Foreign key linking to inventory.physical_inventory. Business justification: MRP runs use confirmed physical inventory counts as the authoritative stock baseline. Linking mrp_run to physical_inventory ensures MRP calculations are grounded in verified stock data, not just syste' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PhysicalInventory .

ind:bomExplosionLevel rdf:type rdf:Property ;
    rdfs:label 'Bom Explosion Level' ;
    rdfs:comment 'Maximum number of BOM levels exploded during the MRP run. Indicates the depth of the product structure traversed to derive dependent requirements for sub-assemblies and raw materials.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityCheckPerformed rdf:type rdf:Property ;
    rdfs:label 'Capacity Check Performed' ;
    rdfs:comment 'Indicates whether a capacity requirements planning (CRP) check was executed as part of this MRP II run to validate work center availability against planned production orders.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityOverloadCount rdf:type rdf:Property ;
    rdfs:label 'Capacity Overload Count' ;
    rdfs:comment 'Number of work centers identified as overloaded (capacity demand exceeds available capacity) during the MRP II capacity check. Requires production scheduling intervention.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coverageShortfallCount rdf:type rdf:Property ;
    rdfs:label 'Coverage Shortfall Count' ;
    rdfs:comment 'Number of materials with identified supply shortfalls (demand exceeds available supply within the planning horizon) after the MRP run. Critical KPI for supply risk management.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionCancelCount rdf:type rdf:Property ;
    rdfs:label 'Exception Cancel Count' ;
    rdfs:comment 'Count of MRP exception messages recommending cancellation of existing planned receipts (purchase orders or production orders) due to excess supply or demand cancellation.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionMessagesTotal rdf:type rdf:Property ;
    rdfs:label 'Exception Messages Total' ;
    rdfs:comment 'Total count of MRP exception messages generated during the run across all materials. Exception messages flag planning anomalies requiring MRP controller review and action.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionNewRequirementCount rdf:type rdf:Property ;
    rdfs:label 'Exception New Requirement Count' ;
    rdfs:comment 'Count of MRP exception messages indicating new demand requirements that have been identified and for which new planned orders or purchase requisitions have been created.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionRescheduleInCount rdf:type rdf:Property ;
    rdfs:label 'Exception Reschedule In Count' ;
    rdfs:comment 'Count of MRP exception messages recommending that existing receipts (purchase orders, production orders) be rescheduled to an earlier date to cover demand shortfalls.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionRescheduleOutCount rdf:type rdf:Property ;
    rdfs:label 'Exception Reschedule Out Count' ;
    rdfs:comment 'Count of MRP exception messages recommending that existing receipts be rescheduled to a later date due to excess supply or demand postponement.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Fiscal period (month) within the fiscal year in which the MRP run was executed. Enables period-over-period comparison of planning run outputs and exception trends.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'Fiscal year in which the MRP planning run was executed. Used for financial period alignment in procurement spend analytics and supply planning reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:horizonEndDate rdf:type rdf:Property ;
    rdfs:label 'Horizon End Date' ;
    rdfs:comment 'The end date of the planning horizon window for this MRP run. Marks the latest date for which planned orders and procurement proposals are generated.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:horizonStartDate rdf:type rdf:Property ;
    rdfs:label 'Horizon Start Date' ;
    rdfs:comment 'The start date of the planning horizon window for this MRP run. Marks the earliest date for which planned orders and procurement proposals are generated.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiatedBy rdf:type rdf:Property ;
    rdfs:label 'Initiated By' ;
    rdfs:comment 'SAP user ID or system job name that triggered the MRP planning run. Distinguishes between manually initiated runs by MRP controllers and automated scheduled batch jobs.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialRangeFrom rdf:type rdf:Property ;
    rdfs:label 'Material Range From' ;
    rdfs:comment 'Starting material number of the material range included in the MRP run when run_scope is \'material_range\'. Enables targeted replanning of specific material groups.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialRangeTo rdf:type rdf:Property ;
    rdfs:label 'Material Range To' ;
    rdfs:comment 'Ending material number of the material range included in the MRP run when run_scope is \'material_range\'. Defines the upper boundary of the material selection.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpArea rdf:type rdf:Property ;
    rdfs:label 'Mrp Area' ;
    rdfs:comment 'SAP MRP area within the plant that scopes the planning run. An MRP area can represent a storage location, subcontractor, or the entire plant, enabling granular supply planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpControllerGroup rdf:type rdf:Property ;
    rdfs:label 'Mrp Controller Group' ;
    rdfs:comment 'SAP MRP controller group code responsible for reviewing and acting on the exception messages and planned orders generated by this MRP run.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedOrdersCreated rdf:type rdf:Property ;
    rdfs:label 'Planned Orders Created' ;
    rdfs:comment 'Number of new planned production orders generated by the MRP run. Planned orders represent internal manufacturing proposals that MRP controllers review and convert to production orders.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningDate rdf:type rdf:Property ;
    rdfs:label 'Planning Date' ;
    rdfs:comment 'The business date used as the reference point for the MRP planning run. All requirements, receipts, and planned orders are evaluated relative to this date.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Days' ;
    rdfs:comment 'Number of calendar days forward from the planning date that the MRP run covers. Defines the time fence within which planned orders and procurement proposals are generated.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningMode rdf:type rdf:Property ;
    rdfs:label 'Planning Mode' ;
    rdfs:comment 'Indicates the planning methodology applied during the run: standard MRP (Material Requirements Planning), MRP II (Manufacturing Resource Planning including capacity), consumption-based, reorder point, or forecast-based planning.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseRequisitionsCreated rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisitions Created' ;
    rdfs:comment 'Number of purchase requisitions automatically generated by the MRP run for externally procured materials. PRs are subsequently converted to purchase orders by the procurement team.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Run Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds for the MRP planning run to complete. Used to monitor system performance, identify degradation trends, and plan batch scheduling windows.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run End Timestamp' ;
    rdfs:comment 'Date and time when the MRP planning run completed in SAP S/4HANA. Combined with run_start_timestamp to calculate run duration for performance benchmarking.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Business-facing alphanumeric identifier for the MRP planning run, used for cross-referencing in SAP S/4HANA PP/MM and audit trail documentation.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runScope rdf:type rdf:Property ;
    rdfs:label 'Run Scope' ;
    rdfs:comment 'Defines the breadth of materials included in the MRP run: a single material, a defined material range, all materials in the MRP area, or the entire plant.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Start Timestamp' ;
    rdfs:comment 'Date and time when the MRP planning run was initiated in SAP S/4HANA. Used for performance monitoring, audit trail, and scheduling conflict detection.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runTriggerType rdf:type rdf:Property ;
    rdfs:label 'Run Trigger Type' ;
    rdfs:comment 'Indicates how the MRP run was initiated: manually by an MRP controller, via a scheduled batch job, triggered by a business event (e.g., large sales order), or via API integration.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the MRP planning run scope: \'regenerative\' replans all materials, \'net_change\' replans only materials with changes since last run, \'net_change_planning_horizon\' limits net change to the planning horizon window.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleLinesCreated rdf:type rdf:Property ;
    rdfs:label 'Schedule Lines Created' ;
    rdfs:comment 'Number of delivery schedule lines generated by the MRP run for scheduling agreement-based procurement. Represents firm or forecast delivery commitments to suppliers.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:schedulingType rdf:type rdf:Property ;
    rdfs:label 'Scheduling Type' ;
    rdfs:comment 'Defines the scheduling logic applied during the MRP run: basic date calculation, lead time scheduling using routing data, or capacity planning with work center load leveling.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRunReference rdf:type rdf:Property ;
    rdfs:label 'Source System Run Reference' ;
    rdfs:comment 'The native identifier of the MRP run in the source operational system (e.g., SAP S/4HANA internal run key). Enables traceability and reconciliation between the lakehouse and the system of record.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalMaterialsPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Materials Planned' ;
    rdfs:comment 'Count of distinct material numbers processed during the MRP run. Used to assess run scope, compare against prior runs, and validate completeness of planning coverage.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mrpPlannedOrderId rdf:type rdf:Property ;
    rdfs:label 'Mrp Planned Order Id' ;
    rdfs:comment 'Unique surrogate identifier for each MRP/MRP II planned order record in the lakehouse silver layer. Serves as the primary key for this entity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MrpPlannedOrder .

ind:forecastId rdf:type rdf:Property ;
    rdfs:label 'Forecast Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_forecast. Business justification: MRP systems convert sales forecasts into planned production orders. Manufacturing planners trace planned orders back to originating sales forecasts to validate material requirements against actual cus' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Forecast .

ind:hierarchyId rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to product.hierarchy. Business justification: MRP planned orders are generated against specific product hierarchy nodes in industrial manufacturing. Planners run MRP at hierarchy level to aggregate demand across product families — used daily in p' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hierarchy .

ind:lineItemId rdf:type rdf:Property ;
    rdfs:label 'Line Item Id' ;
    rdfs:comment 'Foreign key linking to order.line_item. Business justification: MRP planned orders are generated against specific sales order line items in make-to-order environments. Production planners link planned orders to demand lines to ensure customer-specific production s' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LineItem .

ind:productCostEstimateId rdf:type rdf:Property ;
    rdfs:label 'Product Cost Estimate Id' ;
    rdfs:comment 'Foreign key linking to finance.product_cost_estimate. Business justification: MRP planned orders reference product cost estimates to value planned procurement quantities at standard cost. Finance uses this to calculate planned purchase price variances and inventory valuation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductCostEstimate .

ind:sourceListId rdf:type rdf:Property ;
    rdfs:label 'Source List Id' ;
    rdfs:comment 'Foreign key linking to procurement.source_list. Business justification: MRP uses the source list to determine which supplier or contract to assign to a planned order. Planners rely on this link to ensure planned orders are automatically routed to the correct approved supp' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourceList .

ind:stockPositionId rdf:type rdf:Property ;
    rdfs:label 'Stock Position Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_position. Business justification: MRP planned orders are generated based on current stock positions versus demand. The planned order must reference the stock position it is intended to replenish, enabling planners to validate coverage' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockPosition .

ind:uomId rdf:type rdf:Property ;
    rdfs:label 'Uom Id' ;
    rdfs:comment 'Foreign key linking to product.uom. Business justification: MRP planned orders must reference the product\'s unit of measure to correctly calculate order quantities. Procurement planners rely on consistent UOM alignment between product master and planned orders' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Uom .

ind:bomExplosionIndicator rdf:type rdf:Property ;
    rdfs:label 'Bom Explosion Indicator' ;
    rdfs:comment 'Indicates whether the MRP run performed a BOM explosion for this planned order to generate dependent requirements for lower-level components. True for production orders; typically false for externally procured materials.' ;
    rdfs:domain ind:MrpPlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'SAP company code representing the legal entity or subsidiary for which this planned order is generated. Supports multi-company-code MRP planning in a multinational enterprise context and financial reporting alignment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Conversion Timestamp' ;
    rdfs:comment 'The date and time at which the planned order was converted to a purchase requisition or production order. Supports lead time analysis and MRP controller performance tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:convertedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Converted Document Number' ;
    rdfs:comment 'The purchase requisition number or production order number to which this planned order was converted upon firming and release. Populated after conversion; null for unconverted planned orders. Enables traceability from planned to actual procurement.' ;
    rdfs:domain ind:MrpPlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandSourceType rdf:type rdf:Property ;
    rdfs:label 'Demand Source Type' ;
    rdfs:comment 'The type of demand element that triggered the generation of this planned order by MRP (e.g., sales order, planned independent requirement/forecast, safety stock replenishment, dependent demand from BOM explosion, manual reservation, project requirement, service order).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionMessageCode rdf:type rdf:Property ;
    rdfs:label 'Exception Message Code' ;
    rdfs:comment 'SAP MRP exception message code indicating an action required by the MRP controller (e.g., reschedule in, reschedule out, cancel, bring forward, push back). Exception messages highlight planning deviations requiring manual intervention.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionMessageText rdf:type rdf:Property ;
    rdfs:label 'Exception Message Text' ;
    rdfs:comment 'Descriptive text of the MRP exception message associated with this planned order, providing the MRP controller with actionable guidance on the planning deviation (e.g., \'Reschedule order to earlier date\', \'Order quantity exceeds maximum lot size\').' ;
    rdfs:domain ind:MrpPlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptProcessingDays rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Processing Days' ;
    rdfs:comment 'The number of workdays required for goods receipt inspection and posting after physical delivery, as maintained in the SAP material master. Included in MRP lead time calculation to determine the planned start date.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFirmed rdf:type rdf:Property ;
    rdfs:label 'Is Firmed' ;
    rdfs:comment 'Boolean flag indicating whether the planned order has been firmed (fixed) by the MRP controller to prevent automatic rescheduling or deletion by subsequent MRP runs. Firmed orders are protected from MRP changes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotSizeKey rdf:type rdf:Property ;
    rdfs:label 'Lot Size Key' ;
    rdfs:comment 'The lot-sizing procedure applied by MRP to calculate the planned order quantity (e.g., EX=exact lot size, FX=fixed lot size, MB=monthly lot size, HB=replenish to maximum stock level). Determines how demand is aggregated into order quantities.' ;
    rdfs:domain ind:MrpPlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpControllerCode rdf:type rdf:Property ;
    rdfs:label 'Mrp Controller Code' ;
    rdfs:comment 'Code identifying the MRP controller (planner) responsible for reviewing, firming, and converting this planned order. Corresponds to the MRP controller field in the SAP material master MRP 1 view.' ;
    rdfs:domain ind:MrpPlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpRunDate rdf:type rdf:Property ;
    rdfs:label 'Mrp Run Date' ;
    rdfs:comment 'The date on which the MRP/MRP II planning run was executed that generated or last updated this planned order. Used for audit, traceability, and identifying stale planned orders.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mrpType rdf:type rdf:Property ;
    rdfs:label 'Mrp Type' ;
    rdfs:comment 'The MRP procedure used to plan this material (e.g., MRP, MPS, consumption-based planning, reorder point planning). Corresponds to the MRP type field in the SAP material master MRP 1 view.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openingDate rdf:type rdf:Property ;
    rdfs:label 'Opening Date' ;
    rdfs:comment 'The date on which the planned order should be released or converted to an actionable order (purchase requisition or production order), calculated by subtracting the float before production from the planned start date in SAP MRP.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the planned order indicating the intended conversion target: purchase requisition (external procurement), production order (in-house manufacturing), transfer order (stock transfer), subcontracting, or consignment. Drives MRP controller firming decisions.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDeliveryDays rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Days' ;
    rdfs:comment 'The planned delivery time in calendar days for external procurement of this material, as maintained in the SAP material master or purchasing info record. Used by MRP to calculate planned start date from requirements date.' ;
    rdfs:domain ind:MrpPlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedFinishDate rdf:type rdf:Property ;
    rdfs:label 'Planned Finish Date' ;
    rdfs:comment 'The date by which the planned order must be completed (goods receipt or production completion) to satisfy the dependent or independent demand requirement. Derived from MRP scheduling.' ;
    rdfs:domain ind:MrpPlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Planned Order Number' ;
    rdfs:comment 'Business-facing alphanumeric identifier for the planned order as assigned by the MRP/MRP II run in SAP S/4HANA (MD04/MD06). Used by MRP controllers to reference, review, and firm planned orders.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedOrderValue rdf:type rdf:Property ;
    rdfs:label 'Planned Order Value' ;
    rdfs:comment 'Estimated monetary value of the planned order calculated as planned quantity multiplied by the standard or moving average price of the material. Used for spend analytics, budget planning, and procurement commitment reporting.' ;
    rdfs:domain ind:MrpPlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'The quantity of material to be procured or produced as determined by the MRP/MRP II run, expressed in the base unit of measure. Reflects lot-sizing rules, safety stock, and demand requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'The date on which procurement or production activities for this planned order are scheduled to begin, as calculated by the MRP/MRP II backward scheduling logic. Used for capacity and supplier lead time planning.' ;
    rdfs:domain ind:MrpPlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:procurementType rdf:type rdf:Property ;
    rdfs:label 'Procurement Type' ;
    rdfs:comment 'Indicates whether the material is procured externally (E), produced in-house (F), or both (X), as defined in the SAP material master MRP 2 view. Determines the planned order conversion path.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingGroupCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group Code' ;
    rdfs:comment 'SAP purchasing group (buyer group) responsible for the procurement activity associated with this planned order. Used for workload distribution and spend analytics by buyer.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrgCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Org Code' ;
    rdfs:comment 'SAP purchasing organization responsible for converting this planned order into a purchase requisition or purchase order. Relevant for externally procured planned orders.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementsDate rdf:type rdf:Property ;
    rdfs:label 'Requirements Date' ;
    rdfs:comment 'The date on which the material is required to be available in stock to fulfill the demand element (sales order, production order, forecast, safety stock). Drives MRP scheduling backward to determine planned start date.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'The minimum stock level maintained as a buffer against demand variability and supply uncertainty, as defined in the SAP material master MRP 2 view. Influences MRP net requirements calculation and planned order quantities.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourcePlantCode rdf:type rdf:Property ;
    rdfs:label 'Source Plant Code' ;
    rdfs:comment 'For stock transfer planned orders, the supplying plant from which the material will be transferred. Relevant for multi-plant and cross-company-code MRP scenarios in multinational manufacturing environments.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialProcurementKey rdf:type rdf:Property ;
    rdfs:label 'Special Procurement Key' ;
    rdfs:comment 'SAP special procurement type key indicating non-standard procurement scenarios such as subcontracting, consignment, stock transfer from another plant, or phantom assembly. Influences planned order type and conversion behavior.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'The storage location within the plant where the planned goods receipt will be posted upon conversion and execution of the planned order. Supports warehouse and inventory management integration.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandForecastId rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Id' ;
    rdfs:comment 'Unique surrogate identifier for each demand forecast record in the silver layer lakehouse. Serves as the primary key for all downstream joins and lineage tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemandForecast .

ind:blanketOrderId rdf:type rdf:Property ;
    rdfs:label 'Blanket Order Id' ;
    rdfs:comment 'Foreign key linking to order.blanket_order. Business justification: Demand forecasts are based on blanket orders (framework agreements) with committed volumes. Supply planning uses this to align procurement with contracted customer demand over planning horizons.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BlanketOrder .

ind:fiscalPeriodId rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Id' ;
    rdfs:comment 'Foreign key linking to finance.fiscal_period. Business justification: Demand forecasts are bucketed by fiscal period to align procurement planning with financial budgeting cycles. Finance uses period-aligned forecasts to project cash outflows and purchase commitments.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiscalPeriod .

ind:spendCategoryId rdf:type rdf:Property ;
    rdfs:label 'Spend Category Id' ;
    rdfs:comment 'Foreign key linking to procurement.spend_category. Business justification: Demand forecasts are organized by product/spend category to drive category-level supply planning and MRP inputs. The existing product_category_code (STRING) is a denormalized code; adding spend_catego' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpendCategory .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'ABC inventory classification of the forecasted material based on consumption value: A (high value/high attention), B (medium), C (low value/low attention). Drives differentiated forecasting and safety stock policies.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consensusAdjustmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Consensus Adjustment Quantity' ;
    rdfs:comment 'Manual quantity adjustment applied to the statistical baseline during the S&OP consensus process. Positive values indicate upward revision; negative values indicate downward revision. Captures commercial intelligence not reflected in historical data.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandCategory rdf:type rdf:Property ;
    rdfs:label 'Demand Category' ;
    rdfs:comment 'Classification of the demand type: independent (end-customer driven), dependent (derived from parent BOM), spare parts (aftermarket service), promotional (campaign-driven), new product introduction, or phase-out. Drives appropriate forecasting methodology selection.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Forecast Algorithm' ;
    rdfs:comment 'Statistical or algorithmic method used to generate the baseline forecast. Supports model governance, accuracy benchmarking, and algorithm selection optimization within the S&OP process.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastBias rdf:type rdf:Property ;
    rdfs:label 'Forecast Bias' ;
    rdfs:comment 'Systematic directional error in the forecast, calculated as the average of (forecast minus actual) over the evaluation period. Positive bias indicates consistent over-forecasting; negative bias indicates under-forecasting. Used to detect and correct systemic forecast errors.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastEndDate rdf:type rdf:Property ;
    rdfs:label 'Forecast End Date' ;
    rdfs:comment 'End date of the forecast time bucket. Together with forecast_start_date, defines the discrete planning period for which the forecasted quantity applies.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastNumber rdf:type rdf:Property ;
    rdfs:label 'Forecast Number' ;
    rdfs:comment 'Business-facing alphanumeric identifier for the forecast record, used in S&OP meetings, planning reports, and cross-functional communications. Typically sourced from SAP MRP or APO planning run identifiers.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastPeriodType rdf:type rdf:Property ;
    rdfs:label 'Forecast Period Type' ;
    rdfs:comment 'Granularity of the forecast time bucket: weekly (for near-term operational planning), monthly (for mid-term S&OP), or quarterly (for strategic capacity planning and supplier reservation).' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastStartDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Start Date' ;
    rdfs:comment 'Start date of the forecast time bucket (week, month, or quarter). Combined with forecast_end_date, defines the planning horizon window for this forecast record.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastedQuantity rdf:type rdf:Property ;
    rdfs:label 'Forecasted Quantity' ;
    rdfs:comment 'Final consensus demand quantity for the forecast period after all adjustments. This is the primary demand signal consumed by MRP planning runs to generate planned orders and purchase requisitions.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Forecasted Spend Amount' ;
    rdfs:comment 'Estimated procurement spend for the forecasted quantity, calculated using the standard or moving average price. Used for budget planning, spend analytics, and supplier capacity reservation negotiations.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isMrpRelevant rdf:type rdf:Property ;
    rdfs:label 'Is Mrp Relevant' ;
    rdfs:comment 'Indicates whether this forecast record is active and eligible to be consumed as a demand signal in the next MRP planning run. False records are excluded from MRP net requirements calculation.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSupplierShared rdf:type rdf:Property ;
    rdfs:label 'Is Supplier Shared' ;
    rdfs:comment 'Indicates whether this forecast has been shared with the supplier for capacity reservation purposes. Supports collaborative planning (CPFR) and supplier capacity commitment tracking.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotSizeProcedure rdf:type rdf:Property ;
    rdfs:label 'Lot Size Procedure' ;
    rdfs:comment 'SAP lot-sizing procedure used when converting forecast demand into planned orders or purchase requisitions: exact (lot-for-lot), fixed quantity, economic order quantity (EOQ), period-based, or min/max. Affects procurement cost and inventory levels.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mape rdf:type rdf:Property ;
    rdfs:label 'Mape' ;
    rdfs:comment 'Mean Absolute Percentage Error measuring forecast accuracy as a percentage deviation between forecasted and actual demand over the trailing evaluation period. Lower values indicate higher forecast accuracy. Key KPI for S&OP performance management.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningHorizonMonths rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Months' ;
    rdfs:comment 'Number of months into the future this forecast record covers, measured from the forecast creation date. Determines how far out the demand signal extends for supplier capacity reservation and long-lead procurement.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Product Category Code' ;
    rdfs:comment 'Procurement category or commodity code classifying the forecasted material (e.g., raw materials, electronic components, MRO). Enables category-level demand aggregation for strategic sourcing and spend analytics.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'Inventory level at which a replenishment order should be triggered, calculated from the forecast demand rate and supplier lead time. Directly fed into SAP MRP reorder point planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sopCycle rdf:type rdf:Property ;
    rdfs:label 'Sop Cycle' ;
    rdfs:comment 'The S&OP planning cycle (YYYY-MM) in which this forecast was generated or last reviewed. Links the forecast to the specific monthly S&OP process iteration for governance and audit purposes.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalForecastQuantity rdf:type rdf:Property ;
    rdfs:label 'Statistical Forecast Quantity' ;
    rdfs:comment 'System-generated statistical forecast quantity produced by the forecasting algorithm (e.g., exponential smoothing, moving average) before any manual consensus adjustments. Serves as the baseline for S&OP review.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Supplier Lead Time Days' ;
    rdfs:comment 'Planned replenishment lead time in calendar days from purchase order placement to goods receipt, as used in MRP net requirements calculation. Drives the timing of procurement signals relative to the forecast period.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:versionType rdf:type rdf:Property ;
    rdfs:label 'Version Type' ;
    rdfs:comment 'Classifies the nature of the forecast version: baseline (initial statistical run), statistical (algorithm-generated), consensus (cross-functional agreed), final (locked for MRP input), adjusted (manually overridden), or simulation (what-if scenario).' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:xyzClassification rdf:type rdf:Property ;
    rdfs:label 'Xyz Classification' ;
    rdfs:comment 'XYZ demand variability classification: X (stable/predictable demand), Y (variable demand), Z (irregular/sporadic demand). Combined with ABC classification to determine optimal forecasting strategy and safety stock levels.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Supply Agreement Id' ;
    rdfs:comment 'Unique system-generated identifier for the supply agreement record in the procurement data platform. Serves as the primary key for all downstream joins and references.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplyAgreement .

ind:profitabilitySegmentId rdf:type rdf:Property ;
    rdfs:label 'Profitability Segment Id' ;
    rdfs:comment 'Foreign key linking to finance.profitability_segment. Business justification: Supply agreements for direct materials are linked to profitability segments so procurement costs can be traced to product lines or customer segments in margin analysis reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitabilitySegment .

ind:supplierId rdf:type rdf:Property ;
    rdfs:label 'Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: Every supply agreement and blanket purchase agreement is negotiated with a specific supplier. The current supplier_code (STRING) is a denormalized reference to the supplier master. Adding supplier_id ' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:aribaContractReference rdf:type rdf:Property ;
    rdfs:label 'Ariba Contract Reference' ;
    rdfs:comment 'Unique contract identifier assigned by SAP Ariba Contract Management for this supply agreement. Enables cross-system reconciliation between the Ariba contract repository and SAP MM Outline Agreement.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Procurement commodity or spend category code (e.g., UNSPSC or internal taxonomy) classifying the goods or services covered by this supply agreement. Enables spend analytics, category management, and strategic sourcing alignment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfSupply rdf:type rdf:Property ;
    rdfs:label 'Country Of Supply' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code identifying the primary country from which goods or services are supplied under this agreement. Used for supply chain risk assessment, import/export compliance, and REACH/RoHS regulatory tracking.' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCallOffQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Call Off Quantity' ;
    rdfs:comment 'Minimum quantity that must be ordered per release or call-off against this supply agreement, as contractually agreed with the supplier. Violations may trigger penalty clauses or supplier non-compliance flags.' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClauseDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Description' ;
    rdfs:comment 'Textual description of the penalty terms applicable under this supply agreement, including trigger conditions, penalty calculation method, and maximum liability caps. Populated when penalty_clause_flag is true.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingConditionType rdf:type rdf:Property ;
    rdfs:label 'Pricing Condition Type' ;
    rdfs:comment 'Type of pricing mechanism agreed with the supplier. Fixed price locks unit cost for the agreement duration; tiered volume pricing adjusts price based on quantity thresholds; index-linked pricing ties price to a commodity index; cost-plus adds a margin to supplier cost.' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releasedQuantity rdf:type rdf:Property ;
    rdfs:label 'Released Quantity' ;
    rdfs:comment 'Cumulative quantity of goods or services released against this supply agreement through purchase order releases or delivery schedule lines. Used to track agreement consumption against committed volume.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releasedValue rdf:type rdf:Property ;
    rdfs:label 'Released Value' ;
    rdfs:comment 'Cumulative monetary value of all purchase order releases issued against this supply agreement to date. Compared against total_committed_value to monitor agreement utilization and remaining open commitment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of calendar days prior to agreement expiry by which either party must provide written notice of intent not to renew. Used to trigger contract renewal review workflows and supplier negotiation planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sapOutlineAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Outline Agreement Number' ;
    rdfs:comment 'SAP MM document number for the Outline Agreement (scheduling agreement or contract) created via transaction ME31L or ME31K. Primary cross-reference key for integration with SAP S/4HANA procurement and finance modules.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingEventReference rdf:type rdf:Property ;
    rdfs:label 'Sourcing Event Reference' ;
    rdfs:comment 'Reference number of the SAP Ariba sourcing event (RFQ/RFP/auction) that resulted in the award of this supply agreement. Provides traceability from competitive sourcing to contracted agreement for audit and compliance purposes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Short descriptive title of the supply agreement used for identification in procurement systems, dashboards, and supplier communications. Typically includes supplier name, commodity category, and agreement year.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCommittedQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Committed Quantity' ;
    rdfs:comment 'Total volume of goods or services committed under this supply agreement over its validity period, expressed in the agreement unit of measure. Applicable primarily to scheduling agreements and volume-based contracts.' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCommittedValue rdf:type rdf:Property ;
    rdfs:label 'Total Committed Value' ;
    rdfs:comment 'Total monetary value committed under this supply agreement over its validity period, as negotiated with the supplier. For blanket orders, this is the maximum release value. For scheduling agreements, this is the total planned spend. Used for spend commitment reporting and budget planning.' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Negotiated unit price for the primary material or service covered by this supply agreement, expressed in the agreement currency. For tiered or index-linked agreements, this represents the base or reference price.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryScheduleId rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule Id' ;
    rdfs:comment 'Unique system-generated identifier for each delivery schedule line released against a supply agreement or blanket Purchase Order (PO). Serves as the primary key for the delivery_schedule data product.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleLineId rdf:type rdf:Property ;
    rdfs:label 'Schedule Line Id' ;
    rdfs:comment 'Foreign key linking to order.schedule_line. Business justification: Supplier delivery schedules in procurement are directly aligned to customer-facing schedule lines in sales orders. Supply chain coordinators map inbound delivery dates to outbound schedule commitments' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScheduleLine .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Calendar date on which the supplier actually delivered the material and the Goods Receipt Note (GRN) was posted. Compared against scheduled_delivery_date to calculate on-time delivery performance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Quantity' ;
    rdfs:comment 'Quantity confirmed by the supplier as committed for delivery on the scheduled date. May differ from scheduled quantity due to supplier capacity constraints or partial confirmations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeDeliveredQuantity rdf:type rdf:Property ;
    rdfs:label 'Cumulative Delivered Quantity' ;
    rdfs:comment 'Running cumulative total of all quantities actually received against this scheduling agreement line from the start of the agreement period. Enables cumulative quantity reconciliation and supplier delivery performance analysis.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeScheduledQuantity rdf:type rdf:Property ;
    rdfs:label 'Cumulative Scheduled Quantity' ;
    rdfs:comment 'Running cumulative total of all scheduled quantities from the beginning of the scheduling agreement period to the current schedule line. Used in automotive and lean manufacturing for cumulative quantity reconciliation with suppliers.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysEarlyLate rdf:type rdf:Property ;
    rdfs:label 'Days Early Late' ;
    rdfs:comment 'Number of calendar days the actual delivery was early (negative value) or late (positive value) relative to the scheduled delivery date. Key metric for supplier delivery performance scorecards.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveredQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivered Quantity' ;
    rdfs:comment 'Quantity actually received and posted via Goods Receipt Note (GRN) processing against this schedule line. Used to calculate delivery completeness and schedule adherence.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code of the delivery destination, supporting multinational logistics, customs compliance, and cross-border trade documentation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'Supplier-provided delivery note or packing slip number accompanying the physical shipment. Used for three-way matching (PO, GRN, invoice) and discrepancy resolution.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grnNumber rdf:type rdf:Property ;
    rdfs:label 'Grn Number' ;
    rdfs:comment 'Reference number of the Goods Receipt Note (GRN) document posted in SAP S/4HANA upon physical receipt of the delivery. Links the schedule line to the inventory posting and financial accrual.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOnTime rdf:type rdf:Property ;
    rdfs:label 'Is On Time' ;
    rdfs:comment 'Boolean flag indicating whether the actual delivery date fell within the scheduled delivery window (true) or was late/early (false). Populated upon GRN posting and used for supplier on-time delivery (OTD) performance KPI reporting.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jitDeliveryWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Jit Delivery Window End' ;
    rdfs:comment 'Latest acceptable timestamp for supplier delivery under JIT (Just-In-Time) replenishment rules. Deliveries after this timestamp are considered late and trigger schedule adherence exceptions.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:jitDeliveryWindowStart rdf:type rdf:Property ;
    rdfs:label 'Jit Delivery Window Start' ;
    rdfs:comment 'Earliest acceptable timestamp for supplier delivery under JIT (Just-In-Time) replenishment rules. Deliveries before this timestamp are considered early and may be rejected or incur storage costs.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:kanbanSignalNumber rdf:type rdf:Property ;
    rdfs:label 'Kanban Signal Number' ;
    rdfs:comment 'Unique identifier of the Kanban replenishment signal that triggered this delivery schedule line. Applicable for Kanban-managed materials where pull signals drive supplier delivery requests.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line item number within the delivery schedule document, distinguishing individual delivery date/quantity combinations within the same schedule release.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Short description of the material or component to be delivered, providing human-readable context for the material number in reports and supplier communications.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'SAP material number or internal part number identifying the specific raw material, component, or indirect material to be delivered. Used for MRP (Material Requirements Planning) reconciliation and inventory management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpElementType rdf:type rdf:Property ;
    rdfs:label 'Mrp Element Type' ;
    rdfs:comment 'Type of MRP (Material Requirements Planning) planning element that generated or is associated with this delivery schedule line, indicating whether it originated from a planned order, purchase requisition, or scheduling agreement release.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseType rdf:type rdf:Property ;
    rdfs:label 'Release Type' ;
    rdfs:comment 'Indicates whether this schedule line is a forecast release (planning horizon, non-binding), a JIT (Just-In-Time) release (firm, short-term), an immediate release, or a manually created release.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSchedulingAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Scheduling Agreement Number' ;
    rdfs:comment 'SAP S/4HANA internal 10-digit document number for the scheduling agreement (Outline Agreement) from which this delivery schedule line was released. Enables direct traceability to the source system record.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleAdherenceStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Adherence Status' ;
    rdfs:comment 'Categorical assessment of supplier delivery adherence for this schedule line: on_time (within window), early (before JIT window start), late (after scheduled date), partial (quantity shortfall), missed (no delivery), or pending (not yet due).' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Business-facing alphanumeric identifier for the delivery schedule document, used for cross-system reference and supplier communication. Corresponds to the scheduling agreement release number in SAP S/4HANA MM.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Classification of the delivery schedule indicating the replenishment strategy: JIT (Just-In-Time) for time-critical lean deliveries, forecast for planning horizon releases, firm for committed quantities, or Kanban for pull-based replenishment signals.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'Planned calendar date on which the supplier is required to deliver the material to the specified plant or delivery location. Core field for JIT delivery window management and supplier on-time delivery (OTD) performance tracking.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledDeliveryTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Time' ;
    rdfs:comment 'Specific time of day (HH:MM, 24-hour format) within the scheduled delivery date by which the supplier must deliver, supporting JIT (Just-In-Time) delivery window precision and dock scheduling.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledQuantity rdf:type rdf:Property ;
    rdfs:label 'Scheduled Quantity' ;
    rdfs:comment 'Quantity of material scheduled for delivery on the specified date, expressed in the base unit of measure. Drives MRP (Material Requirements Planning) supply coverage calculations and Kanban replenishment signal sizing.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skuCode rdf:type rdf:Property ;
    rdfs:label 'Sku Code' ;
    rdfs:comment 'Stock Keeping Unit (SKU) code used for warehouse and inventory tracking of the scheduled material, aligning with Infor WMS inventory records.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceOverPercent rdf:type rdf:Property ;
    rdfs:label 'Tolerance Over Percent' ;
    rdfs:comment 'Maximum percentage by which the supplier may over-deliver against the scheduled quantity without triggering a rejection or return. Defined in the supply agreement and enforced during GRN processing.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceUnderPercent rdf:type rdf:Property ;
    rdfs:label 'Tolerance Under Percent' ;
    rdfs:comment 'Maximum percentage by which the supplier may under-deliver against the scheduled quantity and still have the delivery accepted as complete. Defined in the supply agreement.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedManufacturerId rdf:type rdf:Property ;
    rdfs:label 'Approved Manufacturer Id' ;
    rdfs:comment 'Foreign key linking to engineering.approved_manufacturer. Business justification: The procurement source list (which suppliers can supply a given part) must be constrained to engineering\'s AML. Only AML-approved manufacturers may appear on the source list — this link enforces that ' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApprovedManufacturer .

ind:plantId rdf:type rdf:Property ;
    rdfs:label 'Plant Id' ;
    rdfs:comment 'Foreign key linking to product.product_plant. Business justification: Source lists in manufacturing are maintained at the product-plant level to define valid supply sources per plant. MRP uses source lists to automatically assign planned orders to approved suppliers for' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:quotaArrangementId rdf:type rdf:Property ;
    rdfs:label 'Quota Arrangement Id' ;
    rdfs:comment 'Foreign key linking to procurement.quota_arrangement. Business justification: Source list entries can reference quota arrangements that define the volume split across multiple approved suppliers. The table has quota_arrangement_number. Adding quota_arrangement_id FK formalizes ' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QuotaArrangement .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code indicating the country where the material is manufactured or sourced from. Used for trade compliance, import/export controls, REACH/RoHS compliance, and supply chain risk assessment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infoRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Info Record Number' ;
    rdfs:comment 'Reference to the SAP purchasing info record that holds the negotiated price and conditions for this material-supplier-plant combination. Used when no outline agreement exists.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBlocked rdf:type rdf:Property ;
    rdfs:label 'Is Blocked' ;
    rdfs:comment 'Indicates whether this source of supply is explicitly blocked from being used for procurement. A blocked source cannot be selected for purchase requisitions or purchase orders, even if within the validity period.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFixedSource rdf:type rdf:Property ;
    rdfs:label 'Is Fixed Source' ;
    rdfs:comment 'Indicates whether this supplier is designated as the fixed (mandatory) source of supply for the material-plant combination. When true, MRP will exclusively generate purchase requisitions for this supplier, overriding other approved sources.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMrpSourceListRequired rdf:type rdf:Property ;
    rdfs:label 'Is Mrp Source List Required' ;
    rdfs:comment 'Indicates whether the source list is mandatory for MRP to generate purchase requisitions for this material-plant combination. When true, MRP will only create purchase requisitions for sources listed in the source list.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPreferredSource rdf:type rdf:Property ;
    rdfs:label 'Is Preferred Source' ;
    rdfs:comment 'Indicates whether this supplier is the preferred (but not mandatory) source of supply. When multiple approved sources exist, the preferred source is prioritized during manual and automatic sourcing decisions.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date when this source list entry was last reviewed and validated by the procurement or category management team. Supports supplier qualification governance and periodic source list maintenance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialGroup rdf:type rdf:Property ;
    rdfs:label 'Material Group' ;
    rdfs:comment 'SAP material group (commodity category) classifying the material for spend analytics, category management, and sourcing strategy alignment. Used in procurement reporting and supplier segmentation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'Maximum quantity that can be ordered from this supplier in a single purchase order. Used to enforce supply capacity constraints and split large requirements across multiple sources.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrpRelevanceIndicator rdf:type rdf:Property ;
    rdfs:label 'Mrp Relevance Indicator' ;
    rdfs:comment 'Controls how MRP uses this source list entry when generating purchase requisitions. 0 = Not relevant for MRP (manual sourcing only); 1 = MRP can generate purchase requisitions for this source; 2 = Source is blocked for MRP (MRP must not use this source). Directly maps to SAP EORD-MODUS field.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:number rdf:type rdf:Property ;
    rdfs:label 'Number' ;
    rdfs:comment 'Business-facing identifier for the source list entry as assigned in SAP MM (EORD table key). Used for cross-referencing with procurement documents and MRP outputs.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderUnit rdf:type rdf:Property ;
    rdfs:label 'Order Unit' ;
    rdfs:comment 'Unit of measure in which the material is ordered from this supplier (e.g., EA, KG, M, L, PC). May differ from the material\'s base unit of measure and is specific to this supplier relationship.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outlineAgreementItem rdf:type rdf:Property ;
    rdfs:label 'Outline Agreement Item' ;
    rdfs:comment 'Line item number within the referenced outline agreement (scheduling agreement or contract) that corresponds to this source list entry. Required when the agreement covers multiple materials.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outlineAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Outline Agreement Number' ;
    rdfs:comment 'Reference to the SAP scheduling agreement or contract (outline agreement) that governs the supply relationship for this source list entry. Links the source list to a binding supply agreement.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantOfSupply rdf:type rdf:Property ;
    rdfs:label 'Plant Of Supply' ;
    rdfs:comment 'For internal/inter-plant supply types, identifies the supplying plant (internal manufacturing or distribution center) that will fulfill the demand. Applicable when supply_type is internal_plant or stock_transfer.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaArrangementNumber rdf:type rdf:Property ;
    rdfs:label 'Quota Arrangement Number' ;
    rdfs:comment 'Reference to the SAP quota arrangement that governs the percentage split of procurement volume across multiple approved sources for this material-plant combination. Enables multi-source supply strategies.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaPercentage rdf:type rdf:Property ;
    rdfs:label 'Quota Percentage' ;
    rdfs:comment 'Percentage of total procurement volume for this material-plant combination allocated to this supplier source. Used in multi-source supply strategies to distribute demand across approved suppliers.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialProcurementType rdf:type rdf:Property ;
    rdfs:label 'Special Procurement Type' ;
    rdfs:comment 'SAP special procurement type code indicating non-standard procurement scenarios such as subcontracting (supplier processes company-owned components), consignment (supplier-owned stock), third-party (direct shipment to customer), or pipeline (continuous supply).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Standard Lead Time Days' ;
    rdfs:comment 'Standard procurement lead time in calendar days from purchase order placement to goods receipt for this material-supplier-plant combination. Used by MRP for scheduling and delivery date calculation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subRange rdf:type rdf:Property ;
    rdfs:label 'Sub Range' ;
    rdfs:comment 'Supplier sub-range code identifying a specific product line, manufacturing site, or division within the supplier\'s organization that is the approved source. Relevant for large suppliers with multiple production facilities.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyType rdf:type rdf:Property ;
    rdfs:label 'Supply Type' ;
    rdfs:comment 'Categorizes the type of supply relationship for this source list entry. External supplier = standard third-party procurement; Internal plant = inter-plant stock transfer; Subcontracting = supplier processes company-owned materials; Consignment = supplier-owned stock at company premises; Stock transfer = intra-company movement.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usage rdf:type rdf:Property ;
    rdfs:label 'Usage' ;
    rdfs:comment 'Defines whether the source list is mandatory (procurement must use only listed sources) or optional (source list is advisory). Controlled at the material master level but captured here for analytical context.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity' ;
    rdfs:comment 'Cumulative quantity already allocated to this supplier under the quota arrangement (EQUK-ZUGMG). Used by MRP to determine which supplier should receive the next procurement order based on quota ratios.' ;
    rdfs:domain ind:QuotaArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arrangementNumber rdf:type rdf:Property ;
    rdfs:label 'Arrangement Number' ;
    rdfs:comment 'Business key identifying the quota arrangement in the source system (SAP MM EQUK table key). Used for cross-system traceability and reconciliation.' ;
    rdfs:domain ind:QuotaArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastResetDate rdf:type rdf:Property ;
    rdfs:label 'Last Reset Date' ;
    rdfs:comment 'Date on which the quota base quantity and allocated quantity counters were last reset. Quota resets are performed periodically to rebalance supplier allocations and reflect updated volume agreements.' ;
    rdfs:domain ind:QuotaArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumLotSize rdf:type rdf:Property ;
    rdfs:label 'Maximum Lot Size' ;
    rdfs:comment 'Maximum order quantity that can be placed with this supplier in a single procurement order under the quota arrangement. Supports capacity and risk management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumLotSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Lot Size' ;
    rdfs:comment 'Minimum order quantity that must be placed with this supplier under the quota arrangement. Prevents splitting orders below economically viable quantities.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outlineAgreementLine rdf:type rdf:Property ;
    rdfs:label 'Outline Agreement Line' ;
    rdfs:comment 'Line item number within the outline agreement referenced by this quota arrangement line. Required when the agreement contains multiple material lines.' ;
    rdfs:domain ind:QuotaArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Numeric priority rank assigned to this quota line relative to other suppliers for the same material and plant. Lower values indicate higher priority for source selection when quota ratios are equal.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaBaseQuantity rdf:type rdf:Property ;
    rdfs:label 'Quota Base Quantity' ;
    rdfs:comment 'Base quantity used as the starting point for quota usage calculation (EQUK-QUOGR). Resets periodically and is used in conjunction with allocated quantity to determine the next source of supply.' ;
    rdfs:domain ind:QuotaArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaUsageCount rdf:type rdf:Property ;
    rdfs:label 'Quota Usage Count' ;
    rdfs:comment 'Number of times this quota line has been selected during automatic source determination (EQUK-QUNUM). Used alongside allocated quantity to track supplier selection frequency.' ;
    rdfs:domain ind:QuotaArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Type of procurement source assigned to this quota line. Indicates whether the quota directs procurement to a vendor directly, a contract, or a scheduling agreement.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyingPlantCode rdf:type rdf:Property ;
    rdfs:label 'Supplying Plant Code' ;
    rdfs:comment 'For stock transfer quota lines, identifies the SAP plant that supplies the material. Applicable when procurement type is internal stock transfer between plants.' ;
    rdfs:domain ind:QuotaArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classId rdf:type rdf:Property ;
    rdfs:label 'Class Id' ;
    rdfs:comment 'Unique system-generated identifier for each asset classification record within the enterprise asset taxonomy.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Class .

ind:classificationId rdf:type rdf:Property ;
    rdfs:label 'Classification Id' ;
    rdfs:comment 'Foreign key linking to product.classification. Business justification: Asset classes are aligned to product classification schemes (e.g., equipment taxonomy). Asset management and product engineering teams share classification structures to ensure consistent categorizati' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Classification .

ind:applicableStandard rdf:type rdf:Property ;
    rdfs:label 'Applicable Standard' ;
    rdfs:comment 'Primary industry or regulatory standard governing the design, operation, or maintenance of assets in this class (e.g., ISO 9001, IEC 61131, ANSI/NFPA 70, CE Marking, UL 508A).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Indicates whether the asset class represents a fixed asset, movable asset, leased asset, or tooling, driving accounting treatment and depreciation rules under IFRS/GAAP.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Capitalization Threshold Amount' ;
    rdfs:comment 'Minimum acquisition cost (in base currency) above which an asset of this class must be capitalized as a fixed asset rather than expensed as OPEX, per company CAPEX policy and GAAP/IFRS guidelines.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalizationThresholdCurrency rdf:type rdf:Property ;
    rdfs:label 'Capitalization Threshold Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the capitalization threshold amount, supporting multi-currency operations across global manufacturing sites.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceMarkingRequired rdf:type rdf:Property ;
    rdfs:label 'Ce Marking Required' ;
    rdfs:comment 'Indicates whether assets of this class require CE Marking for operation within the European Union, ensuring conformity with applicable EU directives (Machinery Directive, Low Voltage Directive, EMC Directive).' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'Default SAP cost center code for assets of this class, used for OPEX maintenance cost allocation and management accounting reporting in SAP S/4HANA CO module.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityRating rdf:type rdf:Property ;
    rdfs:label 'Criticality Rating' ;
    rdfs:comment 'Standardized criticality rating for assets of this class based on impact to production throughput, safety, and quality. Drives maintenance prioritization, spare parts stocking strategy, and OEE reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Accounting depreciation method applied to assets of this class, governing how asset value is expensed over its useful life in compliance with IFRS/GAAP financial reporting standards.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyClass rdf:type rdf:Property ;
    rdfs:label 'Energy Class' ;
    rdfs:comment 'Energy efficiency classification for assets of this class, supporting ISO 50001 energy management compliance and OPEX energy cost reporting across manufacturing facilities.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalRiskClass rdf:type rdf:Property ;
    rdfs:label 'Environmental Risk Class' ;
    rdfs:comment 'Environmental risk classification for assets of this class, indicating potential environmental impact (e.g., refrigerant leaks, chemical containment, emissions) for compliance with ISO 14001 and EPA regulations.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'SAP General Ledger account code associated with this asset class for CAPEX capitalization and OPEX expense posting, ensuring correct financial accounting treatment in SAP S/4HANA FI/CO.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iiotMonitoringEnabled rdf:type rdf:Property ;
    rdfs:label 'Iiot Monitoring Enabled' ;
    rdfs:comment 'Indicates whether assets of this class are configured for real-time condition monitoring via the Siemens MindSphere IIoT platform, enabling predictive maintenance and digital performance analytics.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionAuthority rdf:type rdf:Property ;
    rdfs:label 'Inspection Authority' ;
    rdfs:comment 'Name of the regulatory or certification body responsible for mandating or conducting inspections for assets of this class (e.g., OSHA, TÜV, UL, CE Notified Body, local fire authority).' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency Days' ;
    rdfs:comment 'Mandatory interval in calendar days between regulatory compliance inspections for assets of this class, as prescribed by applicable governing bodies (OSHA, CE, UL, local regulations).' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Inspection Required' ;
    rdfs:comment 'Indicates whether assets of this class are subject to mandatory regulatory inspections (e.g., pressure vessels, lifting equipment, electrical installations) as required by OSHA, CE Marking, or UL certification standards.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Maintenance Frequency Days' ;
    rdfs:comment 'Standard interval in calendar days between scheduled preventive maintenance activities for assets of this class, used to auto-generate work orders in Maximo EAM.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceStrategy rdf:type rdf:Property ;
    rdfs:label 'Maintenance Strategy' ;
    rdfs:comment 'Default maintenance strategy class assigned to assets of this type, aligning with Total Productive Maintenance (TPM) and Reliability-Centered Maintenance (RCM) frameworks configured in Maximo EAM.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanTimeBetweenFailuresHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time Between Failures Hours' ;
    rdfs:comment 'Industry-standard or OEM-specified Mean Time Between Failures (MTBF) in hours for assets of this class, used as a benchmark for reliability analysis, maintenance planning, and OEE calculations.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanTimeToRepairHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time To Repair Hours' ;
    rdfs:comment 'Industry-standard or OEM-specified Mean Time To Repair (MTTR) in hours for assets of this class, used to estimate downtime impact, plan maintenance labor resources, and set SLA targets for work orders.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reachRohsApplicable rdf:type rdf:Property ;
    rdfs:label 'Reach Rohs Applicable' ;
    rdfs:comment 'Indicates whether assets of this class contain substances subject to REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals) or RoHS (Restriction of Hazardous Substances) compliance requirements.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualValuePercent rdf:type rdf:Property ;
    rdfs:label 'Residual Value Percent' ;
    rdfs:comment 'Estimated residual (salvage) value of assets in this class expressed as a percentage of original acquisition cost, used in depreciation base calculations per IFRS IAS 16.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyCritical rdf:type rdf:Property ;
    rdfs:label 'Safety Critical' ;
    rdfs:comment 'Indicates whether assets of this class are designated as safety-critical, requiring enhanced maintenance protocols, mandatory inspection records, and compliance with ISO 45001 occupational health and safety standards.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapAssetClassCode rdf:type rdf:Property ;
    rdfs:label 'Sap Asset Class Code' ;
    rdfs:comment 'Corresponding asset class code in SAP S/4HANA FI-AA module, used for financial accounting, depreciation area assignment, and CAPEX tracking. Ensures EAM-ERP synchronization.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaIntegrated rdf:type rdf:Property ;
    rdfs:label 'Scada Integrated' ;
    rdfs:comment 'Indicates whether assets of this class are integrated with SCADA systems for supervisory control and real-time operational data acquisition, relevant for OT/IT convergence and cybersecurity compliance.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sparePartsStrategy rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Strategy' ;
    rdfs:comment 'Default spare parts inventory strategy for assets of this class, used to configure MRO (Maintenance, Repair and Operations) inventory levels in SAP MM and Infor WMS.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Secondary classification level within the asset category, providing finer granularity (e.g., CNC Machining, Robotic Welding, SCADA Systems, HVAC Chillers) for maintenance strategy alignment.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ulCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Ul Certification Required' ;
    rdfs:comment 'Indicates whether assets of this class require UL (Underwriters Laboratories) product safety certification for operation in North American markets.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Standard expected useful life in years for assets belonging to this class, used to calculate depreciation schedules and plan asset replacement cycles under IFRS IAS 16.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Duration Months' ;
    rdfs:comment 'Standard manufacturer warranty duration in months applicable to assets of this class, used to configure warranty tracking and claim management in Maximo EAM and Salesforce Service Cloud.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenancePlanId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Plan Id' ;
    rdfs:comment 'Unique system-generated identifier for the maintenance plan record within the enterprise asset management system.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenancePlan .

ind:costAllocationId rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_allocation. Business justification: Preventive maintenance plans carry annual budgeted costs assigned to a cost center. Plant controllers use this link to compare planned vs. actual maintenance spend per cost center during budget review' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostAllocation .

ind:entitlementId rdf:type rdf:Property ;
    rdfs:label 'Entitlement Id' ;
    rdfs:comment 'Foreign key linking to service.entitlement. Business justification: Maintenance plans are scoped by what the customer is entitled to receive under their service agreement. Asset managers validate entitlement before scheduling planned maintenance to ensure the work is ' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Entitlement .

ind:partsOriginLocationId rdf:type rdf:Property ;
    rdfs:label 'Parts Origin Location Id' ;
    rdfs:comment 'Foreign key linking to logistics.location. Business justification: Maintenance plans specify which stocking location supplies the required spare parts. Planners reference this logistics location when generating planned orders to ensure parts are sourced from the corr' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:toolingEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Tooling Equipment Id' ;
    rdfs:comment 'Foreign key linking to engineering.tooling_equipment. Business justification: Maintenance plans specify which engineering-defined tooling and equipment is required to perform maintenance activities. Maintenance planners reference engineering tooling records to ensure correct to' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ToolingEquipment .

ind:callHorizonPercentage rdf:type rdf:Property ;
    rdfs:label 'Call Horizon Percentage' ;
    rdfs:comment 'SAP PM call horizon parameter expressed as a percentage of the maintenance cycle. Defines how early within the scheduling horizon a maintenance call is created (e.g., 100% means calls are created at the full horizon distance).' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completionRequirement rdf:type rdf:Property ;
    rdfs:label 'Completion Requirement' ;
    rdfs:comment 'Indicates whether completion of maintenance activities under this plan is mandatory (regulatory or safety-critical), recommended (best practice), or optional (condition-dependent). Drives escalation and overdue handling logic.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'SAP CO cost center code to which maintenance costs generated by this plan are allocated. Enables OPEX tracking, departmental cost reporting, and budget variance analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterReadingAtLastService rdf:type rdf:Property ;
    rdfs:label 'Counter Reading At Last Service' ;
    rdfs:comment 'Meter or counter value (e.g., operating hours, production cycles, kilometers) recorded at the time of the last completed maintenance activity. Used as the baseline for counter-based scheduling.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleUnit rdf:type rdf:Property ;
    rdfs:label 'Cycle Unit' ;
    rdfs:comment 'Unit of measure for the maintenance cycle value. Supports both time-based units (days, weeks, months) and counter-based units (operating hours, production cycles, kilometers) per SAP PM counter configuration.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleValue rdf:type rdf:Property ;
    rdfs:label 'Cycle Value' ;
    rdfs:comment 'Numeric value defining the maintenance cycle interval. For time-based plans this is the duration (e.g., 90 days), for counter-based plans this is the usage count (e.g., 500 operating hours or 10,000 production cycles).' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentCategory rdf:type rdf:Property ;
    rdfs:label 'Equipment Category' ;
    rdfs:comment 'Classification of the equipment type covered by this maintenance plan. Aligns with SAP PM equipment categories and supports filtering for CNC machines, PLC systems, SCADA infrastructure, and other asset classes.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Planned cost in the plan currency for one execution cycle of the maintenance activities, including labor, materials, and external services. Used for OPEX budgeting and CAPEX vs OPEX classification.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'Planned duration in hours required to complete one execution of the maintenance activities defined in this plan. Used for resource capacity planning, downtime scheduling, and OEE impact assessment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalPlanReference rdf:type rdf:Property ;
    rdfs:label 'External Plan Reference' ;
    rdfs:comment 'Cross-system reference identifier for this maintenance plan in the alternate source system (e.g., Maximo PM Program ID when the master record is in SAP PM, or vice versa). Enables reconciliation between SAP PM and Maximo EAM.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Last Completion Date' ;
    rdfs:comment 'Date on which the most recently executed maintenance activity under this plan was completed and confirmed. Used as the baseline for calculating the next due date in time-based plans.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Last Scheduled Date' ;
    rdfs:comment 'Date on which the most recent maintenance call was scheduled under this plan. Used to calculate the next due date and track scheduling cadence compliance.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Number of calendar days before the scheduled maintenance due date that a work order should be generated, allowing time for spare parts procurement, resource scheduling, and production planning coordination.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenancePlant rdf:type rdf:Property ;
    rdfs:label 'Maintenance Plant' ;
    rdfs:comment 'The plant responsible for executing the maintenance activities, which may differ from the plant where the asset is located in multi-site or centralized maintenance organizations.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceType rdf:type rdf:Property ;
    rdfs:label 'Maintenance Type' ;
    rdfs:comment 'Operational classification of the maintenance execution type, distinguishing planned scheduled activities from emergency or shutdown-based maintenance windows.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Due Date' ;
    rdfs:comment 'Calculated date on which the next maintenance activity is due based on the cycle parameters, last completion date, and scheduling rules. Critical for maintenance scheduling dashboards and overdue tracking.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationType rdf:type rdf:Property ;
    rdfs:label 'Notification Type' ;
    rdfs:comment 'Type of maintenance notification generated when the plan triggers a maintenance call. SAP PM notification types (M1 activity report, M2 malfunction report, M3 maintenance request) or digital alert channels.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planCategory rdf:type rdf:Property ;
    rdfs:label 'Plan Category' ;
    rdfs:comment 'Business category of the maintenance plan aligned with Total Productive Maintenance (TPM) disciplines: preventive, predictive, lubrication, calibration, regulatory inspection, or major overhaul.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Business-facing alphanumeric identifier for the maintenance plan, used for cross-system referencing between SAP PM and Maximo EAM.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannerGroup rdf:type rdf:Property ;
    rdfs:label 'Planner Group' ;
    rdfs:comment 'SAP PM planner group code identifying the maintenance planning team responsible for managing and scheduling this maintenance plan. Used for workload distribution and planning accountability.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Specific regulatory standard, clause, or legal requirement that mandates this maintenance plan (e.g., \'OSHA 29 CFR 1910.217\', \'ISO 45001 Clause 8.1\', \'EPA 40 CFR Part 63\'). Required for compliance audit trails.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirement rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement' ;
    rdfs:comment 'Indicates whether this maintenance plan is mandated by a regulatory body (e.g., OSHA, EPA, CE Marking, ISO 45001, pressure vessel inspection regulations). Regulatory plans receive elevated priority and compliance tracking.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Version or revision identifier for the maintenance plan, incremented when significant changes are made to cycle parameters, scope, or strategy. Supports change management and audit trail requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Scheduling Horizon Days' ;
    rdfs:comment 'Forward-looking planning window in days within which the maintenance plan will generate scheduled work orders. Defines how far ahead the system creates maintenance calls for resource and capacity planning.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:strategyType rdf:type rdf:Property ;
    rdfs:label 'Strategy Type' ;
    rdfs:comment 'Classification of the maintenance strategy governing this plan. Time-based triggers on calendar intervals, counter-based on usage meters (hours, cycles), condition-based on sensor thresholds, and predictive leverages IIoT/MindSphere analytics.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Tolerance Percentage' ;
    rdfs:comment 'Allowable deviation percentage from the scheduled maintenance due date or counter threshold before the maintenance is considered overdue. Used to accommodate production scheduling flexibility without triggering compliance violations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workCenter rdf:type rdf:Property ;
    rdfs:label 'Work Center' ;
    rdfs:comment 'SAP PM or Maximo work center code identifying the maintenance team, crew, or organizational unit responsible for executing the maintenance activities defined in this plan.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceItemId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Item Id' ;
    rdfs:comment 'Unique system-generated identifier for each individual maintenance task item within a maintenance plan. Serves as the primary key for the maintenance_item entity in the asset domain.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceItem .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: Maintenance items (spare parts, consumables) are procured via purchase orders. Maintenance planners reference the PO that sourced the part used in a maintenance activity — a daily operational link in ' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:taskListId rdf:type rdf:Property ;
    rdfs:label 'Task List Id' ;
    rdfs:comment 'Foreign key linking to asset.task_list. Business justification: maintenance_item currently stores task_list_number (STRING) and task_list_type (STRING) as denormalized references to the task_list product. task_list has a `number` and `type` attribute that are the ' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaskList .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'Cost accounting activity type used to allocate internal labor costs for this maintenance task to the appropriate cost center. Links maintenance execution to financial controlling (CO) in SAP.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationStandard rdf:type rdf:Property ;
    rdfs:label 'Calibration Standard' ;
    rdfs:comment 'Reference to the applicable calibration standard or specification that governs this calibration task item (e.g., \'ISO 9001 Clause 7.1.5\', \'NIST Traceable\', \'IEC 61315\'). Applicable only when task_type is \'calibration\'. Supports quality management system compliance.' ;
    rdfs:domain ind:MaintenanceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlKey rdf:type rdf:Property ;
    rdfs:label 'Control Key' ;
    rdfs:comment 'SAP PM control key that determines how the maintenance operation is processed, including whether it is internally performed, externally serviced, or a milestone operation. Controls costing, confirmation, and scheduling behavior.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costClassification rdf:type rdf:Property ;
    rdfs:label 'Cost Classification' ;
    rdfs:comment 'Financial classification of the maintenance task cost as either Capital Expenditure (CAPEX) — improving or extending asset life — or Operational Expenditure (OPEX) — routine maintenance to sustain current performance. Critical for financial reporting and asset accounting.' ;
    rdfs:domain ind:MaintenanceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the estimated and actual cost values associated with this maintenance item (e.g., USD, EUR, GBP). Supports multi-currency operations in a multinational enterprise.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedMeasurementValue rdf:type rdf:Property ;
    rdfs:label 'Expected Measurement Value' ;
    rdfs:comment 'Target or nominal measurement value expected at the measurement point during inspection or calibration. Used to assess whether the equipment is operating within acceptable parameters and to trigger corrective actions when deviations occur.' ;
    rdfs:domain ind:MaintenanceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardousMaterialIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Indicator' ;
    rdfs:comment 'Flag indicating whether this maintenance task involves handling, disposal, or exposure to hazardous materials (chemicals, lubricants, refrigerants, etc.). Triggers REACH/RoHS compliance checks and hazardous waste disposal procedures.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intervalUnit rdf:type rdf:Property ;
    rdfs:label 'Interval Unit' ;
    rdfs:comment 'Unit of measure for the maintenance interval, defining whether the interval is time-based (days, weeks, months), usage-based (operating hours, cycles, kilometers), or event-based. Determines the scheduling trigger type.' ;
    rdfs:domain ind:MaintenanceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intervalValue rdf:type rdf:Property ;
    rdfs:label 'Interval Value' ;
    rdfs:comment 'Numeric value of the maintenance interval at which this task should be performed (e.g., 90 for every 90 days, 500 for every 500 operating hours). Combined with interval_unit to define the full maintenance cycle.' ;
    rdfs:domain ind:MaintenanceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itemNumber rdf:type rdf:Property ;
    rdfs:label 'Item Number' ;
    rdfs:comment 'Sequential counter number identifying the position of this task item within its parent maintenance plan or task list. Used for ordering and referencing individual steps (e.g., 0010, 0020, 0030 in SAP PM convention).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemText rdf:type rdf:Property ;
    rdfs:label 'Item Text' ;
    rdfs:comment 'Short descriptive text summarizing the specific maintenance task to be performed, such as \'Inspect hydraulic seals\', \'Lubricate conveyor bearings\', or \'Calibrate pressure sensor\'. Used for display and search.' ;
    rdfs:domain ind:MaintenanceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockoutTagoutRequired rdf:type rdf:Property ;
    rdfs:label 'Lockout Tagout Required' ;
    rdfs:comment 'Indicates whether Lockout/Tagout (LOTO) energy isolation procedures must be applied before performing this maintenance task. Mandatory for tasks involving electrical, hydraulic, pneumatic, or thermal energy sources to prevent accidental energization.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:longText rdf:type rdf:Property ;
    rdfs:label 'Long Text' ;
    rdfs:comment 'Detailed narrative description of the maintenance task including step-by-step instructions, technical specifications, acceptance criteria, and any special notes for the technician. Supports Standard Operating Procedure (SOP) documentation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceCategory rdf:type rdf:Property ;
    rdfs:label 'Maintenance Category' ;
    rdfs:comment 'Broad category of maintenance strategy this item belongs to, distinguishing between preventive (scheduled), predictive (condition-triggered), corrective (reactive), statutory (regulatory-mandated), and other maintenance types. Supports TPM and reliability-centered maintenance (RCM) analysis.' ;
    rdfs:domain ind:MaintenanceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialListIndicator rdf:type rdf:Property ;
    rdfs:label 'Material List Indicator' ;
    rdfs:comment 'Flag indicating whether this maintenance task item has an associated list of required spare parts, consumables, or materials (Bill of Materials for maintenance). When true, material components are defined in the task list component assignment.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementPoint rdf:type rdf:Property ;
    rdfs:label 'Measurement Point' ;
    rdfs:comment 'Identifier or description of the specific measurement point on the equipment where readings are to be taken during inspection or condition monitoring tasks (e.g., \'Bearing Temperature - Drive End\', \'Vibration - Motor NDE\'). Supports IIoT and condition-based maintenance.' ;
    rdfs:domain ind:MaintenanceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'Unit of measure for the expected and actual measurement values recorded during this maintenance task (e.g., °C, bar, mm/s, kPa, RPM, mA). Ensures consistent data capture and comparison against specifications.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfTechnicians rdf:type rdf:Property ;
    rdfs:label 'Number Of Technicians' ;
    rdfs:comment 'Number of maintenance technicians or workers required to perform this task item simultaneously. Used for crew sizing, capacity planning, and safety compliance (e.g., confined space entry requiring minimum two persons).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:permitRequired rdf:type rdf:Property ;
    rdfs:label 'Permit Required' ;
    rdfs:comment 'Indicates whether a formal Permit to Work (PTW) is required before executing this maintenance task. Applies to high-risk activities such as hot work, confined space entry, electrical isolation, or working at height. Mandatory for safety compliance.' ;
    rdfs:domain ind:MaintenanceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permitType rdf:type rdf:Property ;
    rdfs:label 'Permit Type' ;
    rdfs:comment 'Type of work permit required for this maintenance task when permit_required is true. Determines the safety authorization workflow, hazard controls, and regulatory compliance requirements that must be satisfied before work begins.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeRequirements rdf:type rdf:Property ;
    rdfs:label 'Ppe Requirements' ;
    rdfs:comment 'Description of the Personal Protective Equipment (PPE) required for safe execution of this maintenance task (e.g., \'Safety glasses, chemical-resistant gloves, steel-toed boots, hearing protection\'). Supports safety compliance and technician briefing.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationRequirement rdf:type rdf:Property ;
    rdfs:label 'Qualification Requirement' ;
    rdfs:comment 'Required skill, trade certification, or qualification level that the assigned technician must possess to perform this maintenance task (e.g., \'Certified Electrician\', \'Hydraulics Level 2\', \'Confined Space Entry Certified\'). Supports workforce compliance.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopReference rdf:type rdf:Property ;
    rdfs:label 'Sop Reference' ;
    rdfs:comment 'Document number or identifier of the Standard Operating Procedure (SOP) that governs the execution of this maintenance task. Ensures technicians follow approved procedures and supports ISO 9001 document control requirements.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Classification of the specific maintenance activity to be performed. Drives material requirements, skill requirements, and safety protocols. Supports Total Productive Maintenance (TPM) task decomposition and reporting.' ;
    rdfs:domain ind:MaintenanceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceLowerLimit rdf:type rdf:Property ;
    rdfs:label 'Tolerance Lower Limit' ;
    rdfs:comment 'Minimum acceptable measurement value for this maintenance task. Readings below this threshold indicate a non-conformance condition requiring corrective action or Corrective and Preventive Action (CAPA) initiation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceUpperLimit rdf:type rdf:Property ;
    rdfs:label 'Tolerance Upper Limit' ;
    rdfs:comment 'Maximum acceptable measurement value for this maintenance task. Readings above this threshold indicate a non-conformance condition requiring corrective action or Corrective and Preventive Action (CAPA) initiation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetNotificationId rdf:type rdf:Property ;
    rdfs:label 'Asset Notification Id' ;
    rdfs:comment 'Unique surrogate identifier for the maintenance notification record in the lakehouse silver layer. Serves as the primary key for this entity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetNotification .

ind:assembly rdf:type rdf:Property ;
    rdfs:label 'Assembly' ;
    rdfs:comment 'Identifier of the specific assembly, sub-component, or part of the equipment where the fault or damage was observed. Supports root cause analysis and spare parts planning.' ;
    rdfs:domain ind:AssetNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakdownIndicator rdf:type rdf:Property ;
    rdfs:label 'Breakdown Indicator' ;
    rdfs:comment 'Flag indicating whether the notification represents a complete equipment breakdown (unplanned stoppage) as opposed to a degraded performance or minor fault condition. Drives breakdown-specific KPI reporting and emergency response protocols.' ;
    rdfs:domain ind:AssetNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:causeCode rdf:type rdf:Property ;
    rdfs:label 'Cause Code' ;
    rdfs:comment 'Standardized code from the cause catalog identifying the root cause of the equipment failure or malfunction (e.g., operator error, material fatigue, lubrication failure). Supports CAPA processes and reliability engineering.' ;
    rdfs:domain ind:AssetNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:causeDescription rdf:type rdf:Property ;
    rdfs:label 'Cause Description' ;
    rdfs:comment 'Textual description of the identified root cause corresponding to the cause code. Provides narrative context for CAPA documentation and reliability improvement initiatives.' ;
    rdfs:domain ind:AssetNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Timestamp when the notification was formally closed after business completion confirmation, distinguishing technical completion from administrative closure. Used for lifecycle duration analytics.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'Timestamp when the notification was marked as technically completed in the source system, indicating all associated maintenance tasks have been executed and documented.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:damageCode rdf:type rdf:Property ;
    rdfs:label 'Damage Code' ;
    rdfs:comment 'Standardized code from the damage catalog identifying the type of physical damage or defect observed on the equipment (e.g., wear, corrosion, fracture, leakage). Supports failure pattern analysis and FMEA validation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageDescription rdf:type rdf:Property ;
    rdfs:label 'Damage Description' ;
    rdfs:comment 'Textual description of the observed damage or defect corresponding to the damage code. Provides human-readable context for maintenance planners and engineers performing root cause analysis.' ;
    rdfs:domain ind:AssetNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectCode rdf:type rdf:Property ;
    rdfs:label 'Effect Code' ;
    rdfs:comment 'Standardized code describing the operational effect or consequence of the malfunction on production (e.g., production stoppage, reduced output, quality defect). Used in FMEA severity assessment and impact analysis.' ;
    rdfs:domain ind:AssetNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentRelevant rdf:type rdf:Property ;
    rdfs:label 'Environment Relevant' ;
    rdfs:comment 'Flag indicating whether the notified fault has potential environmental impact (e.g., chemical leak, emissions exceedance). Triggers environmental incident reporting per ISO 14001 and EPA regulatory requirements.' ;
    rdfs:domain ind:AssetNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mainWorkCenter rdf:type rdf:Property ;
    rdfs:label 'Main Work Center' ;
    rdfs:comment 'Identifier of the primary maintenance work center (crew or team) responsible for executing the maintenance activities triggered by this notification. Used for capacity planning and workload balancing.' ;
    rdfs:domain ind:AssetNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:malfunctionEndDate rdf:type rdf:Property ;
    rdfs:label 'Malfunction End Date' ;
    rdfs:comment 'Date when the equipment malfunction or breakdown was resolved and the asset was returned to operational status. Used for downtime duration calculation and MTTR analysis.' ;
    rdfs:domain ind:AssetNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:malfunctionEndTime rdf:type rdf:Property ;
    rdfs:label 'Malfunction End Time' ;
    rdfs:comment 'Precise timestamp when the equipment malfunction was resolved and normal operations resumed. Combined with malfunction start timestamp to compute actual downtime for MTTR and OEE calculations.' ;
    rdfs:domain ind:AssetNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:malfunctionStartDate rdf:type rdf:Property ;
    rdfs:label 'Malfunction Start Date' ;
    rdfs:comment 'Date when the equipment malfunction or breakdown actually began, as reported by the operator. May differ from the reported date if the fault was observed after the fact. Used for downtime duration calculation.' ;
    rdfs:domain ind:AssetNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:malfunctionStartTime rdf:type rdf:Property ;
    rdfs:label 'Malfunction Start Time' ;
    rdfs:comment 'Precise timestamp when the equipment malfunction or breakdown commenced. Used in conjunction with malfunction end timestamp to calculate actual downtime duration for OEE and MTBF/MTTR reporting.' ;
    rdfs:domain ind:AssetNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:objectPartCode rdf:type rdf:Property ;
    rdfs:label 'Object Part Code' ;
    rdfs:comment 'Code identifying the specific part or component of the equipment object where the damage or fault was detected. Enables component-level failure frequency analysis and targeted preventive maintenance planning.' ;
    rdfs:domain ind:AssetNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningPlant rdf:type rdf:Property ;
    rdfs:label 'Planning Plant' ;
    rdfs:comment 'Plant code of the maintenance planning plant responsible for processing and planning the work associated with this notification. May differ from the plant where the asset is located in centralized maintenance organizations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedBy rdf:type rdf:Property ;
    rdfs:label 'Reported By' ;
    rdfs:comment 'User ID or personnel number of the individual who created and submitted the maintenance notification, typically a machine operator, technician, or shift supervisor on the shop floor.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'Calendar date on which the maintenance notification was formally reported and entered into the system. Used for aging analysis and SLA compliance measurement.' ;
    rdfs:domain ind:AssetNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Precise date and time when the notification was created in the source system, including timezone offset. Critical for calculating response time SLAs and shift-based analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requiredEndDate rdf:type rdf:Property ;
    rdfs:label 'Required End Date' ;
    rdfs:comment 'Date by which the maintenance work associated with this notification must be completed. Defines the deadline for work order execution and is used for SLA breach detection and escalation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredStartDate rdf:type rdf:Property ;
    rdfs:label 'Required Start Date' ;
    rdfs:comment 'Date by which maintenance work associated with this notification must commence, as specified by the requester or maintenance planner. Used for scheduling and SLA compliance tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyRelevant rdf:type rdf:Property ;
    rdfs:label 'Safety Relevant' ;
    rdfs:comment 'Flag indicating whether the notified malfunction or damage has safety implications for personnel, equipment, or the environment. Triggers mandatory escalation to HSE teams and may invoke OSHA/ISO 45001 incident reporting protocols.' ;
    rdfs:domain ind:AssetNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Reference number of the maintenance work order created from this notification. Captures the downstream linkage between the notification trigger and the execution order for traceability and audit purposes.' ;
    rdfs:domain ind:AssetNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPointId rdf:type rdf:Property ;
    rdfs:label 'Measurement Point Id' ;
    rdfs:comment 'Unique system-generated identifier for a measurement point or counter position defined on a piece of equipment or technical object. Serves as the primary key for the measurement point entity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MeasurementPoint .

ind:alertEnabled rdf:type rdf:Property ;
    rdfs:label 'Alert Enabled' ;
    rdfs:comment 'Indicates whether automated alerts or notifications are configured for this measurement point when readings breach the defined upper or lower limit thresholds. Drives real-time alarm management in SCADA and MindSphere.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calibrationIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Calibration Interval Days' ;
    rdfs:comment 'Number of days between required calibration events for the sensor or instrument at this measurement point. Used to schedule preventive calibration work orders and ensure measurement traceability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationRequired rdf:type rdf:Property ;
    rdfs:label 'Calibration Required' ;
    rdfs:comment 'Indicates whether the sensor or instrument associated with this measurement point requires periodic calibration to maintain measurement accuracy. Drives calibration work order generation and compliance with metrology standards.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:characteristicCode rdf:type rdf:Property ;
    rdfs:label 'Characteristic Code' ;
    rdfs:comment 'Reference code linking this measurement point to a classification characteristic in the EAM/PLM system (e.g., SAP classification characteristic or Teamcenter attribute). Enables structured querying and grouping of measurement points by engineering characteristic.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionMonitoringEnabled rdf:type rdf:Property ;
    rdfs:label 'Condition Monitoring Enabled' ;
    rdfs:comment 'Indicates whether this measurement point is actively used for condition-based maintenance (CBM) monitoring. When true, readings are evaluated against thresholds to trigger predictive maintenance work orders via MindSphere or SAP PM.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:counterOverflowValue rdf:type rdf:Property ;
    rdfs:label 'Counter Overflow Value' ;
    rdfs:comment 'Maximum value a counter-type measurement point can reach before rolling over to zero. Critical for correctly computing cumulative counter readings across overflow events (e.g., an odometer rolling over at 999,999 km). Applicable only to category=\'counter\'.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterReadingDirection rdf:type rdf:Property ;
    rdfs:label 'Counter Reading Direction' ;
    rdfs:comment 'Indicates whether the counter increments upward (ascending, e.g., operating hours accumulating) or decrements downward (descending, e.g., remaining service life countdown). Applicable only to category=\'counter\'.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decimalPlaces rdf:type rdf:Property ;
    rdfs:label 'Decimal Places' ;
    rdfs:comment 'Number of decimal places to which measurement readings are recorded and displayed for this measurement point. Controls precision of data capture and reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Date' ;
    rdfs:comment 'Date on which the most recent calibration of the sensor or instrument at this measurement point was performed. Used to calculate next calibration due date and assess current measurement validity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReadingBy rdf:type rdf:Property ;
    rdfs:label 'Last Reading By' ;
    rdfs:comment 'User ID or system identifier of the person or automated process that recorded the most recent measurement reading. Supports audit trail and data quality validation for manual readings.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReadingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reading Timestamp' ;
    rdfs:comment 'Date and time when the most recent measurement reading was recorded at this point. Used to assess data freshness, identify stale sensors, and support maintenance scheduling based on elapsed time since last reading.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastReadingValue rdf:type rdf:Property ;
    rdfs:label 'Last Reading Value' ;
    rdfs:comment 'Most recent measurement reading recorded at this measurement point. Provides the current state of the monitored parameter for real-time dashboards, maintenance scheduling, and condition assessment without querying the full reading history.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowerLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Limit' ;
    rdfs:comment 'Minimum acceptable value for readings at this measurement point. Readings below this threshold trigger alerts, condition-based maintenance work orders, or SCADA alarms. Used in Statistical Process Control (SPC) and predictive maintenance analytics.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceStrategyCode rdf:type rdf:Property ;
    rdfs:label 'Maintenance Strategy Code' ;
    rdfs:comment 'Code of the maintenance strategy (e.g., time-based, counter-based, condition-based) associated with this measurement point. Determines how maintenance plans and task lists are triggered based on readings from this point.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mindsphereAspectName rdf:type rdf:Property ;
    rdfs:label 'Mindsphere Aspect Name' ;
    rdfs:comment 'Name of the MindSphere aspect (logical grouping of related time-series variables) to which this measurement point\'s sensor variable belongs. Aspects organize sensor data streams for analytics and Digital Twin modeling in MindSphere.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mindsphereAssetReference rdf:type rdf:Property ;
    rdfs:label 'Mindsphere Asset Reference' ;
    rdfs:comment 'Identifier of the digital asset in Siemens MindSphere IIoT Platform to which this measurement point is bound. Enables real-time sensor data ingestion, edge computing, and predictive analytics via MindSphere.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mindsphereVariableName rdf:type rdf:Property ;
    rdfs:label 'Mindsphere Variable Name' ;
    rdfs:comment 'Specific time-series variable name within the MindSphere aspect that maps to this measurement point. Provides the exact binding between the physical sensor signal and the MindSphere data model for real-time streaming and predictive analytics.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plcAddress rdf:type rdf:Property ;
    rdfs:label 'Plc Address' ;
    rdfs:comment 'Memory address or register reference in the PLC that provides the raw signal for this measurement point. Used for IT/OT convergence data pipelines to pull readings directly from PLC registers into the lakehouse.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointNumber rdf:type rdf:Property ;
    rdfs:label 'Point Number' ;
    rdfs:comment 'Business-facing alphanumeric identifier for the measurement point as defined in the source EAM/CMMS system (e.g., SAP PM measurement point number). Used for cross-system referencing and shop-floor identification.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointType rdf:type rdf:Property ;
    rdfs:label 'Point Type' ;
    rdfs:comment 'Physical or engineering type of the measurement being captured at this point. Drives sensor configuration, alarm thresholds, and analytics models in Siemens MindSphere and SAP PM.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingMethod rdf:type rdf:Property ;
    rdfs:label 'Reading Method' ;
    rdfs:comment 'Indicates how measurement readings are captured: \'automatic\' (via IIoT sensor/SCADA integration), \'manual\' (technician enters reading during inspection or maintenance), or \'semi_automatic\' (sensor-assisted but requires manual confirmation).' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Sampling Interval Seconds' ;
    rdfs:comment 'Frequency in seconds at which sensor readings are captured and transmitted for this measurement point. Drives data volume planning, edge computing configuration, and real-time alerting latency in MindSphere and SCADA systems.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scadaTagName rdf:type rdf:Property ;
    rdfs:label 'Scada Tag Name' ;
    rdfs:comment 'Tag name or address in the SCADA or DCS system that corresponds to this measurement point. Enables mapping between the EAM measurement point and the operational technology (OT) data source for automated reading ingestion.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Limit' ;
    rdfs:comment 'Maximum acceptable value for readings at this measurement point. Readings exceeding this threshold trigger alerts, condition-based maintenance work orders, or SCADA alarms. Used in SPC and predictive maintenance analytics.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workCenterCode rdf:type rdf:Property ;
    rdfs:label 'Work Center Code' ;
    rdfs:comment 'Code of the work center or production cell associated with the equipment on which this measurement point resides. Enables OEE and condition monitoring analysis at the work center level.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementReadingId rdf:type rdf:Property ;
    rdfs:label 'Measurement Reading Id' ;
    rdfs:comment 'Unique surrogate identifier for each measurement reading record in the asset domain. Serves as the primary key for the measurement_reading data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MeasurementReading .

ind:sensorMeasurementPointId rdf:type rdf:Property ;
    rdfs:label 'Sensor Measurement Point Id' ;
    rdfs:comment 'Unique identifier of the IIoT sensor, transducer, or instrumentation device that captured the reading. Relevant for automated readings from Siemens MindSphere, SCADA, or PLC/DCS integrations. Supports sensor-level diagnostics and calibration tracking.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MeasurementPoint .

ind:breachSeverity rdf:type rdf:Property ;
    rdfs:label 'Breach Severity' ;
    rdfs:comment 'Severity classification of the threshold breach for this reading: none (within limits), warning (advisory), alarm (action required), or critical (immediate shutdown/intervention required). Drives maintenance priority and escalation workflows.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Due Date' ;
    rdfs:comment 'Date by which the sensor or measurement instrument used for this reading is due for recalibration. Supports instrument calibration compliance tracking per ISO 9001 and ISO/IEC 17025 requirements.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:characteristicValue rdf:type rdf:Property ;
    rdfs:label 'Characteristic Value' ;
    rdfs:comment 'Qualitative or coded value for characteristic-type readings where the result is non-numeric (e.g., \'OK\', \'NOK\', \'Leaking\', \'Corroded\'). Used for inspection-type measurement points that capture condition descriptions rather than numeric values.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterOverflowIndicator rdf:type rdf:Property ;
    rdfs:label 'Counter Overflow Indicator' ;
    rdfs:comment 'Flag indicating whether a counter-type reading has overflowed (i.e., reset to zero after reaching its maximum value). Critical for accurate MTBF and operating hour calculations on assets with cyclical counters.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deltaValue rdf:type rdf:Property ;
    rdfs:label 'Delta Value' ;
    rdfs:comment 'Difference between the current counter reading and the previous counter reading for counter-type measurement points. Represents the incremental consumption or usage since the last reading (e.g., hours run, cycles completed). Used for usage-based maintenance scheduling.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalLocation rdf:type rdf:Property ;
    rdfs:label 'Functional Location' ;
    rdfs:comment 'Hierarchical plant structure identifier representing the physical location of the asset (e.g., plant, production line, work center). Aligns with SAP PM Functional Location (IL01) and Maximo Location hierarchy for spatial analytics.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEstimated rdf:type rdf:Property ;
    rdfs:label 'Is Estimated' ;
    rdfs:comment 'Indicates whether the reading value was estimated (e.g., interpolated due to sensor gap, manually estimated by technician) rather than directly measured. Estimated readings are flagged for analytics quality control and excluded from certain SPC calculations.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowerAlarmLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Alarm Limit' ;
    rdfs:comment 'Lower critical alarm threshold for the measurement point. A reading below this value indicates a critical condition requiring immediate maintenance intervention or asset shutdown to prevent failure.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowerWarningLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Warning Limit' ;
    rdfs:comment 'Lower warning threshold value for the measurement point. A reading below this value triggers a warning alert for condition-based maintenance review, without necessarily requiring immediate action.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenancePlanNumber rdf:type rdf:Property ;
    rdfs:label 'Maintenance Plan Number' ;
    rdfs:comment 'Reference to the preventive maintenance plan or inspection plan that scheduled this reading, if applicable. Supports TPM (Total Productive Maintenance) compliance tracking and planned vs. actual reading analysis.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingDate rdf:type rdf:Property ;
    rdfs:label 'Reading Date' ;
    rdfs:comment 'Calendar date on which the measurement reading was recorded. Used for day-level aggregation, maintenance scheduling, and compliance reporting distinct from the precise timestamp.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:readingNumber rdf:type rdf:Property ;
    rdfs:label 'Reading Number' ;
    rdfs:comment 'Business-facing alphanumeric identifier for the measurement reading, as assigned by the source system (e.g., Maximo EAM or SAP PM). Used for cross-system traceability and audit referencing.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingQuality rdf:type rdf:Property ;
    rdfs:label 'Reading Quality' ;
    rdfs:comment 'Data quality indicator for the reading value, aligned with OPC-UA quality codes. Indicates whether the reading is reliable (good), potentially unreliable (uncertain), or invalid (bad, sensor fault, out of range). Critical for IIoT and SCADA data quality management.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingSource rdf:type rdf:Property ;
    rdfs:label 'Reading Source' ;
    rdfs:comment 'Origin of the measurement reading indicating how it was captured: manual inspection by a technician, automated IIoT sensor via Siemens MindSphere, SCADA system integration, MES shop floor data, PLC/DCS direct feed, or API integration.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingStatus rdf:type rdf:Property ;
    rdfs:label 'Reading Status' ;
    rdfs:comment 'Lifecycle status of the measurement reading record. Active readings are valid for condition monitoring; cancelled readings have been voided; superseded readings have been replaced by corrected values; pending_review readings await technician validation.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingTakenBy rdf:type rdf:Property ;
    rdfs:label 'Reading Taken By' ;
    rdfs:comment 'Identifier or name of the technician, operator, or automated system that captured the reading. For manual readings, this is the personnel ID or name. For automated readings, this is the system or sensor identifier. Supports accountability and audit trails.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reading Timestamp' ;
    rdfs:comment 'Exact date and time when the measurement or counter reading was captured at the measurement point. Critical for time-series analysis, condition-based maintenance triggering, and IIoT/SCADA data correlation via Siemens MindSphere.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:readingType rdf:type rdf:Property ;
    rdfs:label 'Reading Type' ;
    rdfs:comment 'Classification of the reading as a continuous measurement (e.g., temperature, pressure), a counter (e.g., operating hours, cycle count), or a characteristic (e.g., qualitative inspection result). Drives downstream processing logic for condition-based maintenance.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingValue rdf:type rdf:Property ;
    rdfs:label 'Reading Value' ;
    rdfs:comment 'Actual numeric value of the measurement captured at the measurement point (e.g., temperature in Celsius, vibration in mm/s, pressure in bar, counter in hours or cycles). Core data element for condition monitoring and predictive maintenance analytics.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text field for technician or system notes associated with the reading (e.g., observed abnormal noise, sensor replaced prior to reading, reading taken under non-standard operating conditions). Supports qualitative context for maintenance decision-making.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorTag rdf:type rdf:Property ;
    rdfs:label 'Sensor Tag' ;
    rdfs:comment 'Engineering tag name of the sensor or instrument as defined in the plant instrumentation and control system (e.g., P&ID tag number, SCADA tag). Used by maintenance engineers and process engineers for cross-referencing with plant documentation.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemReadingReference rdf:type rdf:Property ;
    rdfs:label 'Source System Reading Reference' ;
    rdfs:comment 'Native identifier of the measurement reading record in the originating source system (e.g., Maximo measurement document number, SAP PM measurement document number). Enables traceability back to the system of record.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdBreachIndicator rdf:type rdf:Property ;
    rdfs:label 'Threshold Breach Indicator' ;
    rdfs:comment 'Flag indicating whether the reading value has breached any defined threshold (warning or alarm limit). When True, the reading triggers downstream condition-based maintenance workflows or work order creation.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:upperAlarmLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Alarm Limit' ;
    rdfs:comment 'Upper critical alarm threshold for the measurement point. A reading above this value indicates a critical condition requiring immediate maintenance intervention or asset shutdown to prevent failure.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperWarningLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Warning Limit' ;
    rdfs:comment 'Upper warning threshold value for the measurement point. A reading above this value triggers a warning alert for condition-based maintenance review, without necessarily requiring immediate action.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureRecordId rdf:type rdf:Property ;
    rdfs:label 'Failure Record Id' ;
    rdfs:comment 'Unique system-generated identifier for each equipment failure or fault event record within the asset management system.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FailureRecord .

ind:pfmeaId rdf:type rdf:Property ;
    rdfs:label 'Pfmea Id' ;
    rdfs:comment 'Foreign key linking to engineering.pfmea. Business justification: Failure records validate Process FMEA predictions. Reliability engineers link actual failures to PFMEA failure modes to update risk priority numbers, improve preventive maintenance strategies, and dri' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pfmea .

ind:purchaseRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_requisition. Business justification: Asset failures often trigger emergency purchase requisitions for replacement parts. Linking the failure record to the resulting PR enables root-cause-to-procurement traceability, used by maintenance a' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseRequisition .

ind:workOrderOperationId rdf:type rdf:Property ;
    rdfs:label 'Work Order Operation Id' ;
    rdfs:comment 'Foreign key linking to asset.work_order_operation. Business justification: Equipment failures result in corrective maintenance work order operations. Linking failure_record.work_order_operation_id → work_order_operation.work_order_operation_id enables traceability from failu' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrderOperation .

ind:actualRepairCost rdf:type rdf:Property ;
    rdfs:label 'Actual Repair Cost' ;
    rdfs:comment 'The actual total cost incurred to repair the failure, captured from work order actuals in the ERP/EAM system, used for OPEX tracking, maintenance cost benchmarking, and ROI analysis.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedProductionQuantity rdf:type rdf:Property ;
    rdfs:label 'Affected Production Quantity' ;
    rdfs:comment 'The quantity of production units (parts, assemblies, or batches) that were impacted, scrapped, or placed on hold as a direct result of this failure event.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Reference Number' ;
    rdfs:comment 'The reference number of the associated CAPA record in the Quality Management System (QMS), linking the failure event to its formal corrective action for traceability and audit purposes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Capa Required Flag' ;
    rdfs:comment 'Indicates whether a formal Corrective and Preventive Action (CAPA) process must be initiated as a result of this failure event, based on severity, recurrence, or regulatory requirements.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'The method by which the failure was first detected, distinguishing between operator-observed, sensor-triggered (IIoT/SCADA), alarm-based, or inspection-based detection. Supports FMEA detectability scoring and predictive maintenance program evaluation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Minutes' ;
    rdfs:comment 'Total duration in minutes that the asset was non-operational due to this failure event. Used for OEE downtime categorization, TPM loss analysis, and MTTR calculation inputs.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Incident Flag' ;
    rdfs:comment 'Indicates whether this failure event caused or contributed to an environmental incident (e.g., spill, emission exceedance), triggering reporting obligations under ISO 14001 and EPA regulations.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedRepairCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Repair Cost' ;
    rdfs:comment 'The estimated total cost to repair the failure, including labor, materials, and contractor costs, used for maintenance budget planning and CAPEX vs. OPEX decision support.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failedComponent rdf:type rdf:Property ;
    rdfs:label 'Failed Component' ;
    rdfs:comment 'Name or description of the specific sub-component, part, or assembly within the asset that failed, enabling component-level reliability analysis and spare parts demand forecasting.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedComponentPartNumber rdf:type rdf:Property ;
    rdfs:label 'Failed Component Part Number' ;
    rdfs:comment 'The material or part number of the failed component as registered in the ERP/PLM system, enabling linkage to BOM, spare parts inventory, and procurement records.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCauseCode rdf:type rdf:Property ;
    rdfs:label 'Failure Cause Code' ;
    rdfs:comment 'Standardized code identifying the root cause of the failure (e.g., wear, fatigue, corrosion, misalignment, overload), used for CAPA initiation and reliability improvement programs.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Cause Description' ;
    rdfs:comment 'Detailed narrative description of the root cause of the failure, providing context beyond the standardized cause code for engineering analysis and FMEA documentation.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureClass rdf:type rdf:Property ;
    rdfs:label 'Failure Class' ;
    rdfs:comment 'High-level classification of the failure type based on the physical or functional domain of the fault, used for trend analysis and FMEA categorization.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCode rdf:type rdf:Property ;
    rdfs:label 'Failure Code' ;
    rdfs:comment 'Standardized alphanumeric code identifying the specific type of failure as defined in the enterprise failure code catalog, aligned with ISO 14224 taxonomy for reliability data collection.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureEffectCode rdf:type rdf:Property ;
    rdfs:label 'Failure Effect Code' ;
    rdfs:comment 'Standardized code describing the consequence or effect of the failure on the asset, process, or production output (e.g., complete shutdown, degraded performance, safety hazard), used in FMEA severity assessment.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureEffectDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Effect Description' ;
    rdfs:comment 'Narrative description of the observed impact of the failure on equipment operation, production continuity, product quality, or safety, supporting FMEA severity scoring and CAPA documentation.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Failure End Timestamp' ;
    rdfs:comment 'The exact date and time when the equipment was restored to operational status following the failure, used to calculate downtime duration and Mean Time To Repair (MTTR).' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failureMode rdf:type rdf:Property ;
    rdfs:label 'Failure Mode' ;
    rdfs:comment 'Description of the observable manner in which the equipment failed (e.g., vibration, overheating, leakage, fracture, corrosion), as used in FMEA and reliability engineering analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureNumber rdf:type rdf:Property ;
    rdfs:label 'Failure Number' ;
    rdfs:comment 'Human-readable business reference number for the failure event, used for cross-referencing in work orders, NCRs, and maintenance reports. Follows the format FR-YYYY-NNNNNN.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Failure Start Timestamp' ;
    rdfs:comment 'The exact date and time when the equipment failure or fault event began, used as the baseline for calculating downtime duration and Mean Time Between Failures (MTBF).' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failureStatus rdf:type rdf:Property ;
    rdfs:label 'Failure Status' ;
    rdfs:comment 'Current lifecycle status of the failure record, tracking progression from initial reporting through investigation, repair, and formal closure in the EAM/CMMS system.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeeLossCategory rdf:type rdf:Property ;
    rdfs:label 'Oee Loss Category' ;
    rdfs:comment 'Classification of the failure event within the OEE loss framework, categorizing the downtime as availability loss, performance loss, or quality loss for TPM and Six Sigma reporting.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionImpact rdf:type rdf:Property ;
    rdfs:label 'Production Impact' ;
    rdfs:comment 'Assessment of the failure\'s impact on production operations, indicating whether the failure caused a complete line stoppage, partial capacity reduction, or had no direct production impact.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Indicates whether this failure is a recurrence of a previously recorded failure on the same asset with the same failure mode, used to identify chronic failure patterns and evaluate CAPA effectiveness.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repairType rdf:type rdf:Property ;
    rdfs:label 'Repair Type' ;
    rdfs:comment 'Classification of the corrective action taken to resolve the failure, used for maintenance cost analysis, spare parts consumption tracking, and CAPA effectiveness evaluation.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Flag' ;
    rdfs:comment 'Indicates whether this failure event resulted in or contributed to a safety incident, near-miss, or hazardous condition, triggering mandatory reporting under OSHA and ISO 45001 requirements.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Classification of the failure impact severity on production, safety, quality, or asset integrity. Used for prioritizing corrective actions, FMEA severity ranking, and OEE loss categorization.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetBomId rdf:type rdf:Property ;
    rdfs:label 'Asset Bom Id' ;
    rdfs:comment 'Unique surrogate identifier for each asset Bill of Materials (BOM) line record in the equipment component hierarchy. Serves as the primary key for the asset_bom entity in the Databricks Silver layer.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetBom .

ind:originLocationId rdf:type rdf:Property ;
    rdfs:label 'Origin Location Id' ;
    rdfs:comment 'Foreign key linking to logistics.location. Business justification: Asset BOM components are sourced from or stored at specific warehouse or plant locations. Linking BOM to a logistics location enables inventory and maintenance teams to know exactly where parts are ph' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:sparePartClassId rdf:type rdf:Property ;
    rdfs:label 'Spare Part Class Id' ;
    rdfs:comment 'Foreign key linking to asset.class. Business justification: asset_bom stores spare_part_class as a STRING classification code for BOM components. The class product is the authoritative classification taxonomy for manufacturing assets including spare parts. Add' ;
    rdfs:domain ind:AssetBom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Class .

ind:alternativePartNumber rdf:type rdf:Property ;
    rdfs:label 'Alternative Part Number' ;
    rdfs:comment 'Approved alternative or interchangeable part number that can substitute for the primary component when the original is unavailable. Supports MRO procurement flexibility and reduces equipment downtime during spare parts shortages.' ;
    rdfs:domain ind:AssetBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeNoticeNumber rdf:type rdf:Property ;
    rdfs:label 'Change Notice Number' ;
    rdfs:comment 'Reference to the Engineering Change Notice (ECN) or Engineering Change Order (ECO) that introduced or modified this BOM line. Provides full traceability of component changes back to the formal change management process in Siemens Teamcenter PLM.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childComponentNumber rdf:type rdf:Property ;
    rdfs:label 'Child Component Number' ;
    rdfs:comment 'Part number or item number of the child component, spare part, or sub-assembly at this BOM line. Corresponds to the material or spare part number in SAP MM or Maximo Item Master used for MRO procurement and inventory management.' ;
    rdfs:domain ind:AssetBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentType rdf:type rdf:Property ;
    rdfs:label 'Component Type' ;
    rdfs:comment 'Functional classification of the component indicating its role in the equipment assembly. Drives MRO stocking strategies, maintenance task material requirements, and spare parts categorization for procurement planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawingNumber rdf:type rdf:Property ;
    rdfs:label 'Drawing Number' ;
    rdfs:comment 'Reference to the engineering drawing or technical document number associated with this component, managed in Siemens Teamcenter PLM or the document management system. Enables maintenance technicians to access assembly diagrams and installation specifications.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which this BOM line item becomes valid and effective for use in maintenance planning and MRO procurement. Supports date-effective BOM management to handle engineering changes (ECN/ECO) and component supersessions over the asset lifecycle.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date after which this BOM line item is no longer valid. Used to manage component supersessions, phase-outs, and engineering change orders (ECO). Null value indicates the line is currently valid with no planned expiry.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedUnitCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Cost' ;
    rdfs:comment 'Estimated procurement cost per unit of this component in the transaction currency. Used for MRO budget planning, CAPEX/OPEX spare parts inventory valuation, and maintenance cost estimation. Sourced from SAP MM moving average price or standard cost.' ;
    rdfs:domain ind:AssetBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installationPosition rdf:type rdf:Property ;
    rdfs:label 'Installation Position' ;
    rdfs:comment 'Physical location or mounting position identifier where the component is installed within the parent assembly (e.g., \'Bearing Housing A\', \'Inlet Valve Position 3\'). Critical for maintenance technicians to locate and replace components during work order execution.' ;
    rdfs:domain ind:AssetBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalPartNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Part Number' ;
    rdfs:comment 'Company-internal material or part number assigned to the component in the ERP/EAM system (SAP MM material number or Maximo item number). Used for internal procurement, inventory management, and work order material reservations.' ;
    rdfs:domain ind:AssetBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRegulatoryControlled rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Controlled' ;
    rdfs:comment 'Indicates whether this component is subject to regulatory control, certification requirements, or compliance obligations (e.g., CE Marking, UL certification, REACH/RoHS compliance, pressure vessel regulations). Triggers mandatory documentation and traceability requirements.' ;
    rdfs:domain ind:AssetBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyCritical rdf:type rdf:Property ;
    rdfs:label 'Is Safety Critical' ;
    rdfs:comment 'Indicates whether this component is classified as safety-critical, meaning its failure could result in personnel injury, environmental incident, or regulatory non-compliance. Safety-critical components require mandatory inspection intervals and controlled replacement procedures per OSHA and ISO 45001.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Name of the original equipment manufacturer (OEM) or component manufacturer. Used for approved vendor list management, warranty validation, and ensuring OEM-specified spare parts are used in maintenance activities to preserve equipment warranties.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'Original manufacturer\'s part number for the component, distinct from the internal material number. Essential for cross-referencing with supplier catalogs, sourcing equivalent parts, and validating OEM compliance during MRO procurement via SAP Ariba.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionNumber rdf:type rdf:Property ;
    rdfs:label 'Position Number' ;
    rdfs:comment 'Sequential numeric position identifier for the component within the BOM structure, following SAP BOM item numbering conventions (e.g., 0010, 0020). Used for ordering and referencing BOM line items in maintenance documentation and work orders.' ;
    rdfs:domain ind:AssetBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Quantity of the child component required per one unit of the parent assembly. Used in MRO spare parts planning, maintenance work order material requirements, and inventory replenishment calculations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reachCompliant rdf:type rdf:Property ;
    rdfs:label 'Reach Compliant' ;
    rdfs:comment 'Indicates whether this component complies with the EU REACH Regulation (EC 1907/2006) for chemical substance registration and restriction. Critical for environmental compliance reporting and supply chain chemical substance management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recommendedStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Recommended Stock Quantity' ;
    rdfs:comment 'Recommended minimum on-hand stock quantity for this spare part based on criticality, lead time, and maintenance frequency. Drives MRO inventory stocking policies and reorder point calculations in the Warehouse Management System (WMS).' ;
    rdfs:domain ind:AssetBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replacementIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Replacement Interval Days' ;
    rdfs:comment 'Recommended or OEM-specified replacement interval for this component expressed in calendar days. Complements the operating-hours-based interval for time-based preventive maintenance scheduling, particularly for components subject to age-related degradation regardless of usage.' ;
    rdfs:domain ind:AssetBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replacementIntervalHours rdf:type rdf:Property ;
    rdfs:label 'Replacement Interval Hours' ;
    rdfs:comment 'Recommended or OEM-specified replacement interval for this component expressed in equipment operating hours. Used to generate preventive maintenance (PM) work orders and schedule planned replacements as part of the TPM program in Maximo EAM.' ;
    rdfs:domain ind:AssetBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revision rdf:type rdf:Property ;
    rdfs:label 'Revision' ;
    rdfs:comment 'Revision or version identifier of the asset BOM, incremented when engineering changes (ECN/ECO) are applied to the component structure. Enables tracking of configuration changes over the asset lifecycle.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rohsCompliant rdf:type rdf:Property ;
    rdfs:label 'Rohs Compliant' ;
    rdfs:comment 'Indicates whether this component complies with the EU RoHS Directive (2011/65/EU) restricting the use of hazardous substances such as lead, mercury, cadmium, and hexavalent chromium. Required for CE Marking compliance and environmental regulatory reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'Physical weight of the component in kilograms. Used for logistics planning, shipping cost estimation, equipment load calculations, and ergonomic risk assessments for maintenance activities per ISO 45001 occupational health requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executionLocationId rdf:type rdf:Property ;
    rdfs:label 'Execution Location Id' ;
    rdfs:comment 'Foreign key linking to logistics.location. Business justification: Each work order operation is performed at a defined physical location (plant, building, field site). Referencing the logistics location ensures field technicians, parts dispatchers, and planners share' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to procurement.goods_receipt. Business justification: Work order operations consuming procured spare parts are confirmed against goods receipts. Warehouse and maintenance teams use this link to verify parts availability and confirm material consumption a' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:productionOrderCostId rdf:type rdf:Property ;
    rdfs:label 'Production Order Cost Id' ;
    rdfs:comment 'Foreign key linking to finance.production_order_cost. Business justification: Maintenance operations performed on production equipment are often settled against production order costs. Manufacturing finance teams link work order operations to production order cost objects to ca' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionOrderCost .

ind:actualDurationHours rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Hours' ;
    rdfs:comment 'Actual elapsed time recorded for completing this operation. Used for Mean Time To Repair (MTTR) analysis, scheduling accuracy assessment, and maintenance performance benchmarking.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualFinishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Timestamp' ;
    rdfs:comment 'Date and time when this operation was confirmed as completed by the executing technician or supervisor. Triggers downstream processes such as cost settlement and equipment return to service.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualLaborHours rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Hours' ;
    rdfs:comment 'Actual number of labor hours recorded upon confirmation of this operation step. Compared against estimated hours for variance analysis, MTTR tracking, and future planning calibration.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Date and time when execution of this operation actually commenced, as recorded by the technician or MES system. Used for schedule adherence analysis and MTTR calculation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completionConfirmationText rdf:type rdf:Property ;
    rdfs:label 'Completion Confirmation Text' ;
    rdfs:comment 'Free-text remarks entered by the technician or supervisor at the time of operation confirmation, describing findings, deviations from plan, or conditions observed during execution.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'Reference number of the time confirmation document recorded against this operation in the EAM/CMMS system. Links the operation to labor time postings and cost accounting entries.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElement rdf:type rdf:Property ;
    rdfs:label 'Cost Element' ;
    rdfs:comment 'General ledger cost element code to which the labor and resource costs of this operation are posted. Enables OPEX tracking and maintenance cost analysis by operation type.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:craftType rdf:type rdf:Property ;
    rdfs:label 'Craft Type' ;
    rdfs:comment 'Trade or skill discipline required to perform this operation (e.g., Mechanical, Electrical, Instrumentation). Enables multi-craft coordination and ensures qualified technicians are assigned.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedLaborHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Hours' ;
    rdfs:comment 'Planned number of labor hours required to complete this operation step, as defined during work order planning. Used for capacity planning, scheduling, and cost estimation.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalServiceOrderNumber rdf:type rdf:Property ;
    rdfs:label 'External Service Order Number' ;
    rdfs:comment 'Purchase order or service order number raised for externally performed operations where a third-party contractor or service provider executes the maintenance task. Links to procurement records.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMilestone rdf:type rdf:Property ;
    rdfs:label 'Is Milestone' ;
    rdfs:comment 'Indicates whether this operation is a milestone step whose completion triggers automatic progression of the work order status or downstream workflow actions (e.g., safety permit release, quality inspection gate).' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationLongText rdf:type rdf:Property ;
    rdfs:label 'Operation Long Text' ;
    rdfs:comment 'Detailed narrative instructions for the maintenance technician performing this operation, including safety precautions, Standard Operating Procedure (SOP) references, and step-by-step guidance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationNumber rdf:type rdf:Property ;
    rdfs:label 'Operation Number' ;
    rdfs:comment 'Sequential step number identifying the position of this operation within the work order (e.g., 0010, 0020, 0030). Determines execution sequence and is used for multi-craft coordination and scheduling.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationShortText rdf:type rdf:Property ;
    rdfs:label 'Operation Short Text' ;
    rdfs:comment 'Brief description of the maintenance task to be performed in this operation step (e.g., \'Inspect bearing assembly\', \'Replace hydraulic seal\'). Used in work order printouts and shop floor instructions.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationType rdf:type rdf:Property ;
    rdfs:label 'Operation Type' ;
    rdfs:comment 'Classification of the maintenance operation type indicating the nature of work to be performed. Drives resource planning, cost allocation, and compliance reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitToWorkNumber rdf:type rdf:Property ;
    rdfs:label 'Permit To Work Number' ;
    rdfs:comment 'Reference number of the Permit to Work (PTW) document issued for this operation. Provides audit trail for safety compliance and regulatory inspections.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitToWorkRequired rdf:type rdf:Property ;
    rdfs:label 'Permit To Work Required' ;
    rdfs:comment 'Indicates whether a formal Permit to Work (PTW) must be issued and approved before this operation can commence. Enforces safety compliance for high-risk maintenance activities.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationCode rdf:type rdf:Property ;
    rdfs:label 'Qualification Code' ;
    rdfs:comment 'Specific skill or certification code required to perform this operation (e.g., high-voltage certification, confined space entry, forklift license). Ensures regulatory compliance and worker safety.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingLaborHours rdf:type rdf:Property ;
    rdfs:label 'Remaining Labor Hours' ;
    rdfs:comment 'Forecasted remaining labor hours needed to complete this operation, updated during partial confirmations. Supports real-time work order progress tracking and resource reallocation decisions.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledFinishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Finish Timestamp' ;
    rdfs:comment 'Planned date and time when this operation is scheduled to be completed. Used for maintenance window management, production impact assessment, and SLA compliance tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'Planned date and time when this operation is scheduled to begin. Used for maintenance scheduling, shift planning, and equipment downtime window coordination.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subOperationNumber rdf:type rdf:Property ;
    rdfs:label 'Sub Operation Number' ;
    rdfs:comment 'Optional sub-step identifier used when an operation is further decomposed into parallel or sequential sub-tasks. Supports detailed multi-craft breakdown within a single operation step.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemStatus rdf:type rdf:Property ;
    rdfs:label 'System Status' ;
    rdfs:comment 'System-generated status code from the source EAM/CMMS system (e.g., CRTD, REL, CNF, TECO) reflecting the technical processing state of the operation. Complements the business-facing status field.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userStatus rdf:type rdf:Property ;
    rdfs:label 'User Status' ;
    rdfs:comment 'User-defined status code applied by maintenance planners or supervisors to reflect business-specific workflow states beyond the system status (e.g., AWMAT - Awaiting Materials, AWPMT - Awaiting Permit).' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationRecordId rdf:type rdf:Property ;
    rdfs:label 'Calibration Record Id' ;
    rdfs:comment 'Unique system-generated identifier for each calibration record within the enterprise asset management system.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CalibrationRecord .

ind:materialSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Material Specification Id' ;
    rdfs:comment 'Foreign key linking to engineering.material_specification. Business justification: Calibration of measurement instruments must reference the engineering material specification that defines acceptable tolerance and measurement standards. Quality and metrology teams use this link to v' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialSpecification .

ind:adjustmentMadeFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Made Flag' ;
    rdfs:comment 'Indicates whether a physical adjustment or repair was made to the instrument during the calibration event. When true, as-found and as-left values will differ, and impact assessment on prior measurements may be required.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:asFoundValue rdf:type rdf:Property ;
    rdfs:label 'As Found Value' ;
    rdfs:comment 'Measured value of the instrument before any calibration adjustment is made. Represents the instrument\'s condition at the time of calibration arrival. Critical for drift analysis and out-of-tolerance impact assessment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asLeftValue rdf:type rdf:Property ;
    rdfs:label 'As Left Value' ;
    rdfs:comment 'Measured value of the instrument after calibration adjustment or verification. Confirms the instrument meets required accuracy specifications before being returned to service.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Date' ;
    rdfs:comment 'Date on which the calibration was performed. Core traceability field required by ISO 9001 QMS calibration control. Used to calculate calibration intervals and overdue status.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationMethod rdf:type rdf:Property ;
    rdfs:label 'Calibration Method' ;
    rdfs:comment 'Reference to the calibration procedure or method used (e.g., SOP number, standard method reference such as ASTM E74, ISO 376). Ensures repeatability and traceability of the calibration process.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationNumber rdf:type rdf:Property ;
    rdfs:label 'Calibration Number' ;
    rdfs:comment 'Human-readable business identifier for the calibration event, typically generated by the QMS or EAM system (e.g., SAP QM or Maximo). Used for cross-referencing with calibration certificates and work orders.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationStandardReference rdf:type rdf:Property ;
    rdfs:label 'Calibration Standard Reference' ;
    rdfs:comment 'Identifier or description of the reference standard used to perform the calibration (e.g., NIST-traceable dead weight tester, certified reference gauge). Establishes metrological traceability chain.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationType rdf:type rdf:Property ;
    rdfs:label 'Calibration Type' ;
    rdfs:comment 'Classification of the calibration event indicating the reason or trigger for calibration. Supports analysis of calibration frequency drivers and QMS audit trails.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issue Date' ;
    rdfs:comment 'Date on which the calibration certificate was formally issued by the performing laboratory or technician. May differ from calibration_date if certificate issuance is delayed.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Unique identifier of the calibration certificate issued upon completion of the calibration. Required for QMS documentation control and regulatory audit traceability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalHumidityPercent rdf:type rdf:Property ;
    rdfs:label 'Environmental Humidity Percent' ;
    rdfs:comment 'Relative humidity percentage at the calibration location at the time of calibration. Required environmental condition documentation per ISO/IEC 17025 for precision metrology.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Environmental Temperature C' ;
    rdfs:comment 'Ambient temperature in degrees Celsius at the time and location of calibration. Environmental conditions can affect measurement accuracy and are required to be documented per ISO/IEC 17025.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instrumentDescription rdf:type rdf:Property ;
    rdfs:label 'Instrument Description' ;
    rdfs:comment 'Descriptive name and specification of the measurement instrument or test equipment being calibrated (e.g., \'Digital Torque Wrench 0-200 Nm\', \'Pressure Transmitter 0-10 bar\').' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentTag rdf:type rdf:Property ;
    rdfs:label 'Instrument Tag' ;
    rdfs:comment 'Plant-specific tag or loop number assigned to the measurement instrument or gauge on the shop floor (e.g., TI-101, FT-205). Used in P&ID documentation and SCADA/DCS systems for field identification.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Accreditation Number' ;
    rdfs:comment 'Accreditation body registration number of the calibration laboratory (e.g., A2LA, UKAS, DAkkS accreditation number). Confirms the laboratory\'s competence per ISO/IEC 17025 and supports regulatory compliance.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryName rdf:type rdf:Property ;
    rdfs:label 'Laboratory Name' ;
    rdfs:comment 'Name of the laboratory or service provider that performed the calibration. May be an internal metrology lab or an external accredited calibration laboratory.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryType rdf:type rdf:Property ;
    rdfs:label 'Laboratory Type' ;
    rdfs:comment 'Classification of the calibration laboratory indicating whether calibration was performed internally or by an external accredited/non-accredited provider. Affects traceability requirements and QMS documentation.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Name of the manufacturer of the measurement instrument or test equipment being calibrated. Used for warranty tracking, spare parts sourcing, and manufacturer-specific calibration procedures.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementUncertainty rdf:type rdf:Property ;
    rdfs:label 'Measurement Uncertainty' ;
    rdfs:comment 'Expanded measurement uncertainty (typically at 95% confidence level, k=2) associated with the calibration result, expressed in the same unit as the measurement. Required by ISO/IEC 17025 accredited laboratories.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer model number of the measurement instrument. Used to identify the correct calibration procedure and reference standard requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfToleranceImpact rdf:type rdf:Property ;
    rdfs:label 'Out Of Tolerance Impact' ;
    rdfs:comment 'Assessment of the potential impact on product quality when an instrument is found out of tolerance. Supports CAPA initiation and product disposition decisions per ISO 9001 requirements.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performedBy rdf:type rdf:Property ;
    rdfs:label 'Performed By' ;
    rdfs:comment 'Employee ID or technician identifier of the person who performed the calibration. Supports competency verification and audit trail requirements. Not a personal name to avoid PII concerns.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:result rdf:type rdf:Property ;
    rdfs:label 'Result' ;
    rdfs:comment 'Overall outcome of the calibration event indicating whether the instrument met the required accuracy specifications. Drives disposition decisions and QMS non-conformance workflows.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer serial number of the measurement instrument. Provides unique physical traceability for the instrument across its calibration history.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Standard Certificate Number' ;
    rdfs:comment 'Certificate number of the reference standard used during calibration, confirming its own traceability to national or international measurement standards (e.g., NIST, PTB, NPL).' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetValuationId rdf:type rdf:Property ;
    rdfs:label 'Asset Valuation Id' ;
    rdfs:comment 'Unique surrogate identifier for each asset valuation record in the SAP FI-AA fixed asset accounting module. Serves as the primary key for the asset_valuation data product in the Databricks Silver layer.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetValuation .

ind:assetLocationId rdf:type rdf:Property ;
    rdfs:label 'Asset Location Id' ;
    rdfs:comment 'Foreign key linking to logistics.location. Business justification: Asset valuation must reflect the physical location of the asset for depreciation, insurance, and tax purposes. Finance and fixed-asset teams link valuations to logistics locations to correctly allocat' ;
    rdfs:domain ind:AssetValuation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:assetTransactionId rdf:type rdf:Property ;
    rdfs:label 'Asset Transaction Id' ;
    rdfs:comment 'Foreign key linking to finance.asset_transaction. Business justification: Asset valuations are directly posted as financial asset transactions (acquisitions, depreciation, write-offs). Fixed asset accounting teams link every valuation movement to its corresponding financial' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetTransaction .

ind:chartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Id' ;
    rdfs:comment 'Foreign key linking to finance.chart_of_accounts. Business justification: Each asset valuation must post to a specific GL account (asset account, accumulated depreciation account). Finance controllers require this link to ensure valuations hit the correct balance sheet acco' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChartOfAccounts .

ind:salesPriceListId rdf:type rdf:Property ;
    rdfs:label 'Sales Price List Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_price_list. Business justification: Asset valuations in industrial manufacturing reference the current sales price list to establish replacement cost or fair market value — used by finance and insurance teams during asset lifecycle revi' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesPriceList .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total depreciation charged against the asset from the capitalization date to the current valuation date. Represents the cumulative reduction in asset value due to wear, obsolescence, and usage over its useful life.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accumulatedDepreciationGlAccount rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation Gl Account' ;
    rdfs:comment 'The SAP General Ledger contra-asset account code used to record accumulated depreciation for this asset. Supports balance sheet presentation of gross asset value less accumulated depreciation.' ;
    rdfs:domain ind:AssetValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'The original historical cost of acquiring the asset, including purchase price, import duties, installation costs, and any directly attributable costs to bring the asset to its intended use. Recorded in the transaction currency per IAS 16.' ;
    rdfs:domain ind:AssetValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the acquisition cost transaction currency (e.g., USD, EUR, CNY). Supports multi-currency asset accounting for multinational operations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionCostGroupCurrency rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost Group Currency' ;
    rdfs:comment 'The acquisition cost translated into the group reporting currency (e.g., USD for a US-headquartered multinational). Used for consolidated financial reporting and CAPEX tracking at the enterprise level.' ;
    rdfs:domain ind:AssetValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'The date on which the asset was acquired or purchased. May differ from the capitalization date if the asset was under construction or in transit before being placed in service.' ;
    rdfs:domain ind:AssetValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetSubNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Sub Number' ;
    rdfs:comment 'SAP FI-AA sub-asset number used to track individual components or additions to a main asset (e.g., a capital improvement added to an existing machine). Enables component-level depreciation tracking.' ;
    rdfs:domain ind:AssetValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetUnderConstructionFlag rdf:type rdf:Property ;
    rdfs:label 'Asset Under Construction Flag' ;
    rdfs:comment 'Indicates whether the asset is currently classified as an Asset Under Construction (AUC) in SAP FI-AA. AUC assets are not yet depreciated and are transferred to a final asset class upon completion and capitalization.' ;
    rdfs:domain ind:AssetValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capexProjectNumber rdf:type rdf:Property ;
    rdfs:label 'Capex Project Number' ;
    rdfs:comment 'The SAP Project System (PS) or internal project number associated with the capital expenditure that funded this asset acquisition. Links the asset to the originating CAPEX budget and project for investment tracking and ROI analysis.' ;
    rdfs:domain ind:AssetValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization Date' ;
    rdfs:comment 'The date on which the asset was capitalized and placed into service for depreciation purposes in SAP FI-AA. This is the start date for depreciation calculation and is critical for CAPEX accounting under IAS 16 and GAAP ASC 360.' ;
    rdfs:domain ind:AssetValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'SAP Controlling (CO) area code that groups company codes for internal cost accounting and CAPEX/OPEX reporting. Enables cross-company cost center analysis and asset cost allocation.' ;
    rdfs:domain ind:AssetValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentPeriodDepreciation rdf:type rdf:Property ;
    rdfs:label 'Current Period Depreciation' ;
    rdfs:comment 'The depreciation expense charged for the current fiscal period (month or year) as calculated by the SAP FI-AA depreciation run. Used for P&L reporting and OPEX cost allocation to cost centers.' ;
    rdfs:domain ind:AssetValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:date rdf:type rdf:Property ;
    rdfs:label 'Date' ;
    rdfs:comment 'The date as of which the asset valuation figures (net book value, accumulated depreciation) are reported. Typically corresponds to the fiscal period-end or year-end closing date for balance sheet reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationKey rdf:type rdf:Property ;
    rdfs:label 'Depreciation Key' ;
    rdfs:comment 'The SAP FI-AA depreciation key code that defines the specific depreciation calculation method, period control, and base value for the asset (e.g., LINR for straight-line, DGRW for declining balance). Drives automated depreciation posting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'The date on which the asset was retired, sold, scrapped, or otherwise disposed of. Triggers derecognition of the asset from the balance sheet and recognition of any gain or loss on disposal per IAS 16.' ;
    rdfs:domain ind:AssetValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'The net proceeds received from the sale or disposal of the asset. Used to calculate the gain or loss on disposal (disposal proceeds minus net book value at disposal date) for P&L reporting.' ;
    rdfs:domain ind:AssetValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Group Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the group/consolidated reporting currency used for enterprise-level CAPEX and asset valuation reporting (e.g., USD, EUR).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impairmentDate rdf:type rdf:Property ;
    rdfs:label 'Impairment Date' ;
    rdfs:comment 'The date on which an impairment loss was recognized for the asset. Required for IAS 36 impairment assessment documentation and audit trail purposes.' ;
    rdfs:domain ind:AssetValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impairmentLoss rdf:type rdf:Property ;
    rdfs:label 'Impairment Loss' ;
    rdfs:comment 'The amount by which the carrying amount of the asset exceeds its recoverable amount, recognized as an impairment loss in the income statement. Recorded when an asset\'s value has declined beyond normal depreciation per IAS 36.' ;
    rdfs:domain ind:AssetValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:model rdf:type rdf:Property ;
    rdfs:label 'Model' ;
    rdfs:comment 'The accounting policy model applied to the asset class for subsequent measurement: \'cost_model\' (cost less accumulated depreciation and impairment) or \'revaluation_model\' (fair value less subsequent depreciation and impairment) per IAS 16.' ;
    rdfs:domain ind:AssetValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'The current carrying amount of the asset on the balance sheet, calculated as acquisition cost minus accumulated depreciation and any accumulated impairment losses. Key metric for IFRS/GAAP fixed asset reporting and balance sheet valuation.' ;
    rdfs:domain ind:AssetValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualValue rdf:type rdf:Property ;
    rdfs:label 'Residual Value' ;
    rdfs:comment 'The estimated amount the organization expects to recover from the asset at the end of its useful life, net of disposal costs. The depreciable amount is acquisition cost minus residual value. Reviewed at each reporting date per IAS 16.' ;
    rdfs:domain ind:AssetValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revaluationAmount rdf:type rdf:Property ;
    rdfs:label 'Revaluation Amount' ;
    rdfs:comment 'The amount by which the asset\'s carrying value was adjusted upward or downward under the revaluation model permitted by IAS 16. Positive values indicate upward revaluation; negative values indicate downward revaluation to revaluation reserve.' ;
    rdfs:domain ind:AssetValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revaluationDate rdf:type rdf:Property ;
    rdfs:label 'Revaluation Date' ;
    rdfs:comment 'The date on which the asset was formally revalued to fair value under the IAS 16 revaluation model. Revaluations must be performed with sufficient regularity to ensure the carrying amount does not differ materially from fair value.' ;
    rdfs:domain ind:AssetValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:usefulLifeMonths rdf:type rdf:Property ;
    rdfs:label 'Useful Life Months' ;
    rdfs:comment 'The estimated useful life of the asset expressed in months, providing finer granularity for depreciation calculation in SAP FI-AA. Used when the useful life does not align to whole years.' ;
    rdfs:domain ind:AssetValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyId rdf:type rdf:Property ;
    rdfs:label 'Warranty Id' ;
    rdfs:comment 'Unique surrogate identifier for each asset warranty record in the lakehouse silver layer.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warranty .

ind:arInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.ar_invoice. Business justification: When warranty claims are billed back to OEM suppliers or customers, an AR invoice is raised. Finance teams link warranty records to AR invoices to track warranty cost recovery — common in industrial e' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:claimProcedure rdf:type rdf:Property ;
    rdfs:label 'Claim Procedure' ;
    rdfs:comment 'Description of the required process for submitting a warranty claim, including required documentation, notification channels, and escalation contacts as specified by the OEM.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimSubmissionDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Claim Submission Deadline Days' ;
    rdfs:comment 'Maximum number of days after a failure event within which a warranty claim must be submitted to the OEM or supplier. Prevents forfeiture of warranty rights due to late filing.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coverageBasis rdf:type rdf:Property ;
    rdfs:label 'Coverage Basis' ;
    rdfs:comment 'Defines whether the warranty is triggered by elapsed time, equipment usage (e.g., operating hours, cycles), a combination of both, or a specific event such as first failure.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coveredComponents rdf:type rdf:Property ;
    rdfs:label 'Covered Components' ;
    rdfs:comment 'Free-text description of the specific components, assemblies, or systems covered under this warranty (e.g., \'Spindle motor and drive unit\', \'Hydraulic pump and seals\'). Supports claim eligibility assessment.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Reference to the physical or digital warranty certificate, OEM warranty booklet, or document management system (DMS) record. Enables retrieval of original warranty terms for claim disputes.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusions rdf:type rdf:Property ;
    rdfs:label 'Exclusions' ;
    rdfs:comment 'Description of items, failure modes, or conditions explicitly excluded from warranty coverage (e.g., \'Consumable wear parts\', \'Damage due to operator misuse\', \'Corrosion from chemical exposure\').' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborCoveredFlag rdf:type rdf:Property ;
    rdfs:label 'Labor Covered Flag' ;
    rdfs:comment 'Indicates whether labor costs for warranty repairs are covered by the OEM or supplier. Drives cost recovery calculations and maintenance work order cost allocation.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationLeadDays rdf:type rdf:Property ;
    rdfs:label 'Notification Lead Days' ;
    rdfs:comment 'Number of days before warranty expiry that automated notifications should be triggered to maintenance planners and procurement teams. Supports proactive warranty management.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openClaimCount rdf:type rdf:Property ;
    rdfs:label 'Open Claim Count' ;
    rdfs:comment 'Number of warranty claims currently open or in-progress against this warranty record. Supports workload management and supplier escalation decisions.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partsCoveredFlag rdf:type rdf:Property ;
    rdfs:label 'Parts Covered Flag' ;
    rdfs:comment 'Indicates whether replacement parts and materials are covered under this warranty. Determines whether spare parts costs should be claimed from the supplier.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Reference to the Purchase Order (PO) under which the equipment or extended warranty was procured. Enables traceability from warranty to procurement records in SAP Ariba and SAP S/4HANA MM.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Deadline Date' ;
    rdfs:comment 'Last date by which the warranty renewal or extension must be initiated to avoid a coverage gap. Triggers proactive notifications to maintenance planners.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Flag' ;
    rdfs:comment 'Indicates whether this warranty is eligible for renewal or extension upon expiry. Supports proactive warranty renewal planning before coverage lapses.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Response Time Hours' ;
    rdfs:comment 'Maximum response time in hours committed by the OEM or service provider under the warranty or service level agreement. Used for SLA compliance monitoring.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Code' ;
    rdfs:comment 'Internal supplier or vendor code from SAP Ariba or ERP identifying the warranty provider. Enables linkage to supplier performance and procurement records.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalClaimCount rdf:type rdf:Property ;
    rdfs:label 'Total Claim Count' ;
    rdfs:comment 'Total number of warranty claims ever submitted against this warranty record. Used for supplier warranty performance tracking and reliability analysis.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalClaimLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Total Claim Limit Amount' ;
    rdfs:comment 'Maximum cumulative monetary value of claims that can be made under this warranty agreement. Supports warranty cost recovery planning and financial exposure assessment.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalClaimedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Claimed Amount' ;
    rdfs:comment 'Cumulative monetary value of all warranty claims submitted against this warranty record to date. Used for warranty cost recovery tracking and supplier performance analysis.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:travelCoveredFlag rdf:type rdf:Property ;
    rdfs:label 'Travel Covered Flag' ;
    rdfs:comment 'Indicates whether travel and field service expenses for on-site warranty repairs are covered by the OEM or supplier. Relevant for remote plant locations.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageLimitUnit rdf:type rdf:Property ;
    rdfs:label 'Usage Limit Unit' ;
    rdfs:comment 'Unit of measure for the usage limit value (e.g., operating hours for CNC machines, cycles for presses, kilometers for transport equipment).' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageLimitValue rdf:type rdf:Property ;
    rdfs:label 'Usage Limit Value' ;
    rdfs:comment 'Maximum usage threshold (e.g., operating hours, cycles, kilometers) beyond which the warranty is void. Applicable when coverage_basis is usage_based or time_and_usage.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceContractId rdf:type rdf:Property ;
    rdfs:label 'Service Contract Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying a vendor-side maintenance service contract for manufacturing equipment assets.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceContract .

ind:apInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.ap_invoice. Business justification: Service contracts with external maintenance vendors generate periodic AP invoices. Accounts payable teams match vendor invoices to service contracts for three-way matching and payment processing — a d' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApInvoice .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Foreign key linking to procurement.procurement_contract. Business justification: Service contracts for asset maintenance originate from procurement contracts. Links commercial terms negotiated by procurement to operational service delivery tracked by asset management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:discountStructureId rdf:type rdf:Property ;
    rdfs:label 'Discount Structure Id' ;
    rdfs:comment 'Foreign key linking to sales.discount_structure. Business justification: Long-term service contracts in industrial manufacturing routinely apply negotiated discount structures. Finance and sales ops teams link the applicable discount tier to the contract to ensure consiste' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DiscountStructure .

ind:freightContractId rdf:type rdf:Property ;
    rdfs:label 'Freight Contract Id' ;
    rdfs:comment 'Foreign key linking to logistics.freight_contract. Business justification: Service contracts for field-maintained assets often include agreed logistics terms for parts shipment (e.g., next-day delivery SLAs). Linking to a freight contract lets contract managers enforce and a' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightContract .

ind:annualValue rdf:type rdf:Property ;
    rdfs:label 'Annual Value' ;
    rdfs:comment 'Annualized monetary value of the service contract, used for year-over-year spend comparison, OPEX budgeting, and financial planning.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractCategory rdf:type rdf:Property ;
    rdfs:label 'Contract Category' ;
    rdfs:comment 'Categorizes the service contract by the nature of the service provider: OEM (Original Equipment Manufacturer) direct service, third-party independent service provider, in-house maintenance team formalization, or consortium arrangement.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTitle rdf:type rdf:Property ;
    rdfs:label 'Contract Title' ;
    rdfs:comment 'Descriptive title of the maintenance service contract, summarizing the scope and covered equipment or service type (e.g., \'Annual Preventive Maintenance - CNC Machining Line 3\').' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the maintenance service contract by commercial and operational structure, distinguishing between full-service agreements, preventive maintenance (PM) contracts, time-and-materials arrangements, OEM service agreements, and emergency response contracts.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coveredAssetScope rdf:type rdf:Property ;
    rdfs:label 'Covered Asset Scope' ;
    rdfs:comment 'Defines the breadth of equipment coverage under this contract: a single asset, a defined group of assets (e.g., all CNC machines in a cell), an entire plant, or enterprise-wide coverage across all facilities.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseIncluded rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Included' ;
    rdfs:comment 'Indicates whether 24/7 emergency breakdown response and corrective maintenance are included within the contract scope, or require separate call-out billing.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'Number of calendar days\' advance notice required by either party to terminate or not renew the contract. Supports procurement planning and avoidance of unintended auto-renewals.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Penalty Rate Percent' ;
    rdfs:comment 'Percentage of the contract value or invoice amount deducted as a financial penalty for each SLA breach event, as defined in the contract penalty clause.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pmVisitsPerYear rdf:type rdf:Property ;
    rdfs:label 'Pm Visits Per Year' ;
    rdfs:comment 'Number of scheduled preventive maintenance visits per year included in the contract scope. Used for maintenance planning, scheduling, and compliance tracking against TPM programs.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preventiveMaintenanceIncluded rdf:type rdf:Property ;
    rdfs:label 'Preventive Maintenance Included' ;
    rdfs:comment 'Indicates whether scheduled preventive maintenance (PM) visits and tasks are included within the scope of this service contract, as opposed to being billed separately.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remoteMonitoringIncluded rdf:type rdf:Property ;
    rdfs:label 'Remote Monitoring Included' ;
    rdfs:comment 'Indicates whether the vendor provides remote condition monitoring and diagnostics services (e.g., via IIoT/MindSphere integration) as part of the contract scope.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'The date on which the service contract was formally executed and signed by authorized representatives of both parties.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaResolutionTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Time Hours' ;
    rdfs:comment 'Contractually guaranteed maximum time in hours from fault notification to full equipment restoration and return to service, as defined in the SLA terms.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaResponseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Hours' ;
    rdfs:comment 'Contractually guaranteed maximum time in hours from fault notification to vendor on-site or remote response, as defined in the SLA terms. Critical for equipment criticality-based maintenance planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sparePartsIncluded rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Included' ;
    rdfs:comment 'Indicates whether the cost of spare parts and consumables used during maintenance activities is covered within the contract value, or billed as additional MRO costs.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:uptimeGuaranteePercent rdf:type rdf:Property ;
    rdfs:label 'Uptime Guarantee Percent' ;
    rdfs:comment 'Contractually guaranteed minimum equipment availability or uptime percentage over a defined measurement period, as specified in the SLA. Directly linked to OEE targets and production planning.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'Internal vendor master code assigned in SAP/ERP to uniquely identify the service vendor, enabling cross-system linkage to procurement and accounts payable records.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'SAP Project System WBS element code used to allocate contract costs to a specific capital project or maintenance program, supporting CAPEX vs. OPEX classification.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knowledgeArticleId rdf:type rdf:Property ;
    rdfs:label 'Knowledge Article Id' ;
    rdfs:comment 'Foreign key linking to service.knowledge_article. Business justification: Task lists reference knowledge articles for standardized work instructions and safety procedures. Technicians executing maintenance tasks follow the linked knowledge article to ensure consistent, comp' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KnowledgeArticle .

ind:estimatedLaborCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Cost' ;
    rdfs:comment 'Estimated labor cost for executing the task list based on technician hours and applicable labor rates. Used for maintenance budget planning and OPEX forecasting.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Material Cost' ;
    rdfs:comment 'Estimated cost of materials and spare parts required to execute the task list, expressed in the cost currency. Used for maintenance budget planning and OPEX forecasting.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupCounter rdf:type rdf:Property ;
    rdfs:label 'Group Counter' ;
    rdfs:comment 'Counter within the task list group distinguishing individual variants (e.g., different equipment configurations or revision levels) within the same group.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupNumber rdf:type rdf:Property ;
    rdfs:label 'Group Number' ;
    rdfs:comment 'SAP PM task list group number that logically groups related task list variants (counters) under a single maintenance activity family.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationCount rdf:type rdf:Property ;
    rdfs:label 'Operation Count' ;
    rdfs:comment 'Total number of individual maintenance operations (steps) defined within this task list. Provides a quick indicator of task complexity for planning and scheduling.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tpmPillar rdf:type rdf:Property ;
    rdfs:label 'Tpm Pillar' ;
    rdfs:comment 'TPM pillar this task list supports, enabling alignment of maintenance activities with the TPM program structure and OEE improvement initiatives.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Number of times this task list has been referenced in maintenance plans or used to generate work orders. Indicates template adoption and supports rationalization of the task list library.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:locationId rdf:type rdf:Property ;
    rdfs:label 'Location Id' ;
    rdfs:comment 'Foreign key linking to logistics.location. Business justification: Stock positions must reference a physical logistics location (warehouse, plant, hub). Inventory planners and logistics coordinators use this link to determine where stock is held and plan inbound/outb' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:reorderPolicyId rdf:type rdf:Property ;
    rdfs:label 'Reorder Policy Id' ;
    rdfs:comment 'Foreign key linking to inventory.reorder_policy. Business justification: stock_position tracks reorder_point and safety_stock_quantity which are governed by reorder_policy. Adding reorder_policy_id FK links each stock position to its governing replenishment policy, enablin' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReorderPolicy .

ind:salesTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Sales Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_territory. Business justification: In industrial manufacturing with regional distribution, stock positions are allocated per sales territory to ensure regional availability commitments are met — territory sales managers check regional ' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesTerritory .

ind:atpQuantity rdf:type rdf:Property ;
    rdfs:label 'Atp Quantity' ;
    rdfs:comment 'Quantity of the material available to commit to new customer orders or production demands, calculated as unrestricted quantity minus reserved quantity. Supports ATP (Available-to-Promise) and CTP (Capable-to-Promise) checks in order management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockedQuantity rdf:type rdf:Property ;
    rdfs:label 'Blocked Quantity' ;
    rdfs:comment 'Quantity of the material that has been blocked and is not available for any use, typically due to quality rejection, damage, or regulatory hold. Corresponds to SAP MARD-SPEME (blocked stock).' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consignmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Consignment Quantity' ;
    rdfs:comment 'Quantity of the material held at the company\'s premises but owned by the supplier (vendor consignment stock). Liability is incurred only upon consumption. Corresponds to SAP special stock type K (vendor consignment).' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countVarianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Count Variance Quantity' ;
    rdfs:comment 'The difference between the physically counted quantity and the system book quantity at the time of the last physical inventory or cycle count. Positive values indicate surplus; negative values indicate shortage. Used for inventory accuracy KPI reporting.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Date' ;
    rdfs:comment 'The date on which the most recent goods receipt was posted for this stock position. Used for FIFO valuation, aging analysis, and supplier delivery performance tracking. Corresponds to SAP MSEG-BUDAT (posting date of goods movement).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inTransitQuantity rdf:type rdf:Property ;
    rdfs:label 'In Transit Quantity' ;
    rdfs:comment 'Quantity of the material that has been shipped from a source location but has not yet been received at the destination location. Includes stock in transfer orders between plants or from suppliers. Corresponds to SAP stock in transit (MARD-UMLME).' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Count Date' ;
    rdfs:comment 'The date on which the most recent physical inventory count or cycle count was performed for this stock position. Used to assess count freshness and schedule next cycle count. Corresponds to SAP MARD-LSOBS (date of last count).' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Movement Date' ;
    rdfs:comment 'The date of the most recent inventory movement (goods receipt, goods issue, transfer, or adjustment) for this stock position. Used to identify slow-moving or obsolete inventory for write-down analysis.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level' ;
    rdfs:comment 'The upper inventory quantity threshold beyond which stock should not be replenished, used to prevent overstock and excess carrying costs. Corresponds to SAP MARC-MABST (maximum stock level).' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onHandQuantity rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity' ;
    rdfs:comment 'Total physical quantity of the material currently present at the storage location, regardless of stock type. Represents the gross inventory count before any reservations or holds are applied. Sourced from SAP MARD-LABST + EINME + SPEME.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionSnapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Position Snapshot Timestamp' ;
    rdfs:comment 'The exact date and time at which this stock position record was captured or last refreshed from the source systems (SAP S/4HANA MM and Infor WMS). Enables point-in-time inventory reporting and audit trail for the Silver Layer data product.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityInspectionQuantity rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Quantity' ;
    rdfs:comment 'Quantity of the material currently held in quality inspection and not yet released for use. Pending QM (Quality Management) inspection lot disposition. Corresponds to SAP MARD-EINME.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'Quantity of the material that has been reserved for specific production orders, sales orders, or project requirements and is therefore not available for other demands. Sourced from SAP reservation management (RESB).' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfLifeExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Expiration Date' ;
    rdfs:comment 'The date on which the current batch or stock position expires and can no longer be used. Applicable to batch-managed materials with shelf-life management enabled. Drives FEFO (First Expired First Out) picking strategies.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slowMovingIndicator rdf:type rdf:Property ;
    rdfs:label 'Slow Moving Indicator' ;
    rdfs:comment 'Flag indicating whether this stock position has been classified as slow-moving based on the absence of inventory movements over a defined threshold period. Triggers review for potential write-down or disposal actions.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stockCategory rdf:type rdf:Property ;
    rdfs:label 'Stock Category' ;
    rdfs:comment 'Indicates the ownership or special stock category of the inventory position. Distinguishes company-owned stock from consignment stock, returnable packaging, pipeline stock, and customer/project-specific stock.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockType rdf:type rdf:Property ;
    rdfs:label 'Stock Type' ;
    rdfs:comment 'Classification of the stock by its usability and availability status. Unrestricted stock is available for use; quality inspection stock is pending QM release; blocked stock is not available; in-transit stock is between locations. Drives ATP (Available-to-Promise) calculations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalStockValue rdf:type rdf:Property ;
    rdfs:label 'Total Stock Value' ;
    rdfs:comment 'Total monetary value of the on-hand stock position, calculated as on-hand quantity multiplied by the valuation price. Expressed in the valuation currency. Used for balance sheet inventory reporting and financial close processes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unrestrictedQuantity rdf:type rdf:Property ;
    rdfs:label 'Unrestricted Quantity' ;
    rdfs:comment 'Quantity of the material that is freely available for use, sales order fulfillment, or production consumption without any quality or usage restrictions. Corresponds to SAP MARD-LABST (unrestricted-use stock).' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationCurrency rdf:type rdf:Property ;
    rdfs:label 'Valuation Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the inventory valuation price and stock value are expressed (e.g., USD, EUR, GBP). Supports multi-currency reporting for multinational operations.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationMethod rdf:type rdf:Property ;
    rdfs:label 'Valuation Method' ;
    rdfs:comment 'The costing method applied to value the inventory position. Standard price uses a fixed planned cost; moving average price recalculates with each goods receipt. FIFO and LIFO are used in specific regulatory contexts.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationPrice rdf:type rdf:Property ;
    rdfs:label 'Valuation Price' ;
    rdfs:comment 'The per-unit price used to value the inventory position, based on the material\'s valuation method (standard price or moving average price). Corresponds to SAP MBEW-STPRS (standard price) or MBEW-VERPR (moving average price).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'Sub-classification of a material for split valuation purposes, allowing different batches or procurement types (e.g., domestic vs. imported) to be valued separately within the same material and plant.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipQuantity rdf:type rdf:Property ;
    rdfs:label 'Wip Quantity' ;
    rdfs:comment 'Quantity of the material currently in the production process as Work-in-Progress (WIP), issued to production orders but not yet completed as finished goods. Tracked via Siemens Opcenter MES and SAP PP production orders.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aisle rdf:type rdf:Property ;
    rdfs:label 'Aisle' ;
    rdfs:comment 'Alphanumeric identifier for the aisle within the warehouse where this storage location is physically situated. Used for navigation, putaway routing, and picking path optimization.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bin rdf:type rdf:Property ;
    rdfs:label 'Bin' ;
    rdfs:comment 'Specific bin or slot identifier within a rack level, representing the most granular physical storage unit. Corresponds to the SAP WM storage bin and Infor WMS bin location.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockReason rdf:type rdf:Property ;
    rdfs:label 'Block Reason' ;
    rdfs:comment 'Reason code explaining why a storage location has been blocked or taken out of service. Required for quality management traceability and corrective action processes (CAPA).' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountIndicator rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Indicator' ;
    rdfs:comment 'Cycle counting frequency classification assigned to this storage location, determining how often physical inventory counts are performed. A-class locations are counted most frequently. Supports inventory accuracy programs and audit compliance.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date on which this storage location was or is scheduled to be permanently decommissioned and removed from active warehouse operations. Supports warehouse layout lifecycle management and historical reporting.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalLocationCode rdf:type rdf:Property ;
    rdfs:label 'External Location Code' ;
    rdfs:comment 'Location identifier used in external or third-party systems such as 3PL warehouse management systems, customer portals, or EDI integrations. Enables cross-system location reconciliation for multi-system environments.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireProtectionClass rdf:type rdf:Property ;
    rdfs:label 'Fire Protection Class' ;
    rdfs:comment 'Fire protection classification assigned to the storage location based on the type of materials stored and applicable fire suppression systems. Supports HSE compliance and emergency response planning.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class' ;
    rdfs:comment 'UN/DOT hazardous materials classification for the storage location, indicating the category of dangerous goods that may be stored. Drives segregation rules, safety signage requirements, and regulatory compliance for hazmat storage zones.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightMm rdf:type rdf:Property ;
    rdfs:label 'Height Mm' ;
    rdfs:comment 'Internal height dimension of the storage location in millimeters. Critical for tall or oversized SKU putaway validation and rack clearance compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'Date on which the most recent physical cycle count was performed for this storage location. Used to schedule upcoming counts, assess inventory accuracy, and support audit trail requirements.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lengthMm rdf:type rdf:Property ;
    rdfs:label 'Length Mm' ;
    rdfs:comment 'Internal length dimension of the storage location in millimeters. Used for dimensional compatibility checks during putaway to ensure SKU packaging fits within the bin.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:level rdf:type rdf:Property ;
    rdfs:label 'Level' ;
    rdfs:comment 'Vertical level or tier designation within a rack or shelving unit (e.g., floor level, level 1, level 2). Used for ergonomic slotting, weight distribution planning, and picking efficiency.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Business-facing alphanumeric code uniquely identifying the storage location within a warehouse or plant. Used in SAP WM as the storage bin number and in Infor WMS as the location ID for putaway and picking operations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Descriptive human-readable name or label for the storage location, used for display in warehouse management interfaces, picking lists, and operational reports.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Indicates whether the storage location is fixed (assigned to a specific SKU), random (dynamically assigned), dedicated, shared, or virtual. Determines slotting strategy and WMS putaway logic.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxPalletCount rdf:type rdf:Property ;
    rdfs:label 'Max Pallet Count' ;
    rdfs:comment 'Maximum number of pallets or handling units that can be stored simultaneously in this location. Used for pallet-level capacity management and putaway strategy in Infor WMS.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Max Temperature C' ;
    rdfs:comment 'Maximum allowable temperature in degrees Celsius for this storage location. Enforced for hazardous material storage compliance and product quality preservation.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Max Volume M3' ;
    rdfs:comment 'Maximum volumetric capacity of the storage location in cubic meters. Used for volumetric putaway checks and space utilization analytics.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Weight Kg' ;
    rdfs:comment 'Maximum allowable weight in kilograms that the storage location can safely hold. Enforced during putaway to prevent structural overloading and ensure workplace safety compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Min Temperature C' ;
    rdfs:comment 'Minimum allowable temperature in degrees Celsius for this storage location. Used for environmental compliance monitoring and material storage condition validation.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mixedLotAllowed rdf:type rdf:Property ;
    rdfs:label 'Mixed Lot Allowed' ;
    rdfs:comment 'Indicates whether multiple lot or batch numbers of the same SKU may be stored together in this location. Critical for pharmaceutical, food, and regulated component traceability and FIFO/FEFO compliance.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mixedSkuAllowed rdf:type rdf:Property ;
    rdfs:label 'Mixed Sku Allowed' ;
    rdfs:comment 'Indicates whether multiple distinct SKUs may be co-located within this storage location simultaneously. When false, the location is restricted to a single SKU to prevent picking errors and inventory commingling.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Next Cycle Count Date' ;
    rdfs:comment 'Planned date for the next physical cycle count at this storage location. Drives cycle count scheduling workflows in SAP MM and Infor WMS to maintain inventory accuracy targets.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pickingStrategy rdf:type rdf:Property ;
    rdfs:label 'Picking Strategy' ;
    rdfs:comment 'Picking strategy assigned to this storage location, determining the sequence and method by which stock is retrieved for outbound orders. Supports FIFO/FEFO compliance for perishable and regulated materials.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayStrategy rdf:type rdf:Property ;
    rdfs:label 'Putaway Strategy' ;
    rdfs:comment 'Putaway strategy assigned to this storage location, governing how incoming stock is directed to this bin. Supports FIFO, FEFO, and zone-directed strategies aligned with Infor WMS and SAP WM putaway rules.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rack rdf:type rdf:Property ;
    rdfs:label 'Rack' ;
    rdfs:comment 'Identifier for the rack or shelving unit within the aisle where this storage location is positioned. Supports physical navigation and structural capacity management.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentStrategy rdf:type rdf:Property ;
    rdfs:label 'Replenishment Strategy' ;
    rdfs:comment 'Replenishment strategy governing how this storage location is restocked from reserve or bulk storage. Supports Kanban, min-max, and demand-driven replenishment models aligned with JIT and MRP principles.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteRegion rdf:type rdf:Property ;
    rdfs:label 'Site Region' ;
    rdfs:comment 'Geographic or organizational region designation for the site where this storage location resides (e.g., EMEA, APAC, Americas). Supports regional inventory reporting, supply chain analytics, and organizational hierarchy alignment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageSectionCode rdf:type rdf:Property ;
    rdfs:label 'Storage Section Code' ;
    rdfs:comment 'Code identifying the storage section within a storage type, used to group bins with similar characteristics for putaway strategy optimization in SAP WM and Infor WMS.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTypeCode rdf:type rdf:Property ;
    rdfs:label 'Storage Type Code' ;
    rdfs:comment 'Code representing the physical storage type classification within the warehouse structure, such as high-rack, open storage, fixed bin, or automated storage. Corresponds to SAP WM storage type and Infor WMS location type.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureZone rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'Temperature classification of the storage location defining the environmental control requirements. Ensures temperature-sensitive materials (chemicals, adhesives, electronic components) are stored in compliant conditions.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthMm rdf:type rdf:Property ;
    rdfs:label 'Width Mm' ;
    rdfs:comment 'Internal width dimension of the storage location in millimeters. Used alongside length and height for volumetric capacity calculations and putaway compatibility validation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoneType rdf:type rdf:Property ;
    rdfs:label 'Zone Type' ;
    rdfs:comment 'Functional zone classification of the storage location defining its operational purpose within the warehouse. Drives putaway and picking strategies, compliance controls, and inventory segregation rules in Infor WMS and SAP WM.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionId rdf:type rdf:Property ;
    rdfs:label 'Transaction Id' ;
    rdfs:comment 'Unique system-generated identifier for each inventory movement event. Serves as the primary key for the inventory_transaction data product and enables precise traceability of every stock movement across the enterprise.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transaction .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Every goods movement transaction (goods receipt, goods issue, transfer) creates a financial accounting document. The inventory-to-GL link is a core integration point in any manufacturing ERP system.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:stockTransferId rdf:type rdf:Property ;
    rdfs:label 'Stock Transfer Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_transfer. Business justification: An inventory transaction record is frequently generated as the result of a stock transfer execution (goods issue at source, goods receipt at destination). Adding a typed FK from transaction to stock_t' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockTransfer .

ind:destinationPlantCode rdf:type rdf:Property ;
    rdfs:label 'Destination Plant Code' ;
    rdfs:comment 'For stock transfer transactions, the receiving plant code to which the material is being transferred. Populated only for inter-plant transfer movements (e.g., SAP movement types 301, 303, 351).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Destination Storage Location' ;
    rdfs:comment 'For stock transfer transactions, the receiving storage location within the destination plant. Populated for intra-plant and inter-plant transfer postings to identify the exact destination of the transferred stock.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date on the source document (e.g., delivery note, goods receipt slip, transfer order) that triggered the inventory transaction. May differ from the posting date when documents are processed with a delay.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'The Goods Receipt Note (GRN) number associated with this transaction when the movement represents an inbound goods receipt. Cross-references the procurement GRN document for three-way matching (PO, GRN, invoice).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDocumentLine rdf:type rdf:Property ;
    rdfs:label 'Material Document Line' ;
    rdfs:comment 'The line item number within the SAP material document corresponding to this inventory transaction. A single material document may contain multiple line items representing different materials or storage locations.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Material Document Number' ;
    rdfs:comment 'The SAP MM material document number assigned to this inventory transaction at the time of posting. Serves as the primary cross-reference to the source system of record for goods movements.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Material Document Year' ;
    rdfs:comment 'The fiscal year associated with the SAP material document number. Required in combination with material_document_number to uniquely identify a document in SAP MM, as document numbers are reset annually.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movementCategory rdf:type rdf:Property ;
    rdfs:label 'Movement Category' ;
    rdfs:comment 'High-level business classification of the inventory movement event. Groups SAP movement types into business-meaningful categories for simplified reporting and analytics (e.g., goods_receipt covers GRN against PO, production, and returns from customer).' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTypeCode rdf:type rdf:Property ;
    rdfs:label 'Movement Type Code' ;
    rdfs:comment 'SAP MM movement type code that classifies the nature of the inventory transaction (e.g., 101=Goods Receipt against PO, 201=Goods Issue to Cost Center, 261=Goods Issue to Production Order, 301=Transfer Posting, 551=Scrapping). Drives account determination and stock update logic.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Movement Type Description' ;
    rdfs:comment 'Human-readable description of the inventory movement type corresponding to the movement_type_code. Provides business context for reporting and analytics without requiring a lookup join.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Order Unit Of Measure' ;
    rdfs:comment 'The unit of measure used in the reference order document (PO, production order, sales order) for this transaction. May differ from the base unit of measure when conversion factors apply.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The accounting date on which the inventory transaction is posted to the general ledger and stock ledger. Determines the fiscal period for inventory valuation and financial reporting. May differ from the document date or actual physical movement date.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posting Timestamp' ;
    rdfs:comment 'The precise date and time at which the inventory transaction was posted in the system, including timezone offset. Used for audit trails, sequencing of concurrent transactions, and intraday inventory position reporting.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'The SAP controlling profit center associated with the inventory transaction. Enables profit center-level inventory valuation and profitability analysis across business segments.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityInOrderUom rdf:type rdf:Property ;
    rdfs:label 'Quantity In Order Uom' ;
    rdfs:comment 'The transaction quantity expressed in the order unit of measure (e.g., purchase order UoM or sales order UoM), which may differ from the base unit of measure. Supports reconciliation with reference documents such as POs and SOs.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Business reason code explaining why the inventory transaction was performed, particularly for adjustments, scrapping, and returns. Supports root cause analysis, quality management reporting, and inventory loss investigation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentLine rdf:type rdf:Property ;
    rdfs:label 'Reference Document Line' ;
    rdfs:comment 'The line item number within the reference document (PO, production order, sales order) associated with this inventory transaction. Required for precise reconciliation between inventory movements and order line items.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'The document number of the business document that triggered this inventory transaction (e.g., PO number for goods receipt, production order number for goods issue, sales order number for outbound delivery). Enables end-to-end process traceability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'The type of business document that triggered or is referenced by this inventory transaction (e.g., purchase_order for GRN, production_order for goods issue to manufacturing, sales_order for outbound delivery). Enables cross-domain traceability.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Indicates whether this inventory transaction is a reversal (cancellation) of a previously posted transaction. Reversed transactions negate the original stock and accounting impact. Critical for audit trail integrity and inventory reconciliation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The material document number of the original transaction that this record reverses. Populated only when reversal_indicator is true. Enables bidirectional linkage between original and reversal transactions for audit and reconciliation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialStockIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Stock Indicator' ;
    rdfs:comment 'SAP special stock indicator identifying whether the material belongs to a special stock category such as sales order stock (E), vendor consignment (K), project stock (Q), or returnable packaging (V). Blank indicates standard own stock.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageBin rdf:type rdf:Property ;
    rdfs:label 'Storage Bin' ;
    rdfs:comment 'The specific bin, rack, or slot within the warehouse where the material was placed or picked during this transaction. Enables precise bin-level inventory tracking and supports warehouse slotting optimization.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Amount' ;
    rdfs:comment 'The monetary value of the inventory quantity moved in this transaction, calculated using the applicable valuation method (standard price, moving average price, or FIFO). Used for inventory accounting, COGS calculation, and financial reporting.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationPricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Valuation Price Per Unit' ;
    rdfs:comment 'The unit price used to calculate the valuation amount for this transaction, expressed in the transaction currency. Reflects the standard price or moving average price at the time of posting. Higher precision (6 decimal places) supports materials with very low unit costs.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Wms Transaction Reference' ;
    rdfs:comment 'The transaction reference number from Infor WMS corresponding to this inventory movement. Used to cross-reference warehouse-level execution details with the ERP material document.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Storage Location Id' ;
    rdfs:comment 'FK to inventory.storage_location' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:sourceStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Source Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: stock_transfer.source_storage_location is a denormalized location code for the origin bin/rack. Normalizing to source_storage_location_id FK with a descriptive prefix distinguishes it from the destina' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:actualGoodsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Actual Goods Issue Date' ;
    rdfs:comment 'The actual calendar date on which the goods issue was posted at the source location, confirming physical departure of stock. Triggers inventory reduction at source and initiates in-transit stock accounting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualGoodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Actual Goods Receipt Date' ;
    rdfs:comment 'The actual calendar date on which the goods receipt was posted at the destination location, confirming physical arrival and acceptance of transferred stock. Triggers inventory increase at destination and closes in-transit stock.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customsDeclarationNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Number' ;
    rdfs:comment 'Official customs declaration or export/import document reference number for cross-border stock transfers. Required for regulatory compliance with customs authorities and trade compliance reporting in multinational operations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Document Number' ;
    rdfs:comment 'SAP outbound delivery document number (VL10) or Infor WMS shipment document number associated with the stock transfer. Links the inventory transfer to the logistics delivery process for goods issue posting and shipment tracking.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the destination plant or warehouse location. Used for cross-border transfer identification, import duty determination, customs compliance, and regulatory reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationWarehouseNumber rdf:type rdf:Property ;
    rdfs:label 'Destination Warehouse Number' ;
    rdfs:comment 'Identifier of the receiving warehouse within the destination plant. Corresponds to the SAP warehouse number or Infor WMS warehouse code at the destination. Used for inbound planning and putaway operations.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Timestamp' ;
    rdfs:comment 'Precise date and time when the goods issue was posted at the source location. Provides sub-day precision for operational tracking, shift-level reporting, and audit trail requirements beyond the goods issue date.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:goodsReceiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Timestamp' ;
    rdfs:comment 'Precise date and time when the goods receipt was posted at the destination location. Enables transit time calculation at sub-day precision and supports SLA compliance monitoring for inter-plant replenishment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isCrossBorder rdf:type rdf:Property ;
    rdfs:label 'Is Cross Border' ;
    rdfs:comment 'Boolean flag indicating whether the stock transfer crosses international borders, requiring customs documentation, export/import declarations, and compliance with trade regulations (e.g., CE Marking, REACH, RoHS, export control).' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIntercompany rdf:type rdf:Property ;
    rdfs:label 'Is Intercompany' ;
    rdfs:comment 'Boolean flag indicating whether the stock transfer crosses legal entity boundaries (intercompany transfer). When true, the transfer requires intercompany billing, transfer pricing compliance, and consolidated financial elimination entries.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuedQuantity rdf:type rdf:Property ;
    rdfs:label 'Issued Quantity' ;
    rdfs:comment 'Actual quantity of the SKU physically issued or picked from the source location and dispatched for transfer. May differ from the planned transfer quantity due to partial shipments or stock availability constraints.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Date and time of the most recent update to the stock transfer record in the source system. Used for change detection in data pipeline processing and audit trail maintenance.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Planned Receipt Date' ;
    rdfs:comment 'The scheduled calendar date on which the transferred stock is expected to arrive and be received at the destination location. Used for inbound planning, safety stock calculations, and Available to Promise (ATP) at the destination.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedTransferDate rdf:type rdf:Property ;
    rdfs:label 'Planned Transfer Date' ;
    rdfs:comment 'The scheduled calendar date on which the stock transfer is planned to be executed (goods issue from source). Used for production planning, MRP scheduling, and Available to Promise (ATP) calculations.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'Actual quantity of the SKU confirmed as received at the destination location. Used to calculate transfer variance and update destination inventory positions. Triggers goods receipt posting in SAP MM.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Company Code' ;
    rdfs:comment 'SAP company code of the receiving legal entity in an intercompany stock transfer. When this differs from the issuing company code, the transfer triggers intercompany billing and cross-company financial postings.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceCountryCode rdf:type rdf:Property ;
    rdfs:label 'Source Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the source plant or warehouse location. Used for cross-border transfer identification, customs compliance, trade statistics, and regulatory reporting.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Order Number' ;
    rdfs:comment 'Business-facing document number assigned to the stock transfer order by the source system (SAP MM STO number or Infor WMS transfer order number). Used for cross-system traceability and communication with logistics and warehouse teams.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferQuantity rdf:type rdf:Property ;
    rdfs:label 'Transfer Quantity' ;
    rdfs:comment 'Ordered or planned quantity of the SKU to be transferred, expressed in the base unit of measure. This is the quantity requested on the transfer order document, which may differ from the actual received quantity.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferReasonCode rdf:type rdf:Property ;
    rdfs:label 'Transfer Reason Code' ;
    rdfs:comment 'Business reason code explaining why the stock transfer was initiated. Used for demand classification, cost allocation, and operational analytics to understand the drivers of inter-plant and inter-warehouse stock movements.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the stock transfer indicating the scope and nature of the movement: plant-to-plant (inter-plant), warehouse-to-warehouse, storage location transfer within a plant, or a formal Stock Transport Order (STO) involving procurement and logistics. Drives process routing and document flow.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferValue rdf:type rdf:Property ;
    rdfs:label 'Transfer Value' ;
    rdfs:comment 'Total monetary value of the stock transfer, calculated as transfer quantity multiplied by the valuation price. Used for financial reporting, intercompany billing, and inventory cost accounting. Stored as a raw business figure; aggregations are performed in the analytics layer.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Transport Reference Number' ;
    rdfs:comment 'Reference number linking the stock transfer to the associated transport or shipment document (e.g., SAP shipment number, carrier waybill, or TMS reference). Enables traceability between inventory movement and physical logistics execution.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountId rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Id' ;
    rdfs:comment 'Unique system-generated identifier for each cycle count record within the inventory management system. Serves as the primary key for all cycle count transactions.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CycleCount .

ind:actualCountDate rdf:type rdf:Property ;
    rdfs:label 'Actual Count Date' ;
    rdfs:comment 'The actual calendar date on which the cycle count was physically performed. Used to measure schedule adherence and compliance with counting frequency requirements.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignedCounterName rdf:type rdf:Property ;
    rdfs:label 'Assigned Counter Name' ;
    rdfs:comment 'Full name of the warehouse employee assigned to perform the physical count. Used for operational reporting and accountability tracking.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countCycleNumber rdf:type rdf:Property ;
    rdfs:label 'Count Cycle Number' ;
    rdfs:comment 'Business-facing alphanumeric identifier for the cycle count, used for cross-system reference between SAP MM and Infor WMS. Follows the format CC-YYYY-NNNNNN.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count End Timestamp' ;
    rdfs:comment 'Precise date and time when the physical counting activity was completed. Combined with count_start_timestamp to calculate count duration for labor and efficiency reporting.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countFrequency rdf:type rdf:Property ;
    rdfs:label 'Count Frequency' ;
    rdfs:comment 'Frequency at which this cycle count is scheduled to recur. Drives the cycle count program calendar and aligns with ABC classification-based counting requirements in SAP MM.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countMethod rdf:type rdf:Property ;
    rdfs:label 'Count Method' ;
    rdfs:comment 'Physical counting method used by warehouse operatives during the cycle count. Includes manual paper-based, RF scanner, barcode scanning, RFID, or voice-directed counting. Impacts accuracy and efficiency metrics.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Start Timestamp' ;
    rdfs:comment 'Precise date and time when the physical counting activity commenced. Used for duration tracking, labor reporting, and operational analytics.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Type of cycle count being performed. Standard counts use system book quantities as reference; blind counts do not show expected quantities to counters; recounts are triggered by variance; audit counts are compliance-driven.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countZone rdf:type rdf:Property ;
    rdfs:label 'Count Zone' ;
    rdfs:comment 'Logical or physical zone within the warehouse designated for this cycle count. Zones are defined in Infor WMS and used to segment counting activities for operational efficiency.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inforWmsCountCode rdf:type rdf:Property ;
    rdfs:label 'Infor Wms Count Code' ;
    rdfs:comment 'Native cycle count identifier from the Infor WMS system. Used for cross-system reconciliation between Infor WMS and SAP S/4HANA MM inventory records.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryAdjustmentPosted rdf:type rdf:Property ;
    rdfs:label 'Inventory Adjustment Posted' ;
    rdfs:comment 'Indicates whether the inventory adjustment resulting from the cycle count variance has been formally posted in SAP MM, updating the book inventory to reflect the physical count results.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryCategory rdf:type rdf:Property ;
    rdfs:label 'Inventory Category' ;
    rdfs:comment 'Category of inventory being counted. Distinguishes between Raw Material, Work In Progress (WIP), Finished Goods, Maintenance Repair and Operations (MRO) stock, packaging, and semi-finished goods.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemsExceedingThreshold rdf:type rdf:Property ;
    rdfs:label 'Items Exceeding Threshold' ;
    rdfs:comment 'Count of SKU line items where the variance between book quantity and counted quantity exceeded the defined variance threshold, requiring recount or investigation.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:itemsWithinThreshold rdf:type rdf:Property ;
    rdfs:label 'Items Within Threshold' ;
    rdfs:comment 'Count of SKU line items where the variance between book quantity and counted quantity fell within the defined variance threshold. Used to calculate count accuracy rate.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reconciliationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Timestamp' ;
    rdfs:comment 'Date and time when the cycle count variances were reviewed, approved, and inventory adjustments were posted in SAP MM. Marks the formal closure of the count cycle.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recountCount rdf:type rdf:Property ;
    rdfs:label 'Recount Count' ;
    rdfs:comment 'Number of recount iterations performed for this cycle count record. Tracks how many times counting was repeated due to variance exceedances. A value of 0 indicates no recount was needed.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recountRequired rdf:type rdf:Property ;
    rdfs:label 'Recount Required' ;
    rdfs:comment 'Indicates whether a recount has been triggered for one or more SKUs in this cycle count due to variances exceeding the defined threshold. Drives workflow escalation in Infor WMS.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapPhysicalInventoryDoc rdf:type rdf:Property ;
    rdfs:label 'Sap Physical Inventory Doc' ;
    rdfs:comment 'SAP MM physical inventory document number generated when the cycle count is initiated in SAP S/4HANA. Provides the cross-reference between the WMS cycle count and the SAP inventory posting document.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledCountDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Count Date' ;
    rdfs:comment 'The planned calendar date on which the cycle count is scheduled to be performed. Used for workforce scheduling and operational planning.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:skuScope rdf:type rdf:Property ;
    rdfs:label 'Sku Scope' ;
    rdfs:comment 'Defines the scope of Stock Keeping Units (SKUs) included in this cycle count. Determines whether all SKUs, a specific ABC class, a material group, or individual SKUs are counted.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBinsCounted rdf:type rdf:Property ;
    rdfs:label 'Total Bins Counted' ;
    rdfs:comment 'Total number of storage bins or locations physically counted during this cycle count. Used to measure count coverage and completeness against the planned scope.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSkuCount rdf:type rdf:Property ;
    rdfs:label 'Total Sku Count' ;
    rdfs:comment 'Total number of distinct SKUs (Stock Keeping Units) included in the scope of this cycle count. Used for workload estimation and count completeness verification.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVarianceQty rdf:type rdf:Property ;
    rdfs:label 'Total Variance Qty' ;
    rdfs:comment 'Aggregate net quantity variance across all SKUs counted in this cycle count, calculated as the sum of (counted quantity minus book quantity). Positive values indicate overages; negative values indicate shortages.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVarianceValue rdf:type rdf:Property ;
    rdfs:label 'Total Variance Value' ;
    rdfs:comment 'Total monetary value of inventory variance identified during the cycle count, expressed in the local currency. Used for financial impact assessment and inventory adjustment postings in SAP FI/CO.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Pct' ;
    rdfs:comment 'Maximum allowable percentage variance between the system book quantity and the physically counted quantity before a recount or investigation is triggered. Expressed as a percentage of book quantity.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdQty rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Qty' ;
    rdfs:comment 'Maximum allowable absolute quantity variance between system book quantity and physically counted quantity before a recount or investigation is triggered. Complements the percentage threshold for high-value items.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleCountResultId rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Result Id' ;
    rdfs:comment 'Unique surrogate identifier for each cycle count result record at the SKU and storage location level. Serves as the primary key for this entity in the Databricks Silver Layer.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CycleCountResult .

ind:qualityNotificationId rdf:type rdf:Property ;
    rdfs:label 'Quality Notification Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_notification. Business justification: When a cycle count reveals a significant discrepancy or damaged goods, a quality notification is raised to investigate root cause. The cycle count result references the notification to track the quali' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityNotification .

ind:adjustmentPostedFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Posted Flag' ;
    rdfs:comment 'Indicates whether the inventory adjustment has been posted to the SAP material ledger following approval of the cycle count variance. When true, the book stock has been updated to reflect the counted quantity.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentPostingDate rdf:type rdf:Property ;
    rdfs:label 'Adjustment Posting Date' ;
    rdfs:comment 'Accounting date on which the inventory adjustment was posted to the general ledger and material ledger. Determines the financial period in which the inventory variance is recognized.' ;
    rdfs:domain ind:CycleCountResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adjustmentPostingReference rdf:type rdf:Property ;
    rdfs:label 'Adjustment Posting Reference' ;
    rdfs:comment 'SAP material document number generated when the inventory difference was posted to adjust the book stock to the counted quantity. Links the cycle count result to the financial and inventory adjustment transaction.' ;
    rdfs:domain ind:CycleCountResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the cycle count result was approved by the authorized supervisor. Supports audit trail and SLA compliance for inventory adjustment turnaround time.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookQuantity rdf:type rdf:Property ;
    rdfs:label 'Book Quantity' ;
    rdfs:comment 'System-recorded (book) quantity of the SKU at the storage location at the time the physical inventory document was created. Represents the expected on-hand quantity before the physical count.' ;
    rdfs:domain ind:CycleCountResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countDate rdf:type rdf:Property ;
    rdfs:label 'Count Date' ;
    rdfs:comment 'Calendar date on which the physical cycle count was performed for this SKU and storage location. Used for inventory accuracy trending and compliance reporting.' ;
    rdfs:domain ind:CycleCountResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countNote rdf:type rdf:Property ;
    rdfs:label 'Count Note' ;
    rdfs:comment 'Free-text remarks entered by the counter or supervisor to explain unusual findings, discrepancies, or special circumstances observed during the cycle count (e.g., damaged goods, misplaced stock).' ;
    rdfs:domain ind:CycleCountResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countRoundNumber rdf:type rdf:Property ;
    rdfs:label 'Count Round Number' ;
    rdfs:comment 'Sequential round number of the count for this SKU and location (1 = initial count, 2 = first recount, 3 = second recount, etc.). Tracks the count iteration history for audit and accuracy analysis.' ;
    rdfs:domain ind:CycleCountResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'Operational status of the individual count line item within the physical inventory document. Tracks progression from not yet counted through to final posting.' ;
    rdfs:domain ind:CycleCountResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Timestamp' ;
    rdfs:comment 'Precise date and time when the physical count entry was recorded in the system. Supports audit trail requirements and time-of-day analysis for count accuracy.' ;
    rdfs:domain ind:CycleCountResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countedQuantity rdf:type rdf:Property ;
    rdfs:label 'Counted Quantity' ;
    rdfs:comment 'Actual physical quantity of the SKU recorded by the counter during the cycle count. This is the primary result of the count event and is compared against the book quantity to determine variance.' ;
    rdfs:domain ind:CycleCountResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterName rdf:type rdf:Property ;
    rdfs:label 'Counter Name' ;
    rdfs:comment 'Full name of the warehouse employee who performed the physical count. Captured for audit trail and accountability purposes in cycle count documentation.' ;
    rdfs:domain ind:CycleCountResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceedsToleranceFlag rdf:type rdf:Property ;
    rdfs:label 'Exceeds Tolerance Flag' ;
    rdfs:comment 'Indicates whether the variance percentage exceeds the configured tolerance threshold for this SKU. When true, triggers a recount workflow or supervisor approval before stock adjustment posting.' ;
    rdfs:domain ind:CycleCountResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the local currency in which the variance value is expressed (e.g., USD, EUR, CNY). Supports multi-currency reporting for multinational operations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalInventoryDocumentItem rdf:type rdf:Property ;
    rdfs:label 'Physical Inventory Document Item' ;
    rdfs:comment 'Line item number within the SAP physical inventory document identifying the specific SKU and storage location combination being counted.' ;
    rdfs:domain ind:CycleCountResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recountFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Flag' ;
    rdfs:comment 'Indicates whether this count record is a recount (second or subsequent count) triggered by an out-of-tolerance variance from the initial count. Supports multi-round count workflows.' ;
    rdfs:domain ind:CycleCountResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recountQuantity rdf:type rdf:Property ;
    rdfs:label 'Recount Quantity' ;
    rdfs:comment 'Physical quantity recorded during the recount round, if a recount was performed. Populated only when recount_flag is true. Used to reconcile the final accepted quantity.' ;
    rdfs:domain ind:CycleCountResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'Variance quantity expressed as a percentage of the book quantity. Used to assess relative inventory accuracy and determine whether the variance exceeds the tolerance threshold for adjustment posting.' ;
    rdfs:domain ind:CycleCountResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'Difference between the counted quantity and the book quantity (counted_quantity minus book_quantity). A positive value indicates a surplus; a negative value indicates a shortage.' ;
    rdfs:domain ind:CycleCountResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceValueLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Variance Value Local Currency' ;
    rdfs:comment 'Monetary value of the inventory variance in the plant local currency, calculated as variance quantity multiplied by the standard or moving average price. Used for financial impact assessment and P&L reporting.' ;
    rdfs:domain ind:CycleCountResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zeroCountFlag rdf:type rdf:Property ;
    rdfs:label 'Zero Count Flag' ;
    rdfs:comment 'Indicates whether the counter explicitly confirmed a zero quantity count (as opposed to the count not yet being entered). Distinguishes between a confirmed zero stock and a missing count entry in SAP.' ;
    rdfs:domain ind:CycleCountResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stockAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Stock Adjustment Id' ;
    rdfs:comment 'Unique system-generated identifier for each stock adjustment record in the inventory management system. Serves as the primary key for the stock_adjustment data product.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockAdjustment .

ind:usageDecisionId rdf:type rdf:Property ;
    rdfs:label 'Usage Decision Id' ;
    rdfs:comment 'Foreign key linking to quality.usage_decision. Business justification: Stock adjustments that move material from inspection stock to unrestricted, blocked, or scrap are directly authorized by a usage decision. The adjustment must reference the decision to maintain a comp' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UsageDecision .

ind:adjustedQuantity rdf:type rdf:Property ;
    rdfs:label 'Adjusted Quantity' ;
    rdfs:comment 'The net quantity change applied to the inventory position. Positive values indicate an inventory increase (surplus found); negative values indicate a decrease (shortage, write-off, or rejection). Expressed in the material\'s base unit of measure.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Number' ;
    rdfs:comment 'Business-facing document number assigned to the stock adjustment, used for cross-referencing with SAP MM inventory difference postings and audit trails. Follows the enterprise document numbering convention.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Classification of the inventory adjustment indicating the business reason category. Drives accounting treatment, approval workflow, and reporting segmentation. Aligned with SAP MM movement type categories.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Approval Threshold Amount' ;
    rdfs:comment 'The monetary threshold value that triggered the approval requirement for this adjustment. Captures the applicable authorization limit at the time of submission, supporting audit and SOX compliance documentation.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Full name of the manager or authorized personnel who approved the inventory adjustment. Captured for audit trail and segregation of duties compliance. Not a direct personal identifier in the operational context.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookQuantityAfter rdf:type rdf:Property ;
    rdfs:label 'Book Quantity After' ;
    rdfs:comment 'The system-recorded (book) inventory quantity for the SKU at the storage location immediately after the adjustment was posted. Confirms the resulting inventory position and supports reconciliation.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookQuantityBefore rdf:type rdf:Property ;
    rdfs:label 'Book Quantity Before' ;
    rdfs:comment 'The system-recorded (book) inventory quantity for the SKU at the storage location immediately before the adjustment was posted. Provides the baseline for variance calculation and audit trail.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'The monetary value of the inventory adjustment calculated as adjusted quantity multiplied by unit cost. Represents the debit or credit to the inventory account and corresponding expense or income account. Negative values indicate a write-down.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'SAP MM three-digit movement type code governing the inventory posting logic (e.g., 551 for scrapping, 701 for inventory difference posting). Determines the general ledger account determination and stock category impact.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'The exact date and time when the inventory adjustment was posted to the SAP inventory ledger and financial accounts. Marks the completion of the adjustment lifecycle and the point at which stock quantities were updated.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'The SAP profit center associated with the inventory adjustment for segment reporting and profitability analysis. Enables P&L impact attribution at the business unit level.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text narrative providing additional context and explanation for the inventory adjustment beyond the standardized reason code. Captures specific circumstances, findings from cycle counts, or quality inspection outcomes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Approval' ;
    rdfs:comment 'Indicates whether this adjustment requires formal management approval before being posted to the inventory ledger. Typically triggered by financial impact thresholds or specific adjustment types such as write-offs.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'The SAP material document number of the reversal posting that cancelled this adjustment. Populated only when reversal_indicator is true. Enables complete audit trail of correction activities.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'The standard or moving average cost per unit of the material at the time of the adjustment, used to calculate the financial impact. Sourced from the SAP material valuation record.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'The SAP user ID or system user identifier of the person who created the stock adjustment record. Supports segregation of duties auditing and traceability requirements.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousSubstanceId rdf:type rdf:Property ;
    rdfs:label 'Hazardous Substance Id' ;
    rdfs:comment 'Foreign key linking to product.hazardous_substance. Business justification: Batches of hazardous materials must reference the product domain\'s hazardous substance classification for regulatory compliance, safe handling instructions, and transport documentation. Eliminates dup' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HazardousSubstance .

ind:batchClassificationClass rdf:type rdf:Property ;
    rdfs:label 'Batch Classification Class' ;
    rdfs:comment 'The SAP classification class assigned to this batch, enabling batch-specific characteristic values (e.g., purity percentage, viscosity, tensile strength) to be stored as classification attributes. Supports batch search, selection, and quality characteristic reporting.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Business-facing alphanumeric identifier assigned to a material lot or production batch. Corresponds to the SAP MM batch number (CHARG field) and is used for traceability, quality inspection, and FIFO/FEFO picking across the supply chain.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchSizeUom rdf:type rdf:Property ;
    rdfs:label 'Batch Size Uom' ;
    rdfs:comment 'The unit of measure used to express the original batch size at the time of production or receipt, which may differ from the current inventory unit of measure. Supports unit conversion tracking and production yield analysis.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchType rdf:type rdf:Property ;
    rdfs:label 'Batch Type' ;
    rdfs:comment 'Classification of the batch origin indicating whether it was produced internally, purchased from a supplier, received on consignment, returned from a customer, created through rework, or designated as a quality sample.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bestBeforeDate rdf:type rdf:Property ;
    rdfs:label 'Best Before Date' ;
    rdfs:comment 'The date up to which the batch retains its optimal quality characteristics, distinct from the hard expiry date. Used for quality-sensitive materials where degraded-but-not-expired stock may be sold at discount or redirected. Supports FEFO picking and customer SLA compliance.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateOfAnalysisNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Number' ;
    rdfs:comment 'The document number of the Certificate of Analysis (CoA) issued for this batch, confirming that the material meets specified quality standards and test results. Required for regulated industries and customer quality documentation packages.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether the material in this batch is classified as hazardous under applicable regulations (e.g., OSHA HazCom, REACH, RoHS, UN dangerous goods). When true, triggers special handling, storage, and transportation requirements including hazmat documentation and labeling.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Number' ;
    rdfs:comment 'The SAP QM inspection lot number (PRUEFLOS) associated with the quality inspection triggered for this batch. Links the batch to its quality inspection results, usage decisions, and defect records in the Quality Management system.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current quality inspection status of the batch controlling its availability for use, picking, and shipment. Unrestricted batches are available for all movements; quality_hold and blocked batches are restricted pending inspection or disposition; restricted batches have limited usage; in_inspection batches are undergoing active QM evaluation. Aligned with SAP QM batch status.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date' ;
    rdfs:comment 'The date on which this batch was manufactured or produced. Used as the baseline for shelf life calculations, FIFO/FEFO picking strategy, and regulatory traceability. Corresponds to SAP batch manufacturing date (HSDAT).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Classification of the material in this batch according to its stage in the production lifecycle. Distinguishes raw materials, Work in Progress (WIP), finished goods, Maintenance Repair and Operations (MRO) stock, semi-finished goods, packaging materials, and spare parts.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxStorageTempC rdf:type rdf:Property ;
    rdfs:label 'Max Storage Temp C' ;
    rdfs:comment 'The maximum allowable storage temperature in degrees Celsius for this batch. Used in conjunction with minimum storage temperature to define the acceptable temperature range for warehouse compliance monitoring and cold chain management.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minStorageTempC rdf:type rdf:Property ;
    rdfs:label 'Min Storage Temp C' ;
    rdfs:comment 'The minimum allowable storage temperature in degrees Celsius for this batch. Used to validate warehouse temperature zone compliance, trigger alerts for out-of-condition storage, and support regulatory documentation for temperature-sensitive materials.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalBatchSize rdf:type rdf:Property ;
    rdfs:label 'Original Batch Size' ;
    rdfs:comment 'The total quantity of material in this batch at the time of initial creation (production completion or goods receipt). Used as the denominator for yield calculations, scrap rate analysis, and batch consumption tracking.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Remaining Shelf Life Days' ;
    rdfs:comment 'The number of days remaining before this batch reaches its expiry date, calculated at the time of the last inventory snapshot or transaction. Used for FEFO picking prioritization, customer minimum shelf life checks, and proactive disposition planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restrictedSubstanceFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Substance Flag' ;
    rdfs:comment 'Indicates whether the material in this batch contains substances restricted under REACH, RoHS, or other environmental regulations. When true, requires compliance documentation, customer disclosure, and may restrict sale in certain markets or regions.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retestDate rdf:type rdf:Property ;
    rdfs:label 'Retest Date' ;
    rdfs:comment 'The date on which this batch is scheduled for re-inspection or retesting to confirm continued conformance to quality specifications. Used for materials with defined retest intervals (e.g., chemicals, raw materials) to prevent use of out-of-specification stock.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'The total shelf life of the material in this batch expressed in days, as defined in the material master. Used to calculate expiry dates when manufacturing date is known and to enforce minimum remaining shelf life rules for customer shipments.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageConditionCode rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Code' ;
    rdfs:comment 'Code identifying the required storage conditions for this batch (e.g., ambient, refrigerated, frozen, controlled atmosphere, hazardous). Drives warehouse slotting, temperature zone assignment, and compliance with material safety data sheet (MSDS) requirements.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Batch Number' ;
    rdfs:comment 'The batch or lot number assigned by the external supplier or vendor for purchased materials. Maintained alongside the internal batch number to enable end-to-end supply chain traceability, supplier quality investigations, and recall management. Corresponds to SAP batch field LICHA.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageDecision rdf:type rdf:Property ;
    rdfs:label 'Usage Decision' ;
    rdfs:comment 'The quality management usage decision recorded for this batch following inspection. Determines whether the batch is accepted for unrestricted use, rejected for disposal, conditionally released with restrictions, sent for rework, scrapped, or pending a decision. Corresponds to SAP QM usage decision (VCODE).' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseBin rdf:type rdf:Property ;
    rdfs:label 'Warehouse Bin' ;
    rdfs:comment 'The specific warehouse bin or slot identifier within the storage location where this batch is physically stored. Enables precise put-away and picking instructions in the Warehouse Management System (WMS) and supports bin-level inventory accuracy.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageDailyUsageQty rdf:type rdf:Property ;
    rdfs:label 'Average Daily Usage Qty' ;
    rdfs:comment 'The average quantity of the SKU consumed or issued per calendar day at this location, based on historical consumption data. Used as the baseline for reorder point and safety stock calculations.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandVariabilityStdDev rdf:type rdf:Property ;
    rdfs:label 'Demand Variability Std Dev' ;
    rdfs:comment 'The standard deviation of demand during the replenishment lead time period, used in statistical safety stock calculations. Reflects the variability of consumption patterns for this SKU at this location.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:economicOrderQty rdf:type rdf:Property ;
    rdfs:label 'Economic Order Qty' ;
    rdfs:comment 'The Economic Order Quantity (EOQ) — the mathematically optimal order quantity that minimizes total inventory holding costs and ordering costs. Used as the target replenishment quantity in cost-optimized procurement strategies.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixedLotSizeQty rdf:type rdf:Property ;
    rdfs:label 'Fixed Lot Size Qty' ;
    rdfs:comment 'The fixed quantity used for replenishment orders when the lot sizing procedure is set to fixed lot size. Overrides EOQ calculations and is typically aligned with supplier standard pack sizes or production batch sizes.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdingCostRatePct rdf:type rdf:Property ;
    rdfs:label 'Holding Cost Rate Pct' ;
    rdfs:comment 'The annual inventory holding cost expressed as a percentage of the unit value (e.g., 20.00 = 20% per year). Includes storage, insurance, obsolescence, and capital cost of inventory. Used in EOQ and total cost of ownership calculations.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSizingProcedure rdf:type rdf:Property ;
    rdfs:label 'Lot Sizing Procedure' ;
    rdfs:comment 'Defines the lot sizing method used by MRP to calculate replenishment order quantities. Options include exact quantity, fixed lot size, Economic Order Quantity (EOQ), period lot sizing, lot-for-lot, and min/max replenishment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumOrderQty rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Qty' ;
    rdfs:comment 'The maximum quantity that can be ordered in a single replenishment order. Used to prevent over-ordering, manage storage capacity constraints, and control cash flow exposure.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumStockLevelQty rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level Qty' ;
    rdfs:comment 'The maximum allowable inventory quantity for the SKU at this location. Replenishment orders are sized to bring stock up to but not exceed this level. Used in min/max replenishment strategies in Infor WMS.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderQty rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Qty' ;
    rdfs:comment 'The Minimum Order Quantity (MOQ) — the smallest quantity that can be ordered from a supplier or produced in a single replenishment run. Reflects supplier contract terms or production batch constraints.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderQuantityRounding rdf:type rdf:Property ;
    rdfs:label 'Order Quantity Rounding' ;
    rdfs:comment 'The rounding value applied to calculated replenishment quantities to align with supplier pack sizes, pallet quantities, or production batch increments. Ensures order quantities are practical multiples.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderingCostAmount rdf:type rdf:Property ;
    rdfs:label 'Ordering Cost Amount' ;
    rdfs:comment 'The fixed cost incurred each time a replenishment order is placed, including administrative, processing, and supplier transaction costs. Used as an input to Economic Order Quantity (EOQ) calculations.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDeliveryTimeDays rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Time Days' ;
    rdfs:comment 'The planned number of working days required for a supplier to deliver the material after purchase order creation. Distinct from total replenishment lead time as it excludes internal processing time.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'Business-facing alphanumeric code uniquely identifying the reorder policy, used for cross-system reference and reporting. Typically sourced from SAP MRP planning data or Infor WMS min/max configuration.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Descriptive name for the reorder policy, providing a human-readable label for reporting, dashboards, and business communication.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current operational status of the reorder policy. Active policies drive automated replenishment triggers. Inactive or suspended policies are excluded from MRP runs. Obsolete policies are retained for audit history.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPointQty rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Qty' ;
    rdfs:comment 'The Reorder Point (ROP) quantity — the inventory level at which a replenishment order is automatically triggered. When on-hand stock falls to or below this level, a procurement or production order is initiated.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Replenishment Lead Time Days' ;
    rdfs:comment 'The total number of calendar days from placement of a replenishment order to receipt of goods at the storage location. Includes supplier lead time, transit time, and goods receipt processing time. Used to calculate the reorder point.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewCycleDays rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Days' ;
    rdfs:comment 'The frequency in calendar days at which inventory levels are reviewed and replenishment decisions are made. Applicable to periodic review replenishment policies (P-system). A value of 0 indicates continuous review.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyStockQty rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Qty' ;
    rdfs:comment 'The minimum buffer stock quantity maintained to protect against demand variability and supply uncertainty. Represents the floor inventory level below which stock should not fall under normal operating conditions.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonalPolicyFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Policy Flag' ;
    rdfs:comment 'Indicates whether this reorder policy incorporates seasonal demand adjustments. When true, reorder point and safety stock parameters may vary by season or planning period.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceLevelTargetPct rdf:type rdf:Property ;
    rdfs:label 'Service Level Target Pct' ;
    rdfs:comment 'The target inventory service level expressed as a percentage (e.g., 95.00 = 95%). Represents the desired probability of fulfilling demand from available stock without a stockout. Used to statistically calculate safety stock requirements.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for each replenishment order record in the Infor WMS replenishment module. Serves as the primary key for the replenishment_order data product.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freightOrderId rdf:type rdf:Property ;
    rdfs:label 'Freight Order Id' ;
    rdfs:comment 'Foreign key linking to logistics.freight_order. Business justification: A replenishment order triggers a freight order to physically move stock from supplier to warehouse. Procurement and logistics teams use this link daily to track inbound shipment status against open re' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightOrder .

ind:inboundDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Inbound Delivery Id' ;
    rdfs:comment 'Foreign key linking to logistics.inbound_delivery. Business justification: Replenishment orders trigger inbound deliveries from suppliers or other warehouses. Inventory planning links replenishment to expected deliveries for stock availability forecasting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundDelivery .

ind:actualQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity' ;
    rdfs:comment 'The actual quantity of the SKU physically moved and confirmed at the destination location upon completion of the replenishment task. Used for variance analysis against requested and confirmed quantities.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Reason code explaining why the replenishment order was cancelled. Used for exception analysis, process improvement, and identifying systemic issues in replenishment triggering logic.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'The date and time when the replenishment order was cancelled, if applicable. Populated only for orders with status \'cancelled\'. Used for exception reporting and root cause analysis.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destinationLocationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Location Code' ;
    rdfs:comment 'Warehouse location code identifying the target location where replenished stock must be delivered (e.g., forward pick face, kanban lane, production staging area). Corresponds to the Infor WMS location master.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocationType rdf:type rdf:Property ;
    rdfs:label 'Destination Location Type' ;
    rdfs:comment 'Classification of the destination warehouse location to which stock is being moved. Supports analytics on replenishment demand by location type and operational zone.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationOnHandQuantity rdf:type rdf:Property ;
    rdfs:label 'Destination On Hand Quantity' ;
    rdfs:comment 'The on-hand stock quantity at the destination location at the time the replenishment order was created. Provides context for the replenishment trigger and supports inventory position reporting.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPartialAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Partial Allowed' ;
    rdfs:comment 'Indicates whether a partial fulfillment of the replenishment order is acceptable when the full requested quantity is not available at the source location. When false, the order must be fulfilled in full or held.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUrgent rdf:type rdf:Property ;
    rdfs:label 'Is Urgent' ;
    rdfs:comment 'Boolean flag indicating whether the replenishment order has been escalated as urgent, typically due to an imminent or active stockout at the destination pick location. Triggers expedited handling by warehouse supervisors.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kanbanCardNumber rdf:type rdf:Property ;
    rdfs:label 'Kanban Card Number' ;
    rdfs:comment 'The kanban card or signal identifier that triggered this replenishment order, applicable when trigger_type is \'kanban\'. Enables traceability between physical kanban signals and digital replenishment records.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensePlateNumber rdf:type rdf:Property ;
    rdfs:label 'License Plate Number' ;
    rdfs:comment 'The License Plate Number (LPN) or handling unit identifier associated with the stock being replenished. Used in Infor WMS for unit-level tracking of pallets, totes, or containers during replenishment movements.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxQuantity rdf:type rdf:Property ;
    rdfs:label 'Max Quantity' ;
    rdfs:comment 'The maximum stock level threshold at the destination location for min/max replenishment. The replenishment order quantity is typically calculated to bring stock up to this level.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minQuantity rdf:type rdf:Property ;
    rdfs:label 'Min Quantity' ;
    rdfs:comment 'The minimum stock level threshold at the destination location that triggered the replenishment order (applicable for min/max trigger type). When on-hand quantity falls below this level, a replenishment order is generated.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Business-facing alphanumeric identifier for the replenishment order, used for tracking and communication across warehouse operations teams. Formatted as REP-{YEAR}-{SEQUENCE}.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityScore rdf:type rdf:Property ;
    rdfs:label 'Priority Score' ;
    rdfs:comment 'Numeric priority score (1–100) assigned by the WMS to enable fine-grained sequencing of replenishment tasks when multiple orders share the same priority tier. Higher scores indicate greater urgency.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replenishmentMethod rdf:type rdf:Property ;
    rdfs:label 'Replenishment Method' ;
    rdfs:comment 'The inventory replenishment strategy applied to this order. Fixed quantity replenishes a set amount each time; fixed cycle replenishes on a schedule; two-bin and kanban are signal-driven; wave-pick is batch-driven by outbound order waves.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedQuantity rdf:type rdf:Property ;
    rdfs:label 'Requested Quantity' ;
    rdfs:comment 'The quantity of the SKU requested to be moved from the source location to the destination location as specified when the replenishment order was created.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Requested Timestamp' ;
    rdfs:comment 'The date and time when the replenishment order was created or triggered in the WMS. Serves as the start of the replenishment lifecycle and is used for lead time and aging analysis.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requiredByTimestamp rdf:type rdf:Property ;
    rdfs:label 'Required By Timestamp' ;
    rdfs:comment 'The date and time by which the replenishment must be completed to prevent a stockout at the destination pick location. Used for SLA compliance monitoring and escalation triggers.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceLocationType rdf:type rdf:Property ;
    rdfs:label 'Source Location Type' ;
    rdfs:comment 'Classification of the source warehouse location from which stock is being moved. Used for operational routing and analytics on replenishment flow patterns.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOnHandQuantity rdf:type rdf:Property ;
    rdfs:label 'Source On Hand Quantity' ;
    rdfs:comment 'The on-hand stock quantity available at the source location at the time the replenishment order was created. Used to assess feasibility of fulfilling the requested quantity and for inventory position analysis.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Started Timestamp' ;
    rdfs:comment 'The date and time when the warehouse operator began executing the replenishment task (first scan or task acceptance). Used to measure task execution time and operator productivity.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskNumber rdf:type rdf:Property ;
    rdfs:label 'Task Number' ;
    rdfs:comment 'The Infor WMS warehouse task identifier assigned to the physical replenishment movement instruction. Used by warehouse operators on handheld devices or voice-directed systems to execute the replenishment.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerType rdf:type rdf:Property ;
    rdfs:label 'Trigger Type' ;
    rdfs:comment 'Indicates the mechanism that initiated the replenishment order. Min/max triggers fire when stock falls below minimum threshold; kanban triggers are signal-card driven; manual orders are created by warehouse staff; demand-driven triggers are based on forecasted pick demand.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveNumber rdf:type rdf:Property ;
    rdfs:label 'Wave Number' ;
    rdfs:comment 'The outbound picking wave number associated with this replenishment order when triggered by a wave-pick process. Links replenishment activity to the outbound order fulfillment wave for operational coordination.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryValuationId rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Id' ;
    rdfs:comment 'Unique surrogate identifier for each inventory valuation record in the silver layer lakehouse. Serves as the primary key for the inventory_valuation data product.' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceListItemId rdf:type rdf:Property ;
    rdfs:label 'Price List Item Id' ;
    rdfs:comment 'Foreign key linking to product.price_list_item. Business justification: Inventory valuation references the authoritative price list item for standard cost or transfer price. Finance uses this to ensure valuation aligns with approved pricing, eliminating duplicated price d' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceListItem .

ind:supplierInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Supplier Invoice Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier_invoice. Business justification: Inventory valuation (especially for moving average or standard cost updates) is directly impacted by supplier invoice prices. Finance and inventory accounting teams link valuations to invoices to reco' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierInvoice .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'The base unit of measure in which the material stock quantity is managed and the valuation price is expressed (e.g., EA, KG, L, M, PC). Corresponds to SAP MARA.MEINS. Required for accurate stock value calculation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:class rdf:type rdf:Property ;
    rdfs:label 'Class' ;
    rdfs:comment 'SAP valuation class (BKLAS) that determines the general ledger accounts updated during inventory movements. Groups materials with similar accounting treatment (e.g., raw materials, finished goods, WIP, MRO). Critical for COGS and balance sheet posting.' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateNumber rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Number' ;
    rdfs:comment 'The SAP product cost estimate number (from CO-PC) that was used to calculate or release the current standard price. Links the inventory valuation to the underlying cost estimate for traceability and variance analysis. Corresponds to SAP KEKO.KALNR.' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The foreign exchange rate applied to translate the local currency inventory value to the group currency as of the valuation date. Used for multi-currency financial consolidation and reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:futurePlannedPrice rdf:type rdf:Property ;
    rdfs:label 'Future Planned Price' ;
    rdfs:comment 'The planned standard price for the next cost estimate or future period, staged for release. Corresponds to SAP MBEW.ZKPRS (future price field). Used in standard cost roll and cost estimate release planning.' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:futurePriceValidFromDate rdf:type rdf:Property ;
    rdfs:label 'Future Price Valid From Date' ;
    rdfs:comment 'The date from which the future planned price becomes effective. Used to schedule standard cost releases at the start of a new fiscal period or cost estimate period. Corresponds to SAP MBEW.ZKDAT.' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPriceChangeDate rdf:type rdf:Property ;
    rdfs:label 'Last Price Change Date' ;
    rdfs:comment 'The date on which the standard price or moving average price was last changed for this material at the valuation area. Corresponds to SAP MBEW.LAEPR. Used for price variance analysis, audit trails, and identifying stale standard costs.' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lowestValueDevaluationPct rdf:type rdf:Property ;
    rdfs:label 'Lowest Value Devaluation Pct' ;
    rdfs:comment 'The percentage devaluation applied to the inventory under the lowest value principle (LVP) for balance sheet reporting. Reflects write-downs for slow-moving, obsolete, or damaged stock. Corresponds to SAP MBEW.ABWKZ / devaluation indicator logic. Required for IFRS IAS 2 net realizable value (NRV) assessment.' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:method rdf:type rdf:Property ;
    rdfs:label 'Method' ;
    rdfs:comment 'The accounting valuation method applied to determine the cost of inventory. Standard Cost uses a predetermined cost; Moving Average Price recalculates with each receipt; FIFO (First-In First-Out) and LIFO (Last-In First-Out) are layer-based methods. Determines COGS and balance sheet inventory value.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movingAveragePrice rdf:type rdf:Property ;
    rdfs:label 'Moving Average Price' ;
    rdfs:comment 'The current weighted moving average cost per unit of measure, recalculated after each goods receipt or invoice verification when price control is \'V\'. Corresponds to SAP MBEW.VERPR. Reflects the most current average procurement cost.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRealizableValue rdf:type rdf:Property ;
    rdfs:label 'Net Realizable Value' ;
    rdfs:comment 'The estimated selling price of the inventory in the ordinary course of business less the estimated costs of completion and the estimated costs necessary to make the sale. Required under IFRS IAS 2 to test whether inventory should be written down below cost. Used for period-end impairment assessment.' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousStandardPrice rdf:type rdf:Property ;
    rdfs:label 'Previous Standard Price' ;
    rdfs:comment 'The standard price that was in effect before the most recent price change. Corresponds to SAP MBEW.ZKPRS. Used for price variance analysis, standard cost roll comparison, and audit of cost changes during period-end closing.' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceControlIndicator rdf:type rdf:Property ;
    rdfs:label 'Price Control Indicator' ;
    rdfs:comment 'Indicates the inventory valuation method applied to the material. \'S\' = Standard Price (fixed standard cost used for all movements); \'V\' = Moving Average Price (price recalculated with each goods receipt). Corresponds to SAP MBEW.VPRSV. Drives how inventory is valued on the balance sheet.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Timestamp' ;
    rdfs:comment 'The timestamp at which this inventory valuation record was extracted from the source system and loaded into the silver layer lakehouse. Used for data freshness tracking, incremental load processing, and audit trail.' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:snapshotType rdf:type rdf:Property ;
    rdfs:label 'Snapshot Type' ;
    rdfs:comment 'Indicates whether this valuation record was captured as part of a scheduled period-end closing, year-end closing, or an on-demand/ad-hoc valuation request. Used to distinguish official financial closing snapshots from operational queries.' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Stock Quantity' ;
    rdfs:comment 'The total quantity of valuated stock on hand for the material at the plant/valuation area as of the valuation date. Corresponds to SAP MBEW.LBKUM. Used to calculate total stock value (total_stock_quantity × price).' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalValueGroupCurrency rdf:type rdf:Property ;
    rdfs:label 'Total Value Group Currency' ;
    rdfs:comment 'The total inventory value translated into the group (corporate) reporting currency for consolidated financial statements. Supports multinational consolidation and group-level balance sheet reporting. Derived from local currency value using the applicable exchange rate.' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalValueLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Total Value Local Currency' ;
    rdfs:comment 'The total inventory value expressed in the local (company code) currency. Corresponds to SAP MBEW.SALK3 for standard price or the MAP-based value. Used for local statutory financial reporting and balance sheet preparation.' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipStockId rdf:type rdf:Property ;
    rdfs:label 'Wip Stock Id' ;
    rdfs:comment 'Unique surrogate identifier for each WIP stock record in the silver layer lakehouse. Serves as the primary key for the wip_stock data product.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WipStock .

ind:bopOperationId rdf:type rdf:Property ;
    rdfs:label 'Bop Operation Id' ;
    rdfs:comment 'Foreign key linking to engineering.bop_operation. Business justification: WIP stock is staged at a specific BOP operation step (e.g., \'after welding\', \'before painting\'). Production control uses this to locate WIP on the shop floor and calculate operation-level throughput a' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BopOperation .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'The date on which the production order was actually fully confirmed and all WIP was converted to finished goods or settled. Populated upon order completion; null while order is open.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Expected Completion Date' ;
    rdfs:comment 'The planned or revised expected date by which the production order is expected to be fully confirmed and WIP converted to finished goods. Critical for delivery commitment and ATP calculations.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Date' ;
    rdfs:comment 'The date on which raw materials or components were issued from inventory to the production order, initiating the WIP position. Corresponds to SAP goods issue posting date.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastConfirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Confirmation Timestamp' ;
    rdfs:comment 'The date and time of the most recent operation confirmation posted against the production order in SAP PP or Siemens Opcenter MES. Tracks real-time production progress.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:makeToStrategy rdf:type rdf:Property ;
    rdfs:label 'Make To Strategy' ;
    rdfs:comment 'Manufacturing strategy governing the production order: Make-To-Order (MTO), Make-To-Stock (MTS), Engineer-To-Order (ETO), or Assemble-To-Order (ATO). Determines how WIP is linked to customer demand.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpController rdf:type rdf:Property ;
    rdfs:label 'Mrp Controller' ;
    rdfs:comment 'The MRP controller code responsible for the material being produced. Used to assign WIP monitoring and exception management responsibilities to the correct planner.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationDescription rdf:type rdf:Property ;
    rdfs:label 'Operation Description' ;
    rdfs:comment 'Human-readable description of the routing operation step where WIP resides (e.g., \'Welding\', \'Assembly\', \'Painting\'). Supports shop floor reporting and WIP analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderQuantity rdf:type rdf:Property ;
    rdfs:label 'Order Quantity' ;
    rdfs:comment 'The total planned quantity of the production order. Used to calculate completion percentage and remaining WIP quantity against the original order target.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionOrderType rdf:type rdf:Property ;
    rdfs:label 'Production Order Type' ;
    rdfs:comment 'SAP order type classification indicating the nature of the production order (e.g., PP01 standard production, PP02 repetitive, PI01 process industry). Drives cost collection and settlement rules.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionScheduler rdf:type rdf:Property ;
    rdfs:label 'Production Scheduler' ;
    rdfs:comment 'The production scheduler or planner code responsible for managing the production order. Supports accountability tracking and workload distribution in production planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionStartDate rdf:type rdf:Property ;
    rdfs:label 'Production Start Date' ;
    rdfs:comment 'The scheduled or actual start date of the production order. Used for WIP aging analysis, lead time calculation, and production scheduling performance reporting.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scrapQuantity rdf:type rdf:Property ;
    rdfs:label 'Scrap Quantity' ;
    rdfs:comment 'Quantity of material scrapped during the production process at the current operation. Impacts WIP valuation and is used for scrap rate analysis and quality reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipValueGroupCurrency rdf:type rdf:Property ;
    rdfs:label 'Wip Value Group Currency' ;
    rdfs:comment 'The financial value of WIP inventory translated to the corporate group reporting currency. Supports consolidated financial reporting across multinational operations.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipValueLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Wip Value Local Currency' ;
    rdfs:comment 'The financial value of WIP inventory in the plant\'s local currency, calculated using SAP CO WIP calculation (actual or standard cost). Used for balance sheet reporting and inventory valuation.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarantineHoldId rdf:type rdf:Property ;
    rdfs:label 'Quarantine Hold Id' ;
    rdfs:comment 'Unique system-generated identifier for each quarantine or quality hold record in the inventory management system.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QuarantineHold .

ind:ecnId rdf:type rdf:Property ;
    rdfs:label 'Ecn Id' ;
    rdfs:comment 'Foreign key linking to engineering.ecn. Business justification: Quarantine holds are frequently triggered by or resolved through an Engineering Change Notice. Quality and engineering teams link the hold to the ECN that either caused the nonconformance or authorize' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ecn .

ind:regulatoryCertificationId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Certification Id' ;
    rdfs:comment 'Foreign key linking to product.product_regulatory_certification. Business justification: Quarantine holds are frequently triggered by regulatory certification failures or expirations. Linking to the certification record allows quality and compliance teams to track which specific certifica' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryCertification .

ind:actualReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Release Date' ;
    rdfs:comment 'Actual calendar date on which the quarantine hold was resolved and the inventory was released, scrapped, returned, or otherwise dispositioned.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizedByName rdf:type rdf:Property ;
    rdfs:label 'Authorized By Name' ;
    rdfs:comment 'Full name of the employee who authorized the disposition decision. Retained for audit trail and regulatory compliance reporting.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDecision rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision' ;
    rdfs:comment 'Final disposition decision made by the quality authority for the quarantined inventory. Drives downstream actions such as stock release, rework order creation, scrap posting, or vendor return.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionNotes rdf:type rdf:Property ;
    rdfs:label 'Disposition Notes' ;
    rdfs:comment 'Free-text notes documenting the rationale, conditions, or instructions associated with the disposition decision, including any deviations or special handling requirements.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Release Date' ;
    rdfs:comment 'Planned date by which the quarantine hold is expected to be resolved and the inventory released or dispositioned. Used for production planning, ATP calculations, and supply chain impact assessment.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdQuantity rdf:type rdf:Property ;
    rdfs:label 'Hold Quantity' ;
    rdfs:comment 'Quantity of the SKU/material placed under quarantine hold, expressed in the base unit of measure. Represents the total blocked stock quantity pending disposition.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdReason rdf:type rdf:Property ;
    rdfs:label 'Hold Reason' ;
    rdfs:comment 'Detailed narrative description of the specific reason the inventory was placed on hold, providing context beyond the hold type classification for quality investigation and reporting.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReasonCode rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Code' ;
    rdfs:comment 'Standardized short code representing the hold reason, used for categorization, reporting, and integration with SAP QM defect codes and Infor WMS hold reason configuration.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Hold Reference Number' ;
    rdfs:comment 'Business-facing alphanumeric reference number assigned to the quarantine hold, used for cross-system tracking and communication with quality, procurement, and operations teams.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdStartDate rdf:type rdf:Property ;
    rdfs:label 'Hold Start Date' ;
    rdfs:comment 'Calendar date on which the inventory was officially placed under quarantine hold. Used for aging analysis, SLA tracking, and regulatory compliance reporting.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Start Timestamp' ;
    rdfs:comment 'Precise date and time when the quarantine hold was initiated in the system, including timezone offset. Used for exact duration calculations and audit trail.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdType rdf:type rdf:Property ;
    rdfs:label 'Hold Type' ;
    rdfs:comment 'Classification of the quarantine hold indicating the primary reason category for blocking the stock. Drives the disposition workflow and responsible team assignment.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdValue rdf:type rdf:Property ;
    rdfs:label 'Hold Value' ;
    rdfs:comment 'Total financial value of the quarantined inventory (hold quantity × valuation price) in the local currency. Used for financial exposure reporting and management escalation thresholds.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initiatingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Initiating Document Number' ;
    rdfs:comment 'Reference number of the source document (NCR number, GRN number, complaint ID, etc.) that triggered the quarantine hold, enabling cross-document traceability.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatingDocumentType rdf:type rdf:Property ;
    rdfs:label 'Initiating Document Type' ;
    rdfs:comment 'Type of source document that triggered the quarantine hold (e.g., Non-Conformance Report, Goods Receipt Note, customer complaint). Establishes the business context and traceability chain.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Release Authorization Number' ;
    rdfs:comment 'Reference number of the formal authorization document approving the disposition decision and release of the quarantine hold. Required for regulated industries and audit compliance.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnToVendorQuantity rdf:type rdf:Property ;
    rdfs:label 'Return To Vendor Quantity' ;
    rdfs:comment 'Quantity of the held inventory to be returned to the originating supplier. Initiates the vendor return process in SAP MM and may trigger supplier corrective action.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reworkQuantity rdf:type rdf:Property ;
    rdfs:label 'Rework Quantity' ;
    rdfs:comment 'Quantity of the held inventory directed to rework operations to bring it into conformance with specifications. Triggers rework production order creation in SAP PP/MES.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scrappedQuantity rdf:type rdf:Property ;
    rdfs:label 'Scrapped Quantity' ;
    rdfs:comment 'Quantity of the held inventory that was dispositioned as scrap following inspection. Used for scrap rate reporting, COGS impact analysis, and waste tracking.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Number' ;
    rdfs:comment 'SAP vendor/supplier number associated with the quarantined material, applicable when the hold is related to incoming goods from a specific supplier. Enables supplier quality performance tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cadModelId rdf:type rdf:Property ;
    rdfs:label 'Cad Model Id' ;
    rdfs:comment 'Foreign key linking to engineering.cad_model. Business justification: High-value serialized units (e.g., automation modules, drives) are linked to the CAD model revision they were built to. Service engineers use this during field maintenance to retrieve the exact as-des' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CadModel .

ind:customerDeliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Delivery Number' ;
    rdfs:comment 'The SAP SD outbound delivery document number associated with the shipment of this serialized unit to a customer. Enables end-to-end traceability from inventory to customer delivery.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterial rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material' ;
    rdfs:comment 'Indicates whether this serialized unit is classified as a hazardous material requiring special handling, storage, or transportation procedures. Drives compliance with OSHA, EPA, and transport regulations.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inforWmsSerialCode rdf:type rdf:Property ;
    rdfs:label 'Infor Wms Serial Code' ;
    rdfs:comment 'The unique serial unit identifier assigned by the Infor WMS system for warehouse operations tracking. Used for reconciliation between SAP MM serial number records and Infor WMS operational data.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMovementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Movement Timestamp' ;
    rdfs:comment 'The precise date and time of the most recent inventory movement for this serialized unit. Provides sub-day precision for operational tracking, audit trails, and MES integration.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityInspectionLot rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Lot' ;
    rdfs:comment 'The SAP QM inspection lot number associated with this serialized unit if it is currently under quality inspection. Links the unit to its quality management workflow and usage decision.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiry Date' ;
    rdfs:comment 'The date on which the warranty for this serialized unit expires. Drives after-sales service eligibility checks, warranty claim processing, and customer service SLA management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adjustmentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Document Number' ;
    rdfs:comment 'SAP material document number generated when inventory variance adjustments are posted to the general ledger following the physical inventory count. Provides traceability from count to financial posting.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether the physical inventory variance adjustments require formal management approval before financial posting. Driven by variance value thresholds and internal controls policy.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countedSkuCount rdf:type rdf:Property ;
    rdfs:label 'Counted Sku Count' ;
    rdfs:comment 'Number of distinct SKUs that have been physically counted as of the current status. Enables tracking of count completion progress against total_sku_count.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'The SAP MM physical inventory document number that uniquely identifies the physical inventory event in the source ERP system. Aligns with SAP transaction MI01/MI04.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsMovementsBlocked rdf:type rdf:Property ;
    rdfs:label 'Goods Movements Blocked' ;
    rdfs:comment 'Indicates whether all goods movements (goods receipts, goods issues, transfers) are blocked in the system for the scope of this physical inventory to prevent stock changes during counting.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedCountDate rdf:type rdf:Property ;
    rdfs:label 'Planned Count Date' ;
    rdfs:comment 'The scheduled calendar date on which the physical inventory count is planned to be executed. Used for resource planning and production freeze scheduling.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionFreezeRequired rdf:type rdf:Property ;
    rdfs:label 'Production Freeze Required' ;
    rdfs:comment 'Indicates whether production activities in the plant or warehouse must be frozen (halted) during the physical inventory count to ensure accurate stock snapshot. Critical for wall-to-wall full counts.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recountSkuCount rdf:type rdf:Property ;
    rdfs:label 'Recount Sku Count' ;
    rdfs:comment 'Number of SKUs flagged for recount due to variances exceeding the tolerance threshold. Tracks the scope of the recount phase within the physical inventory event.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleEmployeeName rdf:type rdf:Property ;
    rdfs:label 'Responsible Employee Name' ;
    rdfs:comment 'Full name of the inventory controller or warehouse manager responsible for the physical inventory count event. Retained for reporting and audit trail purposes.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceSkuCount rdf:type rdf:Property ;
    rdfs:label 'Variance Sku Count' ;
    rdfs:comment 'Number of SKUs where the physically counted quantity differs from the book quantity beyond the defined tolerance threshold. Drives recount and adjustment decisions.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categoryId rdf:type rdf:Property ;
    rdfs:label 'Category Id' ;
    rdfs:comment 'Foreign key linking to product.category. Business justification: Engineering BOMs are classified by product category (e.g., automation module, electrification unit) to route them to the correct engineering team and apply category-specific design rules and complianc' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:plmLifecycleStateId rdf:type rdf:Property ;
    rdfs:label 'Plm Lifecycle State Id' ;
    rdfs:comment 'Foreign key linking to engineering.plm_lifecycle_state. Business justification: Engineering BOMs are PLM-managed objects that progress through formal lifecycle states (In Work, Under Review, Released, Obsolete, Superseded). Linking engineering_bom to plm_lifecycle_state provides ' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlmLifecycleState .

ind:alternativeBom rdf:type rdf:Property ;
    rdfs:label 'Alternative Bom' ;
    rdfs:comment 'SAP alternative BOM counter (01–99) that distinguishes multiple BOMs for the same material/plant combination, enabling variant or alternative production structures for the same finished good or sub-assembly.' ;
    rdfs:domain ind:EngineeringBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseQuantity rdf:type rdf:Property ;
    rdfs:label 'Base Quantity' ;
    rdfs:comment 'Reference quantity of the parent assembly for which all component quantities in the BOM are specified. Typically 1 unit but may be set to a batch size (e.g., 100 units) for process manufacturing or high-volume production to improve precision in component quantity calculations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeNumber rdf:type rdf:Property ;
    rdfs:label 'Change Number' ;
    rdfs:comment 'SAP Engineering Change Management (ECM) change number used to control time-phased BOM changes in SAP PP. Enables change-controlled BOM modifications where component additions, deletions, or quantity changes are governed by an approved change record.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentCount rdf:type rdf:Property ;
    rdfs:label 'Component Count' ;
    rdfs:comment 'Total number of direct child components (line items) defined in this BOM header. Provides a quick indicator of BOM complexity and is used for completeness validation during BOM release and change management reviews.' ;
    rdfs:domain ind:EngineeringBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costingRelevance rdf:type rdf:Property ;
    rdfs:label 'Costing Relevance' ;
    rdfs:comment 'Indicates whether this BOM is included in product cost calculations (standard cost estimate) in SAP CO-PC (Product Costing). When true, the BOM components and quantities are used to calculate the Cost of Goods Sold (COGS) and standard cost for the parent material.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engineeringResponsibility rdf:type rdf:Property ;
    rdfs:label 'Engineering Responsibility' ;
    rdfs:comment 'Name or identifier of the engineering team, department, or responsible engineer who owns this BOM. Used for change management routing, approval workflows, and accountability tracking in Siemens Teamcenter PLM.' ;
    rdfs:domain ind:EngineeringBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConfigurable rdf:type rdf:Property ;
    rdfs:label 'Is Configurable' ;
    rdfs:comment 'Indicates whether this BOM is a configurable/variant BOM (SAP variant configuration) that supports multiple product configurations from a single super-BOM. Relevant for Assemble-to-Order (ATO) and Engineer-to-Order (ETO) automation systems and electrification solutions.' ;
    rdfs:domain ind:EngineeringBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPhantomAssembly rdf:type rdf:Property ;
    rdfs:label 'Is Phantom Assembly' ;
    rdfs:comment 'Indicates whether this BOM represents a phantom assembly — a logical grouping of components that does not physically exist as a stocked sub-assembly. Phantom assemblies are exploded through in MRP and production orders, with their components planned directly at the parent level.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturingStrategy rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Strategy' ;
    rdfs:comment 'Manufacturing execution strategy associated with this BOM, indicating how the parent assembly is produced relative to customer demand. Drives MRP planning parameters, lead time calculations, and order management behavior in SAP PP and Siemens Opcenter MES.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Human-readable name of the parent product, finished good, or sub-assembly for which this BOM is defined. Sourced from the material master description in SAP MM or the item name in Siemens Teamcenter PLM.' ;
    rdfs:domain ind:EngineeringBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionVersion rdf:type rdf:Property ;
    rdfs:label 'Production Version' ;
    rdfs:comment 'SAP production version identifier linking this BOM to a specific routing/work center combination for a given plant. Enables multiple production methods (e.g., different lines or processes) for the same material, each with its own BOM and routing pairing.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceFlags rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flags' ;
    rdfs:comment 'Pipe-delimited set of regulatory compliance certifications applicable to the product defined by this BOM. Supports compliance reporting for RoHS (Restriction of Hazardous Substances), REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals), CE Marking, and UL (Underwriters Laboratories) certification requirements.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releasedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Released Timestamp' ;
    rdfs:comment 'Date and time when this BOM was formally released to production, making it available for use in MRP runs, production orders, and manufacturing execution in Siemens Opcenter MES. Distinct from approval timestamp — release may follow approval after additional validation steps.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:revisionLevel rdf:type rdf:Property ;
    rdfs:label 'Revision Level' ;
    rdfs:comment 'Engineering revision identifier (e.g., A, B, C, 01, 02) indicating the version of the BOM. Incremented upon each approved Engineering Change Notice (ECN) or Engineering Change Order (ECO) that modifies the product structure.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamcenterItemCode rdf:type rdf:Property ;
    rdfs:label 'Teamcenter Item Code' ;
    rdfs:comment 'Cross-reference identifier of the corresponding BOM or product structure item in Siemens Teamcenter PLM. Enables bidirectional traceability between the SAP PP BOM and the engineering BOM (eBOM) managed in Teamcenter for PLM/PDM alignment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomLineId rdf:type rdf:Property ;
    rdfs:label 'Bom Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual BOM line item record in the silver layer lakehouse. Serves as the primary key for the bom_line data product.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BomLine .

ind:alternativeItemGroup rdf:type rdf:Property ;
    rdfs:label 'Alternative Item Group' ;
    rdfs:comment 'Groups multiple BOM line items that are interchangeable alternatives for the same functional requirement. During MRP and production order creation, the system selects the preferred or available alternative based on priority and stock availability. Supports substitute component management and supply chain flexibility.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeItemPriority rdf:type rdf:Property ;
    rdfs:label 'Alternative Item Priority' ;
    rdfs:comment 'Numeric priority rank within an alternative item group, where lower numbers indicate higher preference (1 = first choice). Used by MRP and production planning to determine which substitute component to consume first when multiple alternatives are defined for the same functional position.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alternativeItemUsageProbability rdf:type rdf:Property ;
    rdfs:label 'Alternative Item Usage Probability' ;
    rdfs:comment 'The probability percentage (0–100) that this alternative component will be selected over other alternatives in the same group during production planning. Used by MRP to distribute planned requirements across alternative components proportionally, supporting multi-source procurement strategies.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomItemNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Item Number' ;
    rdfs:comment 'Sequential item number assigned to this BOM line within the parent BOM header, typically in increments of 10 (e.g., 0010, 0020). Used for ordering and referencing line items within the BOM structure in SAP PP.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomLevel rdf:type rdf:Property ;
    rdfs:label 'Bom Level' ;
    rdfs:comment 'The hierarchical depth level of this component within the multi-level BOM structure, where level 0 is the finished good, level 1 is the first-tier sub-assembly, and so on. Used for BOM explosion reporting, MRP low-level code assignment, and production scheduling sequencing.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bomUsage rdf:type rdf:Property ;
    rdfs:label 'Bom Usage' ;
    rdfs:comment 'Defines the business purpose for which this BOM is used, corresponding to SAP BOM usage keys (e.g., 1=Production, 2=Engineering/Design, 3=Universal, 4=Plant Maintenance, 5=Sales, 6=Costing). Determines which BOM is selected during MRP, costing, sales order processing, and maintenance planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentNumber rdf:type rdf:Property ;
    rdfs:label 'Component Number' ;
    rdfs:comment 'The manufacturer or internal part number of the child component as defined in the material master or PLM system. Used for procurement, inventory lookup, and cross-referencing with supplier catalogs and engineering drawings.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivityEndDate rdf:type rdf:Property ;
    rdfs:label 'Effectivity End Date' ;
    rdfs:comment 'The date after which this BOM line item is no longer valid for production planning and MRP explosion. Used to phase out obsolete components following an Engineering Change Notice (ECN) while maintaining historical BOM traceability for previously manufactured products.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivityStartDate rdf:type rdf:Property ;
    rdfs:label 'Effectivity Start Date' ;
    rdfs:comment 'The date from which this BOM line item becomes valid and active for use in production planning and MRP explosion. Supports date-effective BOM management for engineering change implementation, ensuring new component versions are introduced at the correct production date.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findNumber rdf:type rdf:Property ;
    rdfs:label 'Find Number' ;
    rdfs:comment 'Balloon or find number referencing the component\'s callout position on the engineering drawing or assembly diagram. Used by manufacturing engineers and quality inspectors to locate the component on the drawing during First Article Inspection (FAI) and assembly.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedQuantityIndicator rdf:type rdf:Property ;
    rdfs:label 'Fixed Quantity Indicator' ;
    rdfs:comment 'Indicates whether the component quantity on this BOM line is fixed regardless of the production order quantity (true) or variable and proportional to the order quantity (false). Fixed quantities are used for setup materials, tooling, or components consumed once per batch regardless of batch size.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBulkMaterial rdf:type rdf:Property ;
    rdfs:label 'Is Bulk Material' ;
    rdfs:comment 'Indicates whether this BOM line item is a bulk material (e.g., adhesives, lubricants, solder paste, wire) that is consumed in variable quantities and typically not individually issued to production orders. Bulk materials are often backflushed or managed via replenishment rather than discrete picking.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCoProduct rdf:type rdf:Property ;
    rdfs:label 'Is Co Product' ;
    rdfs:comment 'Indicates whether this BOM line item is a co-product or by-product produced alongside the primary output of the manufacturing process. Co-products have positive quantity and receive cost allocation; by-products may have negative cost impact. Relevant for process manufacturing and chemical/electrification solution production.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueLocation rdf:type rdf:Property ;
    rdfs:label 'Issue Location' ;
    rdfs:comment 'The warehouse storage location from which this component is issued to the production order or work order. Drives automatic goods issue (backflush) and pick list generation in SAP WM/WMS and Infor WMS for shop floor material replenishment.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationActivityNumber rdf:type rdf:Property ;
    rdfs:label 'Operation Activity Number' ;
    rdfs:comment 'The routing operation or activity number to which this BOM component is assigned for consumption. Links the component to the specific manufacturing step in the Bill of Process (BoP) where it is consumed, enabling accurate work-in-progress (WIP) tracking and operation-level material staging.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationLeadTimeOffset rdf:type rdf:Property ;
    rdfs:label 'Operation Lead Time Offset' ;
    rdfs:comment 'The number of days (positive or negative) by which the component requirement date is offset from the production order start date. Used in multi-level scheduling to stage component availability at the correct operation step, supporting JIT (Just-In-Time) material staging on the shop floor.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceDesignator rdf:type rdf:Property ;
    rdfs:label 'Reference Designator' ;
    rdfs:comment 'Alphanumeric label identifying the specific physical location(s) of a component on a printed circuit board (PCB) or assembly drawing (e.g., R1, C12, U5). Critical for electronics manufacturing, PCB assembly, and automated optical inspection (AOI) processes.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Scrap Factor Percent' ;
    rdfs:comment 'The anticipated scrap or yield loss percentage for this component during the manufacturing process, expressed as a percentage (e.g., 5.00 = 5%). MRP inflates the gross requirement by this factor to account for expected material loss, ensuring sufficient components are procured or issued to production orders.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyArea rdf:type rdf:Property ;
    rdfs:label 'Supply Area' ;
    rdfs:comment 'The production supply area or supermarket location on the shop floor where this component is staged for consumption at the work center. Supports Kanban and JIT (Just-In-Time) material flow management in Siemens Opcenter MES and SAP PP.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bopId rdf:type rdf:Property ;
    rdfs:label 'Bop Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying a Bill of Process header record in the Databricks Silver Layer. Serves as the primary key for all downstream joins and lineage tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bop .

ind:ecoId rdf:type rdf:Property ;
    rdfs:label 'Eco Id' ;
    rdfs:comment 'Foreign key linking to engineering.eco. Business justification: bop.eco_reference is a STRING reference to the ECO that authorized the routing implementation. Replacing with FK eco_id → eco.eco_id enforces referential integrity. eco_reference is redundant once the' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Eco .

ind:cycleTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Seconds' ;
    rdfs:comment 'Total elapsed time to complete one full execution of the Bill of Process from first operation start to last operation completion, expressed in seconds. Used for capacity planning, OEE calculation, and production scheduling in Siemens Opcenter MES and SAP PP.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalClassification rdf:type rdf:Property ;
    rdfs:label 'Environmental Classification' ;
    rdfs:comment 'Environmental impact classification of the manufacturing process, indicating whether it generates waste, emissions, requires chemical handling, or is energy-intensive. Supports ISO 14001 environmental management compliance and EPA reporting obligations.' ;
    rdfs:domain ind:Bop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finishedProductNumber rdf:type rdf:Property ;
    rdfs:label 'Finished Product Number' ;
    rdfs:comment 'SAP material number or PLM part number of the finished assembly or sub-assembly produced by this Bill of Process. Provides direct linkage to the product master in SAP MM/PP and Siemens Teamcenter for production planning and scheduling.' ;
    rdfs:domain ind:Bop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConcurrentOperationsAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Concurrent Operations Allowed' ;
    rdfs:comment 'Flag indicating whether operations within this Bill of Process may be executed in parallel (concurrently) rather than strictly sequentially. Enables parallel scheduling in Siemens Opcenter MES and SAP PP finite scheduling.' ;
    rdfs:domain ind:Bop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPreferredRouting rdf:type rdf:Property ;
    rdfs:label 'Is Preferred Routing' ;
    rdfs:comment 'Flag indicating whether this Bill of Process is the preferred (primary) routing for the associated finished or semi-finished product. When true, this BoP is selected by default during production order creation in SAP PP unless overridden.' ;
    rdfs:domain ind:Bop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotSizeMax rdf:type rdf:Property ;
    rdfs:label 'Lot Size Max' ;
    rdfs:comment 'Maximum production quantity for which this Bill of Process is valid. Production orders exceeding this quantity may require splitting or use of an alternate routing. Used in SAP PP lot-size-dependent scheduling.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSizeMin rdf:type rdf:Property ;
    rdfs:label 'Lot Size Min' ;
    rdfs:comment 'Minimum production quantity for which this Bill of Process is valid. Production orders below this quantity may require a different routing or process variant. Used in SAP PP lot-size-dependent scheduling and MRP planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processClassification rdf:type rdf:Property ;
    rdfs:label 'Process Classification' ;
    rdfs:comment 'Classification of the manufacturing process type: discrete (individual units), process (batch/continuous), repetitive (high-volume standard), project (one-off), or continuous. Determines scheduling and execution methodology in SAP PP and Siemens Opcenter MES.' ;
    rdfs:domain ind:Bop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processType rdf:type rdf:Property ;
    rdfs:label 'Process Type' ;
    rdfs:comment 'Classification of the BoP indicating whether it represents the standard production process, an alternate routing, a rework process, a prototype build, or a pilot run. Drives routing selection logic in SAP PP and Siemens Opcenter MES.' ;
    rdfs:domain ind:Bop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productFamily rdf:type rdf:Property ;
    rdfs:label 'Product Family' ;
    rdfs:comment 'Product family or product line classification to which the finished assembly produced by this BoP belongs (e.g., \'Drive Systems\', \'Switchgear\', \'Automation Controllers\'). Supports aggregate production planning and portfolio-level reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionPlanNumber rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Plan Number' ;
    rdfs:comment 'Reference to the SAP QM inspection plan or Siemens Opcenter quality plan associated with this Bill of Process. Links the process structure to mandatory quality checkpoints, AQL sampling plans, and SPC control points required by the QMS.' ;
    rdfs:domain ind:Bop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyClassification rdf:type rdf:Property ;
    rdfs:label 'Safety Classification' ;
    rdfs:comment 'Safety classification of the manufacturing process defined by this BoP, indicating special handling, access control, or environmental requirements (e.g., hazardous materials, ESD-sensitive components, cleanroom conditions). Supports OSHA and ISO 45001 compliance.' ;
    rdfs:domain ind:Bop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taktTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Takt Time Seconds' ;
    rdfs:comment 'The available production time divided by customer demand rate, expressed in seconds. Defines the required pace of production for this process to meet customer demand. A fundamental Lean Manufacturing metric used in line balancing and capacity planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOperationCount rdf:type rdf:Property ;
    rdfs:label 'Total Operation Count' ;
    rdfs:comment 'Total number of manufacturing operations (process steps) defined within this Bill of Process. Provides a quick structural indicator of process complexity and is used in MES work order generation and shop floor documentation.' ;
    rdfs:domain ind:Bop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Work Center Category' ;
    rdfs:comment 'Category of the primary work center type associated with this Bill of Process, indicating the dominant manufacturing technology or process family. Used for capacity planning aggregation and shop floor routing in SAP PP and Siemens Opcenter MES.' ;
    rdfs:domain ind:Bop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Base Quantity Unit' ;
    rdfs:comment 'Unit of measure for the base quantity (e.g., EA for each, PC for pieces, KG for kilograms). Aligns with SAP unit of measure configuration and ISO 80000 measurement standards.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecnReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Ecn Reference Number' ;
    rdfs:comment 'Reference number of the Engineering Change Notice (ECN) or Engineering Change Order (ECO) that introduced or last modified this operation. Provides full traceability of process changes to engineering change management records.' ;
    rdfs:domain ind:BopOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalProcessingPrice rdf:type rdf:Property ;
    rdfs:label 'External Processing Price' ;
    rdfs:comment 'Standard price per unit for externally processed operations performed by a subcontractor. Used in product costing and purchase order creation for subcontracting. Corresponds to SAP PP PEINH/PREIS fields.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardousMaterialRelevant rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Relevant' ;
    rdfs:comment 'Flag indicating whether this operation involves handling of hazardous materials, chemicals, or substances subject to REACH, RoHS, or OSHA regulations. Triggers mandatory safety documentation and PPE requirements on the shop floor.' ;
    rdfs:domain ind:BopOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionCharacteristicGroup rdf:type rdf:Property ;
    rdfs:label 'Inspection Characteristic Group' ;
    rdfs:comment 'Code or identifier of the inspection characteristic group (master inspection characteristic catalog) assigned to this operation for in-process quality control. Defines the measurement parameters and tolerances to be checked.' ;
    rdfs:domain ind:BopOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRelevant rdf:type rdf:Property ;
    rdfs:label 'Inspection Relevant' ;
    rdfs:comment 'Flag indicating whether this operation requires a quality inspection step (in-process inspection). When true, inspection characteristics and AQL (Acceptable Quality Level) parameters must be defined for this operation.' ;
    rdfs:domain ind:BopOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interoperationTimeMin rdf:type rdf:Property ;
    rdfs:label 'Interoperation Time Min' ;
    rdfs:comment 'Standard wait and move time in minutes between this operation and the next operation in the routing. Includes queue time, move time, and wait time. Used in lead time calculation and scheduling. Corresponds to SAP PP interoperation times.' ;
    rdfs:domain ind:BopOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborTimeMin rdf:type rdf:Property ;
    rdfs:label 'Labor Time Min' ;
    rdfs:comment 'Standard labor time in minutes per base quantity unit required for this operation. Used for workforce planning, labor cost calculation, and takt time analysis. Corresponds to SAP PP ARBZE field.' ;
    rdfs:domain ind:BopOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:machineTimeMin rdf:type rdf:Property ;
    rdfs:label 'Machine Time Min' ;
    rdfs:comment 'Standard machine processing time in minutes per base quantity unit for this operation. Used for capacity planning, OEE (Overall Equipment Effectiveness) calculation, and production scheduling. Corresponds to SAP PP BEAZE field.' ;
    rdfs:domain ind:BopOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ncProgramNumber rdf:type rdf:Property ;
    rdfs:label 'Nc Program Number' ;
    rdfs:comment 'Identifier of the CNC (Computer Numerical Control) or NC program used to execute this operation on automated machinery. Links to the CAM (Computer-Aided Manufacturing) system for program retrieval.' ;
    rdfs:domain ind:BopOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfResources rdf:type rdf:Property ;
    rdfs:label 'Number Of Resources' ;
    rdfs:comment 'Number of parallel machines or labor resources required to execute this operation simultaneously. Used for capacity planning and scheduling. Corresponds to SAP PP ANZZL field.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:setupTimeMin rdf:type rdf:Property ;
    rdfs:label 'Setup Time Min' ;
    rdfs:comment 'Standard setup time in minutes required to prepare the work center for this operation, including tooling changeover and machine configuration. Used in capacity planning, scheduling, and SMED (Single-Minute Exchange of Dies) analysis. Corresponds to SAP PP RUSTE field.' ;
    rdfs:domain ind:BopOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sopReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sop Reference Number' ;
    rdfs:comment 'Document number or identifier of the Standard Operating Procedure (SOP) governing the execution of this operation. Links to the document management system for shop floor instruction retrieval.' ;
    rdfs:domain ind:BopOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCostActivityType rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Activity Type' ;
    rdfs:comment 'SAP CO activity type code used to assign standard costs to this operation (e.g., machine hours, labor hours). Links the operation to cost center accounting and product costing. Corresponds to SAP CO LSTAR field.' ;
    rdfs:domain ind:BopOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractingVendorCode rdf:type rdf:Property ;
    rdfs:label 'Subcontracting Vendor Code' ;
    rdfs:comment 'Vendor or supplier code for externally processed operations where the operation is performed by a subcontractor. Applicable when operation_type is \'external\' or \'subcontracting\'. Corresponds to SAP PP external processing vendor.' ;
    rdfs:domain ind:BopOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teardownTimeMin rdf:type rdf:Property ;
    rdfs:label 'Teardown Time Min' ;
    rdfs:comment 'Standard teardown or post-processing time in minutes required after the operation is completed, including cleaning, tool removal, and work center reset. Corresponds to SAP PP ABRUE field.' ;
    rdfs:domain ind:BopOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toolingListReference rdf:type rdf:Property ;
    rdfs:label 'Tooling List Reference' ;
    rdfs:comment 'Reference identifier for the tooling list or production resource/tool (PRT) assignment associated with this operation. Specifies jigs, fixtures, cutting tools, and gauges required. Corresponds to SAP PP PRT assignment.' ;
    rdfs:domain ind:BopOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterName rdf:type rdf:Property ;
    rdfs:label 'Work Center Name' ;
    rdfs:comment 'Human-readable name of the work center where the operation is executed (e.g., \'CNC Cell 3\', \'Welding Station A\', \'Final Assembly Line 2\'). Supports shop floor reporting and scheduling.' ;
    rdfs:domain ind:BopOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boundingBoxXMm rdf:type rdf:Property ;
    rdfs:label 'Bounding Box X Mm' ;
    rdfs:comment 'Maximum extent of the CAD model geometry along the X-axis in millimeters, representing the width of the component\'s bounding envelope. Used for packaging analysis, fixture design, and logistics planning (e.g., pallet/container sizing).' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boundingBoxYMm rdf:type rdf:Property ;
    rdfs:label 'Bounding Box Y Mm' ;
    rdfs:comment 'Maximum extent of the CAD model geometry along the Y-axis in millimeters, representing the depth of the component\'s bounding envelope. Used for packaging analysis, fixture design, and logistics planning.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boundingBoxZMm rdf:type rdf:Property ;
    rdfs:label 'Bounding Box Z Mm' ;
    rdfs:comment 'Maximum extent of the CAD model geometry along the Z-axis in millimeters, representing the height of the component\'s bounding envelope. Used for packaging analysis, fixture design, and logistics planning.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cadTool rdf:type rdf:Property ;
    rdfs:label 'Cad Tool' ;
    rdfs:comment 'Name of the CAD/CAM software application used to create and maintain the model (e.g., Siemens NX, CATIA V5/V6, SolidWorks). Determines file format compatibility, interoperability requirements, and licensing needs for downstream engineering and manufacturing processes.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cadToolVersion rdf:type rdf:Property ;
    rdfs:label 'Cad Tool Version' ;
    rdfs:comment 'Version or release number of the CAD/CAM software used to create or last modify the model (e.g., \'NX 2206\', \'CATIA V5 R31\'). Critical for file compatibility management, migration planning, and ensuring models can be opened by the correct software version in the engineering environment.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkedOutBy rdf:type rdf:Property ;
    rdfs:label 'Checked Out By' ;
    rdfs:comment 'Username or employee ID of the engineer who currently has the CAD model checked out for editing in the PLM/PDM system. A checked-out model is locked for exclusive editing. Null if the model is not currently checked out. Corresponds to Teamcenter \'Checked Out By\'.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkoutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Checkout Timestamp' ;
    rdfs:comment 'Date and time when the CAD model was checked out from the PLM/PDM vault for editing. Used to track concurrent engineering activities, identify long-running checkouts that may block other engineers, and support audit trails.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:coordinateSystem rdf:type rdf:Property ;
    rdfs:label 'Coordinate System' ;
    rdfs:comment 'Type of coordinate system used to define the geometry of the CAD model (e.g., Cartesian, Cylindrical). Ensures correct spatial orientation when integrating models into assemblies, simulation environments, or digital twin platforms.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designOwner rdf:type rdf:Property ;
    rdfs:label 'Design Owner' ;
    rdfs:comment 'Name or employee identifier of the responsible design engineer who owns and maintains the CAD model. Accountable for model accuracy, revision control, and release approvals. Corresponds to the Teamcenter \'Owning User\' field.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dfaStatus rdf:type rdf:Property ;
    rdfs:label 'Dfa Status' ;
    rdfs:comment 'Current status of the Design for Assembly (DFA) analysis for this CAD model. Evaluates the ease of assembly, part count reduction opportunities, and assembly process compatibility. Relevant for assembly-type models and sub-assemblies.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dfmStatus rdf:type rdf:Property ;
    rdfs:label 'Dfm Status' ;
    rdfs:comment 'Current status of the Design for Manufacturability (DFM) analysis for this CAD model. Indicates whether the design has been reviewed for manufacturing feasibility, cost optimization, and process compatibility. A \'passed\' status is typically required before release to production.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalTwinReference rdf:type rdf:Property ;
    rdfs:label 'Digital Twin Reference' ;
    rdfs:comment 'Identifier linking this CAD model to its corresponding digital twin instance on the Siemens MindSphere IIoT platform. Enables real-time correlation between the design geometry and operational asset behavior for predictive maintenance and performance optimization.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportControlClass rdf:type rdf:Property ;
    rdfs:label 'Export Control Class' ;
    rdfs:comment 'Export control classification code assigned to the CAD model, indicating whether the design data is subject to export regulations (e.g., ITAR USML category, EAR ECCN code, or \'EAR99\' for unrestricted). Critical for controlling access to design data shared with international suppliers or subsidiaries.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'Native or neutral file format of the CAD model dataset (e.g., STEP, IGES, JT, NX native). Determines interoperability with downstream systems including CAM, FEA simulation, and supplier collaboration. STEP (ISO 10303) is the preferred neutral exchange format for cross-system sharing.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'Full file name of the CAD model dataset as stored in the PLM/PDM vault, including file extension (e.g., \'motor_housing_v2.prt\', \'drive_shaft_asm.CATProduct\'). Used for file retrieval, version tracking, and integration with CAM and simulation tools.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeMb rdf:type rdf:Property ;
    rdfs:label 'File Size Mb' ;
    rdfs:comment 'Size of the CAD model file in megabytes as stored in the PLM vault. Used for storage capacity planning, data migration scoping, and identifying oversized models that may impact system performance or collaboration efficiency.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freezeDate rdf:type rdf:Property ;
    rdfs:label 'Freeze Date' ;
    rdfs:comment 'Date on which the CAD model was frozen, preventing further modifications. Typically aligned with production launch milestones (e.g., PPAP approval, SOP - Start of Production). A frozen model can only be changed via a formal ECO process.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isMasterModel rdf:type rdf:Property ;
    rdfs:label 'Is Master Model' ;
    rdfs:comment 'Boolean flag indicating whether this CAD model is designated as the master geometry model for the component or assembly. The master model is the authoritative source for all downstream derivations (drawings, simulations, CAM programs). Only one master model should exist per component revision.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:massKg rdf:type rdf:Property ;
    rdfs:label 'Mass Kg' ;
    rdfs:comment 'Calculated mass of the component or assembly as derived from the CAD model geometry and assigned material properties, expressed in kilograms. Used for structural analysis, logistics weight calculations, BOM costing, and compliance with weight-sensitive design requirements.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelName rdf:type rdf:Property ;
    rdfs:label 'Model Name' ;
    rdfs:comment 'Human-readable descriptive name of the CAD/CAM model as defined by the design engineer. Typically reflects the component or assembly name (e.g., \'Motor Housing Assembly\', \'Drive Shaft Bracket\'). Corresponds to Teamcenter Item Name.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelType rdf:type rdf:Property ;
    rdfs:label 'Model Type' ;
    rdfs:comment 'Classification of the CAD model by its geometric or representational type. Determines the applicable CAD tools, downstream processes (e.g., CAM toolpath generation, FEA simulation), and BOM linkage. \'3d_solid\' is the primary type for CNC machining and DFM analysis.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obsolescenceDate rdf:type rdf:Property ;
    rdfs:label 'Obsolescence Date' ;
    rdfs:comment 'Date on which the CAD model revision was marked as obsolete, indicating it has been superseded by a newer revision or the component has been discontinued. Used for lifecycle management, archive planning, and BOM cleanup.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:owningGroup rdf:type rdf:Property ;
    rdfs:label 'Owning Group' ;
    rdfs:comment 'Name of the engineering team, department, or organizational group responsible for the CAD model (e.g., \'Mechanical Design\', \'Electrical Engineering\', \'Automation Systems\'). Used for workload distribution, access control, and organizational reporting in PLM.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryMaterial rdf:type rdf:Property ;
    rdfs:label 'Primary Material' ;
    rdfs:comment 'Name or code of the primary engineering material assigned to the CAD model (e.g., \'Aluminum 6061-T6\', \'Stainless Steel 316L\', \'ABS Plastic\'). Drives material requirements planning (MRP), cost estimation, and compliance checks for REACH/RoHS regulations.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLine rdf:type rdf:Property ;
    rdfs:label 'Product Line' ;
    rdfs:comment 'Name of the product line or product family to which the designed component or assembly belongs (e.g., \'Automation Systems\', \'Electrification Solutions\', \'Smart Infrastructure\'). Supports portfolio-level reporting and PLM product structure navigation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Alphanumeric code identifying the engineering project or program under which the CAD model was created. Links the model to project planning, resource allocation, and CAPEX tracking in SAP PS (Project System). Supports APQP phase tracking.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date on which the CAD model revision was formally released (approved and promoted to \'released\' lifecycle state) in the PLM system. Marks the point at which the design is authorized for use in manufacturing, procurement, and BOM structures.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surfaceFinish rdf:type rdf:Property ;
    rdfs:label 'Surface Finish' ;
    rdfs:comment 'Required surface finish or roughness specification for the component as defined in the CAD model (e.g., \'Ra 1.6 µm\', \'Anodized\', \'Powder Coated\'). Drives manufacturing process selection, quality inspection criteria, and supplier specifications.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceClass rdf:type rdf:Property ;
    rdfs:label 'Tolerance Class' ;
    rdfs:comment 'General tolerance class applied to the CAD model for dimensions not individually toleranced (e.g., Fine, Medium, Coarse per ISO 2768). Determines manufacturing precision requirements, process selection, and inspection rigor. Critical for DFM analysis.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawingId rdf:type rdf:Property ;
    rdfs:label 'Drawing Id' ;
    rdfs:comment 'Unique surrogate identifier for each engineering drawing record in the lakehouse silver layer. Serves as the primary key for all downstream joins and lineage tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Drawing .

ind:assemblyLevel rdf:type rdf:Property ;
    rdfs:label 'Assembly Level' ;
    rdfs:comment 'Position of the depicted item within the product structure hierarchy. Indicates whether the drawing represents a top-level assembly, sub-assembly, individual component, or purchased part.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cadFormat rdf:type rdf:Property ;
    rdfs:label 'Cad Format' ;
    rdfs:comment 'Native or exchange file format of the CAD model or drawing file (e.g., Siemens NX, CATIA, STEP, PDF). Determines software compatibility for viewing, editing, and downstream manufacturing use.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkedBy rdf:type rdf:Property ;
    rdfs:label 'Checked By' ;
    rdfs:comment 'Name or employee identifier of the engineer who performed the technical check/peer review of the drawing. Part of the mandatory drawing approval workflow per quality management standards.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Information security classification of the drawing content. Controls access permissions, distribution rights, and handling requirements for the drawing across internal teams, suppliers, and customers.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Calendar date on which the drawing was originally created in the PLM system. Used for drawing age analysis, audit trails, and compliance with document retention policies.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drawnBy rdf:type rdf:Property ;
    rdfs:label 'Drawn By' ;
    rdfs:comment 'Name or employee identifier of the engineer or drafter who created the drawing. Captured in the drawing title block for accountability and traceability per engineering documentation standards.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isControlledDocument rdf:type rdf:Property ;
    rdfs:label 'Is Controlled Document' ;
    rdfs:comment 'Indicates whether the drawing is a controlled document subject to formal change management, revision control, and distribution tracking per the quality management system. Controlled drawings require ECN authorization for any modification.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Date on which the drawing record was most recently updated in the PLM system. Supports change tracking, audit compliance, and identification of recently revised drawings.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialSpecification rdf:type rdf:Property ;
    rdfs:label 'Material Specification' ;
    rdfs:comment 'Primary material specification or standard called out on the drawing (e.g., ASTM A36, DIN EN 10025, AL6061-T6). Drives material procurement, supplier qualification, and incoming inspection requirements.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingDepartment rdf:type rdf:Property ;
    rdfs:label 'Originating Department' ;
    rdfs:comment 'Engineering department or design team responsible for creating and owning the drawing (e.g., Mechanical Engineering, Electrical Engineering, Systems Engineering). Supports ownership accountability and routing.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paperSize rdf:type rdf:Property ;
    rdfs:label 'Paper Size' ;
    rdfs:comment 'Standard paper or sheet size designation for the drawing (ISO A-series or ANSI letter sizes). Governs print and reproduction specifications for physical drawing distribution.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectionMethod rdf:type rdf:Property ;
    rdfs:label 'Projection Method' ;
    rdfs:comment 'Orthographic projection convention used in the drawing (first-angle per ISO/European practice or third-angle per ANSI/US practice). Critical for correct interpretation of multi-view drawings across global manufacturing sites.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scale rdf:type rdf:Property ;
    rdfs:label 'Scale' ;
    rdfs:comment 'Nominal drawing scale expressed as a ratio (e.g., 1:1, 1:2, 2:1, NTS for Not to Scale). Defines the proportional relationship between the drawn representation and the actual object dimensions.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sheetCount rdf:type rdf:Property ;
    rdfs:label 'Sheet Count' ;
    rdfs:comment 'Total number of sheets comprising the complete engineering drawing package. Used for document completeness verification during review, approval, and distribution.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sheetNumber rdf:type rdf:Property ;
    rdfs:label 'Sheet Number' ;
    rdfs:comment 'Identifies the specific sheet within a multi-sheet drawing set (e.g., sheet 1 of 5). Enables precise reference to individual drawing sheets during manufacturing and inspection.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByDrawingNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded By Drawing Number' ;
    rdfs:comment 'Drawing number of the newer drawing that replaces this drawing when it is obsolete or superseded. Enables forward navigation through the drawing revision history for configuration management.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceStandard rdf:type rdf:Property ;
    rdfs:label 'Tolerance Standard' ;
    rdfs:comment 'Governing dimensional and geometric tolerance standard applied to the drawing. Ensures consistent interpretation of tolerances by manufacturing, quality, and supplier teams.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualImplementationCost rdf:type rdf:Property ;
    rdfs:label 'Actual Implementation Cost' ;
    rdfs:comment 'Actual total cost incurred to implement the engineering change upon completion. Compared against estimated_implementation_cost for variance analysis, budget control, and continuous improvement of change cost estimation accuracy.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedItemDescription rdf:type rdf:Property ;
    rdfs:label 'Affected Item Description' ;
    rdfs:comment 'Human-readable description of the primary affected component, assembly, drawing, or process document. Provides context for reviewers and approvers without requiring a PLM system lookup.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedItemNumber rdf:type rdf:Property ;
    rdfs:label 'Affected Item Number' ;
    rdfs:comment 'Primary part number, assembly number, drawing number, or BOM node identifier that is the subject of the engineering change. Represents the main item being modified. Links to the PLM/PDM product structure in Teamcenter.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedItemType rdf:type rdf:Property ;
    rdfs:label 'Affected Item Type' ;
    rdfs:comment 'Classification of the primary item being changed: component (individual part), assembly/sub_assembly (multi-part structure), drawing (2D/3D technical drawing), bom (Bill of Materials structure), process (manufacturing process/BoP), document (SOP, specification), software (firmware/embedded code), or tooling (jigs, fixtures, dies).' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomRevisionFrom rdf:type rdf:Property ;
    rdfs:label 'Bom Revision From' ;
    rdfs:comment 'The current BOM or drawing revision level that is being superseded by this engineering change. Enables before/after comparison and revision history tracking in Teamcenter PLM.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomRevisionTo rdf:type rdf:Property ;
    rdfs:label 'Bom Revision To' ;
    rdfs:comment 'The new BOM or drawing revision level that will be established upon implementation of this engineering change. Defines the target state of the product structure post-change.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Classification of the engineering change by its primary nature: design (geometry, tolerances, CAD), process (manufacturing method, BoP), material (raw material substitution), regulatory (compliance-driven), software (firmware/embedded), documentation (drawing/SOP update), or safety (hazard mitigation). Drives routing and approval authority.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Required' ;
    rdfs:comment 'Indicates whether the engineering change requires formal notification to customers per contractual obligations or regulatory requirements. When true, triggers customer communication workflow in Salesforce CRM and may require customer approval before implementation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionOfExistingStock rdf:type rdf:Property ;
    rdfs:label 'Disposition Of Existing Stock' ;
    rdfs:comment 'Decision on how to handle existing inventory of the affected component or assembly after the engineering change is implemented. Drives warehouse and inventory management actions in Infor WMS and SAP S/4HANA WM to prevent use of obsolete parts.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecoReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Eco Reference Number' ;
    rdfs:comment 'Reference number of the Engineering Change Order (ECO) issued to authorize and execute the physical implementation of this ECN. The ECO is the downstream execution document that follows ECN approval in the change management workflow.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivityType rdf:type rdf:Property ;
    rdfs:label 'Effectivity Type' ;
    rdfs:comment 'Method by which the engineering change becomes effective in production: date_effectivity (change applies from a specific date), serial_number_effectivity (change applies from a specific serial number), lot_effectivity (change applies from a specific production lot), or unit_effectivity (change applies to specific unit numbers). Critical for production control and spare parts management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivityValue rdf:type rdf:Property ;
    rdfs:label 'Effectivity Value' ;
    rdfs:comment 'The specific value defining when the change becomes effective, interpreted according to effectivity_type. For date_effectivity, this is a date string; for serial_number_effectivity, this is the first serial number; for lot_effectivity, this is the lot number. Enables precise production cutover control.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedImplementationCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Implementation Cost' ;
    rdfs:comment 'Estimated total cost to implement the engineering change, including engineering labor, tooling modifications, material write-offs, qualification testing, and production line changeover. Used for change prioritization, CAPEX/OPEX planning, and ROI analysis.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementationDateActual rdf:type rdf:Property ;
    rdfs:label 'Implementation Date Actual' ;
    rdfs:comment 'Date on which the engineering change was fully implemented and the new revision became effective in production. Used for on-time delivery measurement, change cycle time analytics, and regulatory compliance records.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationDatePlanned rdf:type rdf:Property ;
    rdfs:label 'Implementation Date Planned' ;
    rdfs:comment 'Target date by which the engineering change is planned to be fully implemented in production. Used for production planning, material procurement scheduling in SAP MRP, and milestone tracking.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiatorName rdf:type rdf:Property ;
    rdfs:label 'Initiator Name' ;
    rdfs:comment 'Full name of the engineer or technical staff member who initiated the Engineering Change Notice. Retained for display in reports and approval documents where the employee ID alone is insufficient for human-readable audit trails.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningDepartment rdf:type rdf:Property ;
    rdfs:label 'Owning Department' ;
    rdfs:comment 'Organizational department responsible for the engineering change, such as Product Engineering, R&D, Manufacturing Engineering, or Quality. Used for workload distribution, cost allocation, and departmental KPI reporting.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceImpact rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Impact' ;
    rdfs:comment 'Indicates whether the engineering change affects the product\'s compliance status with applicable regulations such as RoHS, REACH, CE Marking, UL certification, or IEC standards. When true, triggers compliance re-evaluation and potential re-certification activities.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Free-text explanation provided by the reviewer or approver when an ECN is rejected. Documents the specific technical, commercial, or compliance reasons for rejection to guide the initiator in revising and resubmitting the change request.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresDfmeaUpdate rdf:type rdf:Property ;
    rdfs:label 'Requires Dfmea Update' ;
    rdfs:comment 'Indicates whether the engineering change necessitates an update to the Design Failure Mode and Effects Analysis (DFMEA) document. Ensures risk assessment documentation remains current and aligned with the changed design.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresPfmeaUpdate rdf:type rdf:Property ;
    rdfs:label 'Requires Pfmea Update' ;
    rdfs:comment 'Indicates whether the engineering change requires an update to the Process Failure Mode and Effects Analysis (PFMEA) document. Ensures manufacturing process risk documentation is updated to reflect changed process steps or parameters.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresPpap rdf:type rdf:Property ;
    rdfs:label 'Requires Ppap' ;
    rdfs:comment 'Indicates whether the engineering change requires a Production Part Approval Process submission to the customer or internal quality authority before the changed part can be used in production. Mandatory for automotive and aerospace supply chain compliance.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyImpact rdf:type rdf:Property ;
    rdfs:label 'Safety Impact' ;
    rdfs:comment 'Indicates whether the engineering change has a potential impact on product safety, operator safety, or end-user safety. When true, triggers mandatory safety review and may require additional regulatory approvals (CE Marking, UL certification, OSHA compliance review).' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'Precise date and time when the Engineering Change Notice was formally submitted for review in Teamcenter. Used for change cycle time measurement, SLA compliance tracking, and audit trail.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Actual total cost incurred to implement the engineering change, captured upon completion. Compared against estimated_cost for variance analysis and continuous improvement of change cost estimation accuracy.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedBomRevisions rdf:type rdf:Property ;
    rdfs:label 'Affected Bom Revisions' ;
    rdfs:comment 'Comma-separated list or description of the Bill of Materials (BOM) revision identifiers that are created or updated as a result of this ECO. Provides traceability between the change order and specific BOM versions in SAP PP and Teamcenter.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedDrawingRevisions rdf:type rdf:Property ;
    rdfs:label 'Affected Drawing Revisions' ;
    rdfs:comment 'Comma-separated list or description of the engineering drawing revision identifiers (CAD/CAM drawings) that are updated as part of this ECO. Ensures drawing version control traceability in Teamcenter PDM.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedPartNumbers rdf:type rdf:Property ;
    rdfs:label 'Affected Part Numbers' ;
    rdfs:comment 'Comma-separated list of material/part numbers (SAP material numbers or Teamcenter item IDs) directly affected by this engineering change. Used for impact analysis and to identify all downstream BOM assemblies requiring update.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedRoutingRevisions rdf:type rdf:Property ;
    rdfs:label 'Affected Routing Revisions' ;
    rdfs:comment 'Comma-separated list or description of the production routing (Bill of Process/BoP) revision identifiers updated by this ECO. Routing changes affect work center assignments, operation sequences, and standard times in SAP PP.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeClass rdf:type rdf:Property ;
    rdfs:label 'Change Class' ;
    rdfs:comment 'Severity classification of the engineering change. Class 1 (Major) changes affect form, fit, or function and require full PPAP re-submission; Class 2 (Minor) changes require limited validation; Class 3 (Administrative) changes are documentation-only.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedDate rdf:type rdf:Property ;
    rdfs:label 'Completed Date' ;
    rdfs:comment 'The actual date on which all implementation tasks for the ECO were confirmed complete, including BOM updates, drawing revisions, routing changes, and shop floor verification. Used for cycle time analysis.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Customer Approval Required' ;
    rdfs:comment 'Indicates whether formal written customer approval must be obtained before the engineering change can be implemented. Applicable for changes to customer-specific designs or regulated products under customer quality agreements.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionOfStock rdf:type rdf:Property ;
    rdfs:label 'Disposition Of Stock' ;
    rdfs:comment 'Defines how existing finished goods and raw material inventory affected by the change are to be handled. Determines whether pre-change stock can be consumed, must be reworked, or must be scrapped.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionOfWip rdf:type rdf:Property ;
    rdfs:label 'Disposition Of Wip' ;
    rdfs:comment 'Defines how existing Work in Progress (WIP) inventory and in-process assemblies are to be handled at the time the engineering change becomes effective. Drives shop floor instructions and material disposition in SAP MM/PP.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivityDate rdf:type rdf:Property ;
    rdfs:label 'Effectivity Date' ;
    rdfs:comment 'The calendar date on which the engineering change becomes effective in production, applicable when effectivity_type is \'date_based\'. Used to schedule BOM and routing updates in SAP PP and Teamcenter.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivityLotNumberFrom rdf:type rdf:Property ;
    rdfs:label 'Effectivity Lot Number From' ;
    rdfs:comment 'The starting production lot number from which the engineering change becomes effective, applicable when effectivity_type is \'lot_based\'. All lots at or above this number incorporate the change.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivitySerialNumberFrom rdf:type rdf:Property ;
    rdfs:label 'Effectivity Serial Number From' ;
    rdfs:comment 'The starting serial number from which the engineering change becomes effective, applicable when effectivity_type is \'serial_number_based\'. All units with serial numbers at or above this value incorporate the change.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationDeadline rdf:type rdf:Property ;
    rdfs:label 'Implementation Deadline' ;
    rdfs:comment 'The mandatory completion date by which all BOM revisions, drawing revisions, routing revisions, and shop floor updates must be fully implemented. Used for scheduling, escalation management, and compliance tracking.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppapLevel rdf:type rdf:Property ;
    rdfs:label 'Ppap Level' ;
    rdfs:comment 'The PPAP submission level required for this engineering change, ranging from Level 1 (Part Submission Warrant only) to Level 5 (full documentation retained at customer location). Determined by customer requirements and change classification.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppapRequired rdf:type rdf:Property ;
    rdfs:label 'Ppap Required' ;
    rdfs:comment 'Indicates whether a Production Part Approval Process (PPAP) submission is required for this engineering change, typically mandated for Class 1 (Major) changes affecting form, fit, or function for automotive or regulated customers.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryDriven rdf:type rdf:Property ;
    rdfs:label 'Regulatory Driven' ;
    rdfs:comment 'Indicates whether this engineering change is mandated by a regulatory requirement (e.g., RoHS/REACH compliance, CE Marking, UL certification, OSHA safety requirement). Regulatory-driven ECOs receive elevated priority and mandatory completion tracking.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releasedDate rdf:type rdf:Property ;
    rdfs:label 'Released Date' ;
    rdfs:comment 'The date on which the ECO was formally released to manufacturing and the updated BOM/routing/drawings were published in SAP PP and Teamcenter for shop floor execution.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedDate rdf:type rdf:Property ;
    rdfs:label 'Requested Date' ;
    rdfs:comment 'The date on which the ECO was formally requested or initiated. Used for lead time analysis and change management performance reporting.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleEngineer rdf:type rdf:Property ;
    rdfs:label 'Responsible Engineer' ;
    rdfs:comment 'Name or employee identifier of the lead engineer accountable for coordinating and completing the ECO implementation. This is the primary point of contact for all technical questions related to the change.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeAffectedItemId rdf:type rdf:Property ;
    rdfs:label 'Change Affected Item Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying each association record between an engineering change (ECN/ECO) and a specific affected item (component, BOM, drawing, routing, or document) within the Siemens Teamcenter PLM change management module.' ;
    rdfs:domain ind:ChangeAffectedItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controlPlanId rdf:type rdf:Property ;
    rdfs:label 'Control Plan Id' ;
    rdfs:comment 'Foreign key linking to quality.control_plan. Business justification: Engineering changes that affect manufacturing processes require control plan updates — the affected item record links to the impacted control plan. This is a mandatory step in engineering change impac' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlPlan .

ind:inspectionPlanId rdf:type rdf:Property ;
    rdfs:label 'Inspection Plan Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_plan. Business justification: Engineering changes affect inspection plans when component specifications change. Change management tracks which inspection plans require updates to reflect new tolerances or characteristics.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionPlan .

ind:affectedPlantCodes rdf:type rdf:Property ;
    rdfs:label 'Affected Plant Codes' ;
    rdfs:comment 'Comma-separated list of SAP plant codes for all manufacturing facilities where this affected item is produced or used, and where the engineering change must be implemented. Supports global change rollout coordination across multinational manufacturing sites.' ;
    rdfs:domain ind:ChangeAffectedItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomPosition rdf:type rdf:Property ;
    rdfs:label 'Bom Position' ;
    rdfs:comment 'The BOM line item position or component item number within the parent assembly\'s Bill of Materials where this affected item resides. Enables precise identification of the structural location of the change within the product hierarchy.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaReference rdf:type rdf:Property ;
    rdfs:label 'Capa Reference' ;
    rdfs:comment 'Reference number of the associated Corrective and Preventive Action (CAPA) record in the Quality Management System (QMS) that triggered or is linked to this engineering change for the affected item. Enables traceability between quality events and engineering change actions.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeAction rdf:type rdf:Property ;
    rdfs:label 'Change Action' ;
    rdfs:comment 'The specific action to be performed on the affected item as a result of the engineering change. \'Revise\' updates an existing item to a new revision; \'Create\' introduces a new item; \'Obsolete\' retires an item from active use; \'Supersede\' replaces one item with another; \'Incorporate\' merges changes into an existing revision; \'Cancel\' voids a previously planned change.' ;
    rdfs:domain ind:ChangeAffectedItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeDescription rdf:type rdf:Property ;
    rdfs:label 'Change Description' ;
    rdfs:comment 'Detailed narrative description of what specifically changed for this affected item, including the nature of the modification, the technical rationale, and any relevant engineering justification. Provides the human-readable explanation of the change for engineers, quality auditors, and regulatory reviewers.' ;
    rdfs:domain ind:ChangeAffectedItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'Standardized code categorizing the primary business reason driving the engineering change for this affected item. Supports root cause analysis, change trend reporting, and CAPA (Corrective and Preventive Action) linkage in the QMS.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Category' ;
    rdfs:comment 'High-level classification of the financial impact of the engineering change on this affected item. Indicates whether the change is expected to reduce, maintain, or increase the cost of the item, supporting financial impact assessment and CAPEX/OPEX planning.' ;
    rdfs:domain ind:ChangeAffectedItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionAction rdf:type rdf:Property ;
    rdfs:label 'Disposition Action' ;
    rdfs:comment 'The required disposition for existing inventory or work-in-progress (WIP) stock of the affected item at the time the change is implemented. Determines whether existing stock should be used as-is, reworked to the new revision, scrapped, returned to supplier, retrofitted in the field, or held pending further review.' ;
    rdfs:domain ind:ChangeAffectedItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivitySerialNumber rdf:type rdf:Property ;
    rdfs:label 'Effectivity Serial Number' ;
    rdfs:comment 'The manufacturing serial number from which the engineering change becomes effective when serial-number-based effectivity is used. Ensures that units produced at or after this serial number incorporate the change, while earlier units retain the previous configuration.' ;
    rdfs:domain ind:ChangeAffectedItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Impact' ;
    rdfs:comment 'The estimated financial impact (positive or negative) of implementing the engineering change on this affected item, expressed in the transaction currency. Negative values indicate cost savings; positive values indicate cost increases. Used for change approval financial justification.' ;
    rdfs:domain ind:ChangeAffectedItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formFitFunctionFlag rdf:type rdf:Property ;
    rdfs:label 'Form Fit Function Flag' ;
    rdfs:comment 'Indicates whether the engineering change affects the form, fit, or function of the affected item. A true value triggers mandatory customer notification, PPAP re-submission, and regulatory re-evaluation workflows in accordance with customer-specific requirements and quality standards.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactLevel rdf:type rdf:Property ;
    rdfs:label 'Impact Level' ;
    rdfs:comment 'Assessment of the severity and scope of the engineering change impact on this affected item. Critical changes affect form, fit, or function and may require customer notification or regulatory re-approval; major changes affect performance or interchangeability; minor changes are non-functional improvements; cosmetic changes affect appearance only.' ;
    rdfs:domain ind:ChangeAffectedItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Date' ;
    rdfs:comment 'The actual date on which the engineering change was physically implemented for this affected item in the production environment. Distinguishes the planned effectivity date from the actual execution date for change tracking and audit purposes.' ;
    rdfs:domain ind:ChangeAffectedItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationStatus rdf:type rdf:Property ;
    rdfs:label 'Implementation Status' ;
    rdfs:comment 'Current status of the engineering change implementation for this specific affected item. Tracks the lifecycle from initial identification through verification, enabling program managers and engineers to monitor change execution progress across all affected items.' ;
    rdfs:domain ind:ChangeAffectedItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemName rdf:type rdf:Property ;
    rdfs:label 'Item Name' ;
    rdfs:comment 'The descriptive name or title of the affected item (e.g., part description, drawing title, document name) as recorded in the PLM/PDM system. Provides human-readable identification alongside the item number.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemType rdf:type rdf:Property ;
    rdfs:label 'Item Type' ;
    rdfs:comment 'Classification of the item affected by the engineering change. Indicates whether the affected object is a component, assembly, Bill of Materials (BOM), engineering drawing, manufacturing routing, controlled document, tooling, specification, software artifact, or firmware image.' ;
    rdfs:domain ind:ChangeAffectedItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrReference rdf:type rdf:Property ;
    rdfs:label 'Ncr Reference' ;
    rdfs:comment 'Reference number of the Non-Conformance Report (NCR) associated with this affected item change record. Links the engineering change to the specific quality non-conformance event that necessitated the design or process modification.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newRevision rdf:type rdf:Property ;
    rdfs:label 'New Revision' ;
    rdfs:comment 'The revision identifier assigned to the affected item after the engineering change is implemented. Represents the updated configuration baseline and is used for release control and downstream BOM/routing updates.' ;
    rdfs:domain ind:ChangeAffectedItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oldRevision rdf:type rdf:Property ;
    rdfs:label 'Old Revision' ;
    rdfs:comment 'The revision identifier (e.g., A, B, 01, REV-C) of the affected item prior to the engineering change being applied. Establishes the baseline from which the change is made and supports full revision history traceability.' ;
    rdfs:domain ind:ChangeAffectedItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningPlantCode rdf:type rdf:Property ;
    rdfs:label 'Owning Plant Code' ;
    rdfs:comment 'The SAP plant code or facility identifier of the manufacturing plant responsible for implementing the change on this affected item. Supports multi-plant change management and ensures the correct facility executes the change in global manufacturing operations.' ;
    rdfs:domain ind:ChangeAffectedItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentItemNumber rdf:type rdf:Property ;
    rdfs:label 'Parent Item Number' ;
    rdfs:comment 'The part number or identifier of the parent assembly or document that directly contains or references the affected item. Supports where-used analysis and impact assessment across the product structure when evaluating the scope of an engineering change.' ;
    rdfs:domain ind:ChangeAffectedItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Planned Implementation Date' ;
    rdfs:comment 'The originally scheduled date for implementing the engineering change on this affected item. Used for program planning, resource scheduling, and on-time delivery tracking. Compared against the actual implementation date to measure change execution performance.' ;
    rdfs:domain ind:ChangeAffectedItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Required' ;
    rdfs:comment 'Indicates whether the engineering change to this affected item requires formal approval from an external regulatory body (e.g., CE Marking re-assessment, UL re-certification, RoHS/REACH compliance re-evaluation) before the change can be released to production.' ;
    rdfs:domain ind:ChangeAffectedItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Current status of the regulatory approval process for the engineering change on this affected item. Tracks whether external certification or compliance re-evaluation has been initiated, submitted to the authority, approved, or rejected.' ;
    rdfs:domain ind:ChangeAffectedItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Critical Flag' ;
    rdfs:comment 'Indicates whether the affected item is classified as safety-critical, requiring mandatory safety review, DFMEA/PFMEA update, and regulatory authority notification before the change can be implemented. Applies to items subject to CE Marking, UL certification, ISO 45001, or OSHA requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'The engineering verification method required to confirm that the change has been correctly implemented and meets design intent for this affected item. First Article Inspection (FAI) is commonly required for safety-critical or form-fit-function changes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Current status of the verification activity for this affected item following change implementation. Indicates whether the required verification (test, inspection, FAI) has been completed successfully, is in progress, has failed, or has been formally waived.' ;
    rdfs:domain ind:ChangeAffectedItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dfmeaId rdf:type rdf:Property ;
    rdfs:label 'Dfmea Id' ;
    rdfs:comment 'Unique system-generated identifier for the DFMEA record within the enterprise data platform. Serves as the primary key for all downstream references and linkages.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dfmea .

ind:fmeaId rdf:type rdf:Property ;
    rdfs:label 'Fmea Id' ;
    rdfs:comment 'Foreign key linking to quality.fmea. Business justification: Design FMEA is a specialized type of FMEA managed in quality systems. Engineering references the quality FMEA framework for risk assessment methodology and tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fmea .

ind:actionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Action Completion Date' ;
    rdfs:comment 'Actual date on which the recommended action was completed and verified. Used to measure APQP schedule adherence and close open DFMEA action items.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionPriority rdf:type rdf:Property ;
    rdfs:label 'Action Priority' ;
    rdfs:comment 'Action Priority classification (H=High, M=Medium, L=Low) per the AIAG-VDA FMEA Handbook, used alongside RPN to determine urgency of recommended actions. High priority requires immediate action regardless of RPN value.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionTaken rdf:type rdf:Property ;
    rdfs:label 'Action Taken' ;
    rdfs:comment 'Description of the actual corrective or preventive action implemented to address the failure mode. Recorded after completion to close the DFMEA action loop and support CAPA documentation.' ;
    rdfs:domain ind:Dfmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apqpPhase rdf:type rdf:Property ;
    rdfs:label 'Apqp Phase' ;
    rdfs:comment 'The APQP phase during which this DFMEA was created or last updated. Phase 1=Plan and Define, Phase 2=Product Design and Development, Phase 3=Process Design and Development, Phase 4=Product and Process Validation, Phase 5=Feedback Assessment and Corrective Action.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerName rdf:type rdf:Property ;
    rdfs:label 'Customer Name' ;
    rdfs:comment 'Name of the external customer or internal program for which this DFMEA is being prepared. Relevant for PPAP submissions and customer-specific requirements (CSR).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designControlDetection rdf:type rdf:Property ;
    rdfs:label 'Design Control Detection' ;
    rdfs:comment 'Current design controls in place to detect the failure mode or cause before the product reaches the customer (e.g., \'prototype testing\', \'FEA simulation\', \'design review checklist\', \'First Article Inspection (FAI)\'). Addresses detection-type controls per AIAG-VDA Step 5.' ;
    rdfs:domain ind:Dfmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designControlPrevention rdf:type rdf:Property ;
    rdfs:label 'Design Control Prevention' ;
    rdfs:comment 'Current design controls in place to prevent the failure cause from occurring (e.g., \'design standard XYZ applied\', \'material specification review\', \'DFM analysis completed\'). Addresses prevention-type controls per AIAG-VDA Step 5.' ;
    rdfs:domain ind:Dfmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionRating rdf:type rdf:Property ;
    rdfs:label 'Detection Rating' ;
    rdfs:comment 'Numeric rating (1–10) assessing the ability of current design controls to detect the failure cause or failure mode before product release. A rating of 10 indicates no detection capability; 1 indicates near-certain detection.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failureCause rdf:type rdf:Property ;
    rdfs:label 'Failure Cause' ;
    rdfs:comment 'The specific design deficiency or root cause mechanism that leads to the failure mode (e.g., \'insufficient wall thickness\', \'incorrect material specification\', \'inadequate clearance between mating parts\'). Identified through DFMEA root cause analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureEffect rdf:type rdf:Property ;
    rdfs:label 'Failure Effect' ;
    rdfs:comment 'The consequence of the failure mode on the next higher-level assembly, end customer, or end user. Describes what the customer experiences if the failure mode occurs (e.g., \'loss of motor control\', \'vehicle does not start\', \'operator injury\').' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRevisedDate rdf:type rdf:Property ;
    rdfs:label 'Last Revised Date' ;
    rdfs:comment 'Date of the most recent revision to the DFMEA document. Tracks the currency of the risk assessment and supports document control requirements.' ;
    rdfs:domain ind:Dfmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modelYear rdf:type rdf:Property ;
    rdfs:label 'Model Year' ;
    rdfs:comment 'The model year or product generation to which this DFMEA applies. Used for product lifecycle tracking and APQP milestone alignment.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occurrenceRating rdf:type rdf:Property ;
    rdfs:label 'Occurrence Rating' ;
    rdfs:comment 'Numeric rating (1–10) estimating the likelihood that the failure cause will occur and result in the failure mode. A rating of 10 indicates near-certain occurrence; 1 indicates extremely unlikely. Based on historical data, design similarity, and engineering judgment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ppapSubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Ppap Submission Required' ;
    rdfs:comment 'Indicates whether this DFMEA is required as part of a PPAP submission package to the customer. When true, the DFMEA must meet customer-specific requirements (CSR) for PPAP level compliance.' ;
    rdfs:domain ind:Dfmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preparationDate rdf:type rdf:Property ;
    rdfs:label 'Preparation Date' ;
    rdfs:comment 'Date on which the DFMEA was initially prepared and documented. Used for APQP timeline tracking and document control.' ;
    rdfs:domain ind:Dfmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preparedBy rdf:type rdf:Property ;
    rdfs:label 'Prepared By' ;
    rdfs:comment 'Name or employee identifier of the engineer or analyst who originally prepared and authored the DFMEA document.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'Specific corrective or preventive action recommended to reduce severity, occurrence, or detection ratings for high-priority failure modes. May include design changes, additional testing, material substitution, or tolerance revisions.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether this DFMEA addresses failure modes related to regulatory compliance requirements such as RoHS, REACH, CE Marking, UL certification, or OSHA/EPA mandates. Triggers mandatory compliance review workflow.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisedDetectionRating rdf:type rdf:Property ;
    rdfs:label 'Revised Detection Rating' ;
    rdfs:comment 'Updated detection rating after implementation of recommended actions. Reflects improved detection capability post-mitigation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisedOccurrenceRating rdf:type rdf:Property ;
    rdfs:label 'Revised Occurrence Rating' ;
    rdfs:comment 'Updated occurrence rating after implementation of recommended actions. Reflects the reduced likelihood of the failure cause occurring post-mitigation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisedRpn rdf:type rdf:Property ;
    rdfs:label 'Revised Rpn' ;
    rdfs:comment 'Recalculated Risk Priority Number (Revised S × Revised O × Revised D) after corrective actions have been implemented. Used to confirm risk reduction and validate DFMEA closure.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisedSeverityRating rdf:type rdf:Property ;
    rdfs:label 'Revised Severity Rating' ;
    rdfs:comment 'Updated severity rating after implementation of recommended actions. Reflects the residual risk level post-mitigation. Compared against original severity to demonstrate risk reduction effectiveness.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rpn rdf:type rdf:Property ;
    rdfs:label 'Rpn' ;
    rdfs:comment 'Risk Priority Number calculated as the product of Severity × Occurrence × Detection ratings (S × O × D). Ranges from 1 to 1000. Used to prioritize failure modes requiring corrective action. Note: AIAG-VDA also uses Action Priority (AP) as a complementary risk metric.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Narrative description of the specific component, assembly, or system covered by this DFMEA, including functional boundaries and interfaces considered in the analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeLevel rdf:type rdf:Property ;
    rdfs:label 'Scope Level' ;
    rdfs:comment 'Defines the hierarchical level of the design analysis scope: component (individual part), subsystem (grouped components), assembly (full assembly), or system (complete product system). Determines the depth and breadth of the FMEA analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityRating rdf:type rdf:Property ;
    rdfs:label 'Severity Rating' ;
    rdfs:comment 'Numeric rating (1–10) indicating the seriousness of the failure effect on the customer or end user. A rating of 10 indicates a safety-critical failure with no warning; 1 indicates no discernible effect. Defined per AIAG-VDA severity criteria.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned date by which the recommended action must be completed and verified. Used for APQP milestone tracking and PPAP readiness assessment.' ;
    rdfs:domain ind:Dfmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:teamcenterDocumentCode rdf:type rdf:Property ;
    rdfs:label 'Teamcenter Document Code' ;
    rdfs:comment 'Unique document identifier assigned by Siemens Teamcenter PLM for the DFMEA document object. Enables direct traceability to the authoritative source document in the PLM/PDM system.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionResponsibility rdf:type rdf:Property ;
    rdfs:label 'Action Responsibility' ;
    rdfs:comment 'Name or role of the person or team responsible for implementing the recommended action. Used for accountability tracking in CAPA workflows and PFMEA review meetings.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionTargetDate rdf:type rdf:Property ;
    rdfs:label 'Action Target Date' ;
    rdfs:comment 'Target date by which the recommended action must be completed and verified. Monitored in SAP QM CAPA tracking and PFMEA review cycles to ensure timely risk mitigation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Number' ;
    rdfs:comment 'Reference number of the linked Corrective and Preventive Action (CAPA) record in SAP QM or the Quality Management System (QMS). Establishes traceability between the PFMEA risk item and the formal corrective action workflow.' ;
    rdfs:domain ind:Pfmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlPlanNumber rdf:type rdf:Property ;
    rdfs:label 'Control Plan Number' ;
    rdfs:comment 'Reference number of the associated SPC Control Plan that incorporates the detection controls and inspection frequencies derived from this PFMEA. Links PFMEA outputs to Siemens Opcenter quality inspection plans.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentDetectionControl rdf:type rdf:Property ;
    rdfs:label 'Current Detection Control' ;
    rdfs:comment 'Description of existing process controls designed to detect the failure mode or failure cause before the product reaches the next operation or customer (e.g., \'In-process CMM inspection\', \'Vision system check\', \'SPC control chart monitoring\').' ;
    rdfs:domain ind:Pfmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentPreventionControl rdf:type rdf:Property ;
    rdfs:label 'Current Prevention Control' ;
    rdfs:comment 'Description of existing process controls designed to prevent the failure cause or failure mode from occurring (e.g., \'Poka-Yoke fixture\', \'Operator SOP training\', \'Incoming material inspection\'). Supports Poka-Yoke and error-proofing documentation.' ;
    rdfs:domain ind:Pfmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lead rdf:type rdf:Property ;
    rdfs:label 'Lead' ;
    rdfs:comment 'Name or employee identifier of the lead process engineer responsible for authoring, maintaining, and updating the PFMEA document. Primary point of contact for PFMEA-related quality inquiries.' ;
    rdfs:domain ind:Pfmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processFunction rdf:type rdf:Property ;
    rdfs:label 'Process Function' ;
    rdfs:comment 'The intended function or purpose of the process step being analyzed, describing what the operation is designed to achieve (e.g., \'Join two steel components with specified weld penetration depth\').' ;
    rdfs:domain ind:Pfmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStep rdf:type rdf:Property ;
    rdfs:label 'Process Step' ;
    rdfs:comment 'Detailed description of the specific process step or sub-operation within the BoP operation being analyzed in this PFMEA record. Provides granular context for the failure mode analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamMembers rdf:type rdf:Property ;
    rdfs:label 'Team Members' ;
    rdfs:comment 'Comma-separated list of names or employee IDs of cross-functional team members who participated in the PFMEA development session. Documents team composition for APQP and PPAP submission requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceMarkingRelevant rdf:type rdf:Property ;
    rdfs:label 'Ce Marking Relevant' ;
    rdfs:comment 'Indicates whether this specification parameter contributes to CE Marking conformity assessment for the European market. CE-relevant parameters must be verified and documented in the Technical File.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryOfApplicability rdf:type rdf:Property ;
    rdfs:label 'Country Of Applicability' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code indicating the primary country or market for which this specification applies. Relevant for region-specific regulatory requirements (e.g., CE for EU, UL for USA, CCC for China).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalCharacteristic rdf:type rdf:Property ;
    rdfs:label 'Is Critical Characteristic' ;
    rdfs:comment 'Indicates whether this specification parameter is designated as a Critical Characteristic (CC) or Key Characteristic (KC) requiring enhanced control, SPC monitoring, and mandatory documentation in the Control Plan. Critical characteristics directly impact safety, regulatory compliance, or product function.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyRelevant rdf:type rdf:Property ;
    rdfs:label 'Is Safety Relevant' ;
    rdfs:comment 'Indicates whether this specification parameter has direct implications for product safety, operator safety, or end-user safety. Safety-relevant parameters require additional review, documentation, and regulatory approval under CE Marking, UL, and ISO 45001.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumValue rdf:type rdf:Property ;
    rdfs:label 'Maximum Value' ;
    rdfs:comment 'Absolute maximum acceptable value for the parameter, representing the hard upper bound. Used in design verification, test planning, and quality inspection to define pass/fail criteria.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Value' ;
    rdfs:comment 'Absolute minimum acceptable value for the parameter, representing the hard lower bound beyond which the product fails to meet specification. Distinct from tolerance_lower which is a deviation from nominal.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nominalValue rdf:type rdf:Property ;
    rdfs:label 'Nominal Value' ;
    rdfs:comment 'The target or ideal value for the specification parameter (e.g., \'24\', \'85\', \'500\'). Stored as STRING to accommodate numeric, alphanumeric, and enumerated nominal values across diverse parameter types.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterName rdf:type rdf:Property ;
    rdfs:label 'Parameter Name' ;
    rdfs:comment 'Name of the specific technical parameter being specified (e.g., \'Input Voltage\', \'Operating Temperature\', \'Tensile Strength\', \'IP Protection Rating\'). Each specification record captures one parameter for traceability granularity.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachRelevant rdf:type rdf:Property ;
    rdfs:label 'Reach Relevant' ;
    rdfs:comment 'Indicates whether this specification parameter is subject to REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals) regulation, applicable to chemical composition and substance-of-very-high-concern (SVHC) thresholds.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rohsRelevant rdf:type rdf:Property ;
    rdfs:label 'Rohs Relevant' ;
    rdfs:comment 'Indicates whether this specification parameter is relevant to RoHS (Restriction of Hazardous Substances) compliance, particularly for material composition specifications governing restricted substances such as lead, mercury, cadmium, and hexavalent chromium.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specificationCategory rdf:type rdf:Property ;
    rdfs:label 'Specification Category' ;
    rdfs:comment 'Engineering discipline category of the specification parameter. Enables domain-specific filtering and routing to the appropriate engineering team for review and verification.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationNumber rdf:type rdf:Property ;
    rdfs:label 'Specification Number' ;
    rdfs:comment 'Formal business identifier for the product specification document, typically assigned by the PLM/PDM system (Siemens Teamcenter). Used for cross-referencing in engineering change notices (ECN), design reviews, and regulatory submissions.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationType rdf:type rdf:Property ;
    rdfs:label 'Specification Type' ;
    rdfs:comment 'Classification of the specification by its engineering purpose. Functional specs define what the product must do; interface specs define integration points; material specs define composition; environmental specs define operating conditions; safety and regulatory specs define compliance requirements.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceLower rdf:type rdf:Property ;
    rdfs:label 'Tolerance Lower' ;
    rdfs:comment 'Minimum allowable deviation below the nominal value for the specification parameter. Used in SPC and inspection to define the lower specification limit (LSL). Null if not applicable.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceUpper rdf:type rdf:Property ;
    rdfs:label 'Tolerance Upper' ;
    rdfs:comment 'Maximum allowable deviation above the nominal value for the specification parameter. Used in Statistical Process Control (SPC) and inspection to define the upper specification limit (USL). Null if not applicable (e.g., enumerated parameters).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedSupplierListRef rdf:type rdf:Property ;
    rdfs:label 'Approved Supplier List Ref' ;
    rdfs:comment 'Reference identifier linking this material specification to the corresponding Approved Supplier List (ASL) record in SAP Ariba or SAP S/4HANA MM. Ensures procurement is restricted to qualified and audited suppliers for this material.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseMaterial rdf:type rdf:Property ;
    rdfs:label 'Base Material' ;
    rdfs:comment 'The primary elemental or compound material, such as \'Steel\', \'Aluminum\', \'Copper\', \'Polypropylene\', or \'Epoxy Resin\'. Provides the foundational material identity before alloy or grade qualification.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chemicalCompositionSpec rdf:type rdf:Property ;
    rdfs:label 'Chemical Composition Spec' ;
    rdfs:comment 'Structured text or JSON-serialized representation of the required chemical composition limits (min/max percentages by weight) for key elements such as C, Mn, Si, Cr, Ni, Cu, Fe. Stored as a structured string for Silver layer compatibility.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictMineralsFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Minerals Flag' ;
    rdfs:comment 'Indicates whether the material contains conflict minerals (tin, tantalum, tungsten, gold — 3TG) sourced from conflict-affected and high-risk areas (CAHRAs). Triggers supply chain due diligence and reporting obligations under EU Conflict Minerals Regulation and SEC Rule 13p-1.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryOfOriginRestriction rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin Restriction' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes from which sourcing of this material is restricted or prohibited, based on export control regulations, trade compliance, or supply chain risk policies.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:densityKgPerM3 rdf:type rdf:Property ;
    rdfs:label 'Density Kg Per M3' ;
    rdfs:comment 'Nominal density of the material expressed in kilograms per cubic meter (kg/m³). Used in weight calculations for BOM costing, shipping logistics, and structural analysis in CAD/CAM systems.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elongationMinPercent rdf:type rdf:Property ;
    rdfs:label 'Elongation Min Percent' ;
    rdfs:comment 'Minimum required elongation at break expressed as a percentage, indicating the material\'s ductility. Used in mechanical property verification during incoming inspection and First Article Inspection (FAI).' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:en10204CertificateType rdf:type rdf:Property ;
    rdfs:label 'En10204 Certificate Type' ;
    rdfs:comment 'Specifies the EN 10204 material test certificate type required for metallic materials: 2.1 (Declaration of Compliance), 2.2 (Test Report), 3.1 (Inspection Certificate by manufacturer), or 3.2 (Inspection Certificate by independent body). Critical for traceability in regulated industries.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeDesignation rdf:type rdf:Property ;
    rdfs:label 'Grade Designation' ;
    rdfs:comment 'Specific grade or alloy designation of the material as defined by the applicable standard, such as \'6061-T6\', \'Grade 304\', \'S235JR\', or \'A36\'. Uniquely identifies the material within its standard family.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardnessMax rdf:type rdf:Property ;
    rdfs:label 'Hardness Max' ;
    rdfs:comment 'Maximum allowable hardness value for the material. Paired with hardness_min to define the acceptable hardness range for incoming inspection and supplier qualification.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hardnessMin rdf:type rdf:Property ;
    rdfs:label 'Hardness Min' ;
    rdfs:comment 'Minimum required hardness value for the material. The hardness scale (HRC, HRB, HV, HB) is specified in the hardness_scale attribute. Used in incoming inspection and quality assurance.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hardnessScale rdf:type rdf:Property ;
    rdfs:label 'Hardness Scale' ;
    rdfs:comment 'The hardness measurement scale used for the hardness_min and hardness_max values (e.g., Rockwell C, Vickers, Brinell). Ensures correct interpretation of hardness requirements during inspection.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialClass rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Class' ;
    rdfs:comment 'UN/GHS hazardous material classification code for the material if applicable (e.g., Class 3 Flammable Liquid, Class 8 Corrosive). Drives storage, handling, and transportation requirements under OSHA HazCom and EPA regulations.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomingInspectionPlanRef rdf:type rdf:Property ;
    rdfs:label 'Incoming Inspection Plan Ref' ;
    rdfs:comment 'Reference to the quality inspection plan in SAP S/4HANA QM module that governs incoming material inspection for this specification. Defines sampling procedures, test methods, and acceptance criteria (AQL) applied at goods receipt.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReachCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Reach Compliant' ;
    rdfs:comment 'Indicates whether the material complies with the EU REACH Regulation (EC) No 1907/2006 regarding Registration, Evaluation, Authorisation and Restriction of Chemicals. Flags whether the material contains Substances of Very High Concern (SVHC) above threshold.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRohsCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Rohs Compliant' ;
    rdfs:comment 'Indicates whether the material meets the EU Restriction of Hazardous Substances (RoHS) Directive 2011/65/EU requirements, restricting the use of lead, mercury, cadmium, hexavalent chromium, PBB, PBDE, and other substances. Mandatory for products sold in the EU market.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingTempMaxC rdf:type rdf:Property ;
    rdfs:label 'Operating Temp Max C' ;
    rdfs:comment 'Maximum operating temperature in degrees Celsius at which the material maintains its specified mechanical and physical properties. Used in thermal analysis and material selection for electrification and industrial automation components.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingTempMinC rdf:type rdf:Property ;
    rdfs:label 'Operating Temp Min C' ;
    rdfs:comment 'Minimum operating temperature in degrees Celsius at which the material maintains its specified mechanical and physical properties. Critical for material selection in automation systems deployed in cold environments.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sds Reference Number' ;
    rdfs:comment 'Reference number or document identifier for the Safety Data Sheet (SDS) associated with this material, as required by OSHA HazCom Standard (29 CFR 1910.1200) and EU REACH Regulation. Links to the document management system for retrieval.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardBody rdf:type rdf:Property ;
    rdfs:label 'Standard Body' ;
    rdfs:comment 'The standards development organization (SDO) that published the applicable standard for this material specification. Used to filter and group specifications by regional or international standards alignment.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surfaceRoughnessMaxUm rdf:type rdf:Property ;
    rdfs:label 'Surface Roughness Max Um' ;
    rdfs:comment 'Maximum allowable surface roughness expressed in micrometers (µm Ra) as required by the material specification. Relevant for sealing surfaces, bearing interfaces, and precision-machined components.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surfaceTreatment rdf:type rdf:Property ;
    rdfs:label 'Surface Treatment' ;
    rdfs:comment 'Required surface treatment or coating specification for the material, such as zinc plating, anodizing, passivation, powder coating, or hot-dip galvanizing. Defines the surface condition required for corrosion protection or functional performance.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:svhcFlag rdf:type rdf:Property ;
    rdfs:label 'Svhc Flag' ;
    rdfs:comment 'Indicates whether the material contains one or more Substances of Very High Concern (SVHC) as listed on the ECHA Candidate List under REACH. Triggers mandatory disclosure obligations when concentration exceeds 0.1% w/w.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperCondition rdf:type rdf:Property ;
    rdfs:label 'Temper Condition' ;
    rdfs:comment 'Heat treatment, temper, or condition designation of the material (e.g., T6, T651, H32, annealed, normalized, quenched and tempered). Defines the mechanical property state resulting from processing.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tensileStrengthMinMpa rdf:type rdf:Property ;
    rdfs:label 'Tensile Strength Min Mpa' ;
    rdfs:comment 'Minimum required ultimate tensile strength of the material expressed in megapascals (MPa), as specified by the applicable standard. Used in incoming inspection and supplier qualification to verify mechanical property compliance.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testCertificateRequirement rdf:type rdf:Property ;
    rdfs:label 'Test Certificate Requirement' ;
    rdfs:comment 'Specifies the type of material test certificate or documentation required from the supplier at delivery. Options include mill certificates (EN 10204 3.1/3.2), certificates of conformance, third-party test reports, or First Article Inspection (FAI) reports.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldStrengthMinMpa rdf:type rdf:Property ;
    rdfs:label 'Yield Strength Min Mpa' ;
    rdfs:comment 'Minimum required yield strength (0.2% proof stress) of the material expressed in megapascals (MPa). Critical for structural and load-bearing component qualification in automation and electrification systems.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amlType rdf:type rdf:Property ;
    rdfs:label 'Aml Type' ;
    rdfs:comment 'Classification of the manufacturer\'s role in the supply strategy for this component. Preferred indicates primary source; alternate is secondary; restricted requires engineering approval for use.' ;
    rdfs:domain ind:ApprovedManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Approval Expiry Date' ;
    rdfs:comment 'Date on which the manufacturer approval expires and re-qualification is required. Supports periodic supplier re-evaluation per quality management requirements.' ;
    rdfs:domain ind:ApprovedManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ceMarkingConfirmed rdf:type rdf:Property ;
    rdfs:label 'Ce Marking Confirmed' ;
    rdfs:comment 'Indicates whether the manufacturer has confirmed CE marking compliance for the part, required for sale in the European Economic Area.' ;
    rdfs:domain ind:ApprovedManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryOfManufacture rdf:type rdf:Property ;
    rdfs:label 'Country Of Manufacture' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code indicating the country where the component is manufactured. Used for trade compliance, tariff classification, and supply chain risk assessment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRequalificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Requalification Date' ;
    rdfs:comment 'Date of the most recent periodic requalification assessment performed for this manufacturer-component combination. Supports ongoing supplier monitoring per ISO 9001.' ;
    rdfs:domain ind:ApprovedManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturerCode rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Code' ;
    rdfs:comment 'Unique short code or identifier assigned to the manufacturer within the enterprise system (e.g., SAP vendor/manufacturer code). Enables cross-system linkage.' ;
    rdfs:domain ind:ApprovedManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerCountry rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the manufacturer\'s registered business location. Used for geopolitical risk assessment and trade compliance screening.' ;
    rdfs:domain ind:ApprovedManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerDatasheetReference rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Datasheet Reference' ;
    rdfs:comment 'Document reference number or URL pointing to the manufacturer\'s official datasheet or technical specification for the approved part.' ;
    rdfs:domain ind:ApprovedManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerDunsNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Duns Number' ;
    rdfs:comment 'Dun & Bradstreet Data Universal Numbering System (D-U-N-S) nine-digit identifier for the manufacturer. Used for global supplier identity verification and risk assessment.' ;
    rdfs:domain ind:ApprovedManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerPartDescription rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Description' ;
    rdfs:comment 'Manufacturer\'s description of the part as stated in their datasheet or catalog. Supports incoming inspection and procurement verification.' ;
    rdfs:domain ind:ApprovedManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppapStatus rdf:type rdf:Property ;
    rdfs:label 'Ppap Status' ;
    rdfs:comment 'Current status of the PPAP submission for this manufacturer-component combination. Determines whether full production release is authorized.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppmDefectRate rdf:type rdf:Property ;
    rdfs:label 'Ppm Defect Rate' ;
    rdfs:comment 'Measured defect rate in Parts Per Million (PPM) for incoming parts from this manufacturer. Key quality KPI for supplier performance monitoring and AQL compliance.' ;
    rdfs:domain ind:ApprovedManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceCurrency rdf:type rdf:Property ;
    rdfs:label 'Price Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the unit price of the manufacturer\'s part (e.g., USD, EUR, GBP). Supports multi-currency global procurement.' ;
    rdfs:domain ind:ApprovedManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationTestReference rdf:type rdf:Property ;
    rdfs:label 'Qualification Test Reference' ;
    rdfs:comment 'Reference number or identifier of the qualification test report, First Article Inspection (FAI) record, or PPAP package that substantiates the manufacturer approval.' ;
    rdfs:domain ind:ApprovedManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'Numeric quality performance score (0–100) assigned to this manufacturer for the component based on incoming inspection results, PPM defect rates, and audit outcomes.' ;
    rdfs:domain ind:ApprovedManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requalificationFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Requalification Frequency Months' ;
    rdfs:comment 'Interval in months at which this manufacturer-component approval must be periodically requalified and reviewed. Drives quality management scheduling.' ;
    rdfs:domain ind:ApprovedManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restrictedToPlantCode rdf:type rdf:Property ;
    rdfs:label 'Restricted To Plant Code' ;
    rdfs:comment 'SAP plant code indicating that use of this approved manufacturer is restricted to a specific manufacturing plant. Null if approved globally across all plants.' ;
    rdfs:domain ind:ApprovedManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ulCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Ul Certification Number' ;
    rdfs:comment 'UL certification file number issued by Underwriters Laboratories for the manufacturer\'s part, confirming product safety compliance for North American markets.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useRestriction rdf:type rdf:Property ;
    rdfs:label 'Use Restriction' ;
    rdfs:comment 'Free-text description of any restrictions on the use of this manufacturer\'s part, such as limited to specific plants, product lines, or applications. Null if no restrictions apply.' ;
    rdfs:domain ind:ApprovedManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowedTransitions rdf:type rdf:Property ;
    rdfs:label 'Allowed Transitions' ;
    rdfs:comment 'Pipe-delimited list of target state codes to which a PLM object may transition from this state (e.g., \'IN_REVIEW|RELEASED|OBSOLETE\'). Defines the authorized state machine edges for workflow enforcement.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableObjectTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Object Types' ;
    rdfs:comment 'Pipe-delimited list of PLM-managed object types to which this lifecycle state applies (e.g., \'Component|BOM|Drawing|CAD_Model|Document\'). Governs which object classes can be assigned this state.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apqpPhaseAlignment rdf:type rdf:Property ;
    rdfs:label 'Apqp Phase Alignment' ;
    rdfs:comment 'Maps this lifecycle state to the corresponding APQP phase, enabling traceability between PLM object maturity and the formal product quality planning process used for new product introduction.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorCodeHex rdf:type rdf:Property ;
    rdfs:label 'Color Code Hex' ;
    rdfs:comment 'Hexadecimal color code used to visually represent this lifecycle state in PLM dashboards, engineering portals, and reporting tools. Supports intuitive visual differentiation of product data maturity stages.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downstreamSystemTrigger rdf:type rdf:Property ;
    rdfs:label 'Downstream System Trigger' ;
    rdfs:comment 'Identifies downstream operational systems that are triggered upon a PLM object entering this lifecycle state (e.g., \'SAP_MM_Material_Master|SAP_PP_BOM|Opcenter_MES\'). Supports IT/OT convergence and PLM-ERP integration governance.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecnRequiredForEntry rdf:type rdf:Property ;
    rdfs:label 'Ecn Required For Entry' ;
    rdfs:comment 'Indicates whether a valid Engineering Change Notice (ECN) or Engineering Change Order (ECO) must be referenced before a PLM object can be transitioned into this lifecycle state. Enforces formal change control governance.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ecnRequiredForExit rdf:type rdf:Property ;
    rdfs:label 'Ecn Required For Exit' ;
    rdfs:comment 'Indicates whether a valid Engineering Change Notice (ECN) or Engineering Change Order (ECO) must be referenced to transition a PLM object out of this lifecycle state. Typically applies to released or frozen states.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exportControlCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Export Control Check Required' ;
    rdfs:comment 'Indicates whether an export control classification review (e.g., EAR, ITAR, dual-use goods assessment) must be completed before a PLM object can be transitioned into this lifecycle state.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iconReference rdf:type rdf:Property ;
    rdfs:label 'Icon Reference' ;
    rdfs:comment 'Reference identifier or file path for the icon image associated with this lifecycle state in the PLM user interface. Used for visual representation in Teamcenter and integrated engineering portals.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFrozenState rdf:type rdf:Property ;
    rdfs:label 'Is Frozen State' ;
    rdfs:comment 'Indicates whether PLM objects in this state are frozen (read-only) and cannot be directly modified. Changes must be initiated via an Engineering Change Notice (ECN) or Engineering Change Order (ECO) process.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInitialState rdf:type rdf:Property ;
    rdfs:label 'Is Initial State' ;
    rdfs:comment 'Indicates whether this lifecycle state is the default starting state assigned to newly created PLM objects. Only one state per applicable object type should be flagged as the initial state.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReleasedState rdf:type rdf:Property ;
    rdfs:label 'Is Released State' ;
    rdfs:comment 'Indicates whether this lifecycle state constitutes a formal release milestone, meaning the PLM object is authorized for use in production, procurement, or downstream processes such as BOM activation or MES execution.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTerminalState rdf:type rdf:Property ;
    rdfs:label 'Is Terminal State' ;
    rdfs:comment 'Indicates whether this lifecycle state is a terminal (end) state from which no further forward transitions are permitted (e.g., Obsolete, Archived). Terminal states represent the end of the active product data lifecycle.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maturityLevel rdf:type rdf:Property ;
    rdfs:label 'Maturity Level' ;
    rdfs:comment 'Standardized maturity level classification associated with this lifecycle state, indicating the degree of completeness and validation of the product data. Used for portfolio-level maturity reporting and APQP phase alignment.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDwellDays rdf:type rdf:Property ;
    rdfs:label 'Max Dwell Days' ;
    rdfs:comment 'Maximum number of calendar days a PLM object is permitted to remain in this lifecycle state before an escalation or alert is triggered. Supports governance of stale or stuck product data records.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumApproverCount rdf:type rdf:Property ;
    rdfs:label 'Minimum Approver Count' ;
    rdfs:comment 'Minimum number of distinct approvers required to authorize a transition into this lifecycle state. Supports multi-signatory approval requirements for safety-critical or regulatory-relevant product data.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationRecipientRoles rdf:type rdf:Property ;
    rdfs:label 'Notification Recipient Roles' ;
    rdfs:comment 'Pipe-delimited list of organizational roles that receive automated notifications upon a PLM object entering this lifecycle state (e.g., \'Procurement|Manufacturing_Engineering|Quality_Assurance\').' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRequired rdf:type rdf:Property ;
    rdfs:label 'Notification Required' ;
    rdfs:comment 'Indicates whether automated notifications must be sent to stakeholders (e.g., engineering team, quality, procurement) when a PLM object transitions into this lifecycle state.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plmWorkflowTemplateName rdf:type rdf:Property ;
    rdfs:label 'Plm Workflow Template Name' ;
    rdfs:comment 'Name of the Teamcenter PLM workflow template associated with transitions into this lifecycle state. Identifies the formal approval and review workflow process definition used to govern state entry.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityGateRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Gate Required' ;
    rdfs:comment 'Indicates whether a formal quality gate review (e.g., APQP phase gate, design review, DFMEA completion check) must be passed before a PLM object can enter this lifecycle state.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Review Required' ;
    rdfs:comment 'Indicates whether regulatory compliance review (e.g., CE Marking, RoHS/REACH, UL certification, export control classification) must be completed before a PLM object can enter this lifecycle state.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredApprovalRoles rdf:type rdf:Property ;
    rdfs:label 'Required Approval Roles' ;
    rdfs:comment 'Pipe-delimited list of organizational roles or job functions that must provide approval before a PLM object can enter this lifecycle state (e.g., \'Design_Engineer|Quality_Manager|Chief_Engineer\'). Enforces the approval governance matrix.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceOrder rdf:type rdf:Property ;
    rdfs:label 'Sequence Order' ;
    rdfs:comment 'Numeric ordering value that defines the canonical progression sequence of lifecycle states from concept through obsolescence. Used for sorting and maturity progression reporting.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTransitionDays rdf:type rdf:Property ;
    rdfs:label 'Sla Transition Days' ;
    rdfs:comment 'Target number of business days within which a PLM object should complete the review and approval process to transition out of this lifecycle state. Used for engineering workflow performance monitoring against SLA targets.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stateCategory rdf:type rdf:Property ;
    rdfs:label 'State Category' ;
    rdfs:comment 'High-level category grouping lifecycle states for reporting and analytics. Enables aggregation of states into broader maturity phases (e.g., all review-type states grouped under \'review\').' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateCode rdf:type rdf:Property ;
    rdfs:label 'State Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the lifecycle state within the PLM system (e.g., CONCEPT, IN_REVIEW, RELEASED, OBSOLETE). Used as the business key for state lookups and workflow routing.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateDescription rdf:type rdf:Property ;
    rdfs:label 'State Description' ;
    rdfs:comment 'Detailed narrative description of the lifecycle state, including its business meaning, entry criteria, and the maturity level it represents within the product data governance framework.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateName rdf:type rdf:Property ;
    rdfs:label 'State Name' ;
    rdfs:comment 'Human-readable name of the lifecycle state as displayed in the Teamcenter PLM user interface and engineering reports (e.g., \'Concept\', \'Under Review\', \'Released for Production\', \'Obsolete\').' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamcenterPolicyName rdf:type rdf:Property ;
    rdfs:label 'Teamcenter Policy Name' ;
    rdfs:comment 'Name of the Teamcenter PLM lifecycle policy (policy object) under which this state is defined. A lifecycle policy groups related states and transition rules for a specific object type family.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamcenterStateUid rdf:type rdf:Property ;
    rdfs:label 'Teamcenter State Uid' ;
    rdfs:comment 'Native Siemens Teamcenter PLM system unique identifier (UID) for this lifecycle state object. Used for cross-system traceability and integration with Teamcenter APIs and downstream PLM-ERP interfaces.' ;
    rdfs:domain ind:PlmLifecycleState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceMarkingStatus rdf:type rdf:Property ;
    rdfs:label 'Ce Marking Status' ;
    rdfs:comment 'Current status of CE marking certification for this product variant, confirming conformity with applicable EU directives (e.g., Low Voltage Directive, Machinery Directive, EMC Directive). Required for sale in the European Economic Area.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationProtocol rdf:type rdf:Property ;
    rdfs:label 'Communication Protocol' ;
    rdfs:comment 'Industrial communication protocol supported by this product variant for integration with PLCs, SCADA systems, and IIoT platforms. Determines compatibility with factory automation architectures.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationCode rdf:type rdf:Property ;
    rdfs:label 'Configuration Code' ;
    rdfs:comment 'Encoded string representing the full combination of selected configuration options (e.g., voltage, power, protocol, enclosure) that define this variant. Used in SAP variant configuration (VC) and order management for ATO/ETO fulfillment.' ;
    rdfs:domain ind:ProductVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enclosureClass rdf:type rdf:Property ;
    rdfs:label 'Enclosure Class' ;
    rdfs:comment 'Ingress protection (IP) or NEMA enclosure classification of the product variant, indicating resistance to dust, water, and environmental hazards. Critical for application suitability and regulatory compliance.' ;
    rdfs:domain ind:ProductVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentModel rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Model' ;
    rdfs:comment 'Manufacturing and fulfillment strategy applicable to this variant: Make to Stock (MTS), Make to Order (MTO), Assemble to Order (ATO), or Engineer to Order (ETO). Drives production planning, lead time commitments, and ATP/CTP logic in SAP S/4HANA.' ;
    rdfs:domain ind:ProductVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:harmonizedTariffCode rdf:type rdf:Property ;
    rdfs:label 'Harmonized Tariff Code' ;
    rdfs:comment 'Harmonized System (HS) tariff code assigned to this product variant for customs classification in international trade. Used for import/export declarations, duty calculation, and trade compliance reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listPrice rdf:type rdf:Property ;
    rdfs:label 'List Price' ;
    rdfs:comment 'Published list price per unit for this product variant as maintained in SAP S/4HANA SD pricing conditions. Serves as the baseline for customer quotations, pricing agreements, and revenue reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:listPriceCurrency rdf:type rdf:Property ;
    rdfs:label 'List Price Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the list price is expressed. Supports global pricing management across multiple sales regions.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketApplicability rdf:type rdf:Property ;
    rdfs:label 'Market Applicability' ;
    rdfs:comment 'Comma-separated list of target markets or regions where this product variant is approved for sale and use (e.g., EU, North America, Asia-Pacific). Drives regional catalog availability and regulatory compliance checks.' ;
    rdfs:domain ind:ProductVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerRatingKw rdf:type rdf:Property ;
    rdfs:label 'Power Rating Kw' ;
    rdfs:comment 'Nominal power rating of the product variant expressed in kilowatts (kW). Core technical specification used for product selection, energy compliance reporting, and ISO 50001 energy management.' ;
    rdfs:domain ind:ProductVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardCost rdf:type rdf:Property ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'Standard manufacturing cost per unit for this product variant as calculated in SAP S/4HANA CO (Controlling) module. Used for inventory valuation, COGS reporting, and profitability analysis. Expressed in the standard cost currency.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the standard cost is expressed (e.g., USD, EUR, CNY). Supports multi-currency operations across global manufacturing sites.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetIndustrySegment rdf:type rdf:Property ;
    rdfs:label 'Target Industry Segment' ;
    rdfs:comment 'Primary industry segment for which this product variant is designed and marketed (e.g., factory automation, building automation, transportation). Supports portfolio segmentation and go-to-market strategy.' ;
    rdfs:domain ind:ProductVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantCode rdf:type rdf:Property ;
    rdfs:label 'Variant Code' ;
    rdfs:comment 'Business-facing alphanumeric code uniquely identifying the product variant within the product catalog. Used in order management, BOM references, and customer-facing documentation. Sourced from SAP S/4HANA MM module material number for configurable variants.' ;
    rdfs:domain ind:ProductVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantNumber rdf:type rdf:Property ;
    rdfs:label 'Variant Number' ;
    rdfs:comment 'Internal engineering variant number as maintained in Siemens Teamcenter PLM, used to cross-reference the variant across PLM and ERP systems. May differ from the commercial variant code.' ;
    rdfs:domain ind:ProductVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantType rdf:type rdf:Property ;
    rdfs:label 'Variant Type' ;
    rdfs:comment 'Classification of the variant by its engineering origin: standard (catalog item), custom (customer-specific modification), engineered (Engineer to Order), configurable (Assemble to Order with option selection), or phantom (planning-only variant).' ;
    rdfs:domain ind:ProductVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voltageRating rdf:type rdf:Property ;
    rdfs:label 'Voltage Rating' ;
    rdfs:comment 'Nominal voltage rating of the product variant (e.g., 24V DC, 400V AC, 690V AC). Key configuration option differentiating variants within the same base product for automation and electrification solutions.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substituteComponentId rdf:type rdf:Property ;
    rdfs:label 'Substitute Component Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for the substitute component association record in the Databricks Silver Layer.' ;
    rdfs:domain ind:SubstituteComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:substitutionId rdf:type rdf:Property ;
    rdfs:label 'Substitution Id' ;
    rdfs:comment 'Foreign key linking to product.substitution. Business justification: Engineering-approved substitute components must align with commercial substitution rules managed in the product domain. Procurement and production use this link to validate that engineering substitute' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Substitution .

ind:costImpactIndicator rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Indicator' ;
    rdfs:comment 'Indicates the directional cost impact of using the substitute component compared to the primary component, supporting cost management and COGS analysis without storing calculated values.' ;
    rdfs:domain ind:SubstituteComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportControlFlag rdf:type rdf:Property ;
    rdfs:label 'Export Control Flag' ;
    rdfs:comment 'Indicates whether the substitute component is subject to export control regulations (e.g., EAR, ITAR), which may restrict its use in certain geographies or customer applications and require additional compliance review.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadTimeDeltaDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Delta Days' ;
    rdfs:comment 'The difference in procurement or manufacturing lead time in days between the substitute component and the primary component (substitute lead time minus primary lead time). Negative values indicate faster availability. Used in MRP scheduling and supply chain resilience planning.' ;
    rdfs:domain ind:SubstituteComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mrpRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Mrp Relevance Flag' ;
    rdfs:comment 'Indicates whether this substitute component record is active and visible to the MRP engine for automatic exception handling and alternate material selection during planning runs.' ;
    rdfs:domain ind:SubstituteComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric rank indicating the preference order when multiple substitutes exist for the same primary component. Lower values indicate higher preference (1 = most preferred). Used by MRP to sequence substitute selection.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityConversionFactor rdf:type rdf:Property ;
    rdfs:label 'Quantity Conversion Factor' ;
    rdfs:comment 'Multiplier applied to the original BOM quantity when using the substitute component. A value of 1.0 means the substitute is used in the same quantity; values other than 1.0 indicate a quantity adjustment is required (e.g., 2.0 means twice as many substitutes are needed).' ;
    rdfs:domain ind:SubstituteComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedBy rdf:type rdf:Property ;
    rdfs:label 'Requested By' ;
    rdfs:comment 'Name or employee identifier of the person who initiated the request to establish this substitute component association, typically a supply chain planner, procurement specialist, or design engineer.' ;
    rdfs:domain ind:SubstituteComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresEngineeringApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Engineering Approval' ;
    rdfs:comment 'Indicates whether use of this substitute component requires explicit engineering sign-off prior to production use, beyond the standard approval captured in the status field.' ;
    rdfs:domain ind:SubstituteComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresQualityRevalidation rdf:type rdf:Property ;
    rdfs:label 'Requires Quality Revalidation' ;
    rdfs:comment 'Indicates whether use of this substitute component triggers a quality revalidation activity such as First Article Inspection (FAI), updated control plan, or re-qualification testing before production release.' ;
    rdfs:domain ind:SubstituteComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictionNotes rdf:type rdf:Property ;
    rdfs:label 'Restriction Notes' ;
    rdfs:comment 'Detailed notes describing any restrictions, limitations, or special handling instructions associated with using this substitute component, including regulatory, safety, or performance constraints.' ;
    rdfs:domain ind:SubstituteComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCostDelta rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Delta' ;
    rdfs:comment 'The difference in standard cost per unit between the substitute component and the primary component (substitute cost minus primary cost). Negative values indicate cost savings. Used for financial impact assessment and BOM costing.' ;
    rdfs:domain ind:SubstituteComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substitutionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Substitution Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why this substitute component was identified and approved. Supports root cause analysis, supply chain resilience reporting, and procurement strategy decisions.' ;
    rdfs:domain ind:SubstituteComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionType rdf:type rdf:Property ;
    rdfs:label 'Substitution Type' ;
    rdfs:comment 'Classification of the substitution relationship: \'full\' indicates the substitute is interchangeable in all contexts; \'conditional\' requires specific conditions to be met; \'temporary\' is time-bounded; \'emergency\' is approved only for urgent supply disruptions.' ;
    rdfs:domain ind:SubstituteComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useCondition rdf:type rdf:Property ;
    rdfs:label 'Use Condition' ;
    rdfs:comment 'Free-text or structured description of the specific conditions under which this substitute may be used, such as \'only when primary component stock is zero\', \'applicable for customer orders above 100 units\', or \'valid only for non-safety-critical assemblies\'.' ;
    rdfs:domain ind:SubstituteComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfUse rdf:type rdf:Property ;
    rdfs:label 'Country Of Use' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code indicating the country where this tooling is deployed. Supports multinational compliance, export control, and regional regulatory reporting.' ;
    rdfs:domain ind:ToolingEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cyclesUsed rdf:type rdf:Property ;
    rdfs:label 'Cycles Used' ;
    rdfs:comment 'Cumulative number of production cycles, shots, or strokes consumed against the rated tool life. Used to calculate remaining tool life and trigger preventive maintenance.' ;
    rdfs:domain ind:ToolingEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:designRevision rdf:type rdf:Property ;
    rdfs:label 'Design Revision' ;
    rdfs:comment 'Current engineering design revision level of the tooling item, aligned with the PLM/PDM revision control system. Changes are tracked via ECN/ECO workflows.' ;
    rdfs:domain ind:ToolingEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date on which the most recent preventive or corrective maintenance was completed on this tooling item.' ;
    rdfs:domain ind:ToolingEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Maintenance Interval Days' ;
    rdfs:comment 'Scheduled preventive maintenance interval in calendar days for this tooling item. Drives work order generation in Maximo EAM and SAP PM.' ;
    rdfs:domain ind:ToolingEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date on which the tooling item was manufactured or first commissioned. Used to calculate tool age, depreciation, and remaining useful life.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Due Date' ;
    rdfs:comment 'Scheduled date by which the next calibration must be completed to maintain compliance with quality management system requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Indicates whether the tooling is owned by the manufacturing company, a customer (customer-supplied tooling), a supplier, or leased. Drives asset accounting treatment and liability.' ;
    rdfs:domain ind:ToolingEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date on which the tooling was formally retired or scrapped. Populated when status transitions to \'retired\' or \'scrapped\'. Used for asset lifecycle reporting.' ;
    rdfs:domain ind:ToolingEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplierName rdf:type rdf:Property ;
    rdfs:label 'Supplier Name' ;
    rdfs:comment 'Name of the external vendor or toolmaker who manufactured or supplied this tooling item. Used for supplier performance tracking and warranty claims.' ;
    rdfs:domain ind:ToolingEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierToolNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Tool Number' ;
    rdfs:comment 'The toolmaker\'s or supplier\'s own reference number for this tooling item. Required for warranty claims, spare part ordering, and supplier communications.' ;
    rdfs:domain ind:ToolingEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolCategory rdf:type rdf:Property ;
    rdfs:label 'Tool Category' ;
    rdfs:comment 'Broader classification grouping tools by their lifecycle stage and investment level. Hard tooling is production-grade; soft tooling is used for prototyping or low-volume runs.' ;
    rdfs:domain ind:ToolingEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolLifeCycles rdf:type rdf:Property ;
    rdfs:label 'Tool Life Cycles' ;
    rdfs:comment 'Maximum rated tool life expressed in number of production cycles, shots, or strokes before the tool requires refurbishment or replacement. Used for predictive maintenance scheduling.' ;
    rdfs:domain ind:ToolingEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toolMaterial rdf:type rdf:Property ;
    rdfs:label 'Tool Material' ;
    rdfs:comment 'Primary material used in the construction of the tooling (e.g., \'H13 Tool Steel\', \'P20 Steel\', \'Aluminum 7075\', \'Carbide\', \'Hardened Steel\'). Influences tool life and maintenance requirements.' ;
    rdfs:domain ind:ToolingEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolNumber rdf:type rdf:Property ;
    rdfs:label 'Tool Number' ;
    rdfs:comment 'Business-assigned alphanumeric identifier for the tooling or equipment item, used across engineering, production, and maintenance systems. Corresponds to the tool number in SAP PM and Siemens Teamcenter.' ;
    rdfs:domain ind:ToolingEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolType rdf:type rdf:Property ;
    rdfs:label 'Tool Type' ;
    rdfs:comment 'Classification of the tooling or equipment by its functional category. Drives maintenance schedules, calibration requirements, and tool life tracking policies.' ;
    rdfs:domain ind:ToolingEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolWeightKg rdf:type rdf:Property ;
    rdfs:label 'Tool Weight Kg' ;
    rdfs:comment 'Physical weight of the tooling assembly in kilograms. Used for logistics planning, crane/lift requirements, and storage rack load calculations.' ;
    rdfs:domain ind:ToolingEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelId rdf:type rdf:Property ;
    rdfs:label 'Channel Id' ;
    rdfs:comment 'Foreign key linking to order.channel. Business justification: Each sales order line item is received through a specific sales channel (direct, distributor, EDI, portal, etc.). Linking line_item to channel enables channel-level reporting, SLA enforcement, commiss' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:priorityId rdf:type rdf:Property ;
    rdfs:label 'Priority Id' ;
    rdfs:comment 'Foreign key linking to order.priority. Business justification: Individual sales order line items carry fulfillment priority levels that drive production scheduling, warehouse pick priority, and expedited freight decisions. Linking line_item to the priority refere' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Priority .

ind:atpCtpConfirmed rdf:type rdf:Property ;
    rdfs:label 'Atp Ctp Confirmed' ;
    rdfs:comment 'Boolean flag indicating whether the line item quantity and delivery date have been confirmed through an Available to Promise (ATP) or Capable to Promise (CTP) check in SAP S/4HANA. True indicates a firm commitment has been made.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingBlock rdf:type rdf:Property ;
    rdfs:label 'Billing Block' ;
    rdfs:comment 'Code indicating a billing block applied to this line item, preventing invoice creation until the block is released (e.g., pending approval, dispute resolution). Corresponds to FAKSP in SAP VBAP.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'The delivery date confirmed by the system following ATP (Available to Promise) or CTP (Capable to Promise) check, representing the committed delivery date to the customer. May differ from requested delivery date.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryBlock rdf:type rdf:Property ;
    rdfs:label 'Delivery Block' ;
    rdfs:comment 'Code indicating a delivery block applied to this line item, preventing delivery processing until the block is released (e.g., credit block, quality hold, export control block). Corresponds to LIFSP in SAP VBAP.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPercent rdf:type rdf:Property ;
    rdfs:label 'Discount Percent' ;
    rdfs:comment 'Percentage discount applied to the gross price for this line item, resulting from customer-specific pricing agreements, volume discounts, or promotional pricing. Used for margin analysis and pricing agreement compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossPrice rdf:type rdf:Property ;
    rdfs:label 'Gross Price' ;
    rdfs:comment 'Gross list price per unit of measure before any discounts or pricing conditions are applied. Represents the catalog or list price for the product. Used for discount analysis and pricing strategy reporting.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:higherLevelItem rdf:type rdf:Property ;
    rdfs:label 'Higher Level Item' ;
    rdfs:comment 'Line item number of the parent item in a hierarchical order structure, used for sub-items, free goods, or configuration components linked to a main item. Corresponds to UEPOS in SAP VBAP. Null for top-level items.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastChangedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Changed Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to the order line item in the source SAP S/4HANA system. Used for change tracking, delta extraction, and audit compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'Net price per unit of measure for this line item after all applicable discounts and pricing conditions have been applied. Used for revenue recognition and order-to-cash reporting. Corresponds to NETPR in SAP VBAP.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netValue rdf:type rdf:Property ;
    rdfs:label 'Net Value' ;
    rdfs:comment 'Total net value of the line item calculated as net price multiplied by ordered quantity. Represents the line item revenue contribution before tax. Corresponds to NETWR in SAP VBAP.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'The quantity of the material or product requested by the customer on this line item, expressed in the sales unit of measure. Corresponds to KWMENG in SAP VBAP.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingDate rdf:type rdf:Property ;
    rdfs:label 'Pricing Date' ;
    rdfs:comment 'The date used to determine applicable pricing conditions, exchange rates, and discounts for this line item. Controls which pricing agreements and condition records are valid for price determination. Corresponds to PRSDT in SAP VBAP.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productHierarchy rdf:type rdf:Property ;
    rdfs:label 'Product Hierarchy' ;
    rdfs:comment 'SAP product hierarchy code classifying the ordered material within the product portfolio structure (e.g., automation systems, electrification solutions, smart infrastructure). Used for sales analysis and reporting by product group.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'The delivery date requested by the customer for this specific line item. Used as the baseline for ATP/CTP checks and delivery scheduling. Corresponds to VDATU in SAP VBAP.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Sales Unit Price' ;
    rdfs:comment 'Price per single unit of the sales unit of measure, used for unit-level pricing analysis and comparison. Distinct from net_price which may reflect pricing per pricing unit (e.g., per 100 units). Corresponds to KPEIN/KMEIN pricing unit logic in SAP.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleLineCount rdf:type rdf:Property ;
    rdfs:label 'Schedule Line Count' ;
    rdfs:comment 'Number of schedule lines (delivery splits) associated with this order line item, indicating how many separate delivery dates or partial shipments have been scheduled. A value greater than 1 indicates split deliveries.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shippingPoint rdf:type rdf:Property ;
    rdfs:label 'Shipping Point' ;
    rdfs:comment 'SAP shipping point from which the goods for this line item will be dispatched. Determines the physical departure location, shipping conditions, and transportation planning. Corresponds to VSTEL in SAP VBAP.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuNumber rdf:type rdf:Property ;
    rdfs:label 'Sku Number' ;
    rdfs:comment 'Stock Keeping Unit (SKU) identifier used for inventory tracking and warehouse management, representing the specific variant of the product being ordered. May differ from material number for configurable products.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'SAP storage location within the assigned plant from which the goods will be picked and shipped for this line item. Used for warehouse management and inventory allocation. Corresponds to LGORT in SAP VBAP.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Tax amount applicable to this line item based on the tax classification of the material and customer. Includes VAT, GST, or other applicable taxes depending on the jurisdiction.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotationId rdf:type rdf:Property ;
    rdfs:label 'Quotation Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying a commercial quotation record in the Silver layer lakehouse. Serves as the primary key for all downstream joins and lineage tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quotation .

ind:currencyExchangeRateId rdf:type rdf:Property ;
    rdfs:label 'Currency Exchange Rate Id' ;
    rdfs:comment 'Foreign key linking to finance.currency_exchange_rate. Business justification: Quotations for international manufacturing customers are issued in customer currency. The exchange rate at quotation time must be locked and referenced for accurate price-to-order conversion and finan' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CurrencyExchangeRate .

ind:rfqRequestId rdf:type rdf:Property ;
    rdfs:label 'Rfq Request Id' ;
    rdfs:comment 'Foreign key linking to order.rfq_request. Business justification: A quotation is issued in response to an RFQ/RFP. The string rfq_reference_number is replaced by FK rfq_request_id, establishing the quote-to-RFQ traceability.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RfqRequest .

ind:acceptedRejectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Accepted Rejected Timestamp' ;
    rdfs:comment 'Date and time at which the customer formally accepted or rejected the quotation. Used to calculate quotation cycle time and measure sales velocity.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:competitorName rdf:type rdf:Property ;
    rdfs:label 'Competitor Name' ;
    rdfs:comment 'Name of the competing supplier identified during the quotation process. Populated when the win/loss reason involves a competitor selection. Used for competitive intelligence and market share analysis.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convertedOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Converted Order Number' ;
    rdfs:comment 'SAP sales order number created when this quotation was accepted and converted. Populated only when status is \'converted\'. Enables end-to-end order-to-cash traceability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Account Number' ;
    rdfs:comment 'SAP customer account number (sold-to party) associated with this quotation. Links the quotation to the customer master record for credit, pricing, and order management purposes.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Lead Time Days' ;
    rdfs:comment 'Number of calendar days from order placement to expected delivery as quoted to the customer. Derived from production scheduling and logistics planning for the specific fulfillment mode.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grossValue rdf:type rdf:Property ;
    rdfs:label 'Gross Value' ;
    rdfs:comment 'Total gross value of the quotation before application of discounts, representing the sum of all line item list prices. Used for discount analysis and margin reporting.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Calendar date on which the quotation was formally issued and transmitted to the customer or prospect.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:opportunityReference rdf:type rdf:Property ;
    rdfs:label 'Opportunity Reference' ;
    rdfs:comment 'Reference identifier linking this quotation to the originating sales opportunity in Salesforce CRM. Supports opportunity-to-order conversion tracking and win/loss analysis.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Probability Percent' ;
    rdfs:comment 'Sales representative\'s estimated probability (0–100%) that this quotation will be accepted and converted to a sales order. Used for pipeline forecasting and revenue planning.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesOffice rdf:type rdf:Property ;
    rdfs:label 'Sales Office' ;
    rdfs:comment 'SAP sales office code identifying the geographic or organizational unit from which the quotation is issued. Supports regional sales performance reporting.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesRepresentative rdf:type rdf:Property ;
    rdfs:label 'Sales Representative' ;
    rdfs:comment 'Name or employee ID of the sales representative responsible for preparing and managing this quotation. Used for commission calculation, workload reporting, and customer relationship management.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the customer\'s ship-to destination. Used for export control screening, customs documentation, and logistics routing.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Date and time at which the quotation was formally submitted to the customer. Used for response time SLA measurement and sales process analytics.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:validityEndDate rdf:type rdf:Property ;
    rdfs:label 'Validity End Date' ;
    rdfs:comment 'Last calendar date through which the quoted prices, terms, and conditions remain valid for customer acceptance. After this date the quotation status transitions to \'expired\'.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'First calendar date from which the quoted prices, terms, and conditions are commercially binding and valid for customer acceptance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:winLossNotes rdf:type rdf:Property ;
    rdfs:label 'Win Loss Notes' ;
    rdfs:comment 'Free-text narrative providing additional context for the win or loss outcome beyond the structured reason code. Captured by the sales representative for qualitative pipeline analysis.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winLossReason rdf:type rdf:Property ;
    rdfs:label 'Win Loss Reason' ;
    rdfs:comment 'Categorized reason code explaining why the quotation was accepted (won) or rejected (lost). Critical input for sales analytics, pricing strategy, and competitive intelligence reporting.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotationLineItemId rdf:type rdf:Property ;
    rdfs:label 'Quotation Line Item Id' ;
    rdfs:comment 'Unique system-generated identifier for each individual line item within a commercial quotation. Serves as the primary key for the quotation_line_item entity.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QuotationLineItem .

ind:atpCtpMethod rdf:type rdf:Property ;
    rdfs:label 'Atp Ctp Method' ;
    rdfs:comment 'Method used to confirm the delivery date for this line item: Available-to-Promise (ATP) based on existing stock, Capable-to-Promise (CTP) based on production capacity, MTO lead time calculation, or manually set by sales.' ;
    rdfs:domain ind:QuotationLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationDescription rdf:type rdf:Property ;
    rdfs:label 'Configuration Description' ;
    rdfs:comment 'Human-readable summary of the product configuration options selected for this line item, including key technical specifications, options, and features. Supports customer-facing quotation documentation.' ;
    rdfs:domain ind:QuotationLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsTariffNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Tariff Number' ;
    rdfs:comment 'Harmonized System (HS) tariff classification number for the quoted product, used for customs declarations, import duty calculation, and trade compliance. Required for cross-border transactions.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineeringChangeNumber rdf:type rdf:Property ;
    rdfs:label 'Engineering Change Number' ;
    rdfs:comment 'Reference to the Engineering Change Notice (ECN) or Engineering Change Order (ECO) applicable to the quoted material at the time of quotation. Ensures the correct revision level is quoted and traceable.' ;
    rdfs:domain ind:QuotationLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNetValue rdf:type rdf:Property ;
    rdfs:label 'Line Net Value' ;
    rdfs:comment 'Total net value of this line item, calculated as quoted net price multiplied by quoted quantity. Represents the commercial value of this specific line in the quotation.' ;
    rdfs:domain ind:QuotationLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productGroup rdf:type rdf:Property ;
    rdfs:label 'Product Group' ;
    rdfs:comment 'Classification grouping for the quoted material, used for pricing, reporting, and sales analysis. Corresponds to the SAP material group or product hierarchy node.' ;
    rdfs:domain ind:QuotationLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotedNetPrice rdf:type rdf:Property ;
    rdfs:label 'Quoted Net Price' ;
    rdfs:comment 'Net unit price offered to the customer on this line item after all applicable discounts, surcharges, and pricing conditions have been applied. This is the contractually binding price per unit.' ;
    rdfs:domain ind:QuotationLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotedQuantity rdf:type rdf:Property ;
    rdfs:label 'Quoted Quantity' ;
    rdfs:comment 'The quantity of the material or product being quoted on this line item, expressed in the specified unit of measure. Basis for pricing and delivery planning.' ;
    rdfs:domain ind:QuotationLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonForRejection rdf:type rdf:Property ;
    rdfs:label 'Reason For Rejection' ;
    rdfs:comment 'Reason code or description explaining why this specific line item was rejected or removed from the quotation. Used for win/loss analysis and sales process improvement.' ;
    rdfs:domain ind:QuotationLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesUnit rdf:type rdf:Property ;
    rdfs:label 'Sales Unit' ;
    rdfs:comment 'Unit of measure used for sales and pricing purposes on this line item, which may differ from the base unit of measure in the material master (e.g., selling in sets while stocking in pieces).' ;
    rdfs:domain ind:QuotationLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subLineNumber rdf:type rdf:Property ;
    rdfs:label 'Sub Line Number' ;
    rdfs:comment 'Secondary sequence number used to identify sub-items or component breakdowns within a parent line item, supporting hierarchical line item structures common in Engineer-to-Order (ETO) and complex system quotations.' ;
    rdfs:domain ind:QuotationLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:surchargePercentage rdf:type rdf:Property ;
    rdfs:label 'Surcharge Percentage' ;
    rdfs:comment 'Percentage surcharge applied to the base price for this line item, covering special handling, expedite fees, hazardous material handling, or custom engineering premiums.' ;
    rdfs:domain ind:QuotationLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Tax classification code applicable to this line item, determining the applicable VAT, GST, or sales tax rate based on the product type and destination country. Used for tax calculation and compliance reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSpecSummary rdf:type rdf:Property ;
    rdfs:label 'Technical Spec Summary' ;
    rdfs:comment 'Condensed summary of the key technical specifications for the product or system being quoted on this line item, including performance parameters, ratings, and compliance certifications relevant to the customer\'s application.' ;
    rdfs:domain ind:QuotationLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Foreign key linking to sales.campaign. Business justification: RFQs in industrial manufacturing are frequently triggered by marketing campaigns (trade shows, product launches). Sales ops tracks which campaign sourced the RFQ to measure campaign ROI and pipeline c' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:applicationType rdf:type rdf:Property ;
    rdfs:label 'Application Type' ;
    rdfs:comment 'Classification of the end-use application domain for which the requested products or systems are intended. Drives product line routing, engineering specialization assignment, and market segment reporting.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedSalesEngineer rdf:type rdf:Property ;
    rdfs:label 'Assigned Sales Engineer' ;
    rdfs:comment 'Name or identifier of the sales engineer or application engineer responsible for managing the RFQ/RFP response. Drives accountability, workload tracking, and commission attribution.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedSalesOffice rdf:type rdf:Property ;
    rdfs:label 'Assigned Sales Office' ;
    rdfs:comment 'The sales office or regional sales unit responsible for managing the customer relationship and RFQ response. Used for territory management, revenue attribution, and regional performance reporting.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardedDate rdf:type rdf:Property ;
    rdfs:label 'Awarded Date' ;
    rdfs:comment 'The date on which the customer formally awarded the contract or purchase order to the company following the RFQ/RFP evaluation. Marks the transition from pre-sales to order management.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Budget Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the budget indication amount provided by the customer. Supports multi-currency commercial operations across global markets.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetIndicationAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Indication Amount' ;
    rdfs:comment 'The customer\'s indicated or estimated budget for the project or procurement as disclosed in the RFQ/RFP. Used for commercial feasibility assessment, pricing strategy, and win probability scoring.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorNames rdf:type rdf:Property ;
    rdfs:label 'Competitor Names' ;
    rdfs:comment 'Names of known competing suppliers or vendors also invited to respond to the RFQ/RFP. Used for competitive intelligence, bid strategy, and win/loss analysis.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements' ;
    rdfs:comment 'Customer-specified regulatory, safety, or certification requirements that the supplied products or systems must meet, such as CE Marking, UL certification, RoHS/REACH compliance, or IEC standards. Drives product compliance validation.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityAgreementRequired rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Agreement Required' ;
    rdfs:comment 'Indicates whether the customer requires a Non-Disclosure Agreement (NDA) or confidentiality agreement to be in place before technical details of the RFQ/RFP can be shared internally or with subcontractors.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryOfDelivery rdf:type rdf:Property ;
    rdfs:label 'Country Of Delivery' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the destination country where the ordered goods or systems are to be delivered. Drives export compliance checks, trade regulation screening, and logistics planning.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Reference Number' ;
    rdfs:comment 'The customer\'s own internal document or project reference number as provided on the RFQ/RFP submission. Used for cross-referencing with the customer\'s procurement system and for communication alignment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineReason rdf:type rdf:Property ;
    rdfs:label 'Decline Reason' ;
    rdfs:comment 'Standardized reason code explaining why the RFQ/RFP was declined, either by the company (no-bid decision) or by the customer (lost to competitor). Used for win/loss analysis and continuous improvement.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedContractValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Contract Value' ;
    rdfs:comment 'Internal estimate of the total contract value if the RFQ/RFP is won, used for pipeline reporting, revenue forecasting, and resource allocation decisions. Distinct from the customer\'s budget indication.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationCriteria rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria' ;
    rdfs:comment 'Description of the criteria the customer will use to evaluate and select a supplier response, such as price, technical compliance, delivery lead time, quality certifications, or after-sales support. Informs bid strategy and proposal emphasis.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaSignedDate rdf:type rdf:Property ;
    rdfs:label 'Nda Signed Date' ;
    rdfs:comment 'The date on which the Non-Disclosure Agreement (NDA) or confidentiality agreement was formally signed between the company and the customer for this RFQ/RFP. Required before sharing proprietary technical information.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentTermsRequested rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Requested' ;
    rdfs:comment 'The payment terms requested or indicated by the customer in the RFQ/RFP, such as net 30, net 60, or milestone-based payments. Used for credit assessment and commercial proposal structuring.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'The name of the customer\'s project or initiative for which the RFQ/RFP is being issued. Provides business context for the request and is used for opportunity tracking and pipeline reporting.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRequired rdf:type rdf:Property ;
    rdfs:label 'Quantity Required' ;
    rdfs:comment 'The total quantity of units, systems, or assemblies requested by the customer in the RFQ/RFP. Used for capacity planning, ATP/CTP checks, and commercial pricing calculations.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit Of Measure' ;
    rdfs:comment 'The unit of measure associated with the requested quantity (e.g., EA for each, SET for a system set, KG for weight-based items). Ensures accurate commercial and production planning interpretation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'The precise date and time at which the RFQ/RFP was received and registered in the system. Used for SLA compliance measurement, response time analytics, and audit trail.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'The date by which the customer requires delivery of the ordered goods or systems. Used for Available-to-Promise (ATP) and Capable-to-Promise (CTP) checks and production scheduling feasibility assessment.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:respondedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Responded Timestamp' ;
    rdfs:comment 'The precise date and time at which the formal quotation or proposal response was submitted to the customer. Used to measure response cycle time and SLA adherence.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'The deadline by which the customer requires a formal quotation or proposal response. Drives prioritization of sales and engineering resources and triggers escalation workflows when approaching.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rfpIndicator rdf:type rdf:Property ;
    rdfs:label 'Rfp Indicator' ;
    rdfs:comment 'Flag indicating whether the inbound request is a formal Request for Proposal (RFP) requiring a detailed technical and commercial proposal, as opposed to a standard Request for Quotation (RFQ) focused on pricing. True = RFP; False = RFQ.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfqNumber rdf:type rdf:Property ;
    rdfs:label 'Rfq Number' ;
    rdfs:comment 'Business-facing alphanumeric identifier assigned to the inbound RFQ or RFP document, used for cross-system reference and customer communication. Corresponds to the customer-provided document number or internally assigned tracking number.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'The date on which the customer or prospect formally submitted the RFQ or RFP to the company. Used to calculate response lead times and track compliance with response SLAs.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:technicalRequirementsSummary rdf:type rdf:Property ;
    rdfs:label 'Technical Requirements Summary' ;
    rdfs:comment 'Free-text summary of the customer\'s technical specifications, performance requirements, and engineering constraints as stated in the RFQ/RFP document. Provides context for application engineering and product configuration.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyRequirement rdf:type rdf:Property ;
    rdfs:label 'Warranty Requirement' ;
    rdfs:comment 'Customer-specified warranty duration, coverage scope, or warranty terms required for the products or systems being quoted. Informs commercial pricing, risk assessment, and after-sales service planning.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winProbabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Win Probability Percent' ;
    rdfs:comment 'Sales team\'s estimated probability (0-100%) of winning the RFQ/RFP and converting it to a sales order. Used for weighted pipeline reporting and revenue forecasting.' ;
    rdfs:domain ind:RfqRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:atpCtpCheckResult rdf:type rdf:Property ;
    rdfs:label 'Atp Ctp Check Result' ;
    rdfs:comment 'Result of the ATP (Available to Promise) or CTP (Capable to Promise) availability check performed for this schedule line. Indicates whether the full quantity was confirmed, partially confirmed, or not confirmed by the availability check engine.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryBlockReason rdf:type rdf:Property ;
    rdfs:label 'Delivery Block Reason' ;
    rdfs:comment 'Descriptive reason explaining why the delivery block was applied to this schedule line (e.g., \'Credit limit exceeded\', \'Export license pending\', \'Customer requested hold\'). Supports operational resolution workflows.' ;
    rdfs:domain ind:ScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryRelevanceIndicator rdf:type rdf:Property ;
    rdfs:label 'Delivery Relevance Indicator' ;
    rdfs:comment 'Indicates whether this schedule line is relevant for outbound delivery document creation. When false, the schedule line is informational only and will not trigger a delivery in the WMS/SD process.' ;
    rdfs:domain ind:ScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exportControlStatus rdf:type rdf:Property ;
    rdfs:label 'Export Control Status' ;
    rdfs:comment 'Status of export control compliance review for this schedule line. Indicates whether the shipment has been cleared for export, is pending license review, or is blocked due to export control regulations (e.g., EAR, ITAR, EU Dual-Use).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Status' ;
    rdfs:comment 'Current status of goods issue processing for this schedule line. Tracks whether goods have been fully issued, partially issued, or not yet issued from the warehouse, enabling fulfillment progress monitoring.' ;
    rdfs:domain ind:ScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousGoodsIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazardous Goods Indicator' ;
    rdfs:comment 'Indicates whether the material on this schedule line is classified as hazardous goods requiring special handling, packaging, and documentation during transportation. Triggers dangerous goods compliance checks.' ;
    rdfs:domain ind:ScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadingDate rdf:type rdf:Property ;
    rdfs:label 'Loading Date' ;
    rdfs:comment 'The planned date on which goods for this schedule line are to be loaded onto the transport vehicle at the shipping point. Used for warehouse and dock scheduling coordination.' ;
    rdfs:domain ind:ScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialAvailabilityDate rdf:type rdf:Property ;
    rdfs:label 'Material Availability Date' ;
    rdfs:comment 'The date by which the material must be available in the warehouse for picking and packing to meet the loading date. Derived from backward scheduling in SAP SD and used to trigger MRP requirements.' ;
    rdfs:domain ind:ScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overDeliveryTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Over Delivery Tolerance Pct' ;
    rdfs:comment 'The maximum percentage by which the delivered quantity may exceed the confirmed quantity without requiring a new order or customer approval. Used in goods receipt and delivery processing to handle minor quantity variances.' ;
    rdfs:domain ind:ScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partialDeliveryAllowed rdf:type rdf:Property ;
    rdfs:label 'Partial Delivery Allowed' ;
    rdfs:comment 'Indicates whether a partial delivery is permitted for this schedule line if the full confirmed quantity cannot be shipped on the confirmed delivery date. Drives ATP/CTP split logic and customer service decisions.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'The unit of measure (UoM) applicable to the confirmed, ordered, and delivered quantities on this schedule line (e.g., EA for each, KG for kilogram, M for meter). Aligns with SAP base unit of measure.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeCode rdf:type rdf:Property ;
    rdfs:label 'Route Code' ;
    rdfs:comment 'The transportation route code assigned to this schedule line, defining the path from shipping point to destination. Determines transit time, carrier selection, and transportation costs in the TMS.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportationPlanningDate rdf:type rdf:Property ;
    rdfs:label 'Transportation Planning Date' ;
    rdfs:comment 'The date by which transportation must be planned and arranged for this schedule line shipment. Used by the Transportation Management System (TMS) to initiate carrier booking and route planning.' ;
    rdfs:domain ind:ScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:underDeliveryTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Under Delivery Tolerance Pct' ;
    rdfs:comment 'The maximum percentage by which the delivered quantity may fall short of the confirmed quantity and still be considered a complete delivery. Prevents unnecessary open item management for minor shortfalls.' ;
    rdfs:domain ind:ScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Status History Id' ;
    rdfs:comment 'Unique surrogate identifier for each order status history record in the Silver Layer lakehouse. Serves as the primary key for the order_status_history data product.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversalReferenceStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Reversal Reference Status History Id' ;
    rdfs:comment 'Reference to the order_status_history_id of the original status transition that this record reverses. Enables bidirectional traceability between a reversal event and the original transition it corrects. NULL when is_reversal is FALSE.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StatusHistory .

ind:blockType rdf:type rdf:Property ;
    rdfs:label 'Block Type' ;
    rdfs:comment 'Categorizes the type of block applied or released during this status transition. Enables analysis of block frequency by type, resolution time, and impact on order-to-cash cycle time.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingReasonCode rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason Code' ;
    rdfs:comment 'SAP SD delivery or billing block reason code applied when the status transition results in an order being blocked (e.g., credit block, export control hold, quality hold). NULL when no block is applied. Aligns with SAP SD blocking reason configuration.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Change Reason Description' ;
    rdfs:comment 'Human-readable description of the reason for the status transition. Provides additional context beyond the reason code, including free-text notes entered by the user or generated by the system.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changedByUser rdf:type rdf:Property ;
    rdfs:label 'Changed By User' ;
    rdfs:comment 'System user ID or service account identifier of the actor who triggered the status transition. May represent a human user (SAP logon ID), an automated process (batch job), or an integration service account. Supports accountability and audit trail requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changedByUserName rdf:type rdf:Property ;
    rdfs:label 'Changed By User Name' ;
    rdfs:comment 'Display name of the user or process that triggered the status transition. Complements the user ID for human-readable audit reporting and compliance documentation.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text notes or comments entered by the user or system at the time of the status transition. Provides additional context, exception details, or customer communication notes not captured by structured reason codes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCheckResult rdf:type rdf:Property ;
    rdfs:label 'Credit Check Result' ;
    rdfs:comment 'Outcome of the credit check performed during this status transition, if applicable. Relevant for transitions involving credit status changes (e.g., order release from credit block). Aligns with SAP SD credit management integration.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationFromPreviousMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration From Previous Minutes' ;
    rdfs:comment 'Time elapsed in minutes between the previous status transition and this status transition. Enables cycle time analysis for each status stage, bottleneck identification, and order-to-cash process optimization.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exportControlCheckResult rdf:type rdf:Property ;
    rdfs:label 'Export Control Check Result' ;
    rdfs:comment 'Result of the export control compliance screening performed during this status transition. Relevant for orders involving controlled goods, dual-use items, or shipments to restricted countries. Supports regulatory compliance with EAR, ITAR, and EU dual-use regulations.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReversal rdf:type rdf:Property ;
    rdfs:label 'Is Reversal' ;
    rdfs:comment 'Indicates whether this status transition represents a reversal or rollback of a previous status change (e.g., un-cancelling an order, reversing a delivery confirmation). TRUE when the transition moves the order backward in its lifecycle. Supports exception and error analysis.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The order status value assigned as a result of this transition. Captures the \'to\' state in the status transition pair. Represents the current status of the order at the point of this event.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether a customer notification (e.g., order confirmation, shipment notification, cancellation notice) was sent as a result of this status transition. Supports customer communication compliance and SLA tracking.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The order status value immediately before this transition occurred. Captures the \'from\' state in the status transition pair. NULL for the initial status record when the order is first created.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseReasonCode rdf:type rdf:Property ;
    rdfs:label 'Release Reason Code' ;
    rdfs:comment 'Standardized code identifying the reason an order block or hold was released during this status transition (e.g., CREDIT_APPROVED, EXPORT_CLEARED, QUALITY_PASSED). NULL when the transition does not involve a release action.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether this status transition occurred after the SLA-defined deadline for reaching this status, constituting an SLA breach. TRUE when the transition is late relative to the SLA target. Supports SLA compliance reporting and customer service analytics.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Target Timestamp' ;
    rdfs:comment 'The SLA-defined deadline by which this status transition was expected to occur. Used to calculate SLA compliance and breach duration for order-to-cash process analytics.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceSystemTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Source System Transaction Reference' ;
    rdfs:comment 'Native transaction or document identifier from the originating system (e.g., SAP change document number, MES work order ID) that caused this status transition. Enables drill-back to the source system for detailed investigation.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangeDate rdf:type rdf:Property ;
    rdfs:label 'Status Change Date' ;
    rdfs:comment 'Calendar date on which the order status transition occurred. Used for day-level reporting, SLA breach detection, and order lifecycle analytics without requiring timestamp precision.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statusChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Status Change Timestamp' ;
    rdfs:comment 'Exact date and time (with timezone) when the order status transition occurred. Critical for SLA compliance tracking, order-to-cash cycle time analysis, and chronological audit trail reconstruction.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transitionType rdf:type rdf:Property ;
    rdfs:label 'Transition Type' ;
    rdfs:comment 'Classifies how the status transition was initiated — whether automatically by system rules (e.g., ATP/CTP check completion), manually by a user, via batch processing, or through system integration. Supports process automation analysis and exception management.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowInstanceReference rdf:type rdf:Property ;
    rdfs:label 'Workflow Instance Reference' ;
    rdfs:comment 'Identifier of the SAP workflow or business process instance that triggered or processed this status transition. Enables traceability from the status history record back to the originating workflow for process mining and automation analysis.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Order Confirmation Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying each order confirmation record in the Silver Layer lakehouse. Serves as the primary key for all downstream joins and lineage tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderConfirmation .

ind:creditCheckId rdf:type rdf:Property ;
    rdfs:label 'Credit Check Id' ;
    rdfs:comment 'Foreign key linking to order.credit_check. Business justification: Order confirmations include a credit status that reflects the outcome of the credit check performed before order validation. The credit_status STRING attribute is a denormalized snapshot of the credit' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditCheck .

ind:atpCtpCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Atp Ctp Check Status' ;
    rdfs:comment 'Result of the Available to Promise (ATP) or Capable to Promise (CTP) availability check performed in SAP S/4HANA prior to issuing the confirmation. Indicates whether confirmed delivery dates are backed by ATP stock availability or CTP production capacity.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedGrossValue rdf:type rdf:Property ;
    rdfs:label 'Confirmed Gross Value' ;
    rdfs:comment 'Total confirmed gross value of the order including all taxes and surcharges. Represents the total financial obligation communicated to the customer in the confirmation.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmedNetValue rdf:type rdf:Property ;
    rdfs:label 'Confirmed Net Value' ;
    rdfs:comment 'Total confirmed net value of the order as stated in the confirmation document, excluding taxes. Represents the contractual financial commitment. Expressed in the document currency.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmedTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Confirmed Tax Amount' ;
    rdfs:comment 'Total tax amount applicable to the confirmed order value, as calculated at the time of confirmation. Includes VAT, GST, or applicable sales tax based on ship-to jurisdiction.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countryOfDestination rdf:type rdf:Property ;
    rdfs:label 'Country Of Destination' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the final delivery destination for the confirmed order. Used for export control classification, customs documentation, VAT/GST determination, and REACH/RoHS compliance assessment.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Customer Acknowledgment Date' ;
    rdfs:comment 'Date on which the customer formally acknowledged and accepted the order confirmation. Used for contractual binding date determination and SLA compliance measurement.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerAcknowledgmentStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Acknowledgment Status' ;
    rdfs:comment 'Status indicating whether the customer has formally acknowledged receipt and acceptance of the order confirmation. \'Acknowledged\' confirms mutual agreement; \'Rejected\' triggers order revision workflow; \'No Response\' may trigger follow-up SLA.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDateDeviationDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Date Deviation Days' ;
    rdfs:comment 'Signed integer representing the difference in calendar days between the confirmed delivery date and the customer-requested delivery date. Negative values indicate early delivery; positive values indicate late delivery. Used for on-time delivery KPI reporting.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviationDescription rdf:type rdf:Property ;
    rdfs:label 'Deviation Description' ;
    rdfs:comment 'Free-text description of any deviations between the original customer order request and the confirmed order terms (e.g., \'Quantity reduced from 500 to 450 due to material shortage; delivery date shifted by 5 days\'). Populated only when deviation_flag is TRUE.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationFlag rdf:type rdf:Property ;
    rdfs:label 'Deviation Flag' ;
    rdfs:comment 'Boolean indicator set to TRUE when the confirmed order contains one or more deviations from the original customer order request (e.g., quantity shortfall, delivery date change, price adjustment). Triggers deviation notification workflow.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededByConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded By Confirmation Number' ;
    rdfs:comment 'Confirmation number of the revised confirmation that replaced this record when status is \'Superseded\'. Enables version chain traceability for audit and dispute resolution purposes.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timestamp rdf:type rdf:Property ;
    rdfs:label 'Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) at which the order confirmation was generated and dispatched. Supports audit trail requirements and SLA measurement at sub-day granularity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:atpCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Atp Commitment Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying each ATP/CTP commitment record in the Silver Layer lakehouse. Serves as the primary key for all downstream joins and lineage tracking.' ;
    rdfs:domain ind:AtpCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backorderQuantity rdf:type rdf:Property ;
    rdfs:label 'Backorder Quantity' ;
    rdfs:comment 'Quantity that could not be confirmed for the requested delivery date and is placed on backorder for future fulfillment. Calculated as requested_quantity minus confirmed_quantity. Critical for backlog management and customer communication.' ;
    rdfs:domain ind:AtpCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checkTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check Timestamp' ;
    rdfs:comment 'Date and time when the ATP/CTP availability check was executed in SAP S/4HANA. Critical for audit trails, commitment versioning, and identifying stale commitments that may need re-evaluation.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkingGroup rdf:type rdf:Property ;
    rdfs:label 'Checking Group' ;
    rdfs:comment 'SAP availability checking group assigned to the material master, controlling the scope of the availability check (e.g., individual requirements vs. collective requirements). Works in conjunction with the checking rule.' ;
    rdfs:domain ind:AtpCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkingRule rdf:type rdf:Property ;
    rdfs:label 'Checking Rule' ;
    rdfs:comment 'SAP checking rule code applied during the ATP/CTP availability check. Determines which stock categories, planned receipts, and replenishment elements are considered in the availability calculation (e.g., \'A\' for sales order check, \'B\' for delivery check).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentNumber rdf:type rdf:Property ;
    rdfs:label 'Commitment Number' ;
    rdfs:comment 'Business-facing alphanumeric identifier for the ATP/CTP commitment record as assigned by the SAP S/4HANA ATP engine. Used for cross-referencing with order management and logistics teams.' ;
    rdfs:domain ind:AtpCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentType rdf:type rdf:Property ;
    rdfs:label 'Commitment Type' ;
    rdfs:comment 'Indicates whether the delivery promise was generated via Available-to-Promise (ATP) logic based on existing stock and planned receipts, or Capable-to-Promise (CTP) logic based on production capacity and lead time feasibility.' ;
    rdfs:domain ind:AtpCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'Date and time when the ATP/CTP commitment was formally confirmed and saved to the sales order schedule line. Marks the point at which the delivery promise becomes binding for order fulfillment planning.' ;
    rdfs:domain ind:AtpCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cumulativeAtpQuantity rdf:type rdf:Property ;
    rdfs:label 'Cumulative Atp Quantity' ;
    rdfs:comment 'Cumulative ATP quantity across all future planning periods at the time of the check. Used in time-phased ATP logic to identify the earliest period with sufficient cumulative availability to fulfill the requested quantity.' ;
    rdfs:domain ind:AtpCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earliestDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Earliest Delivery Date' ;
    rdfs:comment 'Earliest date on which the full requested quantity could be delivered, as calculated by the ATP/CTP engine considering replenishment lead times, production scheduling, and transportation time. Used for alternative delivery date proposals.' ;
    rdfs:domain ind:AtpCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiry Timestamp' ;
    rdfs:comment 'Date and time after which the ATP/CTP commitment is no longer valid and must be re-evaluated. Relevant for quotation-based commitments and time-limited availability holds.' ;
    rdfs:domain ind:AtpCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiptElementNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Element Number' ;
    rdfs:comment 'Document number of the planned receipt element (e.g., planned order number, purchase order number, production order number) used to support the CTP commitment. Enables drill-down from the commitment to the underlying supply plan.' ;
    rdfs:domain ind:AtpCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptElementType rdf:type rdf:Property ;
    rdfs:label 'Receipt Element Type' ;
    rdfs:comment 'Type of planned receipt element (planned order, purchase order, production order, stock transfer order, scheduling agreement) that was used by the CTP engine to confirm the delivery date when current stock was insufficient.' ;
    rdfs:domain ind:AtpCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Order Configuration Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying a specific product configuration captured at the order line item level within SAP S/4HANA Variant Configuration (VC).' ;
    rdfs:domain ind:OrderConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Base Material Number' ;
    rdfs:comment 'SAP material number of the configurable base product (e.g., automation system, drive system, switchgear) from which variant characteristics are selected. Corresponds to the configurable material master in SAP MM.' ;
    rdfs:domain ind:OrderConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomExplosionReference rdf:type rdf:Property ;
    rdfs:label 'Bom Explosion Reference' ;
    rdfs:comment 'Reference identifier linking this configuration to the exploded Bill of Materials (BOM) generated by SAP Variant Configuration, used to identify the specific component set required for production of this configured product.' ;
    rdfs:domain ind:OrderConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomExplosionStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Explosion Status' ;
    rdfs:comment 'Current status of the BOM explosion process for this configuration, indicating whether the variant-specific component list has been successfully generated, is pending, in progress, or has encountered errors.' ;
    rdfs:domain ind:OrderConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationVariant rdf:type rdf:Property ;
    rdfs:label 'Certification Variant' ;
    rdfs:comment 'Customer-selected regional or industry certification variant for the configured product, determining the applicable regulatory marking and compliance documentation (e.g., CE for EU, UL for North America, ATEX for explosive atmospheres).' ;
    rdfs:domain ind:OrderConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characteristicProfileCode rdf:type rdf:Property ;
    rdfs:label 'Characteristic Profile Code' ;
    rdfs:comment 'Identifier of the SAP classification characteristic profile or configuration profile used to define the set of selectable variant characteristics for this product model, enabling traceability to the configuration knowledge base.' ;
    rdfs:domain ind:OrderConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorFinish rdf:type rdf:Property ;
    rdfs:label 'Color Finish' ;
    rdfs:comment 'Customer-selected color or surface finish variant for the configured product enclosure or housing (e.g., RAL 7035 light grey, RAL 9005 black), applicable for panel-mounted and standalone enclosure products.' ;
    rdfs:domain ind:OrderConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlType rdf:type rdf:Property ;
    rdfs:label 'Control Type' ;
    rdfs:comment 'Customer-selected motor or drive control method variant (e.g., scalar V/f control, sensorless vector, closed-loop vector with encoder, servo control), defining the control algorithm and hardware configuration.' ;
    rdfs:domain ind:OrderConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecnReference rdf:type rdf:Property ;
    rdfs:label 'Ecn Reference' ;
    rdfs:comment 'Reference to the Engineering Change Notice (ECN) or Engineering Change Order (ECO) that triggered a revision to this configuration, providing traceability between order configurations and engineering change management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enclosureType rdf:type rdf:Property ;
    rdfs:label 'Enclosure Type' ;
    rdfs:comment 'Customer-selected enclosure protection class for the configured product, defining the degree of protection against ingress of solid objects and liquids (IP rating per IEC 60529 or NEMA standard).' ;
    rdfs:domain ind:OrderConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameSize rdf:type rdf:Property ;
    rdfs:label 'Frame Size' ;
    rdfs:comment 'Customer-selected mechanical frame size designation for the configured product (e.g., FSA, FSB, FSC for drive systems; IEC frame sizes 63 to 355 for motors), determining physical dimensions and mounting footprint.' ;
    rdfs:domain ind:OrderConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputFrequency rdf:type rdf:Property ;
    rdfs:label 'Input Frequency' ;
    rdfs:comment 'Customer-selected mains supply frequency variant for the configured product (50Hz for European/Asian markets, 60Hz for North American markets, or universal 50/60Hz), determining hardware compatibility.' ;
    rdfs:domain ind:OrderConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCustomerApproved rdf:type rdf:Property ;
    rdfs:label 'Is Customer Approved' ;
    rdfs:comment 'Indicates whether the customer has formally approved the final product configuration, required for ETO and ATO orders before production release. Supports PPAP and FAI processes.' ;
    rdfs:domain ind:OrderConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFeasibilityConfirmed rdf:type rdf:Property ;
    rdfs:label 'Is Feasibility Confirmed' ;
    rdfs:comment 'Indicates whether engineering feasibility of the selected configuration has been confirmed by the engineering team, particularly relevant for ETO orders where custom configurations require technical review before production commitment.' ;
    rdfs:domain ind:OrderConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:motorSize rdf:type rdf:Property ;
    rdfs:label 'Motor Size' ;
    rdfs:comment 'Customer-selected motor power rating characteristic for drive systems and motor-integrated products (e.g., 0.75kW, 7.5kW, 110kW), applicable when the configurable product includes a motor or is a motor drive.' ;
    rdfs:domain ind:OrderConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputCurrentRating rdf:type rdf:Property ;
    rdfs:label 'Output Current Rating' ;
    rdfs:comment 'Customer-selected nominal output current rating for drive systems and power electronics products (e.g., 3.0A, 18.5A, 250A), a key sizing characteristic used for BOM explosion and component selection.' ;
    rdfs:domain ind:OrderConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceUplift rdf:type rdf:Property ;
    rdfs:label 'Price Uplift' ;
    rdfs:comment 'Additional price delta applied to the base product price due to the selected variant characteristics and options (e.g., premium communication protocol, ATEX certification, safety integration), expressed in the order currency.' ;
    rdfs:domain ind:OrderConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productModel rdf:type rdf:Property ;
    rdfs:label 'Product Model' ;
    rdfs:comment 'Commercial product model or product family name of the configurable product (e.g., SINAMICS G120, SIRIUS 3RV, SENTRON 3VA), as defined in the product catalog and PLM system.' ;
    rdfs:domain ind:OrderConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIntegrityLevel rdf:type rdf:Property ;
    rdfs:label 'Safety Integrity Level' ;
    rdfs:comment 'Customer-selected functional safety integrity level for the configured product, indicating the required safety performance level per IEC 62061 (SIL) or ISO 13849 (Performance Level), applicable for safety-integrated drives and automation systems.' ;
    rdfs:domain ind:OrderConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version number of the product configuration, incremented when customer-selected variant characteristics are revised or updated during the order lifecycle.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingConditionId rdf:type rdf:Property ;
    rdfs:label 'Pricing Condition Id' ;
    rdfs:comment 'Unique surrogate identifier for each pricing condition record in the silver layer lakehouse. Serves as the primary key for the pricing_condition data product.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessSequenceCode rdf:type rdf:Property ;
    rdfs:label 'Access Sequence Code' ;
    rdfs:comment 'Code identifying the access sequence used to find the applicable condition record. The access sequence defines the hierarchy of search keys (customer/material, price list, material group) used in pricing determination.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationType rdf:type rdf:Property ;
    rdfs:label 'Calculation Type' ;
    rdfs:comment 'Defines the mathematical method used to calculate the condition value: fixed monetary amount, percentage of a base, quantity-based rate, weight-based rate, volume-based rate, formula-driven, or group condition. Directly maps to SAP KONV-KRECH.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionBaseValue rdf:type rdf:Property ;
    rdfs:label 'Condition Base Value' ;
    rdfs:comment 'The base amount upon which the condition rate is applied to derive the condition value. For percentage-based conditions, this is the subtotal from the preceding pricing step.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conditionCategory rdf:type rdf:Property ;
    rdfs:label 'Condition Category' ;
    rdfs:comment 'High-level classification of the pricing condition into business categories: price (base price), discount (reduction), surcharge (addition), freight (logistics cost), tax (statutory levy), rebate, or bonus. Enables aggregated pricing analysis.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionExclusionGroup rdf:type rdf:Property ;
    rdfs:label 'Condition Exclusion Group' ;
    rdfs:comment 'Identifies the exclusion group to which this condition belongs. Conditions in the same exclusion group are mutually exclusive; only the most favorable or highest-priority condition is applied, preventing double discounting.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionInactiveReason rdf:type rdf:Property ;
    rdfs:label 'Condition Inactive Reason' ;
    rdfs:comment 'Reason code explaining why a pricing condition is inactive or was deactivated. Supports audit trail requirements and pricing dispute resolution in commercial transactions.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionOrigin rdf:type rdf:Property ;
    rdfs:label 'Condition Origin' ;
    rdfs:comment 'Indicates how the pricing condition was determined: automatically by the pricing engine, manually entered by a sales representative, derived from a contract, applied from a promotion, or set as an intercompany/transfer price.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionQuantity rdf:type rdf:Property ;
    rdfs:label 'Condition Quantity' ;
    rdfs:comment 'The quantity to which the condition rate applies. For per-unit pricing conditions, this is the reference quantity (e.g., price per 100 units). Directly maps to SAP KONV-KPEIN.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conditionRate rdf:type rdf:Property ;
    rdfs:label 'Condition Rate' ;
    rdfs:comment 'The rate or percentage used to compute the condition value before application to the base amount. For percentage discounts this is the discount rate; for per-unit surcharges this is the per-unit rate.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conditionRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Condition Record Number' ;
    rdfs:comment 'Business key identifying the pricing condition record as sourced from SAP S/4HANA SD pricing tables (KONV/KONP). Used to trace the condition back to the originating ERP record.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionStatus rdf:type rdf:Property ;
    rdfs:label 'Condition Status' ;
    rdfs:comment 'Current lifecycle status of the pricing condition record: active (applied in pricing), inactive (not applied), deleted (removed from document), blocked (temporarily suspended), or statistical (informational only, not included in net value).' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionTypeName rdf:type rdf:Property ;
    rdfs:label 'Condition Type Name' ;
    rdfs:comment 'Human-readable description of the condition type (e.g., \'Price List\', \'Customer-Specific Discount\', \'Freight Surcharge\', \'Value Added Tax\'). Supports business reporting and price transparency.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionUnit rdf:type rdf:Property ;
    rdfs:label 'Condition Unit' ;
    rdfs:comment 'Unit of measure associated with the condition rate (e.g., EA for each, KG for kilogram, PC for piece, TO for metric ton). Relevant for quantity- or weight-based pricing conditions.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionValue rdf:type rdf:Property ;
    rdfs:label 'Condition Value' ;
    rdfs:comment 'The monetary or percentage value of the pricing condition as applied to the sales document. For fixed-amount conditions this is the absolute value; for percentage conditions this is the computed monetary result.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerPriceGroup rdf:type rdf:Property ;
    rdfs:label 'Customer Price Group' ;
    rdfs:comment 'Customer pricing group classification used in pricing determination. Groups customers with similar pricing entitlements (e.g., key accounts, standard customers, government) to apply consistent pricing policies.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isStatistical rdf:type rdf:Property ;
    rdfs:label 'Is Statistical' ;
    rdfs:comment 'Indicates whether this condition is purely statistical (informational) and does not affect the net document value. Statistical conditions are used for reporting and analysis without impacting the price charged to the customer.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manualEntryAllowed rdf:type rdf:Property ;
    rdfs:label 'Manual Entry Allowed' ;
    rdfs:comment 'Indicates whether the condition value can be manually overridden by a sales representative. Controls pricing governance and ensures compliance with approved pricing policies.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialPriceGroup rdf:type rdf:Property ;
    rdfs:label 'Material Price Group' ;
    rdfs:comment 'Material pricing group classification used in pricing determination. Groups products with similar pricing characteristics (e.g., automation components, electrification products, spare parts) for efficient condition record maintenance.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingProcedureCode rdf:type rdf:Property ;
    rdfs:label 'Pricing Procedure Code' ;
    rdfs:comment 'Code identifying the pricing procedure (calculation schema) under which this condition is determined. Pricing procedures define the sequence and logic for price determination in SAP SD.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingProcedureCounter rdf:type rdf:Property ;
    rdfs:label 'Pricing Procedure Counter' ;
    rdfs:comment 'Counter within a pricing procedure step used to differentiate multiple conditions at the same step. Supports complex pricing schemas with multiple conditions at identical step positions.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pricingProcedureStep rdf:type rdf:Property ;
    rdfs:label 'Pricing Procedure Step' ;
    rdfs:comment 'Sequential step number within the pricing procedure at which this condition type is evaluated. Determines the order of price calculation and the base amount for percentage-based conditions.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rebateAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Rebate Agreement Number' ;
    rdfs:comment 'Reference to the rebate agreement under which this condition was generated. Applicable for rebate accrual conditions that accumulate over a period and are settled at agreement end.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleBasisType rdf:type rdf:Property ;
    rdfs:label 'Scale Basis Type' ;
    rdfs:comment 'Defines the dimension on which pricing scales are applied: quantity (volume discount tiers), value (revenue-based tiers), weight, volume, or no scale. Enables tiered pricing models common in industrial manufacturing contracts.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleQuantity rdf:type rdf:Property ;
    rdfs:label 'Scale Quantity' ;
    rdfs:comment 'The quantity threshold at which this pricing scale level applies. Used in conjunction with scale_basis_type to determine the applicable tier for volume-based pricing.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scaleValue rdf:type rdf:Property ;
    rdfs:label 'Scale Value' ;
    rdfs:comment 'The monetary value threshold at which this pricing scale level applies. Used for value-based tiered pricing where discounts or rates change based on order value brackets.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Tax Classification Code' ;
    rdfs:comment 'Tax classification code associated with tax-type conditions (e.g., VAT, GST, sales tax). Identifies the applicable tax category for statutory reporting and compliance with regional tax regulations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnsOrderId rdf:type rdf:Property ;
    rdfs:label 'Returns Order Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer return order (Return Material Authorization) record in the Databricks Silver Layer. Serves as the primary key for this entity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReturnsOrder .

ind:creditMemoArInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Ar Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.ar_invoice. Business justification: Returns orders generate credit memos (AR invoices with negative amounts) to refund customers. Accounts receivable uses this to process customer credits and reconcile payments.' ;
    rdfs:domain ind:ReturnsOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:originalGoodsIssueId rdf:type rdf:Property ;
    rdfs:label 'Original Goods Issue Id' ;
    rdfs:comment 'Foreign key linking to order.goods_issue. Business justification: A customer returns order (RMA) is the reverse logistics counterpart of an original goods issue event. Linking returns_order to the original goods_issue provides full forward-and-reverse traceability f' ;
    rdfs:domain ind:ReturnsOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsIssue .

ind:creditMemoRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Request Flag' ;
    rdfs:comment 'Indicates whether a credit memo request has been triggered in SAP S/4HANA FI/SD for this return order. When true, the accounts receivable team processes the credit memo to reverse the original invoice and issue a customer credit.' ;
    rdfs:domain ind:ReturnsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerReturnAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Return Authorization Number' ;
    rdfs:comment 'Authorization number provided by the customer (buyer) from their own internal system authorizing the return shipment. Used for cross-referencing with the customer\'s procurement or ERP system.' ;
    rdfs:domain ind:ReturnsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionCode rdf:type rdf:Property ;
    rdfs:label 'Disposition Code' ;
    rdfs:comment 'Final disposition decision for the returned material following quality inspection or goods receipt assessment. Determines the subsequent inventory movement: unrestricted stock reposting, scrap posting, transfer to refurbishment order, or vendor return.' ;
    rdfs:domain ind:ReturnsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Required Flag' ;
    rdfs:comment 'Indicates whether a quality inspection is required for the returned goods before disposition decision (restock, scrap, repair). When true, an inspection lot is created in SAP QM and the material is placed in quality inspection stock.' ;
    rdfs:domain ind:ReturnsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialConditionCode rdf:type rdf:Property ;
    rdfs:label 'Material Condition Code' ;
    rdfs:comment 'Assessment code describing the physical condition of the returned material upon receipt at the return plant. Determines disposition routing: restock, refurbish, scrap, or warranty repair. Captured during goods receipt or quality inspection.' ;
    rdfs:domain ind:ReturnsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netReturnValue rdf:type rdf:Property ;
    rdfs:label 'Net Return Value' ;
    rdfs:comment 'Net monetary value of the return order before tax, calculated as return quantity multiplied by the net unit price from the original sales order, less any applicable restocking fee. Forms the basis for credit memo creation in SAP FI.' ;
    rdfs:domain ind:ReturnsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'Date on which the return order was created in SAP S/4HANA SD. Used as the baseline date for return processing SLA measurement, credit memo aging, and return analytics.' ;
    rdfs:domain ind:ReturnsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedPickupDate rdf:type rdf:Property ;
    rdfs:label 'Requested Pickup Date' ;
    rdfs:comment 'Date requested by the customer or logistics team for pickup or collection of the returned goods from the customer\'s site. Used for reverse logistics scheduling and carrier coordination.' ;
    rdfs:domain ind:ReturnsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restockingFee rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee' ;
    rdfs:comment 'Fee charged to the customer for processing the return and restocking the material, deducted from the credit memo value. Applicable based on return reason code, material type, and contractual terms. Expressed in the transaction currency.' ;
    rdfs:domain ind:ReturnsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnDeliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Return Delivery Number' ;
    rdfs:comment 'SAP outbound/inbound delivery document number created for the physical return shipment. Used to track the reverse logistics movement from customer to return plant and triggers goods receipt posting upon arrival.' ;
    rdfs:domain ind:ReturnsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Return Order Number' ;
    rdfs:comment 'Business-facing return order document number assigned by SAP S/4HANA SD during RE order type creation (VA01). This is the externally visible RMA document number used in customer communications and logistics coordination.' ;
    rdfs:domain ind:ReturnsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnPlantCode rdf:type rdf:Property ;
    rdfs:label 'Return Plant Code' ;
    rdfs:comment 'SAP plant code identifying the manufacturing or distribution facility designated to receive and process the returned goods. Determines the inventory posting location, inspection routing, and applicable quality procedures.' ;
    rdfs:domain ind:ReturnsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnQuantity rdf:type rdf:Property ;
    rdfs:label 'Return Quantity' ;
    rdfs:comment 'Quantity of the material authorized for return, expressed in the base unit of measure. Drives credit memo value calculation, inventory reposting, and restocking fee computation.' ;
    rdfs:domain ind:ReturnsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Standardized reason code classifying why the customer is returning the material. Drives credit memo processing rules, restocking fee applicability, warranty claim routing, and quality management CAPA workflows. Sourced from SAP SD return reason configuration.' ;
    rdfs:domain ind:ReturnsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Return Reason Description' ;
    rdfs:comment 'Free-text description providing additional detail on the return reason beyond the standardized reason code. Captures customer-provided narrative or internal notes explaining the specific circumstances of the return.' ;
    rdfs:domain ind:ReturnsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaNumber rdf:type rdf:Property ;
    rdfs:label 'Rma Number' ;
    rdfs:comment 'Customer-facing Return Material Authorization number issued to the customer as authorization to ship back goods. This is the number the customer uses on their return shipment and is distinct from the internal SAP return order number.' ;
    rdfs:domain ind:ReturnsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Flag' ;
    rdfs:comment 'Indicates whether the return is associated with a warranty claim. When true, the return is linked to a warranty case in Salesforce Service Cloud and may trigger a CAPA investigation in the quality management system.' ;
    rdfs:domain ind:ReturnsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:committedQuantity rdf:type rdf:Property ;
    rdfs:label 'Committed Quantity' ;
    rdfs:comment 'Total quantity of material committed by the customer over the blanket order contract period. Expressed in the base unit of measure. Used for capacity planning and MRP.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Release Date' ;
    rdfs:comment 'Date on which the most recent delivery release was issued against this blanket order. Used for consumption tracking and agreement activity monitoring.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openQuantity rdf:type rdf:Property ;
    rdfs:label 'Open Quantity' ;
    rdfs:comment 'Remaining open quantity on the blanket order, calculated as committed quantity minus released quantity. Indicates how much of the customer commitment is yet to be fulfilled.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceUnit rdf:type rdf:Property ;
    rdfs:label 'Price Unit' ;
    rdfs:comment 'The quantity basis for the net unit price (e.g., price per 1 EA, per 100 PC, per 1000 KG). Required to correctly compute line values from quantity and price.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Pricing Agreement Reference' ;
    rdfs:comment 'Reference number of the associated customer pricing agreement or special pricing arrangement that governs the net prices and conditions applied to this blanket order.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseCreationProfile rdf:type rdf:Property ;
    rdfs:label 'Release Creation Profile' ;
    rdfs:comment 'SAP release creation profile controlling the automatic generation of delivery schedule releases (JIT and forecast delivery schedules) based on MRP and planning horizons.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceOverDeliveryPercent rdf:type rdf:Property ;
    rdfs:label 'Tolerance Over Delivery Percent' ;
    rdfs:comment 'Maximum percentage by which a delivery release quantity may exceed the scheduled quantity without triggering a goods receipt block. Defined per customer agreement.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceUnderDeliveryPercent rdf:type rdf:Property ;
    rdfs:label 'Tolerance Under Delivery Percent' ;
    rdfs:comment 'Maximum percentage by which a delivery release quantity may fall short of the scheduled quantity and still be accepted as complete by the customer.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentPlanId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Plan Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying a fulfillment execution plan record in the Databricks Silver Layer. Serves as the primary key for the order_fulfillment_plan entity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentPlan .

ind:inspectionLotId rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_lot. Business justification: Fulfillment plans in manufacturing must reference the associated inspection lot to confirm goods have passed quality checks before scheduling shipment. Planners use this link to gate delivery executio' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionLot .

ind:actualFulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Actual Fulfillment Date' ;
    rdfs:comment 'Date on which the fulfillment plan was actually completed and goods were confirmed as delivered. Used for on-time delivery performance measurement and order-to-cash cycle analysis.' ;
    rdfs:domain ind:FulfillmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bottleneckDescription rdf:type rdf:Property ;
    rdfs:label 'Bottleneck Description' ;
    rdfs:comment 'Free-text description of the identified bottleneck, including the constraining resource, material shortage, or process step causing the delay. Populated when bottleneck_flag is true.' ;
    rdfs:domain ind:FulfillmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bottleneckFlag rdf:type rdf:Property ;
    rdfs:label 'Bottleneck Flag' ;
    rdfs:comment 'Indicates whether a capacity or material bottleneck has been identified in the fulfillment plan that may jeopardize the planned delivery date. Triggers escalation and expediting workflows.' ;
    rdfs:domain ind:FulfillmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmed Timestamp' ;
    rdfs:comment 'Timestamp when the fulfillment plan was formally confirmed, indicating that production, procurement, and logistics commitments have been validated and the plan is executable.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryDelayDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Delay Days' ;
    rdfs:comment 'Number of calendar days by which the actual or projected fulfillment date exceeds the planned delivery date. Positive values indicate lateness; zero or negative values indicate on-time or early delivery.' ;
    rdfs:domain ind:FulfillmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionAlertCode rdf:type rdf:Property ;
    rdfs:label 'Exception Alert Code' ;
    rdfs:comment 'Standardized code identifying the type of exception or alert raised against this fulfillment plan. Used for exception-based management reporting and automated escalation routing.' ;
    rdfs:domain ind:FulfillmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionAlertDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Alert Description' ;
    rdfs:comment 'Detailed narrative describing the exception condition, its root cause, and the corrective actions being taken. Supports CAPA (Corrective and Preventive Action) documentation.' ;
    rdfs:domain ind:FulfillmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfilledQuantity rdf:type rdf:Property ;
    rdfs:label 'Fulfilled Quantity' ;
    rdfs:comment 'Quantity of goods actually delivered and confirmed as fulfilled against this plan. Used to calculate fulfillment completion percentage and identify shortfalls.' ;
    rdfs:domain ind:FulfillmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimeDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Flag' ;
    rdfs:comment 'Indicates whether the fulfillment plan was completed on or before the planned delivery date. Key input for OTD (On-Time Delivery) KPI reporting and customer service level measurement.' ;
    rdfs:domain ind:FulfillmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version number of the fulfillment plan, incremented each time the plan is revised due to schedule changes, capacity adjustments, or customer modifications. Supports plan change history tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Date' ;
    rdfs:comment 'Target date by which the goods are planned to be delivered to the customer or ship-to party, as committed in the fulfillment plan. Derived from ATP/CTP check results and production scheduling.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedGoodsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Planned Goods Issue Date' ;
    rdfs:comment 'Scheduled date for posting goods issue from the warehouse, marking the physical departure of goods from the plant. Triggers inventory reduction and initiates the billing process in SAP.' ;
    rdfs:domain ind:FulfillmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedProductionStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Production Start Date' ;
    rdfs:comment 'Scheduled date on which production activities for this fulfillment plan are planned to commence. Derived from backward scheduling based on the planned delivery date and production lead time.' ;
    rdfs:domain ind:FulfillmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:procurementOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Procurement Order Number' ;
    rdfs:comment 'Reference to the purchase order or procurement document in SAP Ariba or SAP S/4HANA MM created to source materials or components required for this fulfillment plan.' ;
    rdfs:domain ind:FulfillmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Production Order Number' ;
    rdfs:comment 'Reference to the production order created in SAP S/4HANA PP or Siemens Opcenter MES to manufacture the goods required for this fulfillment plan. Bridges the order domain with manufacturing execution.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionPlanner rdf:type rdf:Property ;
    rdfs:label 'Production Planner' ;
    rdfs:comment 'Name or employee ID of the production planner responsible for scheduling and monitoring the production activities associated with this fulfillment plan.' ;
    rdfs:domain ind:FulfillmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueId rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Id' ;
    rdfs:comment 'Unique surrogate identifier for the goods issue event record in the Silver layer lakehouse. Serves as the primary key for this entity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsIssue .

ind:actualGoodsIssueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Goods Issue Timestamp' ;
    rdfs:comment 'The precise date and time at which the goods issue was physically executed and posted in SAP S/4HANA. This timestamp is the definitive event marker for inventory reduction, revenue recognition eligibility, and order-to-cash milestone tracking.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryItemNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Item Number' ;
    rdfs:comment 'Line item number within the outbound delivery document corresponding to this goods issue line, enabling precise traceability between the delivery and the material document.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivery Quantity' ;
    rdfs:comment 'The quantity confirmed on the outbound delivery document for this item. Compared against issued_quantity to identify over/under-delivery situations and partial shipment scenarios.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentItemNumber rdf:type rdf:Property ;
    rdfs:label 'Document Item Number' ;
    rdfs:comment 'Line item number within the goods issue material document, identifying the specific material line within a multi-line goods issue posting.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsRecipient rdf:type rdf:Property ;
    rdfs:label 'Goods Recipient' ;
    rdfs:comment 'The name or identifier of the person or organizational unit designated as the recipient of the issued goods. Used for internal goods issue scenarios (e.g., production orders, cost centers) and for shipping documentation.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this goods issue record represents a reversal (cancellation) of a previously posted goods issue. When true, the issued_quantity will be negative and the original document reference is captured in reversal_reference_document.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReferenceDocument rdf:type rdf:Property ;
    rdfs:label 'Reversal Reference Document' ;
    rdfs:comment 'The original goods issue material document number that this record reverses. Populated only when reversal_flag is true, enabling audit trail linkage between the original posting and its cancellation.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unloadingPoint rdf:type rdf:Property ;
    rdfs:label 'Unloading Point' ;
    rdfs:comment 'The specific unloading point or dock at the customer\'s delivery address where the goods are to be received. Sourced from the customer master or delivery document and used for last-mile logistics coordination.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:value rdf:type rdf:Property ;
    rdfs:label 'Value' ;
    rdfs:comment 'The total inventory value of the issued goods in the document currency, calculated as issued quantity multiplied by the moving average price or standard cost. Represents the COGS impact and triggers revenue recognition eligibility.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseNumber rdf:type rdf:Property ;
    rdfs:label 'Warehouse Number' ;
    rdfs:comment 'The SAP Warehouse Management (WM) warehouse number associated with the storage location from which goods were issued. Used for detailed warehouse operations tracking and transfer order management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequiredAboveValue rdf:type rdf:Property ;
    rdfs:label 'Approval Required Above Value' ;
    rdfs:comment 'Order value threshold above which additional management approval is required before order confirmation for this channel. Supports internal controls and delegation of authority policies for high-value orders.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:atpCtpCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Atp Ctp Check Required' ;
    rdfs:comment 'Indicates whether Available to Promise (ATP) or Capable to Promise (CTP) availability checks are mandatory for orders received through this channel. Ensures delivery date commitments are validated against inventory and production capacity.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionEligible rdf:type rdf:Property ;
    rdfs:label 'Commission Eligible' ;
    rdfs:comment 'Indicates whether orders received through this channel are eligible for sales commission calculation. True for field sales, agent/rep, and distributor channels; typically false for EDI and e-commerce self-service channels.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percent' ;
    rdfs:comment 'Standard commission rate percentage applicable to orders processed through this channel. Used as the default rate in commission calculations for agent/rep and distributor channels. Confidential as it reflects commercial agreements.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Credit Check Required' ;
    rdfs:comment 'Indicates whether orders received through this channel require an automated credit check against the customer credit limit before order confirmation. Typically true for distributor and direct sales channels; may be false for pre-approved EDI or OEM partner channels.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crmChannelCode rdf:type rdf:Property ;
    rdfs:label 'Crm Channel Code' ;
    rdfs:comment 'Corresponding channel or lead source identifier in Salesforce CRM Sales Cloud. Enables cross-system reconciliation between SAP SD distribution channel records and CRM opportunity/lead source tracking for pipeline and conversion analytics.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannelCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Code' ;
    rdfs:comment 'SAP two-character distribution channel code (e.g., 10 for Direct Sales, 20 for Distributor) mapped to this order channel. Used in SAP SD order processing, pricing determination, and customer master assignment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediStandard rdf:type rdf:Property ;
    rdfs:label 'Edi Standard' ;
    rdfs:comment 'Electronic Data Interchange (EDI) messaging standard used by this channel for automated order transmission. EDIFACT is common in European and global trade; ANSI X12 is standard in North American manufacturing. NONE indicates non-EDI channels.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransactionSet rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Set' ;
    rdfs:comment 'EDI transaction set or message type used for order processing on this channel (e.g., 850 Purchase Order, 855 PO Acknowledgment for ANSI X12; ORDERS, ORDRSP for EDIFACT). Null for non-EDI channels.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportControlApplicable rdf:type rdf:Property ;
    rdfs:label 'Export Control Applicable' ;
    rdfs:comment 'Indicates whether orders processed through this channel are subject to export control regulations (e.g., EAR, ITAR, EU Dual-Use). Triggers export license checks and embargo screening during order processing for international channels.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxOrderValue rdf:type rdf:Property ;
    rdfs:label 'Max Order Value' ;
    rdfs:comment 'Maximum net order value (in the channel\'s default currency) permitted for orders submitted through this channel without additional approval. Orders exceeding this threshold trigger escalation workflows or require management authorization.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minOrderValue rdf:type rdf:Property ;
    rdfs:label 'Min Order Value' ;
    rdfs:comment 'Minimum net order value (in the channel\'s default currency) required for orders submitted through this channel. Orders below this threshold may be rejected or subject to a minimum order surcharge. Supports channel profitability management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderEntryMethod rdf:type rdf:Property ;
    rdfs:label 'Order Entry Method' ;
    rdfs:comment 'Method by which orders are entered into the order management system through this channel. Distinguishes manual entry by sales staff, automated EDI transmission, customer self-service via portal, API-based integration, and traditional communication methods.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Partner Agreement Number' ;
    rdfs:comment 'Reference number of the commercial agreement, distributor contract, OEM partnership agreement, or agent/representative contract governing the terms of this order channel. Links to the contract management system for terms and conditions enforcement.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalIntegrationReference rdf:type rdf:Property ;
    rdfs:label 'Portal Integration Reference' ;
    rdfs:comment 'Reference identifier or URL for the e-commerce portal, customer self-service portal, or partner portal integrated with this order channel. Used for technical integration mapping and portal performance monitoring.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalType rdf:type rdf:Property ;
    rdfs:label 'Portal Type' ;
    rdfs:comment 'Classification of the digital portal or platform associated with this order channel. Distinguishes between customer self-service portals, partner/distributor portals, OEM-specific portals, third-party marketplaces, and non-portal channels.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Sales Organization Code' ;
    rdfs:comment 'SAP sales organization code to which this order channel is assigned. Defines the legal entity and organizational unit responsible for selling through this channel. Enables channel performance reporting by sales organization.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaOrderConfirmationHours rdf:type rdf:Property ;
    rdfs:label 'Sla Order Confirmation Hours' ;
    rdfs:comment 'Service Level Agreement (SLA) target in hours for order confirmation after receipt through this channel. Defines the maximum acceptable time from order receipt to order confirmation, used for channel performance monitoring and customer SLA compliance.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicablePlantCode rdf:type rdf:Property ;
    rdfs:label 'Applicable Plant Code' ;
    rdfs:comment 'SAP plant code(s) for which this priority level configuration applies. Allows plant-specific lead time targets and scheduling weights to reflect differences in production capacity and capability across manufacturing sites.' ;
    rdfs:domain ind:Priority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableSalesOrganization rdf:type rdf:Property ;
    rdfs:label 'Applicable Sales Organization' ;
    rdfs:comment 'SAP sales organization code(s) for which this priority level is applicable. Supports multinational operations where priority definitions, lead times, and escalation rules may differ by regional sales organization.' ;
    rdfs:domain ind:Priority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Level' ;
    rdfs:comment 'Minimum organizational authority level required to approve assignment or upgrade of an order to this priority level. Enforces governance controls for high-urgency priorities that carry significant cost and resource implications.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorCode rdf:type rdf:Property ;
    rdfs:label 'Color Code' ;
    rdfs:comment 'Hexadecimal color code used to visually distinguish priority levels in shop floor Andon boards, MES dashboards, Power BI reports, and order management UI screens for rapid visual identification by operators and planners.' ;
    rdfs:domain ind:Priority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costSurchargePercent rdf:type rdf:Property ;
    rdfs:label 'Cost Surcharge Percent' ;
    rdfs:comment 'Percentage surcharge applied to the order net value to recover the incremental operational costs (overtime, expedited freight, premium materials sourcing) associated with fulfilling orders at this priority level.' ;
    rdfs:domain ind:Priority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Required Flag' ;
    rdfs:comment 'Indicates whether the customer must be proactively notified of priority assignment, status changes, or delivery updates for orders at this priority level, supporting SLA transparency and customer satisfaction management.' ;
    rdfs:domain ind:Priority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dedicatedResourceFlag rdf:type rdf:Property ;
    rdfs:label 'Dedicated Resource Flag' ;
    rdfs:comment 'Indicates whether orders at this priority level require dedicated production resources (machines, operators, cells) to be reserved exclusively for their fulfillment, preventing resource sharing with lower-priority orders.' ;
    rdfs:domain ind:Priority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Days' ;
    rdfs:comment 'Number of days before the target ship date at which an unshipped order at this priority level triggers an automatic escalation notification to operations management and customer service.' ;
    rdfs:domain ind:Priority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expeditedFreightFlag rdf:type rdf:Property ;
    rdfs:label 'Expedited Freight Flag' ;
    rdfs:comment 'Indicates whether orders at this priority level are automatically routed to expedited or premium freight carriers to meet compressed delivery timelines, triggering premium freight cost allocation in the TMS.' ;
    rdfs:domain ind:Priority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fulfillmentModeApplicability rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Mode Applicability' ;
    rdfs:comment 'Specifies which order fulfillment modes (Make to Order, Make to Stock, Engineer to Order, Assemble to Order, or all modes) this priority level is applicable to, ensuring correct priority assignment during order entry and ATP/CTP checks.' ;
    rdfs:domain ind:Priority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iconCode rdf:type rdf:Property ;
    rdfs:label 'Icon Code' ;
    rdfs:comment 'Icon identifier or symbol code used in UI systems and dashboards to visually represent the priority level alongside the color code, supporting rapid visual triage on shop floor HMI screens and order management portals.' ;
    rdfs:domain ind:Priority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxOrderValueThreshold rdf:type rdf:Property ;
    rdfs:label 'Max Order Value Threshold' ;
    rdfs:comment 'Maximum order net value (in base currency) up to which this priority level can be assigned without additional financial approval. Orders exceeding this threshold require escalated authorization to control premium fulfillment cost exposure.' ;
    rdfs:domain ind:Priority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npsImpactLevel rdf:type rdf:Property ;
    rdfs:label 'Nps Impact Level' ;
    rdfs:comment 'Qualitative assessment of the potential impact on customer Net Promoter Score (NPS) if orders at this priority level are not fulfilled on time. Used to prioritize customer communication and recovery actions.' ;
    rdfs:domain ind:Priority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtimeAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Overtime Authorization Flag' ;
    rdfs:comment 'Indicates whether orders assigned this priority level automatically authorize shop floor overtime to meet the target lead time, enabling MES and workforce scheduling systems to plan extended shifts without separate approval.' ;
    rdfs:domain ind:Priority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionSchedulingWeight rdf:type rdf:Property ;
    rdfs:label 'Production Scheduling Weight' ;
    rdfs:comment 'Numeric weighting factor applied by the MES and MRP scheduling engine to sequence production jobs for orders at this priority level. Higher values result in earlier scheduling slots and preferential resource allocation.' ;
    rdfs:domain ind:Priority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rank rdf:type rdf:Property ;
    rdfs:label 'Rank' ;
    rdfs:comment 'Numeric rank defining the relative urgency ordering of priority levels, where lower values indicate higher urgency (e.g., 1 = Emergency, 2 = Critical, 3 = Expedite, 4 = Strategic Account, 5 = Standard). Used for automated sequencing logic.' ;
    rdfs:domain ind:Priority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaBreachNotificationHours rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Notification Hours' ;
    rdfs:comment 'Number of hours before the committed delivery deadline at which an automated SLA breach warning notification is triggered for orders at this priority level, enabling proactive intervention by customer service and operations teams.' ;
    rdfs:domain ind:Priority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:strategicAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Strategic Account Flag' ;
    rdfs:comment 'Indicates whether this priority level is reserved for orders from designated strategic accounts (key customers with high revenue, long-term contracts, or critical partnership status), enabling preferential treatment in fulfillment sequencing.' ;
    rdfs:domain ind:Priority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierExpediteFlag rdf:type rdf:Property ;
    rdfs:label 'Supplier Expedite Flag' ;
    rdfs:comment 'Indicates whether procurement teams should automatically initiate supplier expediting actions (accelerated PO delivery, premium sourcing) for materials required to fulfill orders at this priority level.' ;
    rdfs:domain ind:Priority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetOrderToShipLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Target Order To Ship Lead Time Days' ;
    rdfs:comment 'Target number of calendar days from order receipt to shipment dispatch for orders assigned this priority level. Used as the baseline commitment for SLA management and ATP/CTP confirmation.' ;
    rdfs:domain ind:Priority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warehousePickPriority rdf:type rdf:Property ;
    rdfs:label 'Warehouse Pick Priority' ;
    rdfs:comment 'Numeric priority value passed to the WMS (Infor WMS) to sequence warehouse pick tasks for outbound shipments. Lower values indicate higher pick urgency and earlier task assignment to warehouse operatives.' ;
    rdfs:domain ind:Priority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availableCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Available Credit Amount' ;
    rdfs:comment 'Remaining credit available to the customer at the time of the check, calculated as credit limit minus current exposure. A negative value indicates the customer has exceeded their credit limit.' ;
    rdfs:domain ind:CreditCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checkDate rdf:type rdf:Property ;
    rdfs:label 'Check Date' ;
    rdfs:comment 'The calendar date on which the credit check evaluation was performed against the customer\'s credit account, used for aging analysis and audit trails.' ;
    rdfs:domain ind:CreditCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'Business-facing alphanumeric reference number assigned to the credit check evaluation, used for cross-referencing in order management and financial controls.' ;
    rdfs:domain ind:CreditCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkType rdf:type rdf:Property ;
    rdfs:label 'Check Type' ;
    rdfs:comment 'Classification of the credit check method applied. Static checks compare current exposure against a fixed credit limit. Dynamic checks include open orders and deliveries in the exposure calculation. Manual checks are initiated by a credit analyst.' ;
    rdfs:domain ind:CreditCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHorizonDate rdf:type rdf:Property ;
    rdfs:label 'Credit Horizon Date' ;
    rdfs:comment 'Future date up to which open sales orders and deliveries are included in the dynamic credit exposure calculation. Orders with delivery dates beyond this horizon are excluded from the exposure.' ;
    rdfs:domain ind:CreditCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'The maximum approved credit exposure amount authorized for the customer within the credit control area at the time of the credit check. Represents the ceiling against which current exposure is measured.' ;
    rdfs:domain ind:CreditCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Current Exposure Amount' ;
    rdfs:comment 'Total credit exposure of the customer at the time of the credit check, including open receivables, open sales orders, open deliveries, and open billing documents. Compared against the credit limit to determine check outcome.' ;
    rdfs:domain ind:CreditCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openDeliveriesAmount rdf:type rdf:Property ;
    rdfs:label 'Open Deliveries Amount' ;
    rdfs:comment 'Total value of goods delivered to the customer but not yet invoiced, included in the dynamic credit exposure calculation to capture unbilled revenue risk.' ;
    rdfs:domain ind:CreditCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openOrdersAmount rdf:type rdf:Property ;
    rdfs:label 'Open Orders Amount' ;
    rdfs:comment 'Total value of open (undelivered) sales orders for the customer included in the dynamic credit exposure calculation, representing committed but not yet invoiced revenue.' ;
    rdfs:domain ind:CreditCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openReceivablesAmount rdf:type rdf:Property ;
    rdfs:label 'Open Receivables Amount' ;
    rdfs:comment 'Total value of outstanding accounts receivable (unpaid invoices) from the customer included in the dynamic credit exposure calculation at the time of the check.' ;
    rdfs:domain ind:CreditCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderValueAmount rdf:type rdf:Property ;
    rdfs:label 'Order Value Amount' ;
    rdfs:comment 'Net value of the sales order that triggered the credit check. This amount is included in the exposure calculation to determine whether the order can be approved within the customer\'s available credit.' ;
    rdfs:domain ind:CreditCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Indicates whether the credit check result was manually overridden by an authorized user, bypassing the automated credit evaluation outcome. Critical for audit and SOX compliance tracking.' ;
    rdfs:domain ind:CreditCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Free-text justification provided by the authorized user when overriding the automated credit check result, required for audit trail and financial controls compliance.' ;
    rdfs:domain ind:CreditCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentIndex rdf:type rdf:Property ;
    rdfs:label 'Payment Index' ;
    rdfs:comment 'Numerical score reflecting the customer\'s historical payment behavior and timeliness, used as an input to the credit risk assessment. Higher values indicate better payment performance.' ;
    rdfs:domain ind:CreditCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseAuthorizationLevel rdf:type rdf:Property ;
    rdfs:label 'Release Authorization Level' ;
    rdfs:comment 'Authorization level required to release a blocked sales order from credit hold. Higher levels indicate greater credit exposure or risk, requiring more senior approval to release.' ;
    rdfs:domain ind:CreditCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Release Timestamp' ;
    rdfs:comment 'Date and time when a blocked sales order was released from credit hold by an authorized user, used for SLA measurement and audit compliance in the order-to-cash process.' ;
    rdfs:domain ind:CreditCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releasedBy rdf:type rdf:Property ;
    rdfs:label 'Released By' ;
    rdfs:comment 'User ID or name of the credit analyst or manager who authorized the release of a blocked sales order from credit hold, supporting audit trail and segregation of duties compliance.' ;
    rdfs:domain ind:CreditCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Risk classification assigned to the customer at the time of the credit check, derived from the customer\'s credit profile, payment history, and financial standing. Used to determine credit check rules and thresholds.' ;
    rdfs:domain ind:CreditCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Utilization Percent' ;
    rdfs:comment 'Percentage of the customer\'s credit limit consumed by current exposure at the time of the credit check. Calculated as (current_exposure_amount / credit_limit_amount) * 100. Used for risk monitoring and reporting.' ;
    rdfs:domain ind:CreditCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plmClassificationId rdf:type rdf:Property ;
    rdfs:label 'Plm Classification Id' ;
    rdfs:comment 'Identifier of the corresponding classification node in Siemens Teamcenter PLM. Enables cross-system alignment between the commercial product hierarchy (SAP) and the engineering product structure (PLM).' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Classification .

ind:businessSegment rdf:type rdf:Property ;
    rdfs:label 'Business Segment' ;
    rdfs:comment 'Name of the reportable business segment (as defined under IFRS 8 / ASC 280) to which this hierarchy node contributes. Used for segment-level P&L reporting and investor disclosures.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCode rdf:type rdf:Property ;
    rdfs:label 'External Code' ;
    rdfs:comment 'Product hierarchy code used in external-facing systems such as customer portals, distributor catalogs, or EDI transactions. May differ from the internal SAP hierarchy node code.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpcCode rdf:type rdf:Property ;
    rdfs:label 'Gpc Code' ;
    rdfs:comment 'GS1 Global Product Classification brick code that maps this internal hierarchy node to the globally standardized product classification schema. Enables cross-industry product data exchange and benchmarking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLeafNode rdf:type rdf:Property ;
    rdfs:label 'Is Leaf Node' ;
    rdfs:comment 'Indicates whether this node is a terminal leaf node in the hierarchy (i.e., it has no child nodes). Leaf nodes represent the lowest level of classification (Product Line) to which SKUs are directly assigned.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRevenueReportingNode rdf:type rdf:Property ;
    rdfs:label 'Is Revenue Reporting Node' ;
    rdfs:comment 'Indicates whether this hierarchy node is designated as a revenue reporting aggregation point in financial and management reporting. Nodes flagged true are used in P&L roll-up and EBITDA reporting by product line.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:levelType rdf:type rdf:Property ;
    rdfs:label 'Level Type' ;
    rdfs:comment 'Business label for the hierarchy depth of this node. Defines whether the node represents a Product Division, Product Family, Product Group, or Product Line. Enables consistent labeling in reports and catalog navigation.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current stage of the product portfolio lifecycle for this hierarchy node, based on the standard product lifecycle model. Used in portfolio management, investment prioritization, and discontinuation planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longName rdf:type rdf:Property ;
    rdfs:label 'Long Name' ;
    rdfs:comment 'Full descriptive name of the hierarchy node used in catalog navigation, customer-facing materials, and detailed reporting. Maximum 40 characters per SAP S/4HANA product hierarchy configuration.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeCode rdf:type rdf:Property ;
    rdfs:label 'Node Code' ;
    rdfs:comment 'Alphanumeric code uniquely identifying this node within the product hierarchy tree. Corresponds to the SAP S/4HANA product hierarchy key (up to 18 characters). Used as the natural business key for cross-system integration.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productManager rdf:type rdf:Property ;
    rdfs:label 'Product Manager' ;
    rdfs:comment 'Name or employee identifier of the product manager accountable for the product classification represented by this hierarchy node. Used for escalation, catalog governance, and stakeholder communication.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryScope rdf:type rdf:Property ;
    rdfs:label 'Regulatory Scope' ;
    rdfs:comment 'Comma-separated list of applicable regulatory frameworks and compliance standards for products in this hierarchy node (e.g., CE, UL, RoHS, REACH, IEC 62443). Supports compliance tracking and certification management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleOrgUnit rdf:type rdf:Property ;
    rdfs:label 'Responsible Org Unit' ;
    rdfs:comment 'Name or code of the business unit or product management organization responsible for maintaining and governing this hierarchy node. Supports accountability and change management workflows.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapHierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Sap Hierarchy Path' ;
    rdfs:comment 'Full concatenated hierarchy path string as stored in SAP S/4HANA (e.g., \'00100010001\'). Represents the complete ancestry chain from root to this node using fixed-length segment codes. Used for SAP-native hierarchy queries and integration.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated display name for the hierarchy node, used in space-constrained UI elements, reports, and dashboard labels. Maximum 20 characters per SAP S/4HANA product hierarchy configuration.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Numeric sequence controlling the display order of sibling nodes within the same parent in catalog navigation, reports, and UI tree views. Lower values appear first.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:strategicInitiative rdf:type rdf:Property ;
    rdfs:label 'Strategic Initiative' ;
    rdfs:comment 'Name or code of the corporate strategic initiative or growth program associated with this product hierarchy node (e.g., Digital Factory, Green Energy Transition, Smart Buildings). Supports portfolio-level strategic planning and investment tracking.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyPlatform rdf:type rdf:Property ;
    rdfs:label 'Technology Platform' ;
    rdfs:comment 'Name of the underlying technology platform or architecture associated with products in this hierarchy node (e.g., TIA Portal, SIMATIC, SENTRON). Supports technology roadmap planning and R&D investment allocation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unspscCode rdf:type rdf:Property ;
    rdfs:label 'Unspsc Code' ;
    rdfs:comment 'UNSPSC code mapping this hierarchy node to the United Nations Standard Products and Services Classification. Used in procurement, sourcing (SAP Ariba), and spend analytics for category management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableCertification rdf:type rdf:Property ;
    rdfs:label 'Applicable Certification' ;
    rdfs:comment 'Pipe-separated list of regulatory certifications or standards applicable to this feature selection (e.g., \'CE|UL|RoHS|REACH|IECEx|ATEX\'). Drives compliance documentation requirements in order management and export control processes.' ;
    rdfs:domain ind:ProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compatibleProductFamilies rdf:type rdf:Property ;
    rdfs:label 'Compatible Product Families' ;
    rdfs:comment 'Pipe-separated list of product family codes or platform identifiers with which this configuration model is compatible. Supports cross-sell, upsell, and system integration recommendations in CPQ and CRM.' ;
    rdfs:domain ind:ProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Constraint Rule Description' ;
    rdfs:comment 'Plain-language description of the configuration constraint rule for business users and CPQ administrators (e.g., \'High voltage 690V selection requires minimum IP54 enclosure protection rating for safety compliance\').' ;
    rdfs:domain ind:ProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintRuleExpression rdf:type rdf:Property ;
    rdfs:label 'Constraint Rule Expression' ;
    rdfs:comment 'Formal logical expression or condition defining the configuration constraint rule (e.g., \'IF VOLTAGE = 690V THEN ENCLOSURE_RATING IN (IP54, IP65)\'). Encoded in SAP S/4HANA dependency syntax or Teamcenter configurator rule language.' ;
    rdfs:domain ind:ProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintType rdf:type rdf:Property ;
    rdfs:label 'Constraint Type' ;
    rdfs:comment 'Type of configuration constraint rule governing the relationship between feature selections. INCOMPATIBLE prevents two features from being selected together; REQUIRES mandates a dependent selection; EXCLUDES prevents a feature when another is chosen; CONDITIONAL applies rules based on other selections.' ;
    rdfs:domain ind:ProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpqVisibilityRule rdf:type rdf:Property ;
    rdfs:label 'Cpq Visibility Rule' ;
    rdfs:comment 'Conditional expression determining when an option class or feature is visible to the user in the CPQ configurator interface. Controls dynamic display logic based on prior selections (e.g., show REDUNDANCY_MODULE option only when POWER_RATING >= 75KW).' ;
    rdfs:domain ind:ProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displaySequence rdf:type rdf:Property ;
    rdfs:label 'Display Sequence' ;
    rdfs:comment 'Numeric ordering sequence for presenting option classes and feature codes in CPQ configurator interfaces, sales order entry screens, and product catalogs. Lower numbers appear first in the configuration workflow.' ;
    rdfs:domain ind:ProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:featureCode rdf:type rdf:Property ;
    rdfs:label 'Feature Code' ;
    rdfs:comment 'Selectable feature or characteristic value code within an option class (e.g., \'400V\', \'IP65\', \'PROFINET\', \'75KW\'). Represents a specific configurable option that can be selected during CPQ or order entry. Maps to SAP S/4HANA characteristic values.' ;
    rdfs:domain ind:ProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureDescription rdf:type rdf:Property ;
    rdfs:label 'Feature Description' ;
    rdfs:comment 'Full descriptive text for the selectable feature code, providing technical and commercial context for the option (e.g., \'400V Three-Phase Input\', \'IP65 Dust-Tight and Water-Jet Protected Enclosure\', \'PROFINET Industrial Ethernet Interface\').' ;
    rdfs:domain ind:ProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultValue rdf:type rdf:Property ;
    rdfs:label 'Is Default Value' ;
    rdfs:comment 'Indicates whether this feature code is the default pre-selected value for its option class when no explicit customer selection is made. Default values streamline CPQ configuration and reduce order entry errors.' ;
    rdfs:domain ind:ProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'Version number of the configuration model, following semantic versioning conventions. Tracks revisions to the configuration model structure, option classes, and constraint rules over time.' ;
    rdfs:domain ind:ProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionClassCode rdf:type rdf:Property ;
    rdfs:label 'Option Class Code' ;
    rdfs:comment 'Code identifying the option class (characteristic group) within the configuration model, such as VOLTAGE, ENCLOSURE_RATING, COMM_PROTOCOL, MOTOR_SIZE, or COOLING_TYPE. Corresponds to SAP S/4HANA characteristic classes in variant configuration.' ;
    rdfs:domain ind:ProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionClassName rdf:type rdf:Property ;
    rdfs:label 'Option Class Name' ;
    rdfs:comment 'Descriptive name of the option class, providing a human-readable label for the configurable characteristic group (e.g., \'Input Voltage Range\', \'Enclosure Protection Rating\', \'Communication Protocol Interface\').' ;
    rdfs:domain ind:ProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingCurrency rdf:type rdf:Property ;
    rdfs:label 'Pricing Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the pricing impact value (e.g., USD, EUR, GBP, CNY). Supports multi-currency pricing in global CPQ and sales order processes.' ;
    rdfs:domain ind:ProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingImpactType rdf:type rdf:Property ;
    rdfs:label 'Pricing Impact Type' ;
    rdfs:comment 'Defines how the selection of this feature code affects the product price in CPQ pricing calculations. FIXED_ADDER adds a fixed amount; PERCENTAGE_ADDER applies a percentage uplift; MULTIPLIER scales the base price; BASE_PRICE sets the starting price; NO_IMPACT has no pricing effect.' ;
    rdfs:domain ind:ProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingImpactValue rdf:type rdf:Property ;
    rdfs:label 'Pricing Impact Value' ;
    rdfs:comment 'Numeric value associated with the pricing impact type for this feature selection (e.g., fixed adder amount in base currency, percentage uplift rate, or multiplier factor). Used in CPQ price calculation engines.' ;
    rdfs:domain ind:ProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'Manufacturing strategy classification for the configurable product. ETO (Engineer-to-Order) requires custom engineering; ATO (Assemble-to-Order) selects from predefined options; MTO (Make-to-Order) builds to customer specification; MTS (Make-to-Stock) is pre-built; CTO (Configure-to-Order) is a hybrid.' ;
    rdfs:domain ind:ProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapVcClassNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Vc Class Number' ;
    rdfs:comment 'SAP S/4HANA class number for the variant configuration characteristic class associated with this option class. Provides direct linkage to the SAP VC model for order processing, BOM explosion, and routing selection.' ;
    rdfs:domain ind:ProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionCardinality rdf:type rdf:Property ;
    rdfs:label 'Selection Cardinality' ;
    rdfs:comment 'Defines how many feature values can be selected within an option class. SINGLE allows exactly one selection; MULTI allows multiple simultaneous selections; EXACTLY_ONE enforces a single mandatory choice; AT_LEAST_ONE requires one or more selections.' ;
    rdfs:domain ind:ProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamcenterConfigObjectReference rdf:type rdf:Property ;
    rdfs:label 'Teamcenter Config Object Reference' ;
    rdfs:comment 'Reference identifier of the corresponding configuration object in Siemens Teamcenter PLM product configurator. Enables traceability between the commercial CPQ configuration model and the engineering product structure in PLM.' ;
    rdfs:domain ind:ProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightImpactKg rdf:type rdf:Property ;
    rdfs:label 'Weight Impact Kg' ;
    rdfs:comment 'Incremental weight in kilograms added to the product by selecting this feature code. Used for logistics planning, shipping cost estimation, and compliance with transportation weight regulations.' ;
    rdfs:domain ind:ProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEndOfSaleDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Of Sale Date' ;
    rdfs:comment 'The actual date on which the catalog item was removed from the active sales catalog and became unavailable for new orders. Used to measure accuracy of planned vs. actual end-of-sale timing.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualEolDate rdf:type rdf:Property ;
    rdfs:label 'Actual Eol Date' ;
    rdfs:comment 'The actual date on which the catalog item reached End-of-Life status and all support obligations were formally concluded. Used for compliance reporting and aftermarket service closure.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aftermarketSupportEndDate rdf:type rdf:Property ;
    rdfs:label 'Aftermarket Support End Date' ;
    rdfs:comment 'The date through which aftermarket support, spare parts, and maintenance services are committed to be available for the catalog item after End-of-Sale. Critical for customer SLA commitments and service contract management.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Date' ;
    rdfs:comment 'The date on which customers were formally notified of the lifecycle stage transition (e.g., End-of-Sale or End-of-Life announcement). Required for compliance with contractual SLA obligations and customer communication governance.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Status' ;
    rdfs:comment 'Status of the customer notification process for the lifecycle stage transition, particularly for End-of-Sale and End-of-Life events. Tracks whether affected customers have been formally notified per contractual and regulatory obligations.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Erp Material Number' ;
    rdfs:comment 'The material number assigned to the catalog item in SAP S/4HANA. Enables cross-system traceability between the product lifecycle record and procurement, production, and sales transactions in the ERP system.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryWindDownStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Wind Down Status' ;
    rdfs:comment 'Status of the inventory wind-down process for the catalog item as it approaches End-of-Sale or End-of-Life. Coordinates with Infor WMS and SAP S/4HANA MM to manage remaining stock disposition.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrentStage rdf:type rdf:Property ;
    rdfs:label 'Is Current Stage' ;
    rdfs:comment 'Flag indicating whether this record represents the currently active lifecycle stage for the catalog item. Supports efficient querying of the current state without date-range filtering.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTimeBuyDate rdf:type rdf:Property ;
    rdfs:label 'Last Time Buy Date' ;
    rdfs:comment 'The final date by which customers may place orders for the catalog item before it is permanently discontinued. Communicated to customers as part of the End-of-Sale notification process to allow final inventory stocking.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketRegion rdf:type rdf:Property ;
    rdfs:label 'Market Region' ;
    rdfs:comment 'The geographic market region(s) to which this lifecycle stage record applies (e.g., specific country codes or regional market designations). Supports region-specific lifecycle management where a product may be in different stages across markets.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndOfSaleDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Of Sale Date' ;
    rdfs:comment 'The planned date on which the catalog item will no longer be available for new orders (End-of-Sale). Distinct from End-of-Life; aftermarket support may continue after this date. Drives inventory wind-down and last-time-buy notifications.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedEolDate rdf:type rdf:Property ;
    rdfs:label 'Planned Eol Date' ;
    rdfs:comment 'The planned date on which the catalog item is expected to reach End-of-Life (EOL) status, meaning no further support, spare parts, or services will be provided. Critical for customer communication, inventory wind-down, and aftermarket commitments.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plmObjectReference rdf:type rdf:Property ;
    rdfs:label 'Plm Object Reference' ;
    rdfs:comment 'The unique identifier of the corresponding lifecycle object in Siemens Teamcenter PLM. Enables traceability and cross-system reconciliation between the Silver Layer data product and the authoritative PLM system of record.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousStageCode rdf:type rdf:Property ;
    rdfs:label 'Previous Stage Code' ;
    rdfs:comment 'The lifecycle stage code that preceded the current stage for this catalog item. Enables stage transition analysis and audit trail of lifecycle progression.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Reach Compliance Status' ;
    rdfs:comment 'Compliance status of the catalog item with respect to the EU REACH Regulation. Impacts lifecycle stage decisions for products containing substances of very high concern (SVHC) and drives EOL timing in regulated markets.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Flag' ;
    rdfs:comment 'Indicates whether the lifecycle stage transition is on hold due to a pending regulatory review, certification requirement, or compliance obligation (e.g., CE Marking, RoHS, REACH). Prevents premature stage advancement.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryHoldReason rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Reason' ;
    rdfs:comment 'Description of the regulatory or compliance reason for placing the lifecycle stage transition on hold. Provides audit trail for regulatory governance and compliance reporting.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Responsible Business Unit' ;
    rdfs:comment 'The organizational business unit or division accountable for the product\'s lifecycle management (e.g., Factory Automation, Electrification Products, Smart Infrastructure). Supports portfolio governance and reporting by business unit.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleProductManager rdf:type rdf:Property ;
    rdfs:label 'Responsible Product Manager' ;
    rdfs:comment 'Name or employee identifier of the product manager accountable for managing the lifecycle stage of this catalog item. Used for escalation, communication ownership, and governance accountability.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rohsComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Rohs Compliance Status' ;
    rdfs:comment 'Compliance status of the catalog item with respect to the EU RoHS Directive (Restriction of Hazardous Substances). Relevant for lifecycle decisions, particularly when transitioning products to End-of-Sale or End-of-Life in EU markets.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sparePartsAvailabilityCommitment rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Availability Commitment' ;
    rdfs:comment 'The level of spare parts availability committed to customers after the product reaches End-of-Sale. Drives aftermarket inventory planning, MRO procurement, and customer SLA management.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageCode rdf:type rdf:Property ;
    rdfs:label 'Stage Code' ;
    rdfs:comment 'Standardized code representing the current commercial lifecycle stage of the catalog item. Drives proactive customer communication, inventory wind-down, and aftermarket parts availability commitments. Aligned with PLM lifecycle stages in Siemens Teamcenter.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageEffectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Stage Effective End Date' ;
    rdfs:comment 'The date on which the current lifecycle stage ceased to be effective, either because the product transitioned to the next stage or the record was superseded. NULL indicates the stage is currently active.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stageEffectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Stage Effective Start Date' ;
    rdfs:comment 'The date on which the current lifecycle stage became effective for the catalog item. Used to determine how long a product has been in a given stage and to support time-based lifecycle analytics.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stageName rdf:type rdf:Property ;
    rdfs:label 'Stage Name' ;
    rdfs:comment 'Human-readable label for the lifecycle stage corresponding to the lifecycle_stage_code. Used in customer-facing communications, dashboards, and reports.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Transition Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for the lifecycle stage transition. Supports root-cause analysis of portfolio changes and regulatory reporting.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Transition Reason Notes' ;
    rdfs:comment 'Free-text narrative providing additional context for the lifecycle stage transition beyond the standardized reason code. Captures nuanced business justification for audit and governance purposes.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ulCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Ul Certification Status' ;
    rdfs:comment 'Status of the UL (Underwriters Laboratories) product safety certification for the catalog item. Relevant for lifecycle decisions in North American markets and required for certain industrial automation and electrification products.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basePriceListCode rdf:type rdf:Property ;
    rdfs:label 'Base Price List Code' ;
    rdfs:comment 'Reference to the parent or base price list from which this price list is derived. Used when a price list is created as a percentage discount or markup from a standard list price, supporting tiered pricing hierarchies.' ;
    rdfs:domain ind:ProductPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'External reference identifier for this price list as used by customers, distributors, or trading partners in their own systems. Facilitates B2B pricing alignment and EDI/API integration with partner systems.' ;
    rdfs:domain ind:ProductPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLocked rdf:type rdf:Property ;
    rdfs:label 'Is Locked' ;
    rdfs:comment 'Indicates whether the price list is locked against further modifications. A locked price list cannot be edited until explicitly unlocked by an authorized user, ensuring pricing integrity during active sales periods.' ;
    rdfs:domain ind:ProductPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemPriceListCode rdf:type rdf:Property ;
    rdfs:label 'Source System Price List Code' ;
    rdfs:comment 'The native identifier of this price list record in the originating operational system (e.g., SAP S/4HANA condition record number or Salesforce price book ID). Enables traceability and reconciliation between the lakehouse and source systems.' ;
    rdfs:domain ind:ProductPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpqEligible rdf:type rdf:Property ;
    rdfs:label 'Cpq Eligible' ;
    rdfs:comment 'Indicates whether this price list item is available for use in Configure Price Quote (CPQ) processes (True) or restricted to direct order entry only (False). Controls which items appear in the CPQ pricing engine for complex product configurations.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:floorPrice rdf:type rdf:Property ;
    rdfs:label 'Floor Price' ;
    rdfs:comment 'The minimum permissible selling price for the SKU below which sales representatives cannot discount. Used by Configure Price Quote (CPQ) and order management to enforce pricing guardrails and protect margin.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Min Order Quantity' ;
    rdfs:comment 'The minimum quantity a customer must order to qualify for this price list item. Enforced during order entry and CPQ to ensure pricing is only applied when the minimum purchase threshold is met.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceIncludesTax rdf:type rdf:Property ;
    rdfs:label 'Price Includes Tax' ;
    rdfs:comment 'Indicates whether the unit price stated in this price list item is inclusive of applicable taxes (True) or exclusive of taxes (False). Critical for markets where gross pricing is standard (e.g., VAT-inclusive pricing in EU consumer channels).' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'Classification of the price record indicating its commercial role: list_price (standard catalog price), floor_price (minimum allowable selling price), rrp (Recommended Retail Price), transfer_price (intercompany), contract_price (customer-specific negotiated), or promotional_price (time-limited offer).' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Pricing Unit Quantity' ;
    rdfs:comment 'The quantity denominator for the unit price (e.g., price per 100 units, price per 1000 kg). Allows pricing to be expressed per batch or bulk quantity rather than per single unit. Defaults to 1 for per-unit pricing.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateEligible rdf:type rdf:Property ;
    rdfs:label 'Rebate Eligible' ;
    rdfs:comment 'Indicates whether this price list item is eligible for inclusion in rebate agreement calculations (True) or excluded (False). Used by the rebate management process to determine which sales transactions qualify for retrospective rebate accruals.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rrp rdf:type rdf:Property ;
    rdfs:label 'Rrp' ;
    rdfs:comment 'The Recommended Retail Price (RRP) suggested to channel partners and distributors for resale to end customers. Used in distributor price lists and channel management to maintain market price consistency.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesOrgCode rdf:type rdf:Property ;
    rdfs:label 'Sales Org Code' ;
    rdfs:comment 'Code identifying the sales organization for which this price list item is applicable. Supports multi-entity and multi-region pricing structures in global operations (e.g., different prices for EMEA vs. Americas sales organizations).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleBasis rdf:type rdf:Property ;
    rdfs:label 'Scale Basis' ;
    rdfs:comment 'The dimension on which pricing scale breaks are evaluated: quantity (number of units), value (order value in currency), weight (total weight), or volume (total volume). Determines how tier thresholds are measured for volume pricing.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleFromQuantity rdf:type rdf:Property ;
    rdfs:label 'Scale From Quantity' ;
    rdfs:comment 'The lower bound quantity threshold for this pricing tier (e.g., 10 units). When the ordered quantity meets or exceeds this value, the corresponding tier price applies. Used to define volume-based pricing breaks.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scaleToQuantity rdf:type rdf:Property ;
    rdfs:label 'Scale To Quantity' ;
    rdfs:comment 'The upper bound quantity threshold for this pricing tier (e.g., 99 units). Defines the ceiling of the quantity band for this tier. Null or 999999999 indicates the tier applies to all quantities above the from-quantity.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scaleType rdf:type rdf:Property ;
    rdfs:label 'Scale Type' ;
    rdfs:comment 'Defines the type of volume-based pricing scale applied to this item: graduated (tiered pricing where each tier applies to the quantity within that band), base_scale (the entire quantity is priced at the tier rate), group_scale (scale based on cumulative group quantity), or none (flat pricing with no scale).' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Surcharge Amount' ;
    rdfs:comment 'Absolute monetary surcharge applied on top of the unit price for this item (e.g., hazardous material handling surcharge, small order surcharge, freight surcharge). Negative values represent absolute discounts.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surchargePercent rdf:type rdf:Property ;
    rdfs:label 'Surcharge Percent' ;
    rdfs:comment 'Percentage-based surcharge or discount applied to the unit price for this item. Positive values indicate a surcharge; negative values indicate a discount percentage. Used when the adjustment is proportional rather than fixed.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plmClassId rdf:type rdf:Property ;
    rdfs:label 'Plm Class Id' ;
    rdfs:comment 'The classification identifier from Siemens Teamcenter PLM corresponding to this product category, enabling traceability between the commercial catalog taxonomy and the engineering classification structure.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Class .

ind:applicableRegion rdf:type rdf:Property ;
    rdfs:label 'Applicable Region' ;
    rdfs:comment 'Pipe-separated list of ISO 3166-1 alpha-3 country codes or regional designators indicating the geographic markets where this category is commercially active and available for ordering (e.g., \'USA|DEU|CHN|GBR\').' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessDivision rdf:type rdf:Property ;
    rdfs:label 'Business Division' ;
    rdfs:comment 'The internal business division or strategic business unit responsible for the products within this category (e.g., \'Digital Industries\', \'Smart Infrastructure\', \'Mobility\'). Supports divisional P&L reporting and spend analytics.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Default Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code representing the default pricing currency for products in this category (e.g., \'USD\', \'EUR\', \'CNY\'). Used for catalog pricing display and financial reporting alignment.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultUom rdf:type rdf:Property ;
    rdfs:label 'Default Uom' ;
    rdfs:comment 'The default unit of measure for products in this category (e.g., \'EA\' for each, \'KG\' for kilogram, \'M\' for meter), aligned with SAP S/4HANA base unit of measure. Used for procurement, inventory, and order management.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCategoryCode rdf:type rdf:Property ;
    rdfs:label 'External Category Code' ;
    rdfs:comment 'Category code used by external trading partners, distributors, or industry bodies for cross-reference and EDI/B2B integration. Enables mapping between internal taxonomy and partner-specific classification schemes.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imageUrl rdf:type rdf:Property ;
    rdfs:label 'Image Url' ;
    rdfs:comment 'URL pointing to the representative image or icon for this product category, used in digital catalog portals, e-commerce interfaces, and customer-facing product navigation.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySegment rdf:type rdf:Property ;
    rdfs:label 'Industry Segment' ;
    rdfs:comment 'The primary industry vertical or market segment this product category is applicable to, used for targeted catalog presentation, sales analytics, and go-to-market alignment (e.g., \'factory_automation\', \'building_technologies\', \'transportation\').' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOrderable rdf:type rdf:Property ;
    rdfs:label 'Is Orderable' ;
    rdfs:comment 'Indicates whether products within this category are currently available for customer ordering. A value of True means the category is open for order placement; False means ordering is blocked (e.g., for internal or regulatory categories).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProcurementCategory rdf:type rdf:Property ;
    rdfs:label 'Is Procurement Category' ;
    rdfs:comment 'Indicates whether this category is used for procurement spend classification in SAP Ariba, enabling category-level spend analytics, supplier segmentation, and sourcing strategy alignment.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapMaterialGroup rdf:type rdf:Property ;
    rdfs:label 'Sap Material Group' ;
    rdfs:comment 'The SAP S/4HANA Material Group code (field MATKL) mapped to this product category, used for procurement, inventory valuation, and reporting alignment with the ERP system of record.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Spend Category Code' ;
    rdfs:comment 'Procurement spend category code used in SAP Ariba for supplier segmentation, sourcing strategy, and spend analytics. Maps this product category to the enterprise procurement taxonomy for category management.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableDirectives rdf:type rdf:Property ;
    rdfs:label 'Applicable Directives' ;
    rdfs:comment 'Pipe-separated list of EU directives, harmonized standards, or regulatory frameworks under which the certification was granted (e.g., Low Voltage Directive 2014/35/EU|EMC Directive 2014/30/EU|IEC 61010-1). Critical for CE Marking declarations of conformity.' ;
    rdfs:domain ind:RegulatoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableMarkets rdf:type rdf:Property ;
    rdfs:label 'Applicable Markets' ;
    rdfs:comment 'Pipe-separated list of ISO 3166-1 alpha-3 country codes or market identifiers for which this certification grants market access (e.g., DEU|FRA|GBR|USA|CHN). Drives export control decisions and customer compliance documentation.' ;
    rdfs:domain ind:RegulatoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Certificate Document Reference' ;
    rdfs:comment 'Document management system reference or URL pointing to the scanned or digital copy of the official certificate. Enables direct retrieval of the certificate for customer compliance packages, audits, and export documentation.' ;
    rdfs:domain ind:RegulatoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationCost rdf:type rdf:Property ;
    rdfs:label 'Certification Cost' ;
    rdfs:comment 'Total cost incurred to obtain or renew this certification, including testing fees, certification body fees, and audit costs. Expressed in the currency specified by certification_cost_currency. Used for compliance budget tracking and OPEX reporting.' ;
    rdfs:domain ind:RegulatoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Certification Cost Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the certification cost amount (e.g., USD, EUR, GBP, CNY). Supports multi-currency financial reporting for global compliance operations.' ;
    rdfs:domain ind:RegulatoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStandard rdf:type rdf:Property ;
    rdfs:label 'Certification Standard' ;
    rdfs:comment 'Primary technical standard or norm against which the product was tested and certified (e.g., IEC 61010-1:2010, UL 508A, EN 60947-1, IEC 62443-4-2). Provides the technical basis for the certification and is referenced in test reports and declarations of conformity.' ;
    rdfs:domain ind:RegulatoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Classification of the regulatory certification or compliance approval. Identifies the specific scheme under which the product has been certified (e.g., CE Marking for EU market access, UL Listing for North American safety, CCC for China market, EAC for Eurasian Economic Union).' ;
    rdfs:domain ind:RegulatoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationOfConformityReference rdf:type rdf:Property ;
    rdfs:label 'Declaration Of Conformity Reference' ;
    rdfs:comment 'Document reference number or PLM system identifier for the manufacturer\'s Declaration of Conformity (DoC) associated with this certification. Required for CE Marking and other self-declaration schemes under EU New Legislative Framework.' ;
    rdfs:domain ind:RegulatoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousSubstanceDeclaration rdf:type rdf:Property ;
    rdfs:label 'Hazardous Substance Declaration' ;
    rdfs:comment 'Indicates the product\'s compliance declaration status with respect to hazardous substance restrictions (RoHS, REACH, California Prop 65). \'Full Compliance\' means all restricted substances are below threshold; \'Exemption Applied\' means one or more RoHS exemptions are in use.' ;
    rdfs:domain ind:RegulatoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBody rdf:type rdf:Property ;
    rdfs:label 'Issuing Body' ;
    rdfs:comment 'Name of the regulatory authority, notified body, or accredited certification organization that issued the certificate (e.g., TÜV Rheinland, Bureau Veritas, Underwriters Laboratories, SGS, Intertek, DEKRA, China Quality Certification Centre).' ;
    rdfs:domain ind:RegulatoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBodyAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Issuing Body Accreditation Number' ;
    rdfs:comment 'Accreditation number of the notified body or certification organization as registered with the relevant national accreditation authority (e.g., NANDO notified body number for EU, ILAC member accreditation number). Enables verification of the certifier\'s authority.' ;
    rdfs:domain ind:RegulatoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSurveillanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Surveillance Date' ;
    rdfs:comment 'Date of the most recently completed surveillance audit or factory inspection. Used to verify compliance maintenance history and calculate the interval to the next required audit.' ;
    rdfs:domain ind:RegulatoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingSiteCode rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site Code' ;
    rdfs:comment 'Internal code identifying the specific manufacturing plant or facility where the certified product is produced. Some certifications (e.g., UL, CCC) are site-specific and require re-certification if production moves to a different facility.' ;
    rdfs:domain ind:RegulatoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextSurveillanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Surveillance Date' ;
    rdfs:comment 'Scheduled date of the next surveillance audit or periodic factory inspection required to maintain certification validity. Used for compliance calendar management and audit preparation planning.' ;
    rdfs:domain ind:RegulatoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reachSvhcFlag rdf:type rdf:Property ;
    rdfs:label 'Reach Svhc Flag' ;
    rdfs:comment 'Indicates whether the product contains any Substances of Very High Concern (SVHC) as defined under the EU REACH Regulation above the 0.1% w/w threshold. True triggers mandatory customer notification and supply chain communication obligations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Submission Date' ;
    rdfs:comment 'The date on which the renewal application was submitted to the issuing body. Populated when status is \'Under Renewal\'. Used to track renewal progress and ensure continuity of market access.' ;
    rdfs:domain ind:RegulatoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleComplianceOwner rdf:type rdf:Property ;
    rdfs:label 'Responsible Compliance Owner' ;
    rdfs:comment 'Name or employee ID of the internal compliance engineer or regulatory affairs manager responsible for maintaining this certification, managing renewals, and responding to customer compliance inquiries.' ;
    rdfs:domain ind:RegulatoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rohsExemptionCodes rdf:type rdf:Property ;
    rdfs:label 'Rohs Exemption Codes' ;
    rdfs:comment 'Pipe-separated list of RoHS Annex III or Annex IV exemption codes applicable to this product (e.g., 6(a)|6(b)|7(a)). Documents the legal basis for any restricted substance usage above threshold limits. Required for RoHS compliance declarations.' ;
    rdfs:domain ind:RegulatoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardVersion rdf:type rdf:Property ;
    rdfs:label 'Standard Version' ;
    rdfs:comment 'Version, edition, or amendment level of the certification standard applied (e.g., Ed. 3.0, Amendment 1, 2019 revision). Critical for tracking compliance against evolving standards and managing transition periods when new editions are published.' ;
    rdfs:domain ind:RegulatoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusReason rdf:type rdf:Property ;
    rdfs:label 'Status Reason' ;
    rdfs:comment 'Textual explanation for the current certification status, particularly when status is Suspended, Withdrawn, or Cancelled. Documents the root cause (e.g., product design change, non-conformance finding, voluntary withdrawal from market).' ;
    rdfs:domain ind:RegulatoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveillanceAuditRequired rdf:type rdf:Property ;
    rdfs:label 'Surveillance Audit Required' ;
    rdfs:comment 'Indicates whether this certification requires periodic surveillance audits or factory inspections by the issuing body to maintain validity. True triggers scheduling of surveillance visits in the compliance calendar.' ;
    rdfs:domain ind:RegulatoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testReportNumber rdf:type rdf:Property ;
    rdfs:label 'Test Report Number' ;
    rdfs:comment 'Reference number of the test report or evaluation report issued by the testing laboratory that underpins this certification. Used to retrieve supporting technical evidence during audits, customer inquiries, or regulatory inspections.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingLaboratory rdf:type rdf:Property ;
    rdfs:label 'Testing Laboratory' ;
    rdfs:comment 'Name of the accredited testing laboratory that conducted the product testing and issued the test report supporting this certification (e.g., TÜV SÜD Product Service, Intertek Testing Services, SGS Laboratories). May differ from the issuing body.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableRegulation rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulation' ;
    rdfs:comment 'Primary regulatory framework under which this substance is restricted or declarable (e.g., RoHS Directive 2011/65/EU, REACH SVHC, California Proposition 65, TSCA). Drives compliance obligations and documentation requirements.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Expiry Date' ;
    rdfs:comment 'Expiry date of the REACH authorization granted for use of a Substance of Very High Concern (SVHC). After this date, use of the substance is prohibited unless a new authorization is obtained.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Authorization Number' ;
    rdfs:comment 'Authorization number granted by the European Chemicals Agency (ECHA) under REACH Annex XIV permitting the continued use of a Substance of Very High Concern (SVHC) for a specific use case beyond the sunset date.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casNumber rdf:type rdf:Property ;
    rdfs:label 'Cas Number' ;
    rdfs:comment 'Unique numerical identifier assigned by the Chemical Abstracts Service (CAS) to uniquely identify a chemical substance. Used globally for substance identification across regulatory databases.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current regulatory compliance status of the substance record for the associated catalog item. Drives product release decisions, customer material declarations, and corrective action workflows.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationPpm rdf:type rdf:Property ;
    rdfs:label 'Concentration Ppm' ;
    rdfs:comment 'Measured or declared concentration of the hazardous substance in the catalog item or homogeneous material, expressed in parts per million (PPM) by weight. Used to assess compliance against regulatory threshold limits.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSourceType rdf:type rdf:Property ;
    rdfs:label 'Data Source Type' ;
    rdfs:comment 'Origin of the substance concentration data: laboratory test result, supplier-provided declaration, internal engineering analysis, third-party certification, or Material Safety Data Sheet (MSDS/SDS). Indicates data reliability and traceability.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationDate rdf:type rdf:Property ;
    rdfs:label 'Declaration Date' ;
    rdfs:comment 'Date on which the substance declaration or compliance assessment was formally recorded or submitted. Used for regulatory reporting timelines and document version control.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:declarationType rdf:type rdf:Property ;
    rdfs:label 'Declaration Type' ;
    rdfs:comment 'Type of compliance declaration associated with this substance record: exemption (substance use is permitted under a specific regulatory exemption), substitution (substance has been replaced), declaration of conformity (product conforms to limits), or disclosure (substance is declared for transparency).' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecNumber rdf:type rdf:Property ;
    rdfs:label 'Ec Number' ;
    rdfs:comment 'European Community (EC) number assigned by the European Chemicals Agency (ECHA) to substances listed in the EINECS, ELINCS, or NLP inventories. Required for REACH compliance documentation.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceedsThreshold rdf:type rdf:Property ;
    rdfs:label 'Exceeds Threshold' ;
    rdfs:comment 'Indicates whether the measured substance concentration (concentration_ppm) exceeds the regulatory threshold limit (threshold_limit_ppm). True signals a potential non-compliance condition requiring corrective action or exemption documentation.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionReference rdf:type rdf:Property ;
    rdfs:label 'Exemption Reference' ;
    rdfs:comment 'Specific exemption clause or annex reference under the applicable regulation that permits the use of this substance above the threshold limit (e.g., RoHS Annex III exemption 6(c) for lead in glass of cathode ray tubes).' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghsHazardClass rdf:type rdf:Property ;
    rdfs:label 'Ghs Hazard Class' ;
    rdfs:comment 'Hazard classification of the substance under the Globally Harmonized System of Classification and Labelling of Chemicals (GHS), such as acute toxicity, carcinogenicity, reproductive toxicity, or environmental hazard. Drives SDS and labeling requirements.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipc1752SubstanceClass rdf:type rdf:Property ;
    rdfs:label 'Ipc1752 Substance Class' ;
    rdfs:comment 'Substance classification per the IPC-1752A Material Declaration Standard, indicating the level of reporting obligation (Class A through F). Used for generating standardized customer material declarations in the electronics and industrial manufacturing supply chain.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iupacName rdf:type rdf:Property ;
    rdfs:label 'Iupac Name' ;
    rdfs:comment 'Systematic chemical name of the substance as defined by the International Union of Pure and Applied Chemistry (IUPAC) nomenclature standards, used for unambiguous chemical identification.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialApplication rdf:type rdf:Property ;
    rdfs:label 'Material Application' ;
    rdfs:comment 'Description of the specific material, component, or homogeneous material within the catalog item where the substance is present (e.g., solder alloy, PCB substrate, cable insulation, surface coating). Required for IPC-1752A material declarations.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'Analytical test method used to determine the substance concentration in the material or component (e.g., X-Ray Fluorescence (XRF), ICP-OES, GC-MS). Supports traceability and audit requirements under IEC 62321.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategoryScope rdf:type rdf:Property ;
    rdfs:label 'Product Category Scope' ;
    rdfs:comment 'RoHS or REACH product category or equipment category to which this substance restriction applies (e.g., RoHS Annex I Category 1 - Large Household Appliances, Category 9 - Industrial Monitoring and Control Equipment). Determines applicability of restrictions.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prop65ListedFlag rdf:type rdf:Property ;
    rdfs:label 'Prop65 Listed Flag' ;
    rdfs:comment 'Indicates whether the substance is listed under California Proposition 65 (Safe Drinking Water and Toxic Enforcement Act) as known to cause cancer, birth defects, or other reproductive harm. Triggers warning label requirements for products sold in California.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulationListVersion rdf:type rdf:Property ;
    rdfs:label 'Regulation List Version' ;
    rdfs:comment 'Version or revision of the regulatory list or candidate list under which the substance is classified (e.g., REACH SVHC Candidate List version, RoHS Annex II amendment number). Ensures traceability to the specific regulatory update.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Review Due Date' ;
    rdfs:comment 'Scheduled date by which the substance compliance record must be reviewed for accuracy and regulatory currency. Triggered by regulatory list updates, product changes, or periodic review cycles.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rohsRestrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Rohs Restricted Flag' ;
    rdfs:comment 'Indicates whether the substance is restricted under the RoHS Directive 2011/65/EU (Restriction of Hazardous Substances). Restricted substances include lead, mercury, cadmium, hexavalent chromium, PBB, PBDE, and additional substances added under RoHS 3.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdsDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sds Document Number' ;
    rdfs:comment 'Reference number of the Safety Data Sheet (SDS) associated with this hazardous substance, as required under OSHA Hazard Communication Standard (HazCom) and REACH. The SDS provides detailed safety, handling, and disposal information.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substanceCategory rdf:type rdf:Property ;
    rdfs:label 'Substance Category' ;
    rdfs:comment 'Chemical classification category of the hazardous substance used for grouping and risk prioritization in compliance programs (e.g., heavy metal, halogen, phthalate, SVHC).' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substanceFunction rdf:type rdf:Property ;
    rdfs:label 'Substance Function' ;
    rdfs:comment 'Technical function or role of the hazardous substance within the product or material (e.g., flame retardant, plasticizer, colorant, stabilizer). Supports substitution analysis and Design for Environment (DfE) initiatives.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substanceName rdf:type rdf:Property ;
    rdfs:label 'Substance Name' ;
    rdfs:comment 'Official chemical or common name of the hazardous substance as recognized by regulatory bodies (e.g., Lead, Cadmium, Hexavalent Chromium, Bisphenol A).' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionCasNumber rdf:type rdf:Property ;
    rdfs:label 'Substitution Cas Number' ;
    rdfs:comment 'CAS number of the alternative substance used to replace this hazardous substance. Enables precise identification of the substitute chemical for regulatory and procurement purposes.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionSubstanceName rdf:type rdf:Property ;
    rdfs:label 'Substitution Substance Name' ;
    rdfs:comment 'Name of the alternative substance used to replace this hazardous substance when declaration_type is substitution. Supports Design for Environment (DfE) and green chemistry initiatives.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierDeclarationReference rdf:type rdf:Property ;
    rdfs:label 'Supplier Declaration Reference' ;
    rdfs:comment 'Reference number or identifier of the supplier-provided material declaration document (e.g., IPC-1752A form reference, supplier SDS document number) supporting the substance data. Used for audit traceability.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdLimitPpm rdf:type rdf:Property ;
    rdfs:label 'Threshold Limit Ppm' ;
    rdfs:comment 'Maximum allowable concentration of the substance in a homogeneous material as defined by the applicable regulation, expressed in parts per million (PPM). Compliance is determined by comparing concentration_ppm against this limit.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightFractionPercent rdf:type rdf:Property ;
    rdfs:label 'Weight Fraction Percent' ;
    rdfs:comment 'Concentration of the hazardous substance expressed as a percentage by weight (w/w%) of the homogeneous material or article. Used for REACH SVHC disclosure threshold assessment (0.1% w/w trigger) and IPC-1752A declarations.' ;
    rdfs:domain ind:HazardousSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentId rdf:type rdf:Property ;
    rdfs:label 'Document Id' ;
    rdfs:comment 'Unique surrogate identifier for each product document record in the commercial and technical document library.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:accessLevel rdf:type rdf:Property ;
    rdfs:label 'Access Level' ;
    rdfs:comment 'Controls who is authorized to access and download this document. Public documents are available on the product portal; restricted documents require authentication and role-based authorization.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:author rdf:type rdf:Property ;
    rdfs:label 'Author' ;
    rdfs:comment 'Name or employee identifier of the person who authored or is primarily responsible for the content of this document. Used for accountability and document ownership tracking.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the third-party certification or notified body that issued or validated the document (e.g., UL, TÜV, Bureau Veritas, SGS, Intertek). Applicable for test reports, certificates, and declarations of conformity.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumHash rdf:type rdf:Property ;
    rdfs:label 'Checksum Hash' ;
    rdfs:comment 'SHA-256 cryptographic hash of the document file used to verify document integrity and detect unauthorized modifications. Supports regulatory audit trail requirements and tamper-evidence for compliance documents.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialFlag rdf:type rdf:Property ;
    rdfs:label 'Confidential Flag' ;
    rdfs:comment 'Indicates whether this document is classified as confidential and subject to non-disclosure restrictions. Confidential documents require NDA or contractual agreement before distribution.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exportControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Export Controlled Flag' ;
    rdfs:comment 'Indicates whether this document is subject to export control regulations (e.g., EAR, ITAR) and requires authorization before distribution to foreign nationals or international customers.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fileSizeKb rdf:type rdf:Property ;
    rdfs:label 'File Size Kb' ;
    rdfs:comment 'Size of the document file in kilobytes. Used for storage management, download time estimation, and portal performance optimization.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazardousContentFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Content Flag' ;
    rdfs:comment 'Indicates whether this document contains or references hazardous material information (e.g., Safety Data Sheets for products containing restricted substances). Triggers mandatory handling and distribution controls.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownerDepartment rdf:type rdf:Property ;
    rdfs:label 'Owner Department' ;
    rdfs:comment 'Organizational department or business unit responsible for maintaining and updating this document (e.g., Product Engineering, Regulatory Affairs, Marketing, Quality Management).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'Date on which the document was officially published and made available for distribution to internal users, customers, or regulatory bodies.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryStandard rdf:type rdf:Property ;
    rdfs:label 'Regulatory Standard' ;
    rdfs:comment 'The specific regulatory standard, directive, or certification framework that this document supports or demonstrates compliance with (e.g., IEC 61131, CE Marking Directive, RoHS Directive 2011/65/EU, REACH Regulation, UL 508A, ISO 9001). Critical for Declaration of Conformity and test report documents.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Months' ;
    rdfs:comment 'Defined periodic review interval in months for this document type. Drives automated review reminders and ensures documents remain current with product changes and regulatory updates.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sapDmsDocumentKey rdf:type rdf:Property ;
    rdfs:label 'Sap Dms Document Key' ;
    rdfs:comment 'Document key from SAP DMS (Document Management System within SAP S/4HANA) used to link the product document record back to the originating SAP document object for procurement, quality, and production cross-references.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scope rdf:type rdf:Property ;
    rdfs:label 'Scope' ;
    rdfs:comment 'Indicates the breadth of product applicability for this document — whether it applies to a single SKU, a product family, an entire product line, or a platform-wide standard.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationUri rdf:type rdf:Property ;
    rdfs:label 'Storage Location Uri' ;
    rdfs:comment 'Uniform Resource Identifier (URI) pointing to the physical storage location of the document file in the enterprise content management system, cloud storage (e.g., Azure Data Lake, S3), or Teamcenter vault. Enables direct file retrieval.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamcenterDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Teamcenter Document Reference' ;
    rdfs:comment 'Native document identifier from Siemens Teamcenter PLM document management module. Enables direct cross-reference and drill-through to the authoritative source system record.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Source Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to product.hierarchy. Business justification: The substitution product defines approved product substitution and supersession relationships between catalog items. source_hierarchy_id references the ORIGINAL catalog item being substituted (the ite' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hierarchy .

ind:applicationScope rdf:type rdf:Property ;
    rdfs:label 'Application Scope' ;
    rdfs:comment 'Defines the business processes in which this substitution relationship is applicable. Allows selective enablement — e.g., a substitution valid for spare parts cross-referencing in service but not for production BOM substitution.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates whether the substitution applies in one direction only (source can be replaced by target, but not vice versa) or bidirectionally (either product can substitute for the other). Critical for ATP/CTP fallback logic in order management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalEquivalenceLevel rdf:type rdf:Property ;
    rdfs:label 'Functional Equivalence Level' ;
    rdfs:comment 'Describes the degree to which the target product is functionally equivalent to the source product. \'full\' means complete drop-in replacement; \'partial\' means some functional differences exist; \'form-fit-function\' meets dimensional and interface requirements; \'dimensional-only\' matches physical dimensions only; \'performance-limited\' has reduced performance characteristics.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Change Flag' ;
    rdfs:comment 'Indicates whether the substitution involves a change in hazardous material content or classification between the source and target products. Triggers mandatory review under REACH, RoHS, and HSE compliance workflows.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAutoSubstitutionAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Auto Substitution Allowed' ;
    rdfs:comment 'Indicates whether the system is permitted to automatically apply this substitution during order processing (ATP/CTP fallback) without manual intervention. When false, a planner or customer service representative must approve the substitution.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadTimeImpactDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Impact Days' ;
    rdfs:comment 'The difference in procurement or production lead time (in calendar days) between the target and source products. Positive values indicate longer lead time for the substitute; negative values indicate shorter. Used in ATP/CTP calculations.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plmSubstitutionReference rdf:type rdf:Property ;
    rdfs:label 'Plm Substitution Reference' ;
    rdfs:comment 'The corresponding substitution or interchangeability record identifier in Siemens Teamcenter PLM, enabling cross-system traceability between the commercial product catalog and the engineering product data management system.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceImpactIndicator rdf:type rdf:Property ;
    rdfs:label 'Price Impact Indicator' ;
    rdfs:comment 'Indicates the general price impact of applying the substitution relative to the source product. Used by order management and sales to communicate cost implications to customers and for margin analysis.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRatio rdf:type rdf:Property ;
    rdfs:label 'Quantity Ratio' ;
    rdfs:comment 'The quantity conversion ratio between source and target products. A value of 1.0 indicates a 1:1 substitution; a value of 2.0 means 2 units of the target are required to replace 1 unit of the source. Critical for accurate order fulfillment and BOM substitution.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Target Material Number' ;
    rdfs:comment 'SAP material number of the target/replacement product, enabling direct traceability to the ERP material master record for the substitute item.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSku rdf:type rdf:Property ;
    rdfs:label 'Target Sku' ;
    rdfs:comment 'The replacement or substitute product SKU that fulfills the role of the source product. This is the \'to\' side of the substitution relationship.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableEquipmentModels rdf:type rdf:Property ;
    rdfs:label 'Applicable Equipment Models' ;
    rdfs:comment 'Comma-separated list or range expression of equipment model numbers for which this aftermarket part is compatible. Defines the compatibility scope used by field service engineers and customers to verify correct part selection.' ;
    rdfs:domain ind:AftermarketPart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableSerialNumberRange rdf:type rdf:Property ;
    rdfs:label 'Applicable Serial Number Range' ;
    rdfs:comment 'Serial number range expression (e.g., \'SN10000-SN19999\') defining the specific equipment serial numbers for which this part is compatible. Enables precise compatibility filtering when equipment models span multiple hardware revisions.' ;
    rdfs:domain ind:AftermarketPart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceMarked rdf:type rdf:Property ;
    rdfs:label 'Ce Marked' ;
    rdfs:comment 'Indicates whether the aftermarket part carries the CE marking, confirming conformity with applicable EU product safety, health, and environmental protection directives. Required for sale in the European Economic Area.' ;
    rdfs:domain ind:AftermarketPart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eccn rdf:type rdf:Property ;
    rdfs:label 'Eccn' ;
    rdfs:comment 'US Export Administration Regulations (EAR) classification number for the aftermarket part. Determines export license requirements and restricted party screening obligations for international shipments.' ;
    rdfs:domain ind:AftermarketPart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Kg' ;
    rdfs:comment 'Gross weight of the aftermarket part including packaging, in kilograms. Used for freight cost calculation, shipping documentation, and dangerous goods compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBatchManaged rdf:type rdf:Property ;
    rdfs:label 'Is Batch Managed' ;
    rdfs:comment 'Indicates whether this aftermarket part is managed in inventory by production batch or lot number. Batch management enables shelf-life tracking, quality holds, and recall management at the batch level.' ;
    rdfs:domain ind:AftermarketPart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazardous rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous' ;
    rdfs:comment 'Indicates whether the aftermarket part is classified as a hazardous material requiring special handling, storage, labeling, and shipping documentation under applicable regulations (OSHA HazCom, IATA DGR, ADR).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSerialized rdf:type rdf:Property ;
    rdfs:label 'Is Serialized' ;
    rdfs:comment 'Indicates whether individual units of this aftermarket part are tracked by unique serial numbers. Serialized parts require serial number assignment at goods receipt and goods issue, enabling full traceability through the service supply chain.' ;
    rdfs:domain ind:AftermarketPart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifecycleEndDate rdf:type rdf:Property ;
    rdfs:label 'Lifecycle End Date' ;
    rdfs:comment 'Date on which the aftermarket part is scheduled to be discontinued or withdrawn from the service catalog. Used for end-of-life planning, last-time-buy notifications to customers, and inventory drawdown management.' ;
    rdfs:domain ind:AftermarketPart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleStartDate rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Start Date' ;
    rdfs:comment 'Date on which the aftermarket part became commercially available in the service catalog. Marks the beginning of the active selling period and is used for lifecycle reporting and product availability analytics.' ;
    rdfs:domain ind:AftermarketPart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meanTimeBetweenReplacementsHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time Between Replacements Hours' ;
    rdfs:comment 'Average operating hours between required replacements for this part, derived from Mean Time Between Failures (MTBF) analysis. Used to drive preventive maintenance scheduling, spare parts demand forecasting, and service interval recommendations.' ;
    rdfs:domain ind:AftermarketPart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partNumber rdf:type rdf:Property ;
    rdfs:label 'Part Number' ;
    rdfs:comment 'The unique commercial part number assigned to this aftermarket item in the service and spare parts catalog. Used for ordering, quoting, and logistics identification across the aftermarket channel.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partType rdf:type rdf:Property ;
    rdfs:label 'Part Type' ;
    rdfs:comment 'Classification of the aftermarket part by its commercial and functional role in the service channel. OEM spare parts are original manufacturer replacements; consumables are regularly depleted items; wear parts have predictable degradation cycles; repair kits bundle components for a specific repair task; exchange units are refurbished assemblies; upgrade kits extend or enhance equipment capability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementIntervalUnit rdf:type rdf:Property ;
    rdfs:label 'Replacement Interval Unit' ;
    rdfs:comment 'Unit of measure for the mean time between replacements value. Supports multiple interval bases including operating hours, production cycles, calendar months, years, or distance (km) depending on the equipment type.' ;
    rdfs:domain ind:AftermarketPart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceChannel rdf:type rdf:Property ;
    rdfs:label 'Service Channel' ;
    rdfs:comment 'The commercial channel through which this aftermarket part is sold and distributed. Distinguishes direct service (sold by manufacturer service team), distributor (sold through authorized service partners), ecommerce (online self-service), field service (delivered by field engineers), and depot repair (used in repair center operations).' ;
    rdfs:domain ind:AftermarketPart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockingClassification rdf:type rdf:Property ;
    rdfs:label 'Stocking Classification' ;
    rdfs:comment 'Inventory stocking strategy classification for the aftermarket part. Critical spares are held at all times to prevent unplanned downtime; standard parts follow normal replenishment cycles; non-stock parts are procured on demand; consignment parts are held at customer sites; slow-moving parts have low demand frequency.' ;
    rdfs:domain ind:AftermarketPart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByDate rdf:type rdf:Property ;
    rdfs:label 'Superseded By Date' ;
    rdfs:comment 'The effective date on which this part was superseded by the replacement part number. Used to manage transition periods in field service, spare parts ordering, and inventory drawdown.' ;
    rdfs:domain ind:AftermarketPart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ulListed rdf:type rdf:Property ;
    rdfs:label 'Ul Listed' ;
    rdfs:comment 'Indicates whether the aftermarket part has been tested and listed by Underwriters Laboratories (UL) for product safety compliance. Required for North American market access in electrical and industrial applications.' ;
    rdfs:domain ind:AftermarketPart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availabilityCheckRule rdf:type rdf:Property ;
    rdfs:label 'Availability Check Rule' ;
    rdfs:comment 'SAP SD availability check group code controlling how Available-to-Promise (ATP) and Capable-to-Promise (CTP) checks are performed for this product in the sales organization. Determines whether stock, planned orders, or production capacity are considered.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashDiscountIndicator rdf:type rdf:Property ;
    rdfs:label 'Cash Discount Indicator' ;
    rdfs:comment 'Indicates whether the product is eligible for cash discount terms (e.g., early payment discounts) within this sales organization assignment. When true, cash discount conditions are applied during invoice processing.' ;
    rdfs:domain ind:SalesOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionGroup rdf:type rdf:Property ;
    rdfs:label 'Commission Group' ;
    rdfs:comment 'SAP SD commission group code used to classify the product for sales commission calculation and incentive compensation management within the sales organization.' ;
    rdfs:domain ind:SalesOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossSellingMaterial rdf:type rdf:Property ;
    rdfs:label 'Cross Selling Material' ;
    rdfs:comment 'SAP material number of a complementary product recommended for cross-selling alongside this product within the sales organization. Supports guided selling and upsell/cross-sell analytics in CRM and order management.' ;
    rdfs:domain ind:SalesOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveringPlantCode rdf:type rdf:Property ;
    rdfs:label 'Delivering Plant Code' ;
    rdfs:comment 'Default manufacturing or warehouse plant assigned to fulfill orders for this product within the sales organization. Used in Available-to-Promise (ATP) checks and delivery scheduling. Can be overridden at order line level.' ;
    rdfs:domain ind:SalesOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalItemCategoryGroup rdf:type rdf:Property ;
    rdfs:label 'General Item Category Group' ;
    rdfs:comment 'SAP SD general item category group from the material master basic data, used alongside the sales-org-specific item category group for item category determination in sales documents. Distinguishes standard goods, services, configurable products, and third-party items.' ;
    rdfs:domain ind:SalesOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemCategoryGroup rdf:type rdf:Property ;
    rdfs:label 'Item Category Group' ;
    rdfs:comment 'SAP SD item category group assigned to the product for this sales org, controlling how the item behaves in sales order processing (e.g., standard item, configurable item, service item, third-party item). Drives item category determination in order management.' ;
    rdfs:domain ind:SalesOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingGroup rdf:type rdf:Property ;
    rdfs:label 'Loading Group' ;
    rdfs:comment 'SAP SD loading group code classifying the product by its physical handling and loading requirements (e.g., crane required, forklift, manual). Used in shipping point and route determination for logistics planning.' ;
    rdfs:domain ind:SalesOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStatisticsGroup rdf:type rdf:Property ;
    rdfs:label 'Material Statistics Group' ;
    rdfs:comment 'SAP SD material statistics group controlling whether sales transactions for this product are included in the Logistics Information System (LIS) and sales reporting statistics. Governs data collection for demand planning and sales analytics.' ;
    rdfs:domain ind:SalesOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Value Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the minimum order value field, reflecting the transactional currency of the sales organization (e.g., USD, EUR, GBP, CNY).' ;
    rdfs:domain ind:SalesOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingReferenceMaterial rdf:type rdf:Property ;
    rdfs:label 'Pricing Reference Material' ;
    rdfs:comment 'SAP material number of a reference product whose pricing conditions are used as the basis for pricing this product in the sales organization. Enables pricing inheritance for product variants or successor materials.' ;
    rdfs:domain ind:SalesOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesBlockingReason rdf:type rdf:Property ;
    rdfs:label 'Sales Blocking Reason' ;
    rdfs:comment 'Reason code explaining why the product is blocked for sale in this sales organization. Populated when sales_status is \'blocked\' or \'restricted\'. Supports root cause analysis and unblocking workflows.' ;
    rdfs:domain ind:SalesOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesStatus rdf:type rdf:Property ;
    rdfs:label 'Sales Status' ;
    rdfs:comment 'Current commercial availability status of the product within the assigned sales organization and channel. Controls whether the product can be included in sales orders. \'Blocked\' prevents new orders; \'phasing_out\' signals end-of-sale transition; \'pending_activation\' indicates awaiting commercial launch approval.' ;
    rdfs:domain ind:SalesOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesStatusEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Sales Status Effective Date' ;
    rdfs:comment 'Date from which the current sales status is effective for this product-sales org assignment. Used to track status transitions and support time-based commercial availability reporting.' ;
    rdfs:domain ind:SalesOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transportationGroup rdf:type rdf:Property ;
    rdfs:label 'Transportation Group' ;
    rdfs:comment 'SAP SD transportation group code classifying the product by its transportation requirements and constraints (e.g., hazardous goods, oversized, temperature-controlled). Used in route determination and freight cost calculation.' ;
    rdfs:domain ind:SalesOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeRebateGroup rdf:type rdf:Property ;
    rdfs:label 'Volume Rebate Group' ;
    rdfs:comment 'SAP SD rebate group code classifying the product for volume-based rebate agreement processing within the sales organization. Products in the same rebate group are aggregated for rebate accrual and settlement calculations.' ;
    rdfs:domain ind:SalesOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abcIndicator rdf:type rdf:Property ;
    rdfs:label 'Abc Indicator' ;
    rdfs:comment 'ABC classification of this material at the plant based on consumption value or strategic importance. A=High value/critical, B=Medium, C=Low value. Used for inventory prioritization and cycle counting. Corresponds to the ABCIN field in SAP MM Plant Data view.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchManagementRequired rdf:type rdf:Property ;
    rdfs:label 'Batch Management Required' ;
    rdfs:comment 'Indicates whether batch management is activated for this material at this plant, enabling traceability of production batches for quality and regulatory compliance. Corresponds to the XCHPF field in SAP MM Plant Data view.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fixedLotSize rdf:type rdf:Property ;
    rdfs:label 'Fixed Lot Size' ;
    rdfs:comment 'The fixed order quantity used when the lot sizing procedure is set to Fixed Lot Size (FX). MRP will always propose this quantity regardless of actual requirements. Corresponds to the BSTFE field in SAP MM MRP 1 view.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptProcessingTimeDays rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Processing Time Days' ;
    rdfs:comment 'The number of working days required to inspect and process a goods receipt for this material at the plant after delivery. Added to lead time in MRP scheduling. Corresponds to the WEBAZ field in SAP MM MRP 2 view.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazardousMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Number' ;
    rdfs:comment 'Reference number linking this material to its hazardous substance classification record at the plant. Required for materials subject to REACH, RoHS, or OSHA hazardous material regulations.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inHouseProductionTimeDays rdf:type rdf:Property ;
    rdfs:label 'In House Production Time Days' ;
    rdfs:comment 'The number of working days required to produce this material in-house at the plant. Used by MRP to calculate production order start dates. Corresponds to the DZEIT field in SAP MM MRP 2 view.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Issue Storage Location' ;
    rdfs:comment 'The default storage location from which components are issued to production orders at this plant. Corresponds to the LGFSB field in SAP MM MRP 4 view.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceControl rdf:type rdf:Property ;
    rdfs:label 'Price Control' ;
    rdfs:comment 'Defines the inventory valuation method for this material at the plant. S=Standard Price (fixed standard cost), V=Moving Average Price (weighted average). Corresponds to the VPRSV field in SAP MM Accounting view.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Production Storage Location' ;
    rdfs:comment 'The default storage location within the plant where finished goods or semi-finished materials are placed after production. Corresponds to the LGPRO field in SAP MM MRP 4 view.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionSetup rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Setup' ;
    rdfs:comment 'Two-digit code defining the quality inspection type activated for this material at the plant (e.g., goods receipt inspection, in-process inspection, final inspection). Corresponds to the QMATA field in SAP MM QM view.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStock rdf:type rdf:Property ;
    rdfs:label 'Safety Stock' ;
    rdfs:comment 'The minimum buffer stock quantity maintained at the plant to protect against demand variability and supply disruptions. MRP triggers replenishment when stock falls to this level. Corresponds to the EISBE field in SAP MM MRP 2 view.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumberProfile rdf:type rdf:Property ;
    rdfs:label 'Serial Number Profile' ;
    rdfs:comment 'Profile code defining when and how serial numbers are assigned to units of this material at the plant (e.g., at goods receipt, goods issue, or delivery). Supports asset traceability and after-sales service. Corresponds to the SERAIL field in SAP MM Plant Data view.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificMaterialStatusValidFrom rdf:type rdf:Property ;
    rdfs:label 'Specific Material Status Valid From' ;
    rdfs:comment 'The date from which the plant-specific material status becomes effective. Enables time-phased status transitions for production planning and procurement control. Corresponds to the MMSTD field in SAP MM Plant Data view.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:standardPrice rdf:type rdf:Property ;
    rdfs:label 'Standard Price' ;
    rdfs:comment 'The standard cost per base unit of measure for this material at the plant, used for inventory valuation when price control is set to Standard Price (S). Corresponds to the STPRS field in SAP MM Accounting view.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageConditions rdf:type rdf:Property ;
    rdfs:label 'Storage Conditions' ;
    rdfs:comment 'Two-digit code defining the required storage conditions for this material at the plant (e.g., temperature-controlled, humidity-controlled, hazardous material storage). Corresponds to the LGBKZ field in SAP MM Plant Data/Storage view.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureConditionsIndicator rdf:type rdf:Property ;
    rdfs:label 'Temperature Conditions Indicator' ;
    rdfs:comment 'Indicator specifying the temperature range or climate class required for storing this material at the plant. Critical for electrification components and chemical materials. Corresponds to the MHDRZ field in SAP MM Plant Data/Storage view.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationClass rdf:type rdf:Property ;
    rdfs:label 'Valuation Class' ;
    rdfs:comment 'Four-digit code that determines the general ledger accounts updated when inventory movements occur for this material at the plant. Links material master to financial accounting. Corresponds to the BKLAS field in SAP MM Accounting view.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionDenominator rdf:type rdf:Property ;
    rdfs:label 'Conversion Denominator' ;
    rdfs:comment 'The denominator of the conversion factor from this UoM to the base UoM. Together with the numerator, defines the ratio: (numerator / denominator) units of this UoM = 1 base UoM unit. Aligned with SAP S/4HANA MARM-UMREN field.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionFactor rdf:type rdf:Property ;
    rdfs:label 'Conversion Factor' ;
    rdfs:comment 'The pre-computed decimal conversion factor (numerator / denominator) representing how many base UoM units are equivalent to one unit of this UoM. Stored for query performance and reporting convenience. Example: 1 PAL = 48 EA → conversion_factor = 48.000000.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionNumerator rdf:type rdf:Property ;
    rdfs:label 'Conversion Numerator' ;
    rdfs:comment 'The numerator of the conversion factor from this UoM to the base UoM. Together with the denominator, defines the ratio: (numerator / denominator) units of this UoM = 1 base UoM unit. Aligned with SAP S/4HANA MARM-UMREZ field.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eanUpcCode rdf:type rdf:Property ;
    rdfs:label 'Ean Upc Code' ;
    rdfs:comment 'The EAN or UPC barcode associated with this UoM packaging level. Used for point-of-sale scanning, warehouse receiving, and inventory tracking. Aligned with SAP S/4HANA MARM-EAN11 and GS1 standards.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalTradeItemNumber rdf:type rdf:Property ;
    rdfs:label 'Global Trade Item Number' ;
    rdfs:comment 'The GS1-standard Global Trade Item Number (GTIN) associated with this specific UoM packaging level (e.g., GTIN-8 for inner pack, GTIN-13 for case, GTIN-14 for pallet). Enables barcode scanning, EDI transactions, and retail/logistics interoperability.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBaseUom rdf:type rdf:Property ;
    rdfs:label 'Is Base Uom' ;
    rdfs:comment 'Indicates whether this UoM is the base unit of measure for the catalog item. The base UoM is the reference unit to which all other UoM conversions are anchored. Only one UoM per SKU may be the base UoM.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDeliveryUom rdf:type rdf:Property ;
    rdfs:label 'Is Delivery Uom' ;
    rdfs:comment 'Indicates whether this UoM is the delivery unit of measure used in outbound deliveries and shipping documents. Supports logistics and warehouse management processes.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOrderUom rdf:type rdf:Property ;
    rdfs:label 'Is Order Uom' ;
    rdfs:comment 'Indicates whether this UoM is the order unit of measure used in purchase orders and procurement transactions. Corresponds to the SAP S/4HANA purchase order unit (BESTELLEINHEIT).' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProductionUom rdf:type rdf:Property ;
    rdfs:label 'Is Production Uom' ;
    rdfs:comment 'Indicates whether this UoM is used in production orders and manufacturing execution. Supports Bill of Materials (BOM) and production planning processes in SAP PP and Siemens Opcenter MES.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSalesUom rdf:type rdf:Property ;
    rdfs:label 'Is Sales Uom' ;
    rdfs:comment 'Indicates whether this UoM is the sales unit of measure used in customer orders, quotations, and invoices. Corresponds to the SAP S/4HANA sales unit (VRKME).' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStorageUom rdf:type rdf:Property ;
    rdfs:label 'Is Storage Uom' ;
    rdfs:comment 'Indicates whether this UoM is the storage unit of measure used in warehouse and inventory management. Determines how stock is tracked and managed in the warehouse management system.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoCode rdf:type rdf:Property ;
    rdfs:label 'Iso Code' ;
    rdfs:comment 'The ISO 80000-compliant international unit of measure code (e.g., \'KGM\' for kilogram, \'LTR\' for litre, \'MTR\' for metre, \'PCE\' for piece). Used for EDI, cross-system interoperability, and regulatory reporting.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumStackHeight rdf:type rdf:Property ;
    rdfs:label 'Maximum Stack Height' ;
    rdfs:comment 'The maximum number of units of this UoM that can be stacked on top of each other during storage or transportation. Used for warehouse slot planning and load safety compliance.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netWeightKg rdf:type rdf:Property ;
    rdfs:label 'Net Weight Kg' ;
    rdfs:comment 'The net weight of one unit in this UoM, expressed in kilograms, excluding packaging. Used for product content weight declarations, customs documentation, and regulatory compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingType rdf:type rdf:Property ;
    rdfs:label 'Packaging Type' ;
    rdfs:comment 'Describes the physical packaging form associated with this UoM (e.g., each, inner pack, case, carton, pallet). Supports warehouse operations, shipping documentation, and customer order fulfillment.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityPerPackage rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Package' ;
    rdfs:comment 'The number of base units contained within one unit of this UoM packaging level (e.g., 12 EA per case, 48 cases per pallet). Supports packaging hierarchy navigation and order quantity validation.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roundingValue rdf:type rdf:Property ;
    rdfs:label 'Rounding Value' ;
    rdfs:comment 'The rounding quantity in this UoM to which order quantities are rounded up during Material Requirements Planning (MRP) and procurement. Ensures order quantities align with packaging multiples.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variableOrderUnitAllowed rdf:type rdf:Property ;
    rdfs:label 'Variable Order Unit Allowed' ;
    rdfs:comment 'Indicates whether the order unit of measure can be changed at the time of order entry, allowing flexibility in procurement and sales transactions. Aligned with SAP S/4HANA variable order unit configuration.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeM3 rdf:type rdf:Property ;
    rdfs:label 'Volume M3' ;
    rdfs:comment 'The volume of one unit in this UoM, expressed in cubic meters. Used for warehouse space planning, container loading optimization, and freight volume calculations. Aligned with SAP S/4HANA MARM-VOLUM.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:characteristicDataType rdf:type rdf:Property ;
    rdfs:label 'Characteristic Data Type' ;
    rdfs:comment 'Data type of the characteristic value as defined by the classification system (e.g., numeric, string, boolean, coded_value, range, date). Enables correct parsing and validation of characteristic values during EDI exchange and catalog integration.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characteristicName rdf:type rdf:Property ;
    rdfs:label 'Characteristic Name' ;
    rdfs:comment 'Name of the technical characteristic or attribute defined by the classification system for this class (e.g., \'Rated Voltage\', \'IP Protection Class\', \'Power Rating\', \'Rated Current\'). Each classification record captures one characteristic key-value pair per the classification system\'s feature catalog.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characteristicUnit rdf:type rdf:Property ;
    rdfs:label 'Characteristic Unit' ;
    rdfs:comment 'Unit of measure associated with the characteristic value (e.g., \'V\' for voltage, \'kW\' for power, \'A\' for current, \'Hz\' for frequency). Follows SI units as defined by the classification standard. Null for non-numeric or coded characteristics.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classCode rdf:type rdf:Property ;
    rdfs:label 'Class Code' ;
    rdfs:comment 'The specific class or commodity code assigned to the product within the classification system (e.g., eCl@ss class code \'27-37-10-01\' for circuit breakers, UNSPSC code \'39121000\' for power distribution equipment). Used for structured product search and cross-catalog comparison.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:className rdf:type rdf:Property ;
    rdfs:label 'Class Name' ;
    rdfs:comment 'Human-readable name or label of the assigned classification class (e.g., \'Circuit Breaker\', \'Power Distribution Equipment\'). Supports product search, catalog display, and reporting without requiring lookup of the class code.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityCode rdf:type rdf:Property ;
    rdfs:label 'Commodity Code' ;
    rdfs:comment 'Third-level commodity code within the classification hierarchy (e.g., UNSPSC commodity \'391210\' for Circuit Breakers). Provides granular product categorization for procurement sourcing, supplier management via SAP Ariba, and spend analytics.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'Confidence percentage (0.00–100.00) associated with the classification assignment, particularly relevant for automated or AI-assisted classifications. Enables quality filtering and prioritization of manual review for low-confidence assignments. Null for fully manual classifications.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eclassCode rdf:type rdf:Property ;
    rdfs:label 'Eclass Code' ;
    rdfs:comment 'eCl@ss classification code assigned to the product in the format XX-XX-XX-XX (e.g., \'27-37-10-01\' for Low Voltage Circuit Breakers). eCl@ss is the primary classification standard for industrial automation, electrification, and smart infrastructure products in the manufacturing sector.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCatalogCode rdf:type rdf:Property ;
    rdfs:label 'Edi Catalog Code' ;
    rdfs:comment 'Classification code formatted for use in Electronic Data Interchange (EDI) transactions and punchout catalog integrations (e.g., cXML, OCI punchout). May differ from the raw class_code due to EDI partner-specific formatting requirements. Supports SAP Ariba punchout catalog integration.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etimClassCode rdf:type rdf:Property ;
    rdfs:label 'Etim Class Code' ;
    rdfs:comment 'Electrotechnical Information Model (ETIM) class code assigned to the product (e.g., \'EC002714\' for Circuit Breaker). ETIM is the dominant classification standard for electrotechnical and industrial automation products in European markets. Stored as a dedicated field due to its critical importance in the industrial manufacturing sector.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyCode rdf:type rdf:Property ;
    rdfs:label 'Family Code' ;
    rdfs:comment 'Second-level family code within the classification hierarchy (e.g., UNSPSC family \'3912\' for Power Distribution and Protection Equipment). Supports mid-level product grouping for procurement category management and spend analysis.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:punchoutCatalogFlag rdf:type rdf:Property ;
    rdfs:label 'Punchout Catalog Flag' ;
    rdfs:comment 'Indicates whether this classification record is published and active in punchout catalog integrations (e.g., SAP Ariba, Coupa). When true, the classification is available for buyer-side catalog search and procurement workflows.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryRelevance rdf:type rdf:Property ;
    rdfs:label 'Regulatory Relevance' ;
    rdfs:comment 'Indicates whether this classification assignment has direct regulatory compliance relevance. Values include \'ce_marking\' (EU product safety), \'rohs\' (Restriction of Hazardous Substances), \'reach\' (Registration Evaluation Authorization and Restriction of Chemicals), \'ul\' (Underwriters Laboratories), \'multiple\' (more than one regulation applies), or \'none\'.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Top-level segment code within the classification hierarchy (e.g., UNSPSC segment \'39\' for Electrical Systems and Lighting Equipment, eCl@ss segment \'27\' for Electrical Engineering). Enables high-level product portfolio analysis and spend analytics.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:system rdf:type rdf:Property ;
    rdfs:label 'System' ;
    rdfs:comment 'Name of the industry-standard or internal classification system used for this assignment. Supported systems include eCl@ss (electrotechnical/industrial), UNSPSC (United Nations Standard Products and Services Code), ETIM (Electrotechnical Information Model), GPC (GS1 Global Product Classification), HS (Harmonized System), NAICS, and internal/custom schemas.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemVersion rdf:type rdf:Property ;
    rdfs:label 'System Version' ;
    rdfs:comment 'Version or release of the classification system applied (e.g., eCl@ss 12.0, UNSPSC v23.0901, ETIM 8.0). Critical for maintaining traceability as classification standards evolve and for EDI/punchout catalog compatibility.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validatedBy rdf:type rdf:Property ;
    rdfs:label 'Validated By' ;
    rdfs:comment 'Username or employee ID of the person who validated and approved this classification assignment. Required for quality-controlled classification workflows, particularly for regulatory-relevant classifications (CE, RoHS, REACH). Supports ISO 9001 audit trail requirements.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validated Timestamp' ;
    rdfs:comment 'Date and time when the classification assignment was validated and approved. Provides a precise audit trail for compliance reporting and classification governance.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:applicableMarketRegions rdf:type rdf:Property ;
    rdfs:label 'Applicable Market Regions' ;
    rdfs:comment 'Pipe-delimited list of ISO 3166-1 alpha-3 country codes or named regional market groupings (e.g., \'USA|CAN|MEX\' or \'GLOBAL\') identifying the geographic markets where this warranty policy is valid and enforceable.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableProductScope rdf:type rdf:Property ;
    rdfs:label 'Applicable Product Scope' ;
    rdfs:comment 'Defines the scope of catalog items to which this warranty policy applies: all products, a specific product family, product category, individual SKU, or a named product line such as automation systems or electrification solutions.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimLimitCurrency rdf:type rdf:Property ;
    rdfs:label 'Claim Limit Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the max_claim_amount is denominated (e.g., USD, EUR, GBP). Supports multi-currency operations across global markets.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageScope rdf:type rdf:Property ;
    rdfs:label 'Coverage Scope' ;
    rdfs:comment 'Defines what is covered under the warranty: parts only (materials cost), parts and labor (materials plus technician time), full replacement (complete unit swap), on-site service (field technician dispatch), depot repair (return-to-depot), software only, or consumables excluded.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Specifies the contractual mechanism for resolving warranty disputes between the manufacturer and customer: arbitration, mediation, litigation, expert determination, or ombudsman. Relevant for legal and compliance teams.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMonths rdf:type rdf:Property ;
    rdfs:label 'Duration Months' ;
    rdfs:comment 'Total duration of the warranty coverage expressed in months from the warranty start date. Standard industrial automation warranties typically range from 12 to 60 months.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exclusionConditions rdf:type rdf:Property ;
    rdfs:label 'Exclusion Conditions' ;
    rdfs:comment 'Narrative description of conditions, events, or damage types that void or exclude warranty coverage (e.g., misuse, unauthorized modifications, improper installation, use outside rated environmental conditions, consumable wear parts, damage from external causes).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborCoverageMonths rdf:type rdf:Property ;
    rdfs:label 'Labor Coverage Months' ;
    rdfs:comment 'Number of months during which labor costs are covered under the warranty. May differ from total duration_months when labor coverage is shorter than parts coverage (e.g., 12 months labor within a 24-month parts warranty).' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxClaimAmount rdf:type rdf:Property ;
    rdfs:label 'Max Claim Amount' ;
    rdfs:comment 'Maximum monetary value of claims that can be processed under this warranty policy over its lifetime. Caps the manufacturer\'s financial liability exposure per policy instance.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onSiteServiceIncluded rdf:type rdf:Property ;
    rdfs:label 'On Site Service Included' ;
    rdfs:comment 'Indicates whether the warranty policy includes on-site field service dispatch at no additional charge to the customer. Drives field service scheduling and cost allocation in Salesforce Field Service and Maximo EAM.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partsCoverageMonths rdf:type rdf:Property ;
    rdfs:label 'Parts Coverage Months' ;
    rdfs:comment 'Number of months during which replacement parts are covered under the warranty. May differ from labor_coverage_months in tiered warranty structures.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proRataApplicable rdf:type rdf:Property ;
    rdfs:label 'Pro Rata Applicable' ;
    rdfs:comment 'Indicates whether warranty claims are settled on a pro-rata basis (i.e., the reimbursement value decreases proportionally over the warranty period). Common in battery and consumable component warranties.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationRequired rdf:type rdf:Property ;
    rdfs:label 'Registration Required' ;
    rdfs:comment 'Indicates whether the customer must register the product to activate warranty coverage. When true, warranty claims may be rejected if registration was not completed within the required registration window.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationWindowDays rdf:type rdf:Property ;
    rdfs:label 'Registration Window Days' ;
    rdfs:comment 'Number of days from the warranty start basis event within which the customer must register the product to activate warranty coverage. Applicable only when registration_required is true.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewable rdf:type rdf:Property ;
    rdfs:label 'Renewable' ;
    rdfs:comment 'Indicates whether this warranty policy can be renewed or extended at the end of the coverage period, typically through a service contract or extended warranty purchase.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionTimeHours rdf:type rdf:Property ;
    rdfs:label 'Resolution Time Hours' ;
    rdfs:comment 'Maximum number of hours within which the manufacturer commits to resolve or provide a remedy for a warranty claim. Distinct from response_time_hours which covers acknowledgment only.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transferable rdf:type rdf:Property ;
    rdfs:label 'Transferable' ;
    rdfs:comment 'Indicates whether the warranty coverage can be transferred to a subsequent owner of the product (e.g., upon resale of industrial equipment). Relevant for asset-intensive industries where equipment changes ownership.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyStartBasis rdf:type rdf:Property ;
    rdfs:label 'Warranty Start Basis' ;
    rdfs:comment 'Defines the event that triggers the start of the warranty period: ship_date (date product leaves factory), delivery_date (date received by customer), installation_date (date physically installed), commissioning_date (date system is operational), invoice_date, first_use_date, or registration_date.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterId rdf:type rdf:Property ;
    rdfs:label 'Work Center Id' ;
    rdfs:comment 'Unique surrogate identifier for the work center record in the lakehouse silver layer. Serves as the primary key for all downstream joins and references.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkCenter .

ind:assetClassId rdf:type rdf:Property ;
    rdfs:label 'Asset Class Id' ;
    rdfs:comment 'Foreign key linking to asset.class. Business justification: Work centers are classified by asset class (e.g., CNC, press, conveyor) in manufacturing ERP systems. Production planners use this daily to filter capacity by equipment class and apply class-level mai' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Class .

ind:activityTypeCode rdf:type rdf:Property ;
    rdfs:label 'Activity Type Code' ;
    rdfs:comment 'SAP Controlling activity type code (e.g., MACH, LABOR) used to allocate costs from this work center to production orders. Enables granular cost-of-goods-sold (COGS) analysis.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityAvailableHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Capacity Available Hours Per Day' ;
    rdfs:comment 'Total available production hours per day for this work center, calculated from active shifts and break schedules. Used as the baseline for capacity requirements planning (CRP) in MRP II.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityCategory rdf:type rdf:Property ;
    rdfs:label 'Capacity Category' ;
    rdfs:comment 'Defines the primary capacity resource type tracked for this work center (machine hours, labor hours, energy units, tooling). Used in MRP II capacity requirements planning (CRP).' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingFormula rdf:type rdf:Property ;
    rdfs:label 'Costing Formula' ;
    rdfs:comment 'Identifier of the formula used to calculate production costs (machine costs, labor costs, overhead) for operations performed at this work center. Links to SAP CO activity types and cost rates.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:efficiencyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Efficiency Rate Percent' ;
    rdfs:comment 'Ratio of standard time to actual time expressed as a percentage, representing how efficiently the work center converts available time into productive output. Used in capacity planning and OEE calculations.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floorAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Floor Area Sqm' ;
    rdfs:comment 'Physical floor space occupied by the work center in square meters. Used in facility layout planning, 5S audits, and capacity expansion assessments.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hierarchy rdf:type rdf:Property ;
    rdfs:label 'Hierarchy' ;
    rdfs:comment 'Hierarchical grouping path of the work center within the plant structure (e.g., \'Plant A > Production Area 2 > Assembly Line 1\'). Used for aggregated capacity reporting and organizational drill-down in analytics.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moveTimeHours rdf:type rdf:Property ;
    rdfs:label 'Move Time Hours' ;
    rdfs:comment 'Standard time in hours required to physically transport WIP from this work center to the next operation in the routing. Contributes to total manufacturing lead time in MRP II scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfLaborResources rdf:type rdf:Property ;
    rdfs:label 'Number Of Labor Resources' ;
    rdfs:comment 'Number of workers or operators assigned to this work center per shift. Used in labor capacity planning, workforce scheduling via Kronos, and standard cost calculations.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfMachines rdf:type rdf:Property ;
    rdfs:label 'Number Of Machines' ;
    rdfs:comment 'Count of individual machines or equipment units grouped within this work center. Used to calculate aggregate capacity and determine parallel processing capability.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfShifts rdf:type rdf:Property ;
    rdfs:label 'Number Of Shifts' ;
    rdfs:comment 'Number of production shifts per day scheduled at this work center. Directly determines available capacity hours and is used in shift-based scheduling and OEE calculations.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oeeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Target Percent' ;
    rdfs:comment 'Target Overall Equipment Effectiveness (OEE) percentage set for this work center, representing the desired level of availability, performance, and quality combined. Used as the KPI benchmark in TPM and continuous improvement programs.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionStrategy rdf:type rdf:Property ;
    rdfs:label 'Production Strategy' ;
    rdfs:comment 'Manufacturing execution strategy applicable to this work center: Make-to-Order (MTO), Make-to-Stock (MTS), Engineer-to-Order (ETO), or Assemble-to-Order (ATO). Drives order type and scheduling behavior.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queueTimeHours rdf:type rdf:Property ;
    rdfs:label 'Queue Time Hours' ;
    rdfs:comment 'Standard waiting time in hours that a production order or WIP lot is expected to wait in queue before processing begins at this work center. Used in lead time scheduling and order float calculations.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleSupervisor rdf:type rdf:Property ;
    rdfs:label 'Responsible Supervisor' ;
    rdfs:comment 'Name or employee identifier of the shop floor supervisor or foreman accountable for operations at this work center. Used for escalation routing, shift handover, and accountability reporting.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingUsage rdf:type rdf:Property ;
    rdfs:label 'Routing Usage' ;
    rdfs:comment 'Defines the permitted usage of this work center in routing operations: production routing, inspection routing, rework routing, maintenance routing, or all types. Controls which routing types can reference this work center.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Setup Time Minutes' ;
    rdfs:comment 'Standard time in minutes required to prepare (set up) the work center before production begins for a new operation or product. Used in routing time calculations and SMED improvement programs.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftDurationHours rdf:type rdf:Property ;
    rdfs:label 'Shift Duration Hours' ;
    rdfs:comment 'Standard duration in hours of a single production shift at this work center. Combined with number_of_shifts to derive total daily available capacity.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardValueKey rdf:type rdf:Property ;
    rdfs:label 'Standard Value Key' ;
    rdfs:comment 'SAP PP standard value key defining which standard values (setup, machine, labor, teardown) are relevant for operations at this work center. Drives costing formula selection.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teardownTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Teardown Time Minutes' ;
    rdfs:comment 'Standard time in minutes required to clean up and restore the work center after production of an operation is complete. Included in total operation lead time calculations.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Utilization Rate Percent' ;
    rdfs:comment 'Percentage of available capacity time that is actually scheduled or consumed by production orders. A key input to capacity leveling and bottleneck analysis in MRP II.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routingId rdf:type rdf:Property ;
    rdfs:label 'Routing Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying a manufacturing routing record in the Silver Layer lakehouse. Serves as the primary key for all routing-related joins and references.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Routing .

ind:bopReference rdf:type rdf:Property ;
    rdfs:label 'Bop Reference' ;
    rdfs:comment 'Reference identifier linking this routing to the corresponding Bill of Process (BoP) in Siemens Teamcenter PLM. The BoP defines the engineering-side process structure, while the routing is the ERP execution counterpart.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecnNumber rdf:type rdf:Property ;
    rdfs:label 'Ecn Number' ;
    rdfs:comment 'Reference to the Engineering Change Notice (ECN) or Engineering Change Order (ECO) that authorized the creation or last modification of this routing. Provides traceability between process changes and engineering change management.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:group rdf:type rdf:Property ;
    rdfs:label 'Group' ;
    rdfs:comment 'SAP PP routing group key that, together with the routing group counter, uniquely identifies a task list. Groups related routing variants for the same material or product family.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasAlternativeSequences rdf:type rdf:Property ;
    rdfs:label 'Has Alternative Sequences' ;
    rdfs:comment 'Indicates whether the routing contains alternative operation sequences that can be selected based on work center availability, capacity constraints, or material characteristics. Supports flexible shop floor scheduling.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasInspectionOperations rdf:type rdf:Property ;
    rdfs:label 'Has Inspection Operations' ;
    rdfs:comment 'Indicates whether the routing includes quality inspection operations (linked to SAP QM inspection characteristics). Supports integration with the Quality Management System (QMS) and First Article Inspection (FAI) processes.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasParallelSequences rdf:type rdf:Property ;
    rdfs:label 'Has Parallel Sequences' ;
    rdfs:comment 'Indicates whether the routing contains parallel operation sequences (concurrent process branches) in addition to the standard sequence. Parallel sequences enable simultaneous execution of independent operations, reducing total lead time.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotSizeFrom rdf:type rdf:Property ;
    rdfs:label 'Lot Size From' ;
    rdfs:comment 'Minimum production lot size for which this routing is valid. Used in SAP PP lot-size-dependent routing selection to ensure the correct process sequence is applied based on production quantity.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSizeTo rdf:type rdf:Property ;
    rdfs:label 'Lot Size To' ;
    rdfs:comment 'Maximum production lot size for which this routing is valid. Together with lot_size_from, defines the quantity range for routing selection during production order creation and MRP II planning.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plmRoutingCode rdf:type rdf:Property ;
    rdfs:label 'Plm Routing Code' ;
    rdfs:comment 'External identifier of the corresponding routing or process plan object in Siemens Teamcenter PLM. Enables bidirectional traceability between the ERP routing (SAP PP) and the PLM process definition for Engineering Change Management.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingRelevance rdf:type rdf:Property ;
    rdfs:label 'Scheduling Relevance' ;
    rdfs:comment 'Indicates whether this routing is used for production order scheduling and capacity requirements planning (CRP) in MRP II. When true, the routing drives work center load calculations and finite/infinite scheduling.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taktTimeSec rdf:type rdf:Property ;
    rdfs:label 'Takt Time Sec' ;
    rdfs:comment 'Takt time in seconds for this routing, representing the rate at which products must be completed to meet customer demand. Calculated as available production time divided by customer demand rate. Key Lean Manufacturing metric for line balancing and flow design.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taskListType rdf:type rdf:Property ;
    rdfs:label 'Task List Type' ;
    rdfs:comment 'SAP PP task list type code indicating the category of the routing: N=Standard Routing, R=Reference Operation Set, M=Rate Routing, S=Rough-Cut Planning Profile, E=Equipment Task List, Q=Inspection Plan. Drives system behavior in MRP II and shop floor scheduling.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLaborTimeMin rdf:type rdf:Property ;
    rdfs:label 'Total Labor Time Min' ;
    rdfs:comment 'Aggregate standard labor time in minutes across all routing operations for the base quantity. Used for workforce capacity planning, standard cost calculation (labor cost component), and productivity analysis.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Total Lead Time Days' ;
    rdfs:comment 'Total manufacturing lead time in days for the complete routing, representing the elapsed calendar time from start of first operation to completion of last operation. Used in MRP II scheduling, ATP (Available to Promise), and delivery date calculation.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMachineTimeMin rdf:type rdf:Property ;
    rdfs:label 'Total Machine Time Min' ;
    rdfs:comment 'Aggregate standard machine processing time in minutes across all routing operations for the base quantity. Core input for MRP II capacity requirements planning (CRP), takt time analysis, and production scheduling.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSetupTimeMin rdf:type rdf:Property ;
    rdfs:label 'Total Setup Time Min' ;
    rdfs:comment 'Aggregate standard setup time in minutes across all operations in the routing for the base quantity. Used for capacity planning, costing, and OEE (Overall Equipment Effectiveness) analysis. Supports SMED (Single-Minute Exchange of Dies) improvement tracking.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routingOperationId rdf:type rdf:Property ;
    rdfs:label 'Routing Operation Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying a single operation step within a manufacturing routing. Serves as the primary key for the routing_operation entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoutingOperation .

ind:isInspectionOperation rdf:type rdf:Property ;
    rdfs:label 'Is Inspection Operation' ;
    rdfs:comment 'Indicates whether this operation is a quality inspection step that triggers an inspection lot in the Quality Management (QM) module. When true, the operation creates an inspection point and requires quality results recording before the production order can be confirmed.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMilestoneOperation rdf:type rdf:Property ;
    rdfs:label 'Is Milestone Operation' ;
    rdfs:comment 'Indicates whether this operation is a milestone (gate) in the production routing. Milestone operations must be confirmed before subsequent operations can begin, enabling stage-gate control of the production flow and partial goods receipt.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSubcontracting rdf:type rdf:Property ;
    rdfs:label 'Is Subcontracting' ;
    rdfs:comment 'Indicates whether this operation is performed by an external subcontractor rather than internally. When true, the operation triggers a subcontracting purchase order in SAP MM and requires goods issue/receipt processing for the outsourced step.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moveTime rdf:type rdf:Property ;
    rdfs:label 'Move Time' ;
    rdfs:comment 'Standard time required to transport materials or WIP from this operation to the next work center. Contributes to total lead time calculation and is used in scheduling to account for inter-operation material movement.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationUnit rdf:type rdf:Property ;
    rdfs:label 'Operation Unit' ;
    rdfs:comment 'Unit of measure for the operation quantity (e.g., EA for each, KG for kilogram, M for meter). Defines how the operation output is counted and reported on the shop floor and in MES confirmations.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overlapType rdf:type rdf:Property ;
    rdfs:label 'Overlap Type' ;
    rdfs:comment 'Defines whether and how this operation can overlap with the preceding operation in the routing sequence. \'no_overlap\' requires full completion before the next starts; \'time_overlap\' allows a fixed time offset; \'quantity_overlap\' allows partial quantity transfer. Enables lead time compression in scheduling.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overlapValue rdf:type rdf:Property ;
    rdfs:label 'Overlap Value' ;
    rdfs:comment 'Numeric value defining the extent of overlap with the preceding operation. Interpreted based on overlap_type: for time_overlap, the number of time units (per time_unit); for quantity_overlap, the minimum quantity to transfer before the next operation starts.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:queueTime rdf:type rdf:Property ;
    rdfs:label 'Queue Time' ;
    rdfs:comment 'Standard waiting time (queue) before this operation begins, representing the time a work order waits in the queue at the work center. Included in lead time calculation and critical path scheduling. Expressed in the unit defined by time_unit.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scrapPercentage rdf:type rdf:Property ;
    rdfs:label 'Scrap Percentage' ;
    rdfs:comment 'Expected percentage of material or components that will be scrapped during this operation under normal production conditions. Used in MRP II to inflate planned order quantities, in standard cost calculation, and in yield analysis. Expressed as a percentage (0–100).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardLaborTime rdf:type rdf:Property ;
    rdfs:label 'Standard Labor Time' ;
    rdfs:comment 'Standard labor (person) time required per base quantity unit for this operation. Used for labor cost rollup, workforce capacity planning, and standard cost calculation. Expressed in the unit defined by time_unit.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardMachineTime rdf:type rdf:Property ;
    rdfs:label 'Standard Machine Time' ;
    rdfs:comment 'Standard machine processing time per base quantity unit for this operation. Drives machine capacity loading in MRP II, OEE calculations, and takt time analysis. Expressed in the unit defined by time_unit.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardSetupTime rdf:type rdf:Property ;
    rdfs:label 'Standard Setup Time' ;
    rdfs:comment 'Standard time required to set up the work center before production begins for this operation (e.g., tooling changeover, fixture installation, machine calibration). Used in capacity planning, SMED analysis, and production scheduling. Expressed in the unit defined by time_unit.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardTeardownTime rdf:type rdf:Property ;
    rdfs:label 'Standard Teardown Time' ;
    rdfs:comment 'Standard time required to dismantle tooling, clean the work center, and restore it to a ready state after the operation completes. Included in total operation duration for scheduling and capacity loading.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeUnit rdf:type rdf:Property ;
    rdfs:label 'Time Unit' ;
    rdfs:comment 'Unit of measure applied to all standard time values (setup, machine, labor, teardown) for this operation. Ensures consistent interpretation of time fields across scheduling, costing, and capacity planning systems.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitTime rdf:type rdf:Property ;
    rdfs:label 'Wait Time' ;
    rdfs:comment 'Standard time the material must wait after this operation completes before the next operation can begin (e.g., curing time, cooling time, drying time). Included in lead time scheduling and critical path analysis.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleId rdf:type rdf:Property ;
    rdfs:label 'Schedule Id' ;
    rdfs:comment 'Unique surrogate identifier for each production schedule record in the Databricks Silver Layer. Serves as the primary key for the production_schedule data product.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchId rdf:type rdf:Property ;
    rdfs:label 'Batch Id' ;
    rdfs:comment 'Foreign key linking to production.batch. Business justification: production_schedule references a batch for batch-managed production planning. The FK batch_id normalizes the batch_number string reference and enables joins to batch master data for batch-level schedu' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Batch .

ind:plannedOrderId rdf:type rdf:Property ;
    rdfs:label 'Planned Order Id' ;
    rdfs:comment 'Foreign key linking to production.planned_order. Business justification: production_schedule is built from MRP-generated planned_orders. The FK planned_order_id normalizes the planned_order_number string reference and enables joins to planned_order master data for schedule' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlannedOrder .

ind:shiftId rdf:type rdf:Property ;
    rdfs:label 'Shift Id' ;
    rdfs:comment 'Foreign key linking to production.shift. Business justification: Production schedules specify which shift executes the work. Shift supervisors use this for crew assignments and labor planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shift .

ind:atpRelevant rdf:type rdf:Property ;
    rdfs:label 'Atp Relevant' ;
    rdfs:comment 'Indicates whether this production schedule entry contributes to Available to Promise (ATP) stock calculations in SAP S/4HANA SD. When true, the planned production quantity is included in ATP/CTP commitment logic for the order domain.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityLoadPercent rdf:type rdf:Property ;
    rdfs:label 'Capacity Load Percent' ;
    rdfs:comment 'Percentage of the work center\'s available capacity consumed by this production schedule entry. A value of 100 indicates full utilization; values above 100 indicate overload conditions requiring rescheduling or capacity leveling in SAP PP.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freezeHorizonDate rdf:type rdf:Property ;
    rdfs:label 'Freeze Horizon Date' ;
    rdfs:comment 'Date up to which the production schedule is frozen and protected from automatic MRP II rescheduling. Orders within the freeze horizon require manual authorization to change, ensuring shop floor stability and preventing nervousness in the plan.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedCost rdf:type rdf:Property ;
    rdfs:label 'Planned Cost' ;
    rdfs:comment 'Estimated total production cost for this schedule entry in the plant\'s local currency, derived from SAP CO standard cost estimates. Includes material, labor, and overhead components. Used for budget planning and COGS analysis.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningHorizonEnd rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon End' ;
    rdfs:comment 'The last calendar date of the planning horizon covered by this production schedule. Defines the end boundary for MRP II capacity planning and scheduled production orders.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningHorizonStart rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Start' ;
    rdfs:comment 'The first calendar date of the planning horizon covered by this production schedule. Defines the start boundary for MRP II capacity planning and scheduled production orders.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'Reference to the SAP PP routing (Bill of Process) that defines the sequence of operations, work centers, and standard times for producing the scheduled material. Ensures the schedule is aligned with the approved manufacturing process.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned calendar date on which production for this schedule entry is expected to be completed at the assigned work center. Drives delivery date commitments and ATP/CTP calculations for the order domain.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'Precise date and time at which production is scheduled to complete, including shift and time-zone context. Used by Siemens Opcenter MES for detailed shop floor sequencing and completion tracking.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned calendar date on which production for this schedule entry is expected to begin at the assigned work center. Used for shop floor sequencing and ATP/CTP date commitments to the order domain.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'Precise date and time at which production is scheduled to begin, including shift and time-zone context. Used by Siemens Opcenter MES for detailed shop floor sequencing and takt time alignment.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:schedulingStrategy rdf:type rdf:Property ;
    rdfs:label 'Scheduling Strategy' ;
    rdfs:comment 'Scheduling direction applied during MRP II planning. Forward scheduling calculates the earliest possible completion date from a start date; backward scheduling calculates the latest start date from a required delivery date; mixed applies both depending on order priority.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'Shift configuration planned for this production schedule entry, defining the number of operating shifts per day. Drives available capacity calculation and Kronos Workforce Central labor scheduling alignment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeBucket rdf:type rdf:Property ;
    rdfs:label 'Time Bucket' ;
    rdfs:comment 'Granularity of the planning time bucket used in this schedule. Daily buckets are used for short-horizon detailed scheduling; weekly for medium-term MRP II planning; monthly for long-range capacity planning.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderTypeId rdf:type rdf:Property ;
    rdfs:label 'Order Type Id' ;
    rdfs:comment 'Foreign key linking to production.order_type. Business justification: planned_order.order_type (STRING) is a denormalized reference to the order_type master. Adding order_type_id FK normalizes this relationship, enabling joins to retrieve order category, confirmation co' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderType .

ind:versionId rdf:type rdf:Property ;
    rdfs:label 'Version Id' ;
    rdfs:comment 'Foreign key linking to production.production_version. Business justification: planned_order references a production_version that defines the valid BOM and routing combination for manufacturing. The FK production_version_id normalizes the production_version string code and enabl' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Version .

ind:bomNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Number' ;
    rdfs:comment 'Identifier of the Bill of Materials assigned to this planned order, defining the component materials and quantities required for production. Sourced from the production version or material master.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandSourceNumber rdf:type rdf:Property ;
    rdfs:label 'Demand Source Number' ;
    rdfs:comment 'The identifier of the originating demand element (e.g., sales order number, forecast record ID, project WBS element) that triggered this planned order. Enables end-to-end demand-to-production traceability.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inHouseProductionDays rdf:type rdf:Property ;
    rdfs:label 'In House Production Days' ;
    rdfs:comment 'The planned in-house production lead time in calendar days for this planned order, as determined by the routing or material master. Used by MRP for backward and forward scheduling calculations.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isConverted rdf:type rdf:Property ;
    rdfs:label 'Is Converted' ;
    rdfs:comment 'Boolean flag indicating whether this planned order has been fully converted to a production order or purchase requisition. Once converted, the planned order is no longer an open planning element.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mrpRunReference rdf:type rdf:Property ;
    rdfs:label 'Mrp Run Reference' ;
    rdfs:comment 'Unique reference identifier for the MRP/MPS planning run that generated this planned order. Supports audit traceability and re-planning analysis.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledFinishDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Finish Date' ;
    rdfs:comment 'The planned calendar date on which production of this order is scheduled to be completed, as calculated by MRP forward scheduling. Drives delivery date commitments and ATP checks.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shopOrderOperationId rdf:type rdf:Property ;
    rdfs:label 'Shop Order Operation Id' ;
    rdfs:comment 'Unique surrogate identifier for each shop order operation execution record in the silver layer lakehouse. Serves as the primary key for this entity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShopOrderOperation .

ind:machineWorkCenterId rdf:type rdf:Property ;
    rdfs:label 'Machine Work Center Id' ;
    rdfs:comment 'Identifier of the specific machine or equipment asset assigned to execute this operation. Links to the equipment master in Maximo EAM and Siemens MindSphere for OEE tracking, predictive maintenance, and asset utilization reporting.' ;
    rdfs:domain ind:ShopOrderOperation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkCenter .

ind:actualLaborTimeMin rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Time Min' ;
    rdfs:comment 'Actual direct labor time in minutes consumed by the operator(s) for this operation. Used for actual cost confirmation in SAP CO, labor efficiency variance analysis, and workforce productivity reporting.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualRunTimeMin rdf:type rdf:Property ;
    rdfs:label 'Actual Run Time Min' ;
    rdfs:comment 'Actual machine or process run time in minutes for this operation, excluding setup and teardown. Core input for OEE performance rate calculation and cycle time variance analysis against standard run time.' ;
    rdfs:domain ind:ShopOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSetupTimeMin rdf:type rdf:Property ;
    rdfs:label 'Actual Setup Time Min' ;
    rdfs:comment 'Actual time in minutes spent on machine/tooling setup before production run began. Used for SMED (Single-Minute Exchange of Dies) analysis, changeover optimization, and OEE availability loss calculation.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleTimeSec rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Sec' ;
    rdfs:comment 'Actual cycle time in seconds measured for this operation execution, calculated from actual start to actual finish divided by yield quantity. Compared against takt time and standard cycle time for OEE performance rate and lean analysis.' ;
    rdfs:domain ind:ShopOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downtimeMin rdf:type rdf:Property ;
    rdfs:label 'Downtime Min' ;
    rdfs:comment 'Total unplanned downtime in minutes recorded during this operation execution (e.g., machine breakdown, material shortage, quality stop). Core input for OEE availability rate calculation and downtime root cause analysis.' ;
    rdfs:domain ind:ShopOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downtimeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Downtime Reason Code' ;
    rdfs:comment 'Coded classification of the primary downtime cause during this operation (e.g., MECH_FAILURE, TOOLING, MATERIAL, QUALITY_HOLD, CHANGEOVER, PLANNED_MAINT). Used for Pareto analysis of downtime losses and TPM (Total Productive Maintenance) improvement programs.' ;
    rdfs:domain ind:ShopOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncFlag rdf:type rdf:Property ;
    rdfs:label 'Nc Flag' ;
    rdfs:comment 'Indicates whether a non-conformance (NC) was detected during this operation. When true, triggers NCR (Non-Conformance Report) creation in the QMS and may initiate a hold on the production order. Key quality gate indicator.' ;
    rdfs:domain ind:ShopOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ncReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Nc Reference Number' ;
    rdfs:comment 'Reference number of the Non-Conformance Report (NCR) raised against this operation when nc_flag is true. Provides direct traceability to the quality management system record for CAPA and disposition tracking.' ;
    rdfs:domain ind:ShopOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Production shift during which this operation was executed (e.g., DAY, AFTERNOON, NIGHT, WEEKEND). Used for shift-level OEE analysis, labor cost allocation by shift, and production performance benchmarking across shifts.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spcViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Spc Violation Flag' ;
    rdfs:comment 'Indicates whether a Statistical Process Control (SPC) control chart violation (e.g., out-of-control signal) was detected during this operation. Triggers quality alert and potential hold in the MES quality module.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardRunTimeMin rdf:type rdf:Property ;
    rdfs:label 'Standard Run Time Min' ;
    rdfs:comment 'Planned or standard run time in minutes for this operation as defined in the routing master. Used as the baseline for cycle time variance, OEE performance rate, and manufacturing cost standard costing.' ;
    rdfs:domain ind:ShopOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Yield Quantity' ;
    rdfs:comment 'Quantity of conforming (good) units produced by this operation that pass to the next step or are completed. Core metric for OEE quality rate, first-pass yield (FPY), and production order confirmation in SAP PP.' ;
    rdfs:domain ind:ShopOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Production Confirmation Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying a production confirmation record in the Silver Layer lakehouse. Serves as the primary key for all downstream joins and lineage tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionConfirmation .

ind:finishedGoodsStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Finished Goods Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: Production confirmations specify where finished goods are received into inventory. Warehouse systems use this for automatic putaway task generation.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Actual manufacturing cost settled to the production order upon confirmation, including material, labor, machine, and overhead components. Used for actual vs. standard cost variance analysis and COGS reporting.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualMachineTimeMin rdf:type rdf:Property ;
    rdfs:label 'Actual Machine Time Min' ;
    rdfs:comment 'Actual machine runtime in minutes consumed during the confirmed operation. Used for OEE performance rate calculation, machine utilization reporting, and actual vs. standard cost variance analysis.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsMovementDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Movement Document Number' ;
    rdfs:comment 'SAP material document number generated by the inventory posting (goods receipt) triggered by this production confirmation. Provides the audit trail link between the confirmation event and the resulting stock and accounting entries.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAutoGoodsReceipt rdf:type rdf:Property ;
    rdfs:label 'Is Auto Goods Receipt' ;
    rdfs:comment 'Indicates whether the goods receipt (inventory posting from WIP to finished goods) was triggered automatically upon confirmation posting, as configured in the production order control key.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFinalConfirmation rdf:type rdf:Property ;
    rdfs:label 'Is Final Confirmation' ;
    rdfs:comment 'Indicates whether this confirmation is the final posting for the production order operation, triggering order status change to \'Technically Completed\' (TECO) in SAP PP and closing WIP balances.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ncrNumber rdf:type rdf:Property ;
    rdfs:label 'Ncr Number' ;
    rdfs:comment 'Reference to the Non-Conformance Report raised against this confirmation when scrap or rework quantities are posted. Triggers CAPA workflow and feeds the QMS for defect tracking and regulatory reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Lot Number' ;
    rdfs:comment 'SAP QM inspection lot number automatically created upon posting of the production confirmation. Links the confirmed output to the quality inspection process for usage decision and AQL-based sampling.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shift rdf:type rdf:Property ;
    rdfs:label 'Shift' ;
    rdfs:comment 'Manufacturing shift during which the production confirmation was recorded (e.g., Day, Afternoon, Night, Shift-A). Used for shift-level OEE analysis, throughput reporting, and labor cost allocation.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Coded reason explaining deviations from planned quantities, times, or costs (e.g., machine breakdown, material shortage, quality rejection). Feeds variance analysis in SAP CO and supports CAPA and root cause analysis.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Description' ;
    rdfs:comment 'Free-text description providing additional context for the variance reason code. Captures operator or supervisor notes on deviations for root cause analysis and continuous improvement initiatives.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStagingId rdf:type rdf:Property ;
    rdfs:label 'Material Staging Id' ;
    rdfs:comment 'Unique surrogate identifier for each material staging and issuance record on the shop floor. Serves as the primary key for the material_staging data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:MaterialStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryId rdf:type rdf:Property ;
    rdfs:label 'Delivery Id' ;
    rdfs:comment 'Foreign key linking to logistics.delivery. Business justification: Material staging is directly triggered by an inbound or outbound delivery document. Production planners and warehouse staff link staged materials to the delivery to confirm what has arrived and is rea' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Delivery .

ind:actualStagingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Staging Timestamp' ;
    rdfs:comment 'Actual date and time when the material was physically moved to the staging area or production supply area. Captured by MES or WMS system. Used for staging lead time analysis and JIT performance measurement.' ;
    rdfs:domain ind:MaterialStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:backflushIndicator rdf:type rdf:Property ;
    rdfs:label 'Backflush Indicator' ;
    rdfs:comment 'Indicates whether the material is subject to backflushing (automatic goods issue upon production order confirmation) rather than manual goods issue. Backflushed components do not require explicit staging transactions.' ;
    rdfs:domain ind:MaterialStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bomComponentPosition rdf:type rdf:Property ;
    rdfs:label 'Bom Component Position' ;
    rdfs:comment 'Position or item number of the component within the Bill of Materials (BOM) for the production order. Enables traceability from the staged material back to the BOM structure in PLM/ERP.' ;
    rdfs:domain ind:MaterialStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingWarehouse rdf:type rdf:Property ;
    rdfs:label 'Issuing Warehouse' ;
    rdfs:comment 'Identifier of the warehouse or warehouse complex (SAP WM Warehouse Number / Infor WMS Warehouse) from which the material is physically picked and issued to the shop floor. Supports WMS integration.' ;
    rdfs:domain ind:MaterialStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Material Cost Per Unit' ;
    rdfs:comment 'Standard or moving average cost per unit of the material at the time of goods issue, as valuated in SAP S/4HANA CO. Used for WIP costing, COGS calculation, and production order cost analysis.' ;
    rdfs:domain ind:MaterialStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedStagingDate rdf:type rdf:Property ;
    rdfs:label 'Planned Staging Date' ;
    rdfs:comment 'Planned date on which the material should be staged or issued to the shop floor, as determined by MRP II scheduling and production order requirements. Used for material availability planning.' ;
    rdfs:domain ind:MaterialStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredQuantity rdf:type rdf:Property ;
    rdfs:label 'Required Quantity' ;
    rdfs:comment 'Planned quantity of the material required for the production order as specified in the BOM or reservation. Represents the demand quantity before actual issuance. Used for shortage analysis and MRP II planning.' ;
    rdfs:domain ind:MaterialStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservationLine rdf:type rdf:Property ;
    rdfs:label 'Reservation Line' ;
    rdfs:comment 'Line item within the material reservation corresponding to the specific component being staged. Used to match the staging record to the exact reservation item in SAP.' ;
    rdfs:domain ind:MaterialStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'SAP reservation number (RSNUM) created by MRP or production order release, representing the planned material requirement that this staging record fulfills. Supports JIT and MRP II material planning workflows.' ;
    rdfs:domain ind:MaterialStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversal Timestamp' ;
    rdfs:comment 'Date and time when a goods issue reversal (SAP movement type 262) was posted, cancelling a previously issued quantity. Applicable only when staging_status is \'reversed\'. Supports audit trail and WIP cost correction.' ;
    rdfs:domain ind:MaterialStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shortQuantity rdf:type rdf:Property ;
    rdfs:label 'Short Quantity' ;
    rdfs:comment 'Quantity of material that could not be staged or issued due to insufficient stock (shortage). Calculated as required_quantity minus issued_quantity when status is \'short\'. Drives material shortage alerts and expediting actions.' ;
    rdfs:domain ind:MaterialStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shortageIndicator rdf:type rdf:Property ;
    rdfs:label 'Shortage Indicator' ;
    rdfs:comment 'Boolean flag indicating whether a material shortage exists for this staging record (i.e., required_quantity cannot be fully fulfilled from available stock). Drives shortage alerts, expediting, and JIT replenishment triggers.' ;
    rdfs:domain ind:MaterialStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stagedQuantity rdf:type rdf:Property ;
    rdfs:label 'Staged Quantity' ;
    rdfs:comment 'Quantity of material physically moved to the staging area or production supply area (PSA) but not yet formally issued via goods issue posting. Represents the intermediate staging step in JIT and Kanban workflows.' ;
    rdfs:domain ind:MaterialStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stagingDocumentLine rdf:type rdf:Property ;
    rdfs:label 'Staging Document Line' ;
    rdfs:comment 'Line item number within the staging document, identifying the specific component or material being staged or issued within a multi-line goods issue document.' ;
    rdfs:domain ind:MaterialStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stagingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Staging Document Number' ;
    rdfs:comment 'Business document number assigned by SAP S/4HANA (PP/MM) to the goods issue or material staging transaction. Corresponds to the SAP Material Document Number (MBLNR) generated upon goods issue posting.' ;
    rdfs:domain ind:MaterialStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stagingDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Staging Document Year' ;
    rdfs:comment 'Fiscal year associated with the staging document number in SAP S/4HANA. Required to uniquely identify a material document in conjunction with the document number.' ;
    rdfs:domain ind:MaterialStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stagingStatus rdf:type rdf:Property ;
    rdfs:label 'Staging Status' ;
    rdfs:comment 'Current lifecycle status of the material staging record. \'planned\' = reservation created; \'staged\' = material moved to staging area; \'issued\' = goods issue posted; \'short\' = insufficient stock; \'partially_issued\' = partial goods issue; \'reversed\' = goods issue reversed; \'cancelled\' = staging cancelled.' ;
    rdfs:domain ind:MaterialStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalIssuedCost rdf:type rdf:Property ;
    rdfs:label 'Total Issued Cost' ;
    rdfs:comment 'Total cost of the issued material quantity (issued_quantity × material_cost_per_unit) in the transaction currency. Feeds WIP costing, production order actual cost, and COGS reporting.' ;
    rdfs:domain ind:MaterialStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderStatusId rdf:type rdf:Property ;
    rdfs:label 'Order Status Id' ;
    rdfs:comment 'Unique surrogate identifier for each production order status transition event record in the Silver layer lakehouse.' ;
    rdfs:domain ind:OrderStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'The elapsed time in minutes that the production order spent in the from_status before transitioning to the to_status. Enables dwell time analysis, bottleneck identification, and SLA breach detection.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fromStatus rdf:type rdf:Property ;
    rdfs:label 'From Status' ;
    rdfs:comment 'The production order status immediately before the transition event. Represents the prior lifecycle state as recorded in SAP PP or Opcenter MES (e.g., CREATED, RELEASED, IN_PROCESS).' ;
    rdfs:domain ind:OrderStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSlaBreached rdf:type rdf:Property ;
    rdfs:label 'Is Sla Breached' ;
    rdfs:comment 'Indicates whether the production order exceeded its defined SLA target duration at the time of this status transition. Drives escalation workflows and production performance KPI reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mesOperationNumber rdf:type rdf:Property ;
    rdfs:label 'Mes Operation Number' ;
    rdfs:comment 'The specific MES operation or activity number within the production order routing that was active or completed at the time of the status transition. Provides granular shop floor execution context.' ;
    rdfs:domain ind:OrderStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderCategory rdf:type rdf:Property ;
    rdfs:label 'Order Category' ;
    rdfs:comment 'SAP order category distinguishing production orders (discrete manufacturing), process orders (batch/process manufacturing), maintenance orders, rework orders, and inspection orders.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'The business priority assigned to the production order, influencing scheduling and resource allocation decisions. EXPEDITE indicates customer-driven urgency or supply chain escalation.' ;
    rdfs:domain ind:OrderStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qmInspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Qm Inspection Lot Number' ;
    rdfs:comment 'The SAP QM inspection lot number associated with this status transition when the trigger is a quality hold, quality release, or inspection result. Links production order status to quality inspection outcomes.' ;
    rdfs:domain ind:OrderStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'The contracted or internally defined SLA target duration in hours for the production order to complete from release to technical completion. Used to assess whether the order met its lead time commitment.' ;
    rdfs:domain ind:OrderStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemEventCode rdf:type rdf:Property ;
    rdfs:label 'Source System Event Code' ;
    rdfs:comment 'The unique event or change document identifier from the originating source system (SAP change document number or Opcenter event ID) for this status transition. Enables traceability back to the system of record.' ;
    rdfs:domain ind:OrderStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusReasonCode rdf:type rdf:Property ;
    rdfs:label 'Status Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why the status transition occurred (e.g., MATERIAL_SHORTAGE, CAPACITY_CONSTRAINT, QM_INSPECTION_FAIL, CUSTOMER_CHANGE, PLANNED_MAINTENANCE). Supports root cause analysis and production performance reporting.' ;
    rdfs:domain ind:OrderStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Status Reason Description' ;
    rdfs:comment 'Free-text description providing additional context for the status transition reason, supplementing the structured reason code. Allows planners and supervisors to document specific circumstances.' ;
    rdfs:domain ind:OrderStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toStatus rdf:type rdf:Property ;
    rdfs:label 'To Status' ;
    rdfs:comment 'The production order status immediately after the transition event. Represents the new lifecycle state the order has entered (e.g., RELEASED, TECHNICALLY_COMPLETED, CLOSED).' ;
    rdfs:domain ind:OrderStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transition Timestamp' ;
    rdfs:comment 'The exact date and time (with timezone offset) at which the status transition occurred. Critical for SLA tracking, lead time calculation, and audit trail compliance.' ;
    rdfs:domain ind:OrderStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:triggerEventType rdf:type rdf:Property ;
    rdfs:label 'Trigger Event Type' ;
    rdfs:comment 'The business event or system action that caused the status transition (e.g., MRP run, manual release by planner, system confirmation from MES, QM hold from quality inspection). Enables root cause analysis of order lifecycle events.' ;
    rdfs:domain ind:OrderStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeredByUser rdf:type rdf:Property ;
    rdfs:label 'Triggered By User' ;
    rdfs:comment 'The SAP or Opcenter user ID of the person or system account that initiated the status transition. Used for accountability, audit trail, and change management compliance.' ;
    rdfs:domain ind:OrderStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityRequirementId rdf:type rdf:Property ;
    rdfs:label 'Capacity Requirement Id' ;
    rdfs:comment 'Unique surrogate identifier for each capacity requirement record generated by MRP II capacity planning in SAP PP (CM01). Serves as the primary key for the capacity_requirement data product in the Databricks Silver layer.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availableCapacityHours rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Hours' ;
    rdfs:comment 'Total capacity (in hours) available at the work center during the planning period, derived from the work center\'s capacity definition and shift model in SAP PP. Used to compute load percentage and identify overloads.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Capacity Category Code' ;
    rdfs:comment 'SAP capacity category code distinguishing the type of capacity being planned (e.g., machine capacity, labor capacity, tool capacity). Corresponds to SAP PP capacity category (e.g., 001 = Machine, 002 = Labor).' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityCategoryName rdf:type rdf:Property ;
    rdfs:label 'Capacity Category Name' ;
    rdfs:comment 'Human-readable description of the capacity category (Machine, Labor, Tool, Other). Used for filtering and grouping in capacity leveling and bottleneck analysis.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure' ;
    rdfs:comment 'Unit of measure in which capacity requirements and availability are expressed (e.g., H = Hours, MIN = Minutes). Ensures consistent interpretation of capacity figures across work centers.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityVersion rdf:type rdf:Property ;
    rdfs:label 'Capacity Version' ;
    rdfs:comment 'SAP planning version identifier (e.g., 000 for active version, simulation versions) under which this capacity requirement was calculated. Enables what-if scenario management and simulation-based capacity planning.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:efficiencyRate rdf:type rdf:Property ;
    rdfs:label 'Efficiency Rate' ;
    rdfs:comment 'Efficiency factor (as a percentage) applied to the work center when calculating available capacity, reflecting the expected productive utilization rate (e.g., 85% efficiency means 85% of nominal capacity is available). Sourced from SAP PP work center definition.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isOverloaded rdf:type rdf:Property ;
    rdfs:label 'Is Overloaded' ;
    rdfs:comment 'Flag indicating whether the work center is overloaded during the planning period (required capacity exceeds available capacity). Triggers capacity leveling actions and what-if scheduling scenarios.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:levelingAction rdf:type rdf:Property ;
    rdfs:label 'Leveling Action' ;
    rdfs:comment 'Action taken during capacity leveling to resolve an overload condition at the work center (e.g., Rescheduled, Split, Outsourced, Overtime, Deferred). Supports audit trail of capacity leveling decisions.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadPercentage rdf:type rdf:Property ;
    rdfs:label 'Load Percentage' ;
    rdfs:comment 'Ratio of required capacity to available capacity expressed as a percentage (required_capacity_hours / available_capacity_hours × 100). Key indicator for bottleneck identification and capacity leveling decisions.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrpRunNumber rdf:type rdf:Property ;
    rdfs:label 'Mrp Run Number' ;
    rdfs:comment 'Unique identifier of the MRP II planning run that generated this capacity requirement. Supports audit traceability and comparison between planning runs for what-if scenario analysis.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderCount rdf:type rdf:Property ;
    rdfs:label 'Order Count' ;
    rdfs:comment 'Number of production orders and planned orders contributing to the capacity requirement for this work center and planning period. Indicates the complexity of the load and supports scheduling prioritization.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overloadHours rdf:type rdf:Property ;
    rdfs:label 'Overload Hours' ;
    rdfs:comment 'Number of hours by which required capacity exceeds available capacity during the planning period. Quantifies the severity of the overload for prioritization and leveling decisions.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedOrderHours rdf:type rdf:Property ;
    rdfs:label 'Planned Order Hours' ;
    rdfs:comment 'Capacity hours contributed by MRP-generated planned orders (not yet converted to production orders) within the planning period. Distinguishes firm demand from planned demand for capacity analysis.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningHorizonType rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Type' ;
    rdfs:comment 'Granularity of the planning time bucket used for capacity aggregation (Daily, Weekly, Monthly). Determines the resolution of capacity load visibility for scheduling and leveling.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'End date of the planning period for which the capacity requirement is calculated. Together with planning_period_start_date, defines the time bucket for capacity load aggregation.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'Start date of the planning period (day, week, or shift bucket) for which the capacity requirement is calculated. Defines the time horizon of the capacity load record.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processingHours rdf:type rdf:Property ;
    rdfs:label 'Processing Hours' ;
    rdfs:comment 'Portion of the required capacity hours attributable to actual production/processing activities (machine run time or labor operation time) at the work center during the planning period.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionOrderHours rdf:type rdf:Property ;
    rdfs:label 'Production Order Hours' ;
    rdfs:comment 'Capacity hours contributed by firm production orders (released or confirmed) within the planning period. Represents committed capacity load as opposed to planned/tentative demand.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingCapacityHours rdf:type rdf:Property ;
    rdfs:label 'Remaining Capacity Hours' ;
    rdfs:comment 'Residual available capacity hours after subtracting required capacity from available capacity (available_capacity_hours − required_capacity_hours). Negative values indicate overload conditions.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredCapacityHours rdf:type rdf:Property ;
    rdfs:label 'Required Capacity Hours' ;
    rdfs:comment 'Total capacity (in hours) required at the work center during the planning period, as calculated by MRP II from open production orders and planned orders. Core metric for capacity load analysis.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requirementNumber rdf:type rdf:Property ;
    rdfs:label 'Requirement Number' ;
    rdfs:comment 'Business-facing unique identifier for the capacity requirement record as assigned by SAP PP capacity planning (CM01). Used for cross-system traceability and operational reference.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingOperationNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Operation Number' ;
    rdfs:comment 'Specific operation number within the routing that generates the capacity requirement at this work center. Enables operation-level capacity traceability within a multi-step routing.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupHours rdf:type rdf:Property ;
    rdfs:label 'Setup Hours' ;
    rdfs:comment 'Portion of the required capacity hours attributable to setup/changeover activities at the work center during the planning period. Supports SMED analysis and setup time reduction initiatives.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teardownHours rdf:type rdf:Property ;
    rdfs:label 'Teardown Hours' ;
    rdfs:comment 'Portion of the required capacity hours attributable to teardown/cleanup activities at the work center during the planning period. Included in total capacity requirement calculations.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationRate rdf:type rdf:Property ;
    rdfs:label 'Utilization Rate' ;
    rdfs:comment 'Utilization factor (as a percentage) applied to the work center capacity, representing the proportion of available time the resource is scheduled for productive work. Sourced from SAP PP work center definition.' ;
    rdfs:domain ind:CapacityRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apqpStatus rdf:type rdf:Property ;
    rdfs:label 'Apqp Status' ;
    rdfs:comment 'The APQP approval status for this production version, indicating whether the manufacturing process has been formally validated through the Advanced Product Quality Planning process. Required for automotive and regulated manufacturing.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomAlternative rdf:type rdf:Property ;
    rdfs:label 'Bom Alternative' ;
    rdfs:comment 'The BOM alternative number (STLAL) assigned to this production version. Multiple BOM alternatives can exist for the same material, each representing a different component configuration or manufacturing method.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomExplosionType rdf:type rdf:Property ;
    rdfs:label 'Bom Explosion Type' ;
    rdfs:comment 'Defines how the BOM is exploded during MRP II planning and production order creation for this version: single-level (one level only), multi-level (full BOM tree), or phantom (virtual assembly, components passed through).' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingLotSize rdf:type rdf:Property ;
    rdfs:label 'Costing Lot Size' ;
    rdfs:comment 'The reference lot size used for product cost calculation (standard cost estimate) for this production version. Determines the per-unit cost allocation of fixed setup and overhead costs.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultVersion rdf:type rdf:Property ;
    rdfs:label 'Default Version' ;
    rdfs:comment 'Indicates whether this is the default (preferred) production version for the material-plant combination. When multiple versions are valid, MRP II and production planners use the default version unless overridden.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deletionFlag rdf:type rdf:Property ;
    rdfs:label 'Deletion Flag' ;
    rdfs:comment 'Indicates whether this production version has been flagged for deletion in the source SAP system (MKAL.LOEKZ). A flagged version is excluded from MRP II planning and production order creation but retained for historical traceability.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastChangedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Changed By User' ;
    rdfs:comment 'The SAP user ID of the person who last modified this production version record. Supports accountability, audit trail, and change management traceability.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSizeUnit rdf:type rdf:Property ;
    rdfs:label 'Lot Size Unit' ;
    rdfs:comment 'The unit of measure (MEINS) applicable to the minimum and maximum lot size values for this production version (e.g., EA, KG, L, M). Aligns with the base unit of measure of the material.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpRelevance rdf:type rdf:Property ;
    rdfs:label 'Mrp Relevance' ;
    rdfs:comment 'Indicates whether this production version is considered by MRP II during planning runs. When false, the version is excluded from automatic planned order generation even if it is within its validity period.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionLine rdf:type rdf:Property ;
    rdfs:label 'Production Line' ;
    rdfs:comment 'The specific production line or work center group (ARBPL) designated for this production version. Used in repetitive manufacturing and rate-based scheduling to assign the version to a physical line.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Receiving Storage Location' ;
    rdfs:comment 'The SAP storage location (LGORT) to which the finished goods produced under this version are received upon goods receipt. Supports inventory management and warehouse operations.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repetitiveManufacturingAllowed rdf:type rdf:Property ;
    rdfs:label 'Repetitive Manufacturing Allowed' ;
    rdfs:comment 'Indicates whether this production version is enabled for repetitive manufacturing (SAP MKAL.SERKZ). When true, rate-based planning and backflushing are applicable. Relevant for high-volume, continuous production scenarios.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routingType rdf:type rdf:Property ;
    rdfs:label 'Routing Type' ;
    rdfs:comment 'The type of task list (PLNTY) associated with this production version. \'routing\' is standard discrete manufacturing; \'rate_routing\' is used for repetitive manufacturing; \'master_recipe\' is used for process manufacturing.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationClassNumber rdf:type rdf:Property ;
    rdfs:label 'Classification Class Number' ;
    rdfs:comment 'SAP classification class number (KLASSE) assigned to this batch for batch classification. Defines the set of characteristics (e.g., purity, viscosity, tensile strength) used to describe and search for batches.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationValues rdf:type rdf:Property ;
    rdfs:label 'Classification Values' ;
    rdfs:comment 'Serialized JSON string containing all batch classification characteristic values from SAP Classification System (AUSP) that do not have dedicated columns (e.g., color, hardness, moisture content, particle size). Enables flexible storage of material-specific quality parameters without schema changes.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRestrictedSubstanceCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Restricted Substance Compliant' ;
    rdfs:comment 'Indicates whether this batch has been verified as compliant with restricted substance regulations including EU RoHS (Restriction of Hazardous Substances) and REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals). Required for CE marking and export compliance.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Date' ;
    rdfs:comment 'Scheduled date for the next periodic quality inspection of this batch. Supports recurring inspection planning for long-shelf-life or regulated materials and triggers QM inspection lot creation.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originType rdf:type rdf:Property ;
    rdfs:label 'Origin Type' ;
    rdfs:comment 'Indicates whether the batch was created through internal manufacturing (production order), external procurement (purchase order/GRN), subcontracting, or customer returns. Drives traceability and genealogy logic.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purityPercent rdf:type rdf:Property ;
    rdfs:label 'Purity Percent' ;
    rdfs:comment 'Purity level of the batch expressed as a percentage, stored as a batch classification characteristic value. Critical quality parameter for chemical, pharmaceutical, and specialty material batches used in acceptance/rejection decisions.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tensileStrengthMpa rdf:type rdf:Property ;
    rdfs:label 'Tensile Strength Mpa' ;
    rdfs:comment 'Tensile strength of the batch material in megapascals (MPa), stored as a batch classification characteristic. Critical mechanical property for metal, composite, and structural material batches used in quality release decisions.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageDecisionCode rdf:type rdf:Property ;
    rdfs:label 'Usage Decision Code' ;
    rdfs:comment 'SAP QM usage decision code (ENTSCHEIDUNG) for the inspection lot associated with this batch. Determines the quality disposition: accept (unrestricted use), reject (block/scrap), or conditional release. Drives automatic batch status change.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viscosityMpaS rdf:type rdf:Property ;
    rdfs:label 'Viscosity Mpa S' ;
    rdfs:comment 'Viscosity measurement of the batch in millipascal-seconds (mPa·s), stored as a batch classification characteristic. Key quality parameter for fluid, adhesive, coating, and polymer material batches.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchGenealogyId rdf:type rdf:Property ;
    rdfs:label 'Batch Genealogy Id' ;
    rdfs:comment 'Unique surrogate identifier for each batch genealogy relationship record in the Silver layer lakehouse. Serves as the primary key for the batch_genealogy data product.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentBatchId rdf:type rdf:Property ;
    rdfs:label 'Parent Batch Id' ;
    rdfs:comment 'Foreign key linking to production.batch. Business justification: batch_genealogy tracks the parent batch consumed during manufacturing. The FK parent_batch_id normalizes the parent_batch_number string reference and enables joins to batch master data for upstream tr' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Batch .

ind:childBatchExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Child Batch Expiry Date' ;
    rdfs:comment 'Shelf life expiration date of the child (produced) batch as recorded in SAP batch master. Used for finished product shelf life management, customer delivery compliance, and regulatory traceability.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:childBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Child Batch Number' ;
    rdfs:comment 'Identifier of the child batch — the output material, assembly, or finished product batch that was produced or resulted from the manufacturing operation. In SAP PP, this corresponds to the \'To Batch\' in the batch where-used list.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childBatchStatus rdf:type rdf:Property ;
    rdfs:label 'Child Batch Status' ;
    rdfs:comment 'Quality/inventory status of the child (produced) batch at the time of production confirmation, as recorded in SAP QM. Indicates whether the produced batch passed quality inspection or requires further disposition.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childMaterialDescription rdf:type rdf:Property ;
    rdfs:label 'Child Material Description' ;
    rdfs:comment 'Human-readable description of the child batch material, denormalized for traceability reports, recall notifications, and regulatory submissions.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Child Material Number' ;
    rdfs:comment 'SAP material number (or equivalent ERP identifier) of the child batch material. Enables cross-referencing to the material master for finished product specifications and compliance data.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumedQuantity rdf:type rdf:Property ;
    rdfs:label 'Consumed Quantity' ;
    rdfs:comment 'Actual quantity of the parent batch that was consumed during the manufacturing operation. Used for material balance calculations, yield analysis, and traceability completeness verification.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumedQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Consumed Quantity Uom' ;
    rdfs:comment 'Unit of measure for the consumed quantity of the parent batch (e.g., KG, L, EA). Aligned with SAP base unit of measure for the parent material.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfManufactureCode rdf:type rdf:Property ;
    rdfs:label 'Country Of Manufacture Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the batch transformation occurred. Required for customs declarations, CE marking, RoHS/REACH compliance, and country-of-origin traceability in global supply chains.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genealogyRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Genealogy Record Number' ;
    rdfs:comment 'Business-facing unique identifier for the batch genealogy relationship record, used in quality investigations, recall management, and regulatory submissions. Typically sourced from SAP PP Batch Where-Used or Siemens Opcenter MES.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mergeSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Merge Sequence Number' ;
    rdfs:comment 'Sequential number identifying the order of parent batches when multiple parent batches are merged into a single child batch (relationship_type = \'merge\'). Enables reconstruction of the full merge genealogy and proportional quantity attribution.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Operation End Timestamp' ;
    rdfs:comment 'Actual end date and time of the manufacturing operation during which the batch relationship was established. Together with operation_start_timestamp, defines the production time window for traceability and cycle time analysis.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Operation Start Timestamp' ;
    rdfs:comment 'Actual start date and time of the manufacturing operation during which the batch relationship was established. Used for time-based traceability, shift analysis, and process timeline reconstruction during quality investigations.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:parentBatchExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Parent Batch Expiry Date' ;
    rdfs:comment 'Shelf life expiration date of the parent batch as recorded in SAP batch master. Critical for FEFO (First Expired First Out) compliance, regulatory submissions, and determining if expired materials were used in production.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentBatchStatus rdf:type rdf:Property ;
    rdfs:label 'Parent Batch Status' ;
    rdfs:comment 'Quality/inventory status of the parent batch at the time of consumption, as recorded in SAP QM batch status management. Indicates whether the consumed batch was in unrestricted use, under quality inspection, or blocked — critical for quality investigations.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentMaterialDescription rdf:type rdf:Property ;
    rdfs:label 'Parent Material Description' ;
    rdfs:comment 'Human-readable description of the parent batch material, denormalized for reporting and traceability documents without requiring a join to the material master.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Parent Material Number' ;
    rdfs:comment 'SAP material number (or equivalent ERP identifier) of the parent batch material. Enables cross-referencing to the material master for specification, classification, and compliance data.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:producedQuantity rdf:type rdf:Property ;
    rdfs:label 'Produced Quantity' ;
    rdfs:comment 'Actual quantity of the child batch that was produced or resulted from the manufacturing operation. Used for yield calculations, material balance, and production confirmation reporting.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:producedQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Produced Quantity Uom' ;
    rdfs:comment 'Unit of measure for the produced quantity of the child batch (e.g., KG, EA, L). Aligned with SAP base unit of measure for the child material.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Flag' ;
    rdfs:comment 'Indicates whether this batch genealogy record has been flagged as part of an active product recall or field action. When true, the record is included in recall scope reports and regulatory notifications. Critical for recall management and regulatory compliance.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Recall Reference Number' ;
    rdfs:comment 'Reference number of the product recall or field action campaign to which this batch genealogy record belongs. Populated when recall_flag is true. Enables aggregation of all affected batches under a single recall event.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Lifecycle status of the batch genealogy record. \'active\' indicates a valid, confirmed relationship; \'reversed\' indicates the goods movement was reversed in SAP; \'cancelled\' indicates the production order was cancelled; \'superseded\' indicates the record was replaced by a corrected entry.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceStandard rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Standard' ;
    rdfs:comment 'Primary regulatory or quality standard under which this batch genealogy record must be maintained and reported. Drives retention period, traceability depth, and reporting format requirements. Multiple standards may apply; the most stringent is recorded.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:splitSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Split Sequence Number' ;
    rdfs:comment 'Sequential number identifying the order of child batches when a parent batch is split into multiple child batches (relationship_type = \'split\'). Enables reconstruction of the full split genealogy tree and quantity reconciliation.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:traceabilityDirection rdf:type rdf:Property ;
    rdfs:label 'Traceability Direction' ;
    rdfs:comment 'Indicates the direction of traceability this record supports. \'forward\' traces from raw material/component to finished product (where-used); \'backward\' traces from finished product to raw material/component (where-from); \'bidirectional\' supports both directions. Critical for product recall scope determination.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traceabilityTimestamp rdf:type rdf:Property ;
    rdfs:label 'Traceability Timestamp' ;
    rdfs:comment 'The precise date and time at which the batch genealogy relationship was recorded in the system of record (SAP PP or Siemens Opcenter MES). This is the authoritative timestamp for regulatory traceability and recall scope determination.' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:yieldRatePercent rdf:type rdf:Property ;
    rdfs:label 'Yield Rate Percent' ;
    rdfs:comment 'Ratio of produced quantity to consumed quantity expressed as a percentage, representing the material conversion efficiency for this specific batch relationship. Supports yield analysis and process capability monitoring (SPC).' ;
    rdfs:domain ind:BatchGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downtimeEventId rdf:type rdf:Property ;
    rdfs:label 'Downtime Event Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying each downtime event record in the silver layer lakehouse. Serves as the primary key for all downstream joins and OEE/TPM calculations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DowntimeEvent .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Description of the immediate corrective action taken to restore production (e.g., replaced bearing, reset PLC, cleared material jam). Distinct from CAPA — this is the immediate fix, not the systemic preventive action.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'Exact date and time when the downtime event was resolved and production resumed. Used with start_timestamp to compute duration and MTTR. Null if the event is still open.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Human-readable business identifier for the downtime event, typically generated by Siemens Opcenter MES or SAP PM. Used for cross-system referencing, shop floor communication, and audit trails.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faultCode rdf:type rdf:Property ;
    rdfs:label 'Fault Code' ;
    rdfs:comment 'Fault or alarm code generated by the PLC, SCADA, or DCS system at the time of the downtime event. Provides precise machine-level diagnostic information for maintenance engineers and reliability analysis.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPlanned rdf:type rdf:Property ;
    rdfs:label 'Is Planned' ;
    rdfs:comment 'Indicates whether the downtime event was planned (e.g., scheduled maintenance, changeover, trial run) or unplanned (e.g., breakdown, quality hold). Critical for correctly computing OEE availability — only unplanned downtime reduces OEE availability.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lostProductionQuantity rdf:type rdf:Property ;
    rdfs:label 'Lost Production Quantity' ;
    rdfs:comment 'Quantity of production units lost or not produced as a direct result of the downtime event. Feeds OEE performance and availability loss calculations, and supports financial impact assessment of downtime.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lostProductionUom rdf:type rdf:Property ;
    rdfs:label 'Lost Production Uom' ;
    rdfs:comment 'Unit of measure for the lost production quantity (e.g., EA for each, KG for kilograms, M for meters). Ensures dimensional consistency when aggregating lost production across different product types.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:machineCode rdf:type rdf:Property ;
    rdfs:label 'Machine Code' ;
    rdfs:comment 'Unique identifier of the specific machine or equipment asset within the work center that experienced the downtime. Corresponds to the equipment number in SAP PM and Maximo EAM.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:machineName rdf:type rdf:Property ;
    rdfs:label 'Machine Name' ;
    rdfs:comment 'Descriptive name of the machine or equipment asset that experienced the downtime. Supports readability in OEE dashboards and TPM reports.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceWorkOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Maintenance Work Order Number' ;
    rdfs:comment 'Reference to the SAP PM or Maximo EAM maintenance work order created to address the downtime event. Links downtime records to maintenance execution, spare parts consumption, and labor cost tracking.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesEventCode rdf:type rdf:Property ;
    rdfs:label 'Mes Event Code' ;
    rdfs:comment 'Native event identifier from Siemens Opcenter MES downtime module. Enables traceability back to the source system record for reconciliation and audit purposes.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mindsphereAssetCode rdf:type rdf:Property ;
    rdfs:label 'Mindsphere Asset Code' ;
    rdfs:comment 'Asset identifier from Siemens MindSphere IIoT platform used to correlate the downtime event with real-time telemetry, predictive alerts, and condition monitoring data from the affected machine or work center.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeeImpactCategory rdf:type rdf:Property ;
    rdfs:label 'Oee Impact Category' ;
    rdfs:comment 'Classification of how this downtime event impacts the OEE calculation — specifically which OEE loss category it belongs to (availability loss for unplanned stops, planned stop for scheduled downtime). Enables automated OEE waterfall chart generation.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedBy rdf:type rdf:Property ;
    rdfs:label 'Resolved By' ;
    rdfs:comment 'Employee ID or username of the maintenance technician or engineer who resolved the downtime event. Used for MTTR analysis by technician, skills gap identification, and TPM workforce planning.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Department accountable for resolving or owning the downtime event (e.g., Maintenance, Production, Quality, Logistics). Used for departmental KPI reporting and escalation routing.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Identified root cause of the downtime event as determined through investigation (e.g., 5-Why analysis, fishbone diagram). Populated after CAPA investigation is completed. Supports TPM and continuous improvement programs.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Exact date and time when the downtime event began, as recorded by Opcenter MES or MindSphere IIoT. Critical for MTBF calculations, OEE availability component, and shift-level downtime reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Duration Minutes' ;
    rdfs:comment 'Total scheduled break time in minutes for the shift (sum of all meal breaks, rest breaks, and paid/unpaid breaks). Subtracted from gross duration to derive net available production time.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breakScheduleDetails rdf:type rdf:Property ;
    rdfs:label 'Break Schedule Details' ;
    rdfs:comment 'Structured text description of the break schedule within the shift, specifying break start times and durations (e.g., \'10:00-10:15 rest; 12:00-12:30 meal; 15:00-15:15 rest\'). Stored as a formatted string for display in MES and scheduling tools.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossesMidnight rdf:type rdf:Property ;
    rdfs:label 'Crosses Midnight' ;
    rdfs:comment 'Indicates whether the shift spans across midnight (i.e., end_time is earlier than start_time on the clock). Critical for correct date assignment of production orders and OEE period calculations for night shifts.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total gross duration of the shift in decimal hours (e.g., 8.00, 10.00, 12.00). Represents the full clock time from start to end before deducting breaks. Used as the denominator in OEE availability calculations.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'Scheduled end time of the shift in HH:mm:ss 24-hour format (e.g., 14:00:00 for Day Shift). Combined with start_time to determine the gross shift window for capacity and OEE calculations.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fridayApplicable rdf:type rdf:Property ;
    rdfs:label 'Friday Applicable' ;
    rdfs:comment 'Indicates whether this shift definition is scheduled to operate on Fridays. Used in weekly production scheduling and MRP II capacity planning.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Labor Agreement Code' ;
    rdfs:comment 'Code referencing the collective bargaining agreement or labor contract governing this shift\'s working conditions, break entitlements, and overtime rules. Ensures compliance with labor regulations and union agreements.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mondayApplicable rdf:type rdf:Property ;
    rdfs:label 'Monday Applicable' ;
    rdfs:comment 'Indicates whether this shift definition is scheduled to operate on Mondays. Used in weekly production scheduling and MRP II capacity planning.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netAvailableTimeHours rdf:type rdf:Property ;
    rdfs:label 'Net Available Time Hours' ;
    rdfs:comment 'Planned available production time in decimal hours after deducting all scheduled breaks and planned downtime from the gross shift duration. This is the planned operating time used as the basis for OEE availability rate calculations per ISO 22400-2.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfBreaks rdf:type rdf:Property ;
    rdfs:label 'Number Of Breaks' ;
    rdfs:comment 'Count of distinct scheduled break periods within the shift (e.g., 1 meal break + 2 rest breaks = 3). Used in MES break scheduling and shop floor Andon system configuration.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overtimeEligible rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligible' ;
    rdfs:comment 'Indicates whether production hours worked in this shift beyond the standard duration qualify for overtime compensation under the applicable labor agreement. Used in labor cost calculations and payroll integration.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patternCode rdf:type rdf:Property ;
    rdfs:label 'Pattern Code' ;
    rdfs:comment 'Code referencing the shift rotation pattern or schedule group to which this shift belongs (e.g., 3-SHIFT-ROTATING, 2-SHIFT-FIXED, CONTINENTAL). Links individual shift definitions to their broader scheduling pattern for MRP II capacity planning.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumPayRatePercent rdf:type rdf:Property ;
    rdfs:label 'Premium Pay Rate Percent' ;
    rdfs:comment 'Percentage premium applied to the base labor rate for hours worked in this shift (e.g., 25% night shift premium, 50% weekend premium). Used in production cost calculations and COGS reporting.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:saturdayApplicable rdf:type rdf:Property ;
    rdfs:label 'Saturday Applicable' ;
    rdfs:comment 'Indicates whether this shift definition is scheduled to operate on Saturdays. Relevant for extended production weeks, overtime scheduling, and weekend capacity planning.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'Scheduled start time of the shift in HH:mm:ss 24-hour format (e.g., 06:00:00 for Day Shift). Used to calculate available production time and assign production orders to the correct shift window.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sundayApplicable rdf:type rdf:Property ;
    rdfs:label 'Sunday Applicable' ;
    rdfs:comment 'Indicates whether this shift definition is scheduled to operate on Sundays. Relevant for 24/7 continuous production environments and holiday/weekend capacity planning.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thursdayApplicable rdf:type rdf:Property ;
    rdfs:label 'Thursday Applicable' ;
    rdfs:comment 'Indicates whether this shift definition is scheduled to operate on Thursdays. Used in weekly production scheduling and MRP II capacity planning.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA timezone identifier for the plant location where this shift operates (e.g., America/New_York, Europe/Berlin, Asia/Shanghai). Critical for correct timestamp interpretation in global MES integrations and cross-plant OEE reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tuesdayApplicable rdf:type rdf:Property ;
    rdfs:label 'Tuesday Applicable' ;
    rdfs:comment 'Indicates whether this shift definition is scheduled to operate on Tuesdays. Used in weekly production scheduling and MRP II capacity planning.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wednesdayApplicable rdf:type rdf:Property ;
    rdfs:label 'Wednesday Applicable' ;
    rdfs:comment 'Indicates whether this shift definition is scheduled to operate on Wednesdays. Used in weekly production scheduling and MRP II capacity planning.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scrapRecordId rdf:type rdf:Property ;
    rdfs:label 'Scrap Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each scrap record event in the production domain. Serves as the primary key for the scrap_record data product in the Databricks Silver layer.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectCodeId rdf:type rdf:Property ;
    rdfs:label 'Defect Code Id' ;
    rdfs:comment 'Foreign key linking to quality.defect_code. Business justification: Production scrap must be categorized using standardized defect codes for Pareto analysis, trend reporting, and quality improvement initiatives. Used by production supervisors during scrap reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DefectCode .

ind:scrapStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Scrap Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: Scrapped materials move to designated scrap storage locations. Material handlers need exact locations for segregation and disposal processing.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:shipmentItemId rdf:type rdf:Property ;
    rdfs:label 'Shipment Item Id' ;
    rdfs:comment 'Foreign key linking to logistics.shipment_item. Business justification: Scrap can originate from defective incoming shipment items. Quality and production teams trace scrap back to the specific shipment item to support supplier claims, incoming quality control, and root c' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShipmentItem .

ind:defectCode rdf:type rdf:Property ;
    rdfs:label 'Defect Code' ;
    rdfs:comment 'Specific defect classification code from the quality defect catalog (SAP QM or Opcenter Quality) identifying the type of defect that caused the scrap. Supports SPC analysis and defect Pareto reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRework rdf:type rdf:Property ;
    rdfs:label 'Is Rework' ;
    rdfs:comment 'Boolean flag indicating whether the scrapped item has been designated for rework rather than disposal. When true, a rework order reference should be present. Distinguishes reworkable non-conformances from permanent scrap for cost and yield analysis.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reporting Timestamp' ;
    rdfs:comment 'Date and time when the scrap event was reported in the MES or ERP system by the operator or automated process. Used for time-series scrap trend analysis and shift-level reporting.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reworkOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Rework Order Number' ;
    rdfs:comment 'Reference number of the rework production order created to remediate the scrapped item. Populated only when is_rework is true. Enables end-to-end rework cost tracking and yield recovery analysis.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapCategory rdf:type rdf:Property ;
    rdfs:label 'Scrap Category' ;
    rdfs:comment 'High-level classification of the scrap event origin: process scrap (inherent process loss), machine scrap (equipment malfunction), material defect (incoming material issue), operator error, design defect, tooling defect, or incoming material. Drives root cause categorization for Six Sigma and CAPA programs.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapCost rdf:type rdf:Property ;
    rdfs:label 'Scrap Cost' ;
    rdfs:comment 'Monetary value of the scrapped material calculated using the standard or moving average cost from the material master. Key input for COGS variance analysis, scrap cost reporting, and financial impact assessment of quality failures.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scrapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Scrap Document Number' ;
    rdfs:comment 'Business-facing document number assigned to the scrap event by the source system (SAP PP or Opcenter MES). Used for cross-system traceability and audit purposes.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapReasonCode rdf:type rdf:Property ;
    rdfs:label 'Scrap Reason Code' ;
    rdfs:comment 'Standardized reason code from the MES or ERP scrap reason catalog describing the specific cause of scrap (e.g., dimensional out-of-tolerance, surface defect, wrong material). Used for Pareto analysis and CAPA prioritization.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Scrap Reason Description' ;
    rdfs:comment 'Free-text description providing additional context for the scrap reason beyond the standardized code. Captures operator observations and nuanced failure details for quality investigations.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchClassificationRequired rdf:type rdf:Property ;
    rdfs:label 'Batch Classification Required' ;
    rdfs:comment 'Indicates whether batch classification (assignment of batch characteristics and values) is mandatory for production orders of this type. Relevant for regulated industries and traceability requirements.' ;
    rdfs:domain ind:OrderType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityRelevanceIndicator rdf:type rdf:Property ;
    rdfs:label 'Capacity Relevance Indicator' ;
    rdfs:comment 'Indicates whether production orders of this type generate capacity requirements on work centers. When true, orders of this type are included in capacity planning and leveling processes.' ;
    rdfs:domain ind:OrderType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmationControlKey rdf:type rdf:Property ;
    rdfs:label 'Confirmation Control Key' ;
    rdfs:comment 'SAP confirmation control key that defines the confirmation behavior for operations in production orders of this type, including whether milestone confirmations, partial confirmations, or automatic final confirmations are permitted.' ;
    rdfs:domain ind:OrderType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'SAP controlling area code associated with this order type, defining the organizational unit within which cost accounting and internal reporting are performed for production orders of this type.' ;
    rdfs:domain ind:OrderType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingSheet rdf:type rdf:Property ;
    rdfs:label 'Costing Sheet' ;
    rdfs:comment 'SAP overhead costing sheet assigned to this order type, defining the overhead calculation rules (overhead rates, base values, credit objects) applied to production orders for overhead absorption and cost allocation.' ;
    rdfs:domain ind:OrderType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingVariant rdf:type rdf:Property ;
    rdfs:label 'Costing Variant' ;
    rdfs:comment 'SAP costing variant code (e.g., PPP1, PPP2) assigned to this order type. Determines the valuation approach, cost component structure, and overhead calculation method used for production order cost estimation and actual cost collection.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueIndicator rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Indicator' ;
    rdfs:comment 'Defines the component goods issue (GI) method for production orders of this type. Manual requires explicit GI posting; backflush automatically posts GI at confirmation; automatic triggers GI at order release.' ;
    rdfs:domain ind:OrderType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Indicator' ;
    rdfs:comment 'Indicates whether an automatic goods receipt (GR) posting is triggered upon final confirmation of a production order of this type. When true, the finished goods inventory is updated automatically without a separate GR transaction.' ;
    rdfs:domain ind:OrderType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'SAP QM inspection type code (e.g., 03 for goods receipt from production, 89 for in-process inspection) automatically assigned to inspection lots created for production orders of this type. Drives quality inspection planning and execution.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderReleaseControl rdf:type rdf:Property ;
    rdfs:label 'Order Release Control' ;
    rdfs:comment 'Controls when a production order of this type transitions to Released status. Manual requires explicit user action; automatic_on_creation releases immediately upon order creation; automatic_on_save releases when the order is saved.' ;
    rdfs:domain ind:OrderType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderUsage rdf:type rdf:Property ;
    rdfs:label 'Order Usage' ;
    rdfs:comment 'Business usage classification of the order type indicating the manufacturing scenario it supports: standard production, rework of non-conforming material, prototype/development builds, co-product manufacturing, disassembly, subcontracting, or repair orders.' ;
    rdfs:domain ind:OrderType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printControl rdf:type rdf:Property ;
    rdfs:label 'Print Control' ;
    rdfs:comment 'SAP print control key that determines which shop floor documents (traveler, pick list, routing sheet, label) are automatically printed when a production order of this type is created or released.' ;
    rdfs:domain ind:OrderType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceOrderType rdf:type rdf:Property ;
    rdfs:label 'Reference Order Type' ;
    rdfs:comment 'SAP order type code used as the reference template when creating orders of this type. Enables inheritance of default parameters from a base order type, supporting standardized configuration management.' ;
    rdfs:domain ind:OrderType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultsAnalysisKey rdf:type rdf:Property ;
    rdfs:label 'Results Analysis Key' ;
    rdfs:comment 'SAP results analysis key assigned to the order type, controlling how work-in-progress (WIP) and reserves for unrealized costs are calculated during period-end closing. Relevant for ETO and long-running production orders.' ;
    rdfs:domain ind:OrderType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementProfile rdf:type rdf:Property ;
    rdfs:label 'Settlement Profile' ;
    rdfs:comment 'SAP settlement profile code that defines the rules for settling production order variances and costs to cost objects (e.g., material stock, cost center, profitability segment). Controls period-end cost settlement behavior.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusProfile rdf:type rdf:Property ;
    rdfs:label 'Status Profile' ;
    rdfs:comment 'SAP user status profile assigned to this order type, defining the allowed user-defined statuses and permissible status transitions for production orders of this type (e.g., HOLD, QUAL, APPR). Enables differentiated status management beyond standard system statuses.' ;
    rdfs:domain ind:OrderType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceKey rdf:type rdf:Property ;
    rdfs:label 'Variance Key' ;
    rdfs:comment 'SAP variance key assigned to this order type, controlling which variance categories (input price, quantity, resource-usage, output price, mixed-price, remaining) are calculated during period-end variance analysis for production orders.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Wip Calculation Method' ;
    rdfs:comment 'Defines the method used to calculate Work In Progress (WIP) value for production orders of this type during period-end closing. Target cost uses standard cost; actual cost uses confirmed actual costs; none excludes WIP calculation.' ;
    rdfs:domain ind:OrderType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadId rdf:type rdf:Property ;
    rdfs:label 'Lead Id' ;
    rdfs:comment 'Unique system-generated identifier for the lead record in the industrial sales pipeline. Serves as the primary key for all lead-related data operations and cross-system referencing.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installationRecordId rdf:type rdf:Property ;
    rdfs:label 'Installation Record Id' ;
    rdfs:comment 'Foreign key linking to service.installation_record. Business justification: Sales leads for industrial automation upgrades or expansions are frequently generated from existing installation records. Sales reps use installed base data daily to identify upsell opportunities at s' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InstallationRecord .

ind:requestId rdf:type rdf:Property ;
    rdfs:label 'Request Id' ;
    rdfs:comment 'Foreign key linking to service.service_request. Business justification: Service requests generate upsell leads when customers need upgrades or additional equipment. Service teams identify expansion opportunities during support interactions. Common lead source for installe' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Request .

ind:annualRevenue rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue' ;
    rdfs:comment 'Estimated or reported annual revenue of the prospect company in the transaction currency. Used for lead scoring, segmentation, and prioritization of enterprise vs. mid-market accounts.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedOwner rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner' ;
    rdfs:comment 'Name or identifier of the sales representative or team currently responsible for working the lead. Drives accountability, workload balancing, and performance reporting.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentObtained rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained' ;
    rdfs:comment 'Indicates whether explicit consent has been obtained from the lead contact for marketing communications, as required under GDPR and applicable privacy regulations.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:convertedDate rdf:type rdf:Property ;
    rdfs:label 'Converted Date' ;
    rdfs:comment 'Date on which the lead was converted to a qualified opportunity or account. Used to calculate lead-to-opportunity conversion cycle time and sales velocity metrics.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:crmLeadCode rdf:type rdf:Property ;
    rdfs:label 'Crm Lead Code' ;
    rdfs:comment 'External lead identifier as assigned by Salesforce Sales Cloud CRM system. Used for cross-system reconciliation and traceability between the lakehouse silver layer and the source CRM.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disqualificationReason rdf:type rdf:Property ;
    rdfs:label 'Disqualification Reason' ;
    rdfs:comment 'Reason code explaining why a lead was disqualified or marked as unqualified. Supports pipeline quality analysis, process improvement, and marketing feedback loops.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotContact rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact' ;
    rdfs:comment 'Indicates that the lead contact has opted out of all sales and marketing communications. Enforces compliance with GDPR, CCPA, and CAN-SPAM opt-out requirements.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeCount rdf:type rdf:Property ;
    rdfs:label 'Employee Count' ;
    rdfs:comment 'Approximate number of employees at the prospect organization. Used for company size segmentation and determining appropriate product tier and sales motion (enterprise vs. SMB).' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedDealValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Deal Value' ;
    rdfs:comment 'Sales representative\'s initial estimate of the potential contract or project value if the lead converts to an opportunity. Used for pipeline forecasting and territory planning for industrial automation projects.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productInterest rdf:type rdf:Property ;
    rdfs:label 'Product Interest' ;
    rdfs:comment 'Primary product or solution category the lead has expressed interest in. Drives routing to the appropriate product specialist and informs solution scoping for industrial automation, electrification, or system integration projects.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the prospect\'s intended project scope. Greenfield indicates new facility build; brownfield indicates retrofit or upgrade of existing infrastructure. Informs solution complexity and sales cycle length for industrial automation projects.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseTimeframe rdf:type rdf:Property ;
    rdfs:label 'Purchase Timeframe' ;
    rdfs:comment 'Prospect\'s indicated or estimated timeframe for making a purchase decision. Used in BANT qualification and pipeline forecasting for industrial automation and electrification solution sales.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Indicates whether the lead has been assessed against qualification criteria (e.g., budget, authority, need, timeline — BANT framework). Determines readiness for conversion to a sales opportunity.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rating rdf:type rdf:Property ;
    rdfs:label 'Rating' ;
    rdfs:comment 'Sales team\'s qualitative assessment of the lead\'s urgency and likelihood to convert. Hot leads receive immediate follow-up; cold leads enter nurture workflows.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'Indicates whether the lead is being pursued through direct sales or an indirect channel (partner, distributor, system integrator, OEM). Determines commission structure and engagement model.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Numeric score (0–100) assigned to the lead based on behavioral signals, demographic fit, and engagement level. Used to prioritize outreach and automate lead routing in the CRM.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:source rdf:type rdf:Property ;
    rdfs:label 'Source' ;
    rdfs:comment 'Channel or origin through which the lead was generated. Supports marketing attribution analysis, campaign ROI measurement, and channel effectiveness reporting for industrial automation and electrification solutions.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDetail rdf:type rdf:Property ;
    rdfs:label 'Source Detail' ;
    rdfs:comment 'Supplementary detail about the lead source, such as specific trade show name, campaign name, or referring partner. Provides granular attribution beyond the primary source category.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountPlanId rdf:type rdf:Property ;
    rdfs:label 'Account Plan Id' ;
    rdfs:comment 'Unique system-generated identifier for the strategic account plan record within the sales domain.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Amount' ;
    rdfs:comment 'Internal sales budget allocated to support execution of this account plan, covering travel, entertainment, marketing development funds, and pre-sales engineering resources.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitivePosition rdf:type rdf:Property ;
    rdfs:label 'Competitive Position' ;
    rdfs:comment 'Assessment of the company\'s current competitive standing within the account: incumbent (primary supplier), challenger (competing against incumbent), new entrant (no prior business), preferred vendor, sole source, or at risk of displacement.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmRecordCode rdf:type rdf:Property ;
    rdfs:label 'Crm Record Code' ;
    rdfs:comment 'External reference identifier for the corresponding account plan or account record in the Salesforce CRM system, enabling traceability and data lineage between the lakehouse silver layer and the system of record.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Score' ;
    rdfs:comment 'Most recent customer satisfaction rating for the account on a 0–10 scale, sourced from formal satisfaction surveys or Net Promoter Score (NPS) assessments, used to gauge relationship health.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engagementPlanSummary rdf:type rdf:Property ;
    rdfs:label 'Engagement Plan Summary' ;
    rdfs:comment 'Narrative summary of planned customer engagement activities for the account plan period, including executive briefings, technical workshops, site visits, trade show participation, and joint business reviews.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpCustomerNumber rdf:type rdf:Property ;
    rdfs:label 'Erp Customer Number' ;
    rdfs:comment 'Customer master number assigned to the account in SAP S/4HANA (SD module), used to link the strategic account plan to transactional sales orders, contracts, and billing records in the ERP system.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkAgreementRef rdf:type rdf:Property ;
    rdfs:label 'Framework Agreement Ref' ;
    rdfs:comment 'Reference number or identifier of any active master supply agreement, blanket purchase order, or long-term framework contract with the account that governs pricing, terms, and delivery conditions for the plan period.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGlobalAccount rdf:type rdf:Property ;
    rdfs:label 'Is Global Account' ;
    rdfs:comment 'Indicates whether this account is managed as a global strategic account with coordinated multi-country engagement, requiring cross-regional sales team collaboration and consolidated reporting.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keySolutionFocus rdf:type rdf:Property ;
    rdfs:label 'Key Solution Focus' ;
    rdfs:comment 'Primary product or solution category targeted for growth within this account during the plan period, aligned to the company\'s core offerings in industrial automation, electrification, and smart infrastructure.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'Date on which the account plan period officially ends, after which the plan is reviewed for renewal, revision, or archival.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Descriptive name of the strategic account plan, typically including the account name and planning cycle year (e.g., \'Siemens AG – FY2025 Strategic Account Plan\').' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'Date on which the account plan period officially begins, marking the start of the planning cycle for revenue targets, engagement activities, and strategic objectives.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the account plan by planning horizon: annual (12-month cycle), multi-year (2–5 year strategic), quarterly (90-day tactical), or campaign (project-specific engagement).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planYear rdf:type rdf:Property ;
    rdfs:label 'Plan Year' ;
    rdfs:comment 'Fiscal or calendar year for which this strategic account plan is applicable, used to align planning cycles across the sales organization.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCompetitor rdf:type rdf:Property ;
    rdfs:label 'Primary Competitor' ;
    rdfs:comment 'Name of the main competing vendor or supplier posing the greatest threat to revenue retention or growth within this account, used for competitive intelligence and win/loss analysis.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorYearRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Prior Year Revenue Amount' ;
    rdfs:comment 'Actual revenue recognized from this account in the prior fiscal year, used as a baseline for growth target-setting and year-over-year performance benchmarking.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Internal sales region designation (e.g., North America, EMEA, APAC) to which the account is assigned for territory management and quota allocation purposes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Target Amount' ;
    rdfs:comment 'Total annual revenue target set for the account in the plan currency, representing the committed sales goal for the planning period across all product lines and solutions.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueTargetCurrency rdf:type rdf:Property ;
    rdfs:label 'Revenue Target Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the revenue target amount is denominated, supporting multi-currency planning for multinational accounts.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesMotion rdf:type rdf:Property ;
    rdfs:label 'Sales Motion' ;
    rdfs:comment 'Primary go-to-market approach for this account: direct (company sales team engages the account directly), channel (engagement through distributor or partner), or hybrid (combination of both).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicObjective rdf:type rdf:Property ;
    rdfs:label 'Strategic Objective' ;
    rdfs:comment 'Primary strategic goal for the account during the plan period, such as expanding automation system footprint, displacing a competitor, securing a multi-year framework agreement, or growing electrification solution share.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:whitespaceOpportunityAmount rdf:type rdf:Property ;
    rdfs:label 'Whitespace Opportunity Amount' ;
    rdfs:comment 'Estimated total addressable revenue from untapped product lines, solutions, or business units within the account where the company currently has no footprint, representing expansion potential.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountCountTarget rdf:type rdf:Property ;
    rdfs:label 'Account Count Target' ;
    rdfs:comment 'Target number of active customer accounts to be managed within this territory during the quota period, used for territory sizing, workload balancing, and coverage planning.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualRevenueQuota rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Quota' ;
    rdfs:comment 'Total annual revenue target assigned to this territory in the territory\'s local currency, representing the committed sales performance expectation for the fiscal year.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crmTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Crm Territory Code' ;
    rdfs:comment 'Native territory identifier from the source CRM system (Salesforce CRM), used for cross-system reconciliation and data lineage tracing between the lakehouse and the operational system of record.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOverlay rdf:type rdf:Property ;
    rdfs:label 'Is Overlay' ;
    rdfs:comment 'Indicates whether this territory is an overlay (specialist) territory that operates across other territories (e.g., a vertical industry specialist or solution overlay team) rather than a primary geographic or named-account territory.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStrategic rdf:type rdf:Property ;
    rdfs:label 'Is Strategic' ;
    rdfs:comment 'Flags this territory as a strategic priority territory, typically associated with key accounts, high-growth markets, or flagship industrial automation projects requiring executive attention and dedicated resources.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pipelineTarget rdf:type rdf:Property ;
    rdfs:label 'Pipeline Target' ;
    rdfs:comment 'Target value of the sales pipeline (open opportunities) that should be maintained in this territory at any given time, expressed in local currency. Typically a multiple of the annual quota.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postalCodeRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Postal Code Range End' ;
    rdfs:comment 'Ending postal/ZIP code defining the upper boundary of the geographic coverage range for this territory, used in conjunction with postal_code_range_start.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCodeRangeStart rdf:type rdf:Property ;
    rdfs:label 'Postal Code Range Start' ;
    rdfs:comment 'Starting postal/ZIP code defining the lower boundary of the geographic coverage range for this territory, used for precise geographic territory delineation.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryProductLine rdf:type rdf:Property ;
    rdfs:label 'Primary Product Line' ;
    rdfs:comment 'The primary product line or solution portfolio that this territory is responsible for selling, aligned with the company\'s industrial automation and electrification product categories.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaAttainmentTargetPct rdf:type rdf:Property ;
    rdfs:label 'Quota Attainment Target Pct' ;
    rdfs:comment 'Minimum percentage of annual revenue quota that must be achieved to meet the territory\'s performance threshold, used in commission and incentive plan calculations.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaFiscalYear rdf:type rdf:Property ;
    rdfs:label 'Quota Fiscal Year' ;
    rdfs:comment 'Four-digit fiscal year to which the annual revenue quota applies, enabling year-over-year quota tracking and performance comparison.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regionName rdf:type rdf:Property ;
    rdfs:label 'Region Name' ;
    rdfs:comment 'Named geographic macro-region to which this territory belongs (e.g., North America, EMEA, Asia Pacific), used for global sales reporting and executive dashboards.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesModel rdf:type rdf:Property ;
    rdfs:label 'Sales Model' ;
    rdfs:comment 'Indicates whether the territory is served through direct field sales, channel/partner sales, or a hybrid of both motions for industrial automation and electrification solutions.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDistributionChannel rdf:type rdf:Property ;
    rdfs:label 'Sap Distribution Channel' ;
    rdfs:comment 'Two-character SAP S/4HANA distribution channel code (e.g., direct sales, dealer, OEM) associated with this territory\'s primary go-to-market route.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDivision rdf:type rdf:Property ;
    rdfs:label 'Sap Division' ;
    rdfs:comment 'Two-character SAP S/4HANA division code representing the product line or business unit (e.g., automation systems, electrification) primarily sold within this territory.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSalesOrg rdf:type rdf:Property ;
    rdfs:label 'Sap Sales Org' ;
    rdfs:comment 'Four-character SAP S/4HANA Sales Organization code associated with this territory, enabling alignment between CRM territory structures and ERP sales area configurations for order management and revenue recognition.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Territory Assignment Id' ;
    rdfs:comment 'Unique system-generated identifier for each territory assignment record linking a sales representative or channel partner to a specific territory.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Human-readable business reference number for the territory assignment, used in correspondence, reporting, and cross-system reconciliation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason' ;
    rdfs:comment 'Business reason for creating or modifying this territory assignment, supporting audit trails, change management, and territory planning analytics.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Classification of the assignment role: primary (sole owner), secondary (supporting rep), overlay (specialist overlay such as product or vertical specialist), backup (coverage during absence), channel (indirect partner), or split (shared territory with quota split).' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionSplitPercent rdf:type rdf:Property ;
    rdfs:label 'Commission Split Percent' ;
    rdfs:comment 'Percentage of commissions earned on deals closed within the territory that are credited to this assignment record. May differ from quota split percent in overlay or specialist scenarios.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isSplitTerritory rdf:type rdf:Property ;
    rdfs:label 'Is Split Territory' ;
    rdfs:comment 'Indicates whether this territory is shared among multiple sales representatives or partners (True), requiring quota and commission splits, or is exclusively owned by a single assignee (False).' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productLineScope rdf:type rdf:Property ;
    rdfs:label 'Product Line Scope' ;
    rdfs:comment 'Description of the product lines or solution portfolios (e.g., \'Automation Systems\', \'Electrification Solutions\', \'Smart Infrastructure\') that the assigned representative is authorized to sell within the territory.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaAmount rdf:type rdf:Property ;
    rdfs:label 'Quota Amount' ;
    rdfs:comment 'Annual or period-based revenue quota assigned to this representative or partner for the territory, expressed in the assignment currency. Supports split-territory scenarios where quota is distributed across multiple reps.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaCurrency rdf:type rdf:Property ;
    rdfs:label 'Quota Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the territory quota amount is denominated (e.g., USD, EUR, GBP), supporting multi-currency global operations.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaPeriodType rdf:type rdf:Property ;
    rdfs:label 'Quota Period Type' ;
    rdfs:comment 'Time granularity of the quota cycle for this assignment (annual, semi-annual, quarterly, or monthly), determining how quota attainment and commission calculations are periodized.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaSplitPercent rdf:type rdf:Property ;
    rdfs:label 'Quota Split Percent' ;
    rdfs:comment 'Percentage of the total territory quota allocated to this specific assignment record. Used in split-territory scenarios common in large industrial project sales where multiple reps collaborate on a single account or geography. All splits for a territory must sum to 100%.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesRole rdf:type rdf:Property ;
    rdfs:label 'Sales Role' ;
    rdfs:comment 'Functional sales role of the assigned representative within the territory, used for commission plan mapping, reporting hierarchy, and quota allocation.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaId rdf:type rdf:Property ;
    rdfs:label 'Quota Id' ;
    rdfs:comment 'Unique system-generated identifier for each sales quota record assigned to a sales representative, channel partner, or territory team.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quota .

ind:acceleratorThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Accelerator Threshold Pct' ;
    rdfs:comment 'The quota attainment percentage at which accelerated commission rates (accelerators) are triggered (e.g., 1.00 = 100% attainment). Above this threshold, higher commission multipliers apply to incentivize overperformance.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attainmentBasis rdf:type rdf:Property ;
    rdfs:label 'Attainment Basis' ;
    rdfs:comment 'Defines the measurement basis used to calculate quota attainment: booked_revenue (order entry), invoiced_revenue (billing), collected_revenue (cash receipt), shipped_units, ordered_units, or gross_margin. Critical for commission calculation accuracy.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Floor Threshold Pct' ;
    rdfs:comment 'The minimum quota attainment percentage required before any commission is earned (e.g., 0.50 = 50% attainment floor). Below this threshold, no commission is paid regardless of sales activity.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'The time granularity of the quota measurement cycle: monthly, quarterly, semi-annual, or annual. Determines the cadence for attainment tracking and commission calculations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLineCode rdf:type rdf:Property ;
    rdfs:label 'Product Line Code' ;
    rdfs:comment 'The internal product line or SKU (Stock Keeping Unit) category code that scopes the quota to a specific product line within the product family. Used for granular attainment tracking by product portfolio.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'The business reason for the most recent quota revision or adjustment (e.g., territory realignment, headcount change, market adjustment). Required for audit compliance and management reporting on quota changes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAmount rdf:type rdf:Property ;
    rdfs:label 'Target Amount' ;
    rdfs:comment 'The primary monetary or unit target value assigned for this quota period. For revenue quotas, this is the revenue target in the transaction currency. For unit quotas, this represents the target unit count. For margin quotas, this is the gross margin target.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Target Amount Usd' ;
    rdfs:comment 'The quota target amount converted to US Dollars using the applicable exchange rate at the time of quota creation. Enables global consolidated reporting and cross-territory comparisons.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMarginPct rdf:type rdf:Property ;
    rdfs:label 'Target Margin Pct' ;
    rdfs:comment 'The target gross margin percentage required to achieve full quota attainment for margin-based quotas. Expressed as a decimal (e.g., 0.35 = 35%). Supports profitability-driven sales incentive programs.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetUnits rdf:type rdf:Property ;
    rdfs:label 'Target Units' ;
    rdfs:comment 'The target number of product units or solution contracts to be sold within the quota period. Applicable for unit-based quotas; may be populated alongside revenue targets for blended quota plans.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basePriceType rdf:type rdf:Property ;
    rdfs:label 'Base Price Type' ;
    rdfs:comment 'Defines the pricing methodology used to establish base prices on this list. List price is the standard published price; transfer price applies to intercompany transactions; cost-plus adds a margin to COGS; market-based aligns to competitive benchmarks; negotiated reflects customer-specific agreements.' ;
    rdfs:domain ind:SalesPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isNetPrice rdf:type rdf:Property ;
    rdfs:label 'Is Net Price' ;
    rdfs:comment 'Indicates whether prices on this list represent net prices (after all standard discounts have been applied) or gross list prices (before discounts). Critical for correct pricing calculation in SAP S/4HANA condition records.' ;
    rdfs:domain ind:SalesPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxDiscountPercent rdf:type rdf:Property ;
    rdfs:label 'Max Discount Percent' ;
    rdfs:comment 'The maximum allowable discount percentage that sales representatives are authorized to apply on top of this price list without requiring additional approval. Enforces discount governance and margin protection policies.' ;
    rdfs:domain ind:SalesPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingProcedure rdf:type rdf:Property ;
    rdfs:label 'Pricing Procedure' ;
    rdfs:comment 'SAP S/4HANA pricing procedure code that governs how condition types (base price, discounts, surcharges, taxes) are calculated and sequenced when this price list is applied during order processing.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundingRule rdf:type rdf:Property ;
    rdfs:label 'Rounding Rule' ;
    rdfs:comment 'Defines the price rounding rule applied to calculated prices on this list. Commercial rounding follows standard mathematical rounding; round_up and round_down enforce directional rounding for margin protection or competitive positioning.' ;
    rdfs:domain ind:SalesPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByCode rdf:type rdf:Property ;
    rdfs:label 'Superseded By Code' ;
    rdfs:comment 'The code of the price list that replaces this one when it is superseded or retired. Enables version chain tracking and ensures sales teams can identify the current active replacement list.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionType rdf:type rdf:Property ;
    rdfs:label 'Condition Type' ;
    rdfs:comment 'SAP SD condition type code representing this discount in the pricing procedure (e.g., \'K004\' for customer discount, \'K005\' for customer/material discount, \'K007\' for customer discount group).' ;
    rdfs:domain ind:DiscountStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmPriceRuleCode rdf:type rdf:Property ;
    rdfs:label 'Crm Price Rule Code' ;
    rdfs:comment 'External reference identifier for the corresponding price rule or discount record in Salesforce CRM, enabling bi-directional synchronization between SAP SD and CRM systems.' ;
    rdfs:domain ind:DiscountStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'The customer classification or industry segment to which this discount structure is applicable. Enables targeted commercial policies for key accounts, strategic customers, or specific verticals.' ;
    rdfs:domain ind:DiscountStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountBasis rdf:type rdf:Property ;
    rdfs:label 'Discount Basis' ;
    rdfs:comment 'Defines how the discount is calculated: as a flat percentage, fixed monetary amount, tiered percentage by volume bracket, tiered fixed amount, or sliding scale.' ;
    rdfs:domain ind:DiscountStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountType rdf:type rdf:Property ;
    rdfs:label 'Discount Type' ;
    rdfs:comment 'Classification of the discount structure by commercial purpose: trade (channel/distributor), volume (quantity-based), project (large capital project), promotional (time-limited campaign), loyalty, competitive, rebate, early payment, or bundle.' ;
    rdfs:domain ind:DiscountStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionGroup rdf:type rdf:Property ;
    rdfs:label 'Exclusion Group' ;
    rdfs:comment 'SAP SD condition exclusion group code that governs mutual exclusivity between discount structures. Discount structures in the same exclusion group cannot be applied simultaneously.' ;
    rdfs:domain ind:DiscountStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Fixed Discount Amount' ;
    rdfs:comment 'The fixed monetary discount amount applied per unit or per order when discount_basis is fixed_amount. Denominated in the currency specified by currency_code.' ;
    rdfs:domain ind:DiscountStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Max Discount Pct' ;
    rdfs:comment 'The ceiling discount percentage authorized under this structure. No individual deal may exceed this threshold without escalated approval. Expressed as a percentage (e.g., 15.00 = 15%).' ;
    rdfs:domain ind:DiscountStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Min Discount Pct' ;
    rdfs:comment 'The floor discount percentage applicable under this structure. Ensures a baseline discount is always applied when the structure is invoked.' ;
    rdfs:domain ind:DiscountStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'Business owner responsible for maintaining and governing this discount structure (typically a Sales Director or Pricing Manager). Point of contact for escalations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresJustification rdf:type rdf:Property ;
    rdfs:label 'Requires Justification' ;
    rdfs:comment 'Indicates whether a written business justification is mandatory when applying this discount structure to a sales opportunity or order. Enforces governance for high-value or sensitive discounts.' ;
    rdfs:domain ind:DiscountStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stackable rdf:type rdf:Property ;
    rdfs:label 'Stackable' ;
    rdfs:comment 'Indicates whether this discount structure can be combined (stacked) with other active discount structures on the same order or line item. Critical for margin protection governance.' ;
    rdfs:domain ind:DiscountStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Standard Discount Pct' ;
    rdfs:comment 'The default or baseline discount percentage applied when no special conditions are met. Serves as the starting point for sales negotiations.' ;
    rdfs:domain ind:DiscountStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractLineId rdf:type rdf:Property ;
    rdfs:label 'Contract Line Id' ;
    rdfs:comment 'Foreign key linking to service.contract_line. Business justification: Sales forecasts for service renewals are directly tied to specific contract lines. Revenue forecasting teams use this link to project recurring service revenue by contract line, enabling accurate annu' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractLine .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Qualitative confidence rating assigned by the submitter indicating the reliability of the forecast (high, medium, low). Complements the numeric probability and forecast category fields.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmForecastCode rdf:type rdf:Property ;
    rdfs:label 'Crm Forecast Code' ;
    rdfs:comment 'Native forecast record identifier from Salesforce CRM Sales Cloud, used for cross-system traceability and reconciliation between the lakehouse and the CRM system of record.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleType rdf:type rdf:Property ;
    rdfs:label 'Cycle Type' ;
    rdfs:comment 'Defines the cadence of the forecast cycle: monthly, quarterly, annual, or rolling 12-month. Determines the aggregation period and S&OP review frequency.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastedMarginAmount rdf:type rdf:Property ;
    rdfs:label 'Forecasted Margin Amount' ;
    rdfs:comment 'Projected gross margin amount (revenue minus cost of goods sold) for the forecast period in transaction currency. Used for profitability planning and EBITDA forecasting.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastedMarginPct rdf:type rdf:Property ;
    rdfs:label 'Forecasted Margin Pct' ;
    rdfs:comment 'Projected gross margin as a percentage of forecasted revenue. Key profitability KPI used in S&OP reviews and financial planning.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Forecasted Revenue Amount' ;
    rdfs:comment 'Projected gross revenue amount for the forecast period in the transaction currency. Represents the top-line revenue expectation before discounts and adjustments.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastedRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Forecasted Revenue Usd' ;
    rdfs:comment 'Projected gross revenue amount converted to US Dollars using the applicable exchange rate, enabling global consolidation and cross-currency reporting.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastedUnits rdf:type rdf:Property ;
    rdfs:label 'Forecasted Units' ;
    rdfs:comment 'Projected quantity of units (SKUs, systems, or assemblies) expected to be sold during the forecast period. Supports volume-based S&OP and production planning (MRP).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The calendar end date of the forecast period being projected. Defines the boundary of the forecast window for revenue recognition and planning purposes.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The calendar start date of the forecast period being projected. Used for time-series alignment in S&OP and financial planning.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:probabilityPct rdf:type rdf:Property ;
    rdfs:label 'Probability Pct' ;
    rdfs:comment 'Numeric probability (0–100%) that the forecasted revenue will be realized within the forecast period. Used for weighted pipeline calculations and risk-adjusted forecasting.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToQuotaAmount rdf:type rdf:Property ;
    rdfs:label 'Variance To Quota Amount' ;
    rdfs:comment 'Absolute difference between the forecasted revenue amount and the quota amount (forecast minus quota). Negative values indicate a forecast below quota; positive values indicate over-forecast.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionLabel rdf:type rdf:Property ;
    rdfs:label 'Version Label' ;
    rdfs:comment 'Human-readable label describing the nature of this forecast version (e.g., initial submission, revised, final, reforecast after major order change).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityId rdf:type rdf:Property ;
    rdfs:label 'Activity Id' ;
    rdfs:comment 'Unique surrogate identifier for each sales activity record in the lakehouse silver layer. Serves as the primary key for the sales_activity data product.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attendeeCount rdf:type rdf:Property ;
    rdfs:label 'Attendee Count' ;
    rdfs:comment 'Total number of participants (both internal and customer-side) who attended the sales activity. Indicates engagement breadth and multi-stakeholder involvement.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Sales channel through which the activity was conducted. Distinguishes between direct sales engagements and channel/partner-mediated interactions for channel performance analysis.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorMentioned rdf:type rdf:Property ;
    rdfs:label 'Competitor Mentioned' ;
    rdfs:comment 'Name of any competitor(s) mentioned or evaluated by the customer during the activity. Supports competitive intelligence tracking and win/loss analysis for industrial automation market positioning.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactTitle rdf:type rdf:Property ;
    rdfs:label 'Contact Title' ;
    rdfs:comment 'Job title or role of the primary customer contact (e.g., Plant Manager, VP Engineering, Procurement Director). Supports stakeholder mapping and executive engagement tracking.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmActivityCode rdf:type rdf:Property ;
    rdfs:label 'Crm Activity Code' ;
    rdfs:comment 'Native activity identifier from Salesforce CRM (Task or Event object ID). Used for cross-system traceability and reconciliation with the source system of record.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalAttendees rdf:type rdf:Property ;
    rdfs:label 'Internal Attendees' ;
    rdfs:comment 'Comma-separated list of internal employee names or IDs who participated in the activity (e.g., sales rep, pre-sales engineer, product specialist). Supports team selling analysis.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isKeyAccount rdf:type rdf:Property ;
    rdfs:label 'Is Key Account' ;
    rdfs:comment 'Indicates whether the activity is associated with a strategically designated key account. Key accounts receive elevated engagement standards and executive sponsorship per the account plan framework.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationAddress rdf:type rdf:Property ;
    rdfs:label 'Location Address' ;
    rdfs:comment 'Physical address or virtual meeting URL where the sales activity was conducted. Supports field sales logistics, territory management, and travel expense reporting.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextStep rdf:type rdf:Property ;
    rdfs:label 'Next Step' ;
    rdfs:comment 'Defined follow-up action or next step agreed upon as a result of this activity. Drives pipeline progression and ensures accountability for subsequent customer engagement.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextStepDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Step Due Date' ;
    rdfs:comment 'Target date by which the defined next step must be completed. Used for follow-up tracking, overdue activity alerts, and sales cadence management.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:opportunityStage rdf:type rdf:Property ;
    rdfs:label 'Opportunity Stage' ;
    rdfs:comment 'Stage of the associated sales opportunity at the time this activity was conducted. Enables analysis of activity patterns by pipeline stage and stage-to-stage conversion effectiveness.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Overall result or outcome of the sales activity as assessed by the sales representative. Indicates whether the engagement advanced the opportunity, was neutral, or resulted in a negative signal.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeDescription rdf:type rdf:Property ;
    rdfs:label 'Outcome Description' ;
    rdfs:comment 'Free-text narrative describing the result of the sales activity, key discussion points, customer reactions, and any commitments made. Captured from Salesforce activity notes.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresTechnicalSupport rdf:type rdf:Property ;
    rdfs:label 'Requires Technical Support' ;
    rdfs:comment 'Indicates whether the activity required or will require involvement of pre-sales engineers, application specialists, or technical consultants. Supports resource planning for technical sales support.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:solutionType rdf:type rdf:Property ;
    rdfs:label 'Solution Type' ;
    rdfs:comment 'Category of industrial solution discussed or demonstrated during the activity. Aligns with the company\'s core product lines: automation systems, electrification solutions, smart infrastructure, and system integration contracts.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Short descriptive title or subject line of the sales activity, as recorded in Salesforce. Provides a quick summary of the engagement purpose (e.g., \'Q3 OEE Solution Demo – Plant Manager\').' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorId rdf:type rdf:Property ;
    rdfs:label 'Competitor Id' ;
    rdfs:comment 'Unique system-generated identifier for the competitor master record in the industrial automation and electrification market.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Competitor .

ind:battlecardUrl rdf:type rdf:Property ;
    rdfs:label 'Battlecard Url' ;
    rdfs:comment 'URL link to the latest competitive battlecard document for this competitor, stored in the content management system. Provides sales teams with quick access to competitive positioning guidance.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifications rdf:type rdf:Property ;
    rdfs:label 'Certifications' ;
    rdfs:comment 'Comma-separated list of known industry certifications held by the competitor (e.g., ISO 9001, ISO 14001, CE Marking, UL, IEC 62443). Used to assess compliance parity and differentiation in regulated markets.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveThreatLevel rdf:type rdf:Property ;
    rdfs:label 'Competitive Threat Level' ;
    rdfs:comment 'Assessed level of competitive threat posed by this competitor to the company\'s business, based on market overlap, win/loss history, and strategic positioning. Used to prioritize competitive intelligence investment.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmCompetitorCode rdf:type rdf:Property ;
    rdfs:label 'Crm Competitor Code' ;
    rdfs:comment 'External identifier for this competitor record in the Salesforce CRM system, enabling cross-system traceability and deduplication.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCountRange rdf:type rdf:Property ;
    rdfs:label 'Employee Count Range' ;
    rdfs:comment 'Approximate employee headcount range of the competitor organization, used to gauge organizational scale and investment capacity.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAnnualRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Revenue Usd' ;
    rdfs:comment 'Estimated annual revenue of the competitor in US dollars, sourced from public filings, analyst reports, or market intelligence. Used for competitive sizing and market share analysis.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedMarketSharePct rdf:type rdf:Property ;
    rdfs:label 'Estimated Market Share Pct' ;
    rdfs:comment 'Estimated percentage of the relevant market held by the competitor, based on analyst reports or internal market intelligence. Used for competitive positioning and strategic planning.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicPresence rdf:type rdf:Property ;
    rdfs:label 'Geographic Presence' ;
    rdfs:comment 'Scope of the competitor\'s geographic market coverage. Global indicates worldwide operations; multi_regional spans several regions; regional is limited to one region; local is country or sub-country level.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goToMarketModel rdf:type rdf:Property ;
    rdfs:label 'Go To Market Model' ;
    rdfs:comment 'The competitor\'s primary sales and distribution model (direct sales force, channel partners, OEM, distributor network, or hybrid). Used to assess competitive reach and channel conflict risk.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City where the competitor\'s global headquarters is located, used for geographic competitive analysis and regional strategy planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country where the competitor\'s global headquarters is located.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intelligenceAsOfDate rdf:type rdf:Property ;
    rdfs:label 'Intelligence As Of Date' ;
    rdfs:comment 'Date as of which the competitive intelligence in this record was last validated or refreshed. Used to flag stale records requiring review.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intelligenceSource rdf:type rdf:Property ;
    rdfs:label 'Intelligence Source' ;
    rdfs:comment 'Primary source from which competitive intelligence for this record was gathered. Used to assess data reliability and freshness for competitive analysis.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knownStrengths rdf:type rdf:Property ;
    rdfs:label 'Known Strengths' ;
    rdfs:comment 'Narrative description of the competitor\'s recognized competitive strengths, such as technology leadership, brand recognition, pricing, distribution network, or service capabilities. Used in sales strategy and opportunity competitive analysis.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knownWeaknesses rdf:type rdf:Property ;
    rdfs:label 'Known Weaknesses' ;
    rdfs:comment 'Narrative description of the competitor\'s recognized weaknesses or vulnerabilities, such as limited product range, poor service, high pricing, or geographic gaps. Used to identify differentiation opportunities in sales engagements.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossRateAgainstPct rdf:type rdf:Property ;
    rdfs:label 'Loss Rate Against Pct' ;
    rdfs:comment 'Percentage of competitive opportunities where the company lost to this competitor, calculated from closed opportunity win/loss data. Identifies areas requiring competitive strategy improvement.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketSegmentsServed rdf:type rdf:Property ;
    rdfs:label 'Market Segments Served' ;
    rdfs:comment 'Comma-separated list of market verticals or customer segments the competitor actively targets (e.g., automotive, food and beverage, oil and gas, utilities), supporting targeted competitive strategy.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingCountries rdf:type rdf:Property ;
    rdfs:label 'Operating Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing countries where the competitor actively operates or sells, used for territory-level competitive mapping.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownedBy rdf:type rdf:Property ;
    rdfs:label 'Owned By' ;
    rdfs:comment 'Name or employee identifier of the sales or competitive intelligence team member responsible for maintaining and updating this competitor record.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCompanyName rdf:type rdf:Property ;
    rdfs:label 'Parent Company Name' ;
    rdfs:comment 'Name of the parent or holding company if the competitor is a subsidiary or division of a larger corporate group, supporting corporate hierarchy analysis.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDifferentiator rdf:type rdf:Property ;
    rdfs:label 'Primary Differentiator' ;
    rdfs:comment 'The single most significant competitive differentiator the competitor uses in the market (e.g., lowest total cost of ownership, open architecture, fastest delivery, strongest brand). Used to prepare counter-positioning in sales engagements.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLossReason rdf:type rdf:Property ;
    rdfs:label 'Primary Loss Reason' ;
    rdfs:comment 'Most frequently cited reason for losing opportunities to this competitor, derived from win/loss analysis. Used to prioritize product, pricing, or service improvements.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLines rdf:type rdf:Property ;
    rdfs:label 'Product Lines' ;
    rdfs:comment 'Comma-separated list of the competitor\'s known product lines or solution portfolios (e.g., PLCs, drives, switchgear, SCADA, MES), used to map competitive overlap against the company\'s own product families.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publiclyTraded rdf:type rdf:Property ;
    rdfs:label 'Publicly Traded' ;
    rdfs:comment 'Indicates whether the competitor is a publicly traded company listed on a stock exchange, enabling access to public financial disclosures for competitive analysis.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recentAcquisitions rdf:type rdf:Property ;
    rdfs:label 'Recent Acquisitions' ;
    rdfs:comment 'Narrative or comma-separated list of recent mergers, acquisitions, or divestitures by the competitor that may affect their product portfolio, market reach, or competitive threat level.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockTicker rdf:type rdf:Property ;
    rdfs:label 'Stock Ticker' ;
    rdfs:comment 'Stock exchange ticker symbol for publicly traded competitors, used to link to financial market data for revenue and valuation tracking.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicAlliances rdf:type rdf:Property ;
    rdfs:label 'Strategic Alliances' ;
    rdfs:comment 'Comma-separated list of known strategic partnerships, alliances, or OEM relationships the competitor maintains, which may affect competitive dynamics or channel conflict.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winRateAgainstPct rdf:type rdf:Property ;
    rdfs:label 'Win Rate Against Pct' ;
    rdfs:comment 'Percentage of competitive opportunities where the company won against this competitor, calculated from closed opportunity win/loss data. Supports competitive performance tracking and sales coaching.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opportunityCompetitorId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Competitor Id' ;
    rdfs:comment 'Unique surrogate identifier for the opportunity-competitor association record in the Databricks Silver Layer.' ;
    rdfs:domain ind:OpportunityCompetitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitorInstallationRecordId rdf:type rdf:Property ;
    rdfs:label 'Competitor Installation Record Id' ;
    rdfs:comment 'Foreign key linking to service.installation_record. Business justification: In competitive displacement deals, the opportunity-competitor record references the competitor\'s installed equipment at the customer site. Sales engineers use this to understand what is being replaced' ;
    rdfs:domain ind:OpportunityCompetitor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InstallationRecord .

ind:crmOpportunityCompetitorId rdf:type rdf:Property ;
    rdfs:label 'Crm Opportunity Competitor Id' ;
    rdfs:comment 'Native record identifier for the opportunity competitor association as stored in Salesforce CRM (OpportunityCompetitor object), used for source system traceability.' ;
    rdfs:domain ind:OpportunityCompetitor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Competitor .

ind:battlecardVersion rdf:type rdf:Property ;
    rdfs:label 'Battlecard Version' ;
    rdfs:comment 'Version identifier of the competitive battlecard document used by the sales team when engaging against this competitor in the opportunity. Enables tracking of battlecard effectiveness.' ;
    rdfs:domain ind:OpportunityCompetitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveStrength rdf:type rdf:Property ;
    rdfs:label 'Competitive Strength' ;
    rdfs:comment 'Sales representative\'s assessment of the competitor\'s relative strength in this specific opportunity, used to prioritize competitive response resources.' ;
    rdfs:domain ind:OpportunityCompetitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorPriceCurrency rdf:type rdf:Property ;
    rdfs:label 'Competitor Price Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the competitor price estimate (e.g., USD, EUR, CNY).' ;
    rdfs:domain ind:OpportunityCompetitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorPriceEstimate rdf:type rdf:Property ;
    rdfs:label 'Competitor Price Estimate' ;
    rdfs:comment 'Estimated or known price/bid value submitted by the competitor for this opportunity. Used for competitive pricing analysis and deal strategy. Classified as confidential business intelligence.' ;
    rdfs:domain ind:OpportunityCompetitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorProductCategory rdf:type rdf:Property ;
    rdfs:label 'Competitor Product Category' ;
    rdfs:comment 'Category of the competitor\'s proposed product or solution, aligned to the industrial manufacturing solution taxonomy for competitive benchmarking.' ;
    rdfs:domain ind:OpportunityCompetitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorProductName rdf:type rdf:Property ;
    rdfs:label 'Competitor Product Name' ;
    rdfs:comment 'Name of the specific product, solution, or system proposed by the competitor in this opportunity (e.g., a competing PLC platform, automation suite, or electrification solution).' ;
    rdfs:domain ind:OpportunityCompetitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorRelationshipStrength rdf:type rdf:Property ;
    rdfs:label 'Competitor Relationship Strength' ;
    rdfs:comment 'Assessment of the competitor\'s relationship strength with the customer\'s key decision-makers and stakeholders in this opportunity.' ;
    rdfs:domain ind:OpportunityCompetitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displacementStrategy rdf:type rdf:Property ;
    rdfs:label 'Displacement Strategy' ;
    rdfs:comment 'Strategy employed by the sales team to displace or counter this competitor in the opportunity. Supports post-deal analysis of which strategies are most effective.' ;
    rdfs:domain ind:OpportunityCompetitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displacementStrategyDetail rdf:type rdf:Property ;
    rdfs:label 'Displacement Strategy Detail' ;
    rdfs:comment 'Free-text description of the specific tactics and actions taken as part of the competitive displacement strategy for this opportunity.' ;
    rdfs:domain ind:OpportunityCompetitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'Date on which this competitor was first identified as active in the opportunity. Supports competitive timeline analysis and early warning metrics.' ;
    rdfs:domain ind:OpportunityCompetitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incumbentFlag rdf:type rdf:Property ;
    rdfs:label 'Incumbent Flag' ;
    rdfs:comment 'Indicates whether this competitor is the incumbent supplier at the customer account, representing an existing installed base or contract relationship that must be displaced.' ;
    rdfs:domain ind:OpportunityCompetitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intelligenceConfidence rdf:type rdf:Property ;
    rdfs:label 'Intelligence Confidence' ;
    rdfs:comment 'Confidence level of the competitive intelligence captured for this record, reflecting the reliability of the source and data quality.' ;
    rdfs:domain ind:OpportunityCompetitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossReason rdf:type rdf:Property ;
    rdfs:label 'Loss Reason' ;
    rdfs:comment 'Primary reason the opportunity was lost to this competitor. Captured when outcome is \'Lost\' to enable structured win/loss analysis and corrective action planning.' ;
    rdfs:domain ind:OpportunityCompetitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossReasonDetail rdf:type rdf:Property ;
    rdfs:label 'Loss Reason Detail' ;
    rdfs:comment 'Free-text elaboration on the primary loss reason, providing qualitative context for win/loss review sessions and competitive intelligence programs.' ;
    rdfs:domain ind:OpportunityCompetitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceDifferentialPct rdf:type rdf:Property ;
    rdfs:label 'Price Differential Pct' ;
    rdfs:comment 'Percentage difference between the company\'s proposed price and the competitor\'s estimated price for this opportunity. Positive value indicates company is priced higher; negative indicates lower.' ;
    rdfs:domain ind:OpportunityCompetitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryCompetitorFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Competitor Flag' ;
    rdfs:comment 'Indicates whether this competitor is the primary or most significant competitive threat in the opportunity. An opportunity may have multiple competitors but only one primary.' ;
    rdfs:domain ind:OpportunityCompetitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:winLossReviewCompleted rdf:type rdf:Property ;
    rdfs:label 'Win Loss Review Completed' ;
    rdfs:comment 'Indicates whether a formal win/loss review interview or debrief has been completed for this competitive engagement, supporting pipeline quality and sales process compliance.' ;
    rdfs:domain ind:OpportunityCompetitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:winLossReviewDate rdf:type rdf:Property ;
    rdfs:label 'Win Loss Review Date' ;
    rdfs:comment 'Date on which the formal win/loss review or debrief was conducted for this competitive engagement.' ;
    rdfs:domain ind:OpportunityCompetitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:winThemeUsed rdf:type rdf:Property ;
    rdfs:label 'Win Theme Used' ;
    rdfs:comment 'Primary win theme or value proposition message used to differentiate against this competitor (e.g., \'Integrated Automation + Electrification\', \'Total Cost of Ownership\', \'Local Service Network\').' ;
    rdfs:domain ind:OpportunityCompetitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamId rdf:type rdf:Property ;
    rdfs:label 'Team Id' ;
    rdfs:comment 'Unique surrogate identifier for a sales team record assigned to a major industrial project opportunity or key account in the Databricks Silver Layer.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Name of the key account or customer organization this sales team is assigned to support, used for account-level reporting and CRM alignment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmTeamCode rdf:type rdf:Property ;
    rdfs:label 'Crm Team Code' ;
    rdfs:comment 'Native identifier of the sales team record in the Salesforce CRM system, enabling traceability and synchronization between the lakehouse and the system of record.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLeadTeam rdf:type rdf:Property ;
    rdfs:label 'Is Lead Team' ;
    rdfs:comment 'Indicates whether this team is the primary (lead) team on the opportunity or account when multiple teams are involved. The lead team holds primary accountability for the commercial outcome.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memberCount rdf:type rdf:Property ;
    rdfs:label 'Member Count' ;
    rdfs:comment 'Total number of active members currently assigned to this sales team, used for capacity planning, workload analysis, and team sizing governance.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opportunityAmount rdf:type rdf:Property ;
    rdfs:label 'Opportunity Amount' ;
    rdfs:comment 'Total estimated commercial value of the opportunity or key account engagement managed by this team, expressed in the team\'s transactional currency. Used for pipeline reporting and commission basis.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opportunityAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Opportunity Amount Usd' ;
    rdfs:comment 'Total estimated commercial value of the opportunity converted to USD at the prevailing exchange rate, enabling global pipeline consolidation and cross-currency reporting.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiresEngineering rdf:type rdf:Property ;
    rdfs:label 'Requires Engineering' ;
    rdfs:comment 'Indicates whether the opportunity or account managed by this team requires dedicated application engineering or solution architecture support, triggering resource allocation workflows.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetCloseDate rdf:type rdf:Property ;
    rdfs:label 'Target Close Date' ;
    rdfs:comment 'Anticipated date by which the team expects to close the associated opportunity or finalize the key account engagement, used for pipeline forecasting and resource planning.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalCommissionSplitPct rdf:type rdf:Property ;
    rdfs:label 'Total Commission Split Pct' ;
    rdfs:comment 'Aggregate commission split percentage allocated to this team as a whole from the opportunity or account, which is then distributed among individual team members. Must sum to 100% across all teams on the same opportunity.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Total approved budget allocated to the campaign, covering marketing activities, events, partner enablement, and promotional materials. Expressed in the campaign currency.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Budget Amount Usd' ;
    rdfs:comment 'Campaign budget converted to US Dollars using the applicable exchange rate, enabling global financial consolidation and cross-regional budget comparison.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crmCampaignCode rdf:type rdf:Property ;
    rdfs:label 'Crm Campaign Code' ;
    rdfs:comment 'External campaign identifier from the Salesforce CRM system, enabling traceability and synchronization between the lakehouse silver layer and the operational CRM.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter in which the campaign is primarily active, supporting quarterly revenue forecasting and sales quota alignment.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGlobal rdf:type rdf:Property ;
    rdfs:label 'Is Global' ;
    rdfs:comment 'Indicates whether the campaign is executed globally across all regions or is limited to a specific region or country. Supports global vs. local campaign reporting.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadTargetCount rdf:type rdf:Property ;
    rdfs:label 'Lead Target Count' ;
    rdfs:comment 'Target number of qualified leads expected to be generated through the campaign, used for campaign effectiveness measurement and sales funnel planning.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opportunityTargetCount rdf:type rdf:Property ;
    rdfs:label 'Opportunity Target Count' ;
    rdfs:comment 'Target number of sales opportunities expected to be created from campaign-generated leads, supporting conversion rate tracking and pipeline forecasting.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pipelineTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Pipeline Target Amount' ;
    rdfs:comment 'Target value of sales pipeline (opportunities) expected to be generated by the campaign, expressed in the campaign currency. Supports pipeline coverage ratio analysis.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueTargetUsd rdf:type rdf:Property ;
    rdfs:label 'Revenue Target Usd' ;
    rdfs:comment 'Revenue target converted to US Dollars for global consolidation, executive reporting, and cross-regional campaign performance benchmarking.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:theme rdf:type rdf:Property ;
    rdfs:label 'Theme' ;
    rdfs:comment 'High-level strategic theme or messaging pillar of the campaign, such as \'Digital Transformation\', \'Sustainable Manufacturing\', or \'Industry 4.0 Readiness\'.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Reach Compliance Required' ;
    rdfs:comment 'Indicates whether the contract mandates supplier compliance with the EU REACH regulation (Registration, Evaluation, Authorisation and Restriction of Chemicals).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rohsComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Rohs Compliance Required' ;
    rdfs:comment 'Indicates whether the contract mandates supplier compliance with the EU Restriction of Hazardous Substances (RoHS) directive for all delivered materials.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'Maximum total monetary value committed under this contract over its full validity period, in the contract currency. Used for spend commitment tracking and financial planning.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredSupplierListId rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier List Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying each preferred supplier list entry in the Databricks Silver Layer.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PreferredSupplierList .

ind:supplierQualificationSupplierId rdf:type rdf:Property ;
    rdfs:label 'Supplier Qualification Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.procurement_supplier_qualification. Business justification: PSL designation should reference the formal qualification record. The qualification_status and qualification_expiry_date in PSL are redundant with the authoritative data in procurement_supplier_qualif' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:aribaPslReference rdf:type rdf:Property ;
    rdfs:label 'Ariba Psl Reference' ;
    rdfs:comment 'External identifier from SAP Ariba Supplier Management module corresponding to this preferred supplier list entry, enabling cross-system traceability.' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryManagerName rdf:type rdf:Property ;
    rdfs:label 'Category Manager Name' ;
    rdfs:comment 'Name of the category manager responsible for managing the supplier relationship and preferred status within this spend category.' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictMineralsCompliant rdf:type rdf:Property ;
    rdfs:label 'Conflict Minerals Compliant' ;
    rdfs:comment 'Indicates whether the supplier has provided conflict minerals compliance documentation (3TG: tin, tantalum, tungsten, gold) per Dodd-Frank Section 1502 requirements.' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:designationReason rdf:type rdf:Property ;
    rdfs:label 'Designation Reason' ;
    rdfs:comment 'Business rationale documenting why this supplier was designated at the specified preference tier, including strategic alignment, competitive sourcing outcome, or qualification result.' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDiversitySupplier rdf:type rdf:Property ;
    rdfs:label 'Is Diversity Supplier' ;
    rdfs:comment 'Flag indicating whether this supplier qualifies as a diversity supplier (e.g., minority-owned, women-owned, veteran-owned), supporting supplier diversity program compliance and reporting.' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSingleSource rdf:type rdf:Property ;
    rdfs:label 'Is Single Source' ;
    rdfs:comment 'Flag indicating that this supplier is the sole approved source for the designated category and plant, requiring documented single-source justification per procurement policy.' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStrategicSupplier rdf:type rdf:Property ;
    rdfs:label 'Is Strategic Supplier' ;
    rdfs:comment 'Flag indicating whether this supplier is classified as a strategic partner, warranting executive-level relationship management, joint development programs, and enhanced collaboration.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferenceTier rdf:type rdf:Property ;
    rdfs:label 'Preference Tier' ;
    rdfs:comment 'Procurement policy designation indicating the level of preference for this supplier within the category. \'Preferred\' directs buyers to use this supplier first; \'Approved\' allows use without restriction; \'Conditional\' requires additional justification; \'Restricted\' limits use to specific circumstances.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pslNumber rdf:type rdf:Property ;
    rdfs:label 'Psl Number' ;
    rdfs:comment 'Business-facing alphanumeric identifier for the preferred supplier list entry, used in procurement communications and audit trails.' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:singleSourceJustification rdf:type rdf:Property ;
    rdfs:label 'Single Source Justification' ;
    rdfs:comment 'Documented business justification for sole-source designation, required when is_single_source is true. Captures technical, commercial, or regulatory reasons for limiting to one supplier.' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingStrategy rdf:type rdf:Property ;
    rdfs:label 'Sourcing Strategy' ;
    rdfs:comment 'Procurement sourcing strategy alignment for this supplier-category combination, indicating whether the supplier is a sole source, one of multiple approved sources, or part of a strategic partnership.' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendAllocationPercent rdf:type rdf:Property ;
    rdfs:label 'Spend Allocation Percent' ;
    rdfs:comment 'Target percentage of category spend to be directed to this supplier as part of a multi-source or quota-based sourcing strategy. Supports spend distribution governance.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:characteristicId rdf:type rdf:Property ;
    rdfs:label 'Characteristic Id' ;
    rdfs:comment 'Foreign key linking to quality.characteristic. Business justification: Inspection plans are built around specific quality characteristics (CTQ features). This FK links the inspection plan master to the characteristic master, enabling direct traceability from the inspecti' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Characteristic .

ind:aqlLevel rdf:type rdf:Property ;
    rdfs:label 'Aql Level' ;
    rdfs:comment 'Acceptable Quality Level expressed as the maximum percent defective (or defects per hundred units) that is considered satisfactory as a process average. Governs the accept/reject decision for inspection lots per ANSI/ASQ Z1.4 or ISO 2859-1 sampling tables.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpkMinimumRequired rdf:type rdf:Property ;
    rdfs:label 'Cpk Minimum Required' ;
    rdfs:comment 'Minimum acceptable Cpk (Process Capability Index - Centered) threshold that must be achieved for quantitative characteristics in this plan. Typically 1.33 for standard processes and 1.67 for safety-critical characteristics per Six Sigma and AIAG standards.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerCode rdf:type rdf:Property ;
    rdfs:label 'Customer Code' ;
    rdfs:comment 'Customer identifier when this inspection plan is tailored to meet a specific customer\'s quality requirements or contractual specifications. Supports customer-specific PPAP and SLA compliance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructiveTest rdf:type rdf:Property ;
    rdfs:label 'Destructive Test' ;
    rdfs:comment 'Indicates whether any inspection characteristic in this plan requires destructive testing, which renders the sampled unit unusable after inspection. Impacts sample size planning and material cost accounting.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dynamicModificationRule rdf:type rdf:Property ;
    rdfs:label 'Dynamic Modification Rule' ;
    rdfs:comment 'SAP QM dynamic modification rule code that governs automatic tightening, normal, or reduced inspection switching based on cumulative quality history (accept/reject run). Implements skip-lot and reduced inspection per ISO 2859-3.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faiRequired rdf:type rdf:Property ;
    rdfs:label 'Fai Required' ;
    rdfs:comment 'Indicates whether a First Article Inspection (FAI) must be completed using this plan before serial production is authorized. FAI validates that the manufacturing process can produce parts conforming to all design requirements.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionCategory rdf:type rdf:Property ;
    rdfs:label 'Inspection Category' ;
    rdfs:comment 'Broad category of inspection methodology applied in this plan, indicating the nature of the quality checks performed (e.g., dimensional measurement, visual examination, functional testing, non-destructive testing).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLevel rdf:type rdf:Property ;
    rdfs:label 'Inspection Level' ;
    rdfs:comment 'Inspection level (I, II, III, or special levels S-1 through S-4) as defined in ANSI/ASQ Z1.4 / ISO 2859-1, determining the relative sample size used for the inspection. Level II is the standard default.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionMethodCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Method Code' ;
    rdfs:comment 'Code identifying the standardized inspection method or test procedure (e.g., CMM measurement, visual gauge, hardness test, tensile test) to be applied for the characteristics in this plan.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementEquipmentType rdf:type rdf:Property ;
    rdfs:label 'Measurement Equipment Type' ;
    rdfs:comment 'Type of measurement or test equipment required to execute the inspection characteristics defined in this plan. Used for calibration scheduling and equipment reservation in Maximo EAM.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planGroup rdf:type rdf:Property ;
    rdfs:label 'Plan Group' ;
    rdfs:comment 'SAP QM plan group key that logically groups related inspection plans for the same material or process. Multiple plan group counters can exist within a single plan group.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planGroupCounter rdf:type rdf:Property ;
    rdfs:label 'Plan Group Counter' ;
    rdfs:comment 'Sequential counter within a plan group distinguishing alternative inspection plans (e.g., different sampling levels or customer-specific variants) for the same material.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rohsReachApplicable rdf:type rdf:Property ;
    rdfs:label 'Rohs Reach Applicable' ;
    rdfs:comment 'Indicates whether this inspection plan includes characteristics required to verify compliance with RoHS (Restriction of Hazardous Substances) and/or REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals) regulations for the material.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Fixed or calculated number of units to be drawn from an inspection lot for measurement and evaluation. May be overridden by dynamic sampling rules based on quality history.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSizeUnit rdf:type rdf:Property ;
    rdfs:label 'Sample Size Unit' ;
    rdfs:comment 'Unit of measure for the sample size (e.g., EA for each/piece, KG for kilogram, L for liter). Aligns with SAP base unit of measure for the material.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingProcedureCode rdf:type rdf:Property ;
    rdfs:label 'Sampling Procedure Code' ;
    rdfs:comment 'Code referencing the statistical sampling procedure defined in SAP QM, specifying the sampling scheme (e.g., fixed sample, percentage, skip-lot) applied during inspection lot creation.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skipLotEnabled rdf:type rdf:Property ;
    rdfs:label 'Skip Lot Enabled' ;
    rdfs:comment 'Indicates whether skip-lot inspection is permitted for this plan, allowing certain lots to bypass full inspection based on a positive quality history. Governed by the dynamic modification rule.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spcEnabled rdf:type rdf:Property ;
    rdfs:label 'Spc Enabled' ;
    rdfs:comment 'Indicates whether Statistical Process Control (SPC) charting and Cp/Cpk capability analysis are activated for the quantitative characteristics in this inspection plan. When true, measurement results feed SPC control charts.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageDecisionRequired rdf:type rdf:Property ;
    rdfs:label 'Usage Decision Required' ;
    rdfs:comment 'Indicates whether a formal usage decision (accept, reject, conditional release) must be recorded in SAP QM upon completion of the inspection lot governed by this plan. Mandatory for regulated or safety-critical materials.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptedQuantity rdf:type rdf:Property ;
    rdfs:label 'Accepted Quantity' ;
    rdfs:comment 'Quantity of material within the inspection lot that passed inspection and was accepted for unrestricted use or further processing. Used for yield calculation and stock posting to unrestricted stock.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectsFound rdf:type rdf:Property ;
    rdfs:label 'Defects Found' ;
    rdfs:comment 'Total count of defects or non-conformances identified during inspection of this lot. Used for PPM (Parts Per Million) defect rate calculation, SPC charting, and quality trend analysis.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionEndDate rdf:type rdf:Property ;
    rdfs:label 'Inspection End Date' ;
    rdfs:comment 'Actual date on which all inspection activities and results recording were completed for this lot. Used to calculate inspection cycle time and identify bottlenecks in the quality process.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionResultSummary rdf:type rdf:Property ;
    rdfs:label 'Inspection Result Summary' ;
    rdfs:comment 'Overall summarized outcome of all inspection characteristic results for the lot. Indicates whether the lot passed, failed, or was conditionally accepted based on the aggregate of individual characteristic evaluations.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStage rdf:type rdf:Property ;
    rdfs:label 'Inspection Stage' ;
    rdfs:comment 'Current inspection severity stage for this lot as determined by the dynamic modification rule. Reflects the quality history-based adjustment to inspection intensity: Normal, Tightened (stricter), Reduced (less frequent), or Skip (no inspection).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStartDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Start Date' ;
    rdfs:comment 'Planned or actual date on which physical inspection activities commenced for this lot. Used for scheduling, workload planning, and measuring inspection lead time.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Inspection Type Description' ;
    rdfs:comment 'Human-readable description of the inspection type code, such as \'Goods Receipt from Purchase Order\' or \'In-Process Inspection\'. Supports reporting and user interface display.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFirstArticleInspection rdf:type rdf:Property ;
    rdfs:label 'Is First Article Inspection' ;
    rdfs:comment 'Indicates whether this inspection lot represents a First Article Inspection (FAI) event, typically performed on the first production run of a new or revised part. FAI lots require full dimensional and functional verification per PPAP requirements.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lot Created Timestamp' ;
    rdfs:comment 'Date and time when the inspection lot was created in SAP QM, either automatically triggered by a business event (e.g., goods receipt, production order confirmation) or manually by a quality user.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Business-facing alphanumeric identifier for the inspection lot as displayed in SAP QM. Used for cross-referencing with production orders, goods receipts, and quality notifications.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotOrigin rdf:type rdf:Property ;
    rdfs:label 'Lot Origin' ;
    rdfs:comment 'Business process that triggered the creation of the inspection lot. Identifies whether the lot originated from a production order, goods receipt, customer delivery, manual creation, or other source. Critical for traceability and root cause analysis.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotQuantity rdf:type rdf:Property ;
    rdfs:label 'Lot Quantity' ;
    rdfs:comment 'Total quantity of material submitted for inspection in this lot. Expressed in the base unit of measure of the material. Used for AQL sampling plan determination and yield calculations.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nonconformingQuantity rdf:type rdf:Property ;
    rdfs:label 'Nonconforming Quantity' ;
    rdfs:comment 'Quantity of material within the inspection lot that was found to be nonconforming and not accepted for unrestricted use. Drives scrap rate and yield calculations at the lot level.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageDecisionBy rdf:type rdf:Property ;
    rdfs:label 'Usage Decision By' ;
    rdfs:comment 'User ID or name of the quality inspector or quality engineer who made the final usage decision for the inspection lot. Required for accountability, audit trail, and regulatory compliance.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageDecisionDescription rdf:type rdf:Property ;
    rdfs:label 'Usage Decision Description' ;
    rdfs:comment 'Human-readable description of the usage decision code, such as \'Accept - Unrestricted Use\', \'Reject - Scrap\', or \'Conditional Release - Rework Required\'. Supports quality reporting and disposition documentation.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageDecisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Usage Decision Timestamp' ;
    rdfs:comment 'Date and time when the usage decision was made and recorded in SAP QM. Critical for measuring inspection cycle time, SLA compliance, and audit trail requirements under ISO 9001.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Name of the external supplier or vendor associated with the inspection lot for incoming goods receipt inspections. Supports supplier quality management reporting without requiring a join to the vendor master.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Number' ;
    rdfs:comment 'SAP vendor/supplier number associated with the inspection lot when the origin is a goods receipt from a purchase order. Enables supplier quality performance tracking, PPM analysis, and vendor scorecard reporting.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionResultId rdf:type rdf:Property ;
    rdfs:label 'Inspection Result Id' ;
    rdfs:comment 'Unique system-generated identifier for each individual inspection result record captured during inspection lot execution.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gaugeId rdf:type rdf:Property ;
    rdfs:label 'Gauge Id' ;
    rdfs:comment 'Identifier of the measurement instrument or gauge used to capture this result, enabling traceability to calibration records and Measurement System Analysis (MSA) studies.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gauge .

ind:attributeResult rdf:type rdf:Property ;
    rdfs:label 'Attribute Result' ;
    rdfs:comment 'Pass/fail conformance result for attribute-type characteristics (e.g., visual inspection, go/no-go gauge). Null for variable characteristics where measured_value is used.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characteristicType rdf:type rdf:Property ;
    rdfs:label 'Characteristic Type' ;
    rdfs:comment 'Classification of the characteristic as variable (measured numeric value), attribute (pass/fail conformance), or count (number of defects). Drives the applicable SPC methodology.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conformanceDecision rdf:type rdf:Property ;
    rdfs:label 'Conformance Decision' ;
    rdfs:comment 'The quality conformance decision for this individual characteristic result: accepted (within spec), rejected (out of spec), conditional accept (use-as-is disposition), rework required, scrap, or pending review.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpIndex rdf:type rdf:Property ;
    rdfs:label 'Cp Index' ;
    rdfs:comment 'Process Capability Index (Cp) for this characteristic, measuring the ratio of the specification width to the process spread (6 sigma). Indicates potential process capability without centering.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpkIndex rdf:type rdf:Property ;
    rdfs:label 'Cpk Index' ;
    rdfs:comment 'Process Capability Index Centered (Cpk) for this characteristic, measuring actual process capability accounting for process centering relative to specification limits. Key Six Sigma metric.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionOperationNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Operation Number' ;
    rdfs:comment 'Operation or step number within the inspection plan at which this characteristic was measured, aligning to the inspection plan structure in SAP QM.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'Date and time when the measurement was physically taken and recorded, in ISO 8601 format. Critical for SPC time-series analysis and traceability.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Full name of the quality inspector who performed the measurement. Retained for audit trail and regulatory compliance purposes.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowerControlLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Control Limit' ;
    rdfs:comment 'Statistical Process Control (SPC) lower control limit for the characteristic, calculated from process data (typically mean - 3 sigma). Triggers SPC alerts when breached.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowerSpecLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Spec Limit' ;
    rdfs:comment 'The minimum allowable value for the characteristic as defined in the engineering specification or drawing. Used for conformance determination and Cp/Cpk calculation.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'Actual numeric measurement recorded for a variable characteristic during inspection (e.g., 24.987 mm). Null for attribute-type characteristics.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retestFlag rdf:type rdf:Property ;
    rdfs:label 'Retest Flag' ;
    rdfs:comment 'Indicates whether this result is a retest measurement taken after a previous failed or inconclusive result for the same characteristic on the same sample.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retestSequence rdf:type rdf:Property ;
    rdfs:label 'Retest Sequence' ;
    rdfs:comment 'Sequential number indicating which retest attempt this result represents (1 = first retest, 2 = second retest, etc.). Value is 0 for the original measurement.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleNumber rdf:type rdf:Property ;
    rdfs:label 'Sample Number' ;
    rdfs:comment 'Sequential number of this individual sample or specimen within the inspection lot sample set, enabling traceability to specific physical units measured.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sign Off Timestamp' ;
    rdfs:comment 'Date and time when the inspector formally signed off on this inspection result, confirming the measurement is complete and the conformance decision is final.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:spcRuleViolated rdf:type rdf:Property ;
    rdfs:label 'Spc Rule Violated' ;
    rdfs:comment 'Identifies the specific SPC rule that was violated (e.g., \'Rule 1: Point beyond 3-sigma\', \'Rule 2: 9 consecutive points same side\', \'Rule 4: 14 alternating points\'). Null if no violation.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperControlLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Control Limit' ;
    rdfs:comment 'Statistical Process Control (SPC) upper control limit for the characteristic, calculated from process data (typically mean + 3 sigma). Triggers SPC alerts when exceeded.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperSpecLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Spec Limit' ;
    rdfs:comment 'The maximum allowable value for the characteristic as defined in the engineering specification or drawing. Used for conformance determination and Cp/Cpk calculation.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capaId rdf:type rdf:Property ;
    rdfs:label 'Capa Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_capa. Business justification: When a usage decision results in rejection or conditional release, a CAPA is typically initiated. This FK links the formal quality disposition (usage decision) to the corrective action record, providi' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Capa .

ind:conditionalReleaseConditions rdf:type rdf:Property ;
    rdfs:label 'Conditional Release Conditions' ;
    rdfs:comment 'Free-text description of the specific conditions, restrictions, or requirements that must be met for material released under a conditional usage decision to be used in production or shipped to customers. Applicable only when decision_category is \'conditional_release\'.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionCategory rdf:type rdf:Property ;
    rdfs:label 'Decision Category' ;
    rdfs:comment 'High-level classification of the usage decision outcome used for reporting and analytics. Maps multiple decision codes to a standardized category for cross-plant and cross-material quality performance analysis.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionCode rdf:type rdf:Property ;
    rdfs:label 'Decision Code' ;
    rdfs:comment 'Standardized quality decision code assigned at the conclusion of the inspection lot, representing the formal disposition outcome (e.g., A=Accept, R=Reject, C=Conditional Release, S=Scrap). Drives downstream stock posting in SAP QM.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'The calendar date on which the formal usage decision was made and recorded in the Quality Management System. Used for cycle time analysis, compliance reporting, and inspection lot closure tracking.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionDescription rdf:type rdf:Property ;
    rdfs:label 'Decision Description' ;
    rdfs:comment 'Human-readable description of the usage decision code, providing context for the disposition outcome (e.g., \'Accepted — All characteristics within specification\', \'Rejected — Critical defect found\').' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionReversalReason rdf:type rdf:Property ;
    rdfs:label 'Decision Reversal Reason' ;
    rdfs:comment 'Free-text explanation provided when a previously made usage decision is reversed or overturned. Documents the business justification for the reversal, supporting audit trail and corrective action analysis.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionStatus rdf:type rdf:Property ;
    rdfs:label 'Decision Status' ;
    rdfs:comment 'Current lifecycle status of the usage decision record. Tracks whether the decision is still open (inspection lot not yet closed), under review, formally decided, reversed (decision overturned), or cancelled.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) at which the usage decision was recorded in the system. Supports audit trail requirements and precise cycle time measurement from inspection lot creation to decision closure.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
    rdfs:comment 'Textual description of the primary defect or nonconformance identified during inspection that influenced the usage decision. Provides qualitative context for the defect code and supports root cause analysis.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLotCreatedDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Created Date' ;
    rdfs:comment 'The date on which the inspection lot was originally created in SAP QM. Combined with decision_date, enables calculation of inspection cycle time (time from lot creation to usage decision), a key quality process KPI.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionLotOrigin rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Origin' ;
    rdfs:comment 'The business process that triggered the creation of the inspection lot subject to this usage decision. Indicates whether the inspection arose from a goods receipt, production order completion, outbound delivery, customer complaint, or other quality event.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionQuantity rdf:type rdf:Property ;
    rdfs:label 'Inspection Quantity' ;
    rdfs:comment 'Total quantity of material submitted for inspection in the inspection lot, expressed in the base unit of measure. Represents the full lot size against which the usage decision is applied.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Numeric quality score (0–100) assigned to the inspection lot at the time of the usage decision, reflecting the overall conformance level of the inspected material. Derived from inspection results and used for supplier quality scorecards and trend analysis.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryHold rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold' ;
    rdfs:comment 'Indicates whether the material subject to this usage decision is placed under a regulatory hold (e.g., due to RoHS/REACH non-compliance, CE Marking failure, or FDA regulatory action). When true, stock posting is blocked pending regulatory clearance.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Rejected Quantity' ;
    rdfs:comment 'Quantity of material from the inspection lot that is rejected and posted to blocked stock or returned to supplier following the usage decision. Drives downstream NCR creation and disposition workflows.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleQualityEngineer rdf:type rdf:Property ;
    rdfs:label 'Responsible Quality Engineer' ;
    rdfs:comment 'Name or employee identifier of the quality engineer who made and recorded the formal usage decision. Establishes accountability and supports audit trail requirements under ISO 9001 and regulatory frameworks.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockPostingInstruction rdf:type rdf:Property ;
    rdfs:label 'Stock Posting Instruction' ;
    rdfs:comment 'The inventory posting instruction generated by the usage decision, directing SAP MM to transfer stock from quality inspection stock to the appropriate stock category (e.g., unrestricted, blocked, scrap). This is the primary downstream trigger for inventory movement in SAP QM.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockPostingStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Posting Status' ;
    rdfs:comment 'Current execution status of the stock posting instruction associated with the usage decision. Indicates whether the inventory transfer triggered by the decision has been successfully posted in SAP MM or is pending/failed.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionOwner rdf:type rdf:Property ;
    rdfs:label 'Action Owner' ;
    rdfs:comment 'Name or employee ID of the individual responsible for implementing the corrective or preventive action and ensuring timely closure of the CAPA.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionOwnerDepartment rdf:type rdf:Property ;
    rdfs:label 'Action Owner Department' ;
    rdfs:comment 'Department or organizational unit of the CAPA action owner, used for workload distribution, escalation routing, and departmental quality performance reporting.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualClosureDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closure Date' ;
    rdfs:comment 'Date on which the CAPA was formally closed after successful verification of effectiveness, used to measure cycle time and on-time closure performance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedPartDescription rdf:type rdf:Property ;
    rdfs:label 'Affected Part Description' ;
    rdfs:comment 'Human-readable description of the affected part, component, or material to provide context without requiring a lookup.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedPartNumber rdf:type rdf:Property ;
    rdfs:label 'Affected Part Number' ;
    rdfs:comment 'Part number or SKU of the product, component, or material directly affected by the nonconformance or quality issue.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProcess rdf:type rdf:Property ;
    rdfs:label 'Affected Process' ;
    rdfs:comment 'Name or code of the manufacturing process, work center, or production stage where the nonconformance was identified or originated.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Detailed description of the corrective or preventive actions planned and implemented to eliminate the root cause and prevent recurrence of the nonconformance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotifiedDate rdf:type rdf:Property ;
    rdfs:label 'Customer Notified Date' ;
    rdfs:comment 'Date on which the customer was formally notified of the nonconformance and the corrective actions being taken.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Rating' ;
    rdfs:comment 'Formal assessment of whether the implemented corrective or preventive action successfully eliminated the root cause and prevented recurrence of the nonconformance.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateContainmentAction rdf:type rdf:Property ;
    rdfs:label 'Immediate Containment Action' ;
    rdfs:comment 'Description of the short-term containment actions taken to prevent further nonconforming product from reaching the customer or next process stage while the root cause is investigated.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'Date on which the CAPA was formally initiated and entered into the Quality Management System.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:problemStatement rdf:type rdf:Property ;
    rdfs:label 'Problem Statement' ;
    rdfs:comment 'Detailed description of the quality problem, nonconformance, or potential risk being addressed, including what, where, when, and extent of the issue.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceCapaNumber rdf:type rdf:Property ;
    rdfs:label 'Recurrence Capa Number' ;
    rdfs:comment 'Reference number of the new CAPA raised if the original nonconformance recurred, enabling traceability of recurring quality issues and escalation chains.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'Name of the regulatory authority or certification body to which the nonconformance must be reported (e.g., OSHA, EPA, UL, CE, RoHS authority).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required' ;
    rdfs:comment 'Indicates whether the nonconformance or corrective action requires formal notification to a regulatory body such as OSHA, EPA, or a product certification authority.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisedClosureDate rdf:type rdf:Property ;
    rdfs:label 'Revised Closure Date' ;
    rdfs:comment 'Updated target closure date if the original target was extended due to complexity, resource constraints, or scope changes, with justification tracked separately.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'Categorization of the root cause using the 6M Ishikawa framework: Man, Machine, Material, Method, Measurement, or Environment, enabling systemic trend analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed narrative of the identified root cause(s) of the nonconformance as determined through the root cause analysis methodology.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseMethod rdf:type rdf:Property ;
    rdfs:label 'Root Cause Method' ;
    rdfs:comment 'Methodology used to identify the root cause of the nonconformance, such as 5-Why analysis, Ishikawa (fishbone) diagram, Fault Tree Analysis, or 8D problem solving.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Source Reference Number' ;
    rdfs:comment 'Reference number of the originating document or record that triggered the CAPA (e.g., NCR number, audit finding ID, customer complaint number).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetClosureDate rdf:type rdf:Property ;
    rdfs:label 'Target Closure Date' ;
    rdfs:comment 'Planned date by which all corrective or preventive actions must be implemented and the CAPA formally closed, used for SLA tracking and escalation management.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationEvidence rdf:type rdf:Property ;
    rdfs:label 'Verification Evidence' ;
    rdfs:comment 'Description or reference to objective evidence (inspection records, audit results, SPC charts, production data) demonstrating the effectiveness of the implemented actions.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or employee ID of the quality engineer or auditor who performed and approved the effectiveness verification of the CAPA.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Action Completed Date' ;
    rdfs:comment 'Actual date on which the recommended action was completed and evidence of implementation was recorded.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designStage rdf:type rdf:Property ;
    rdfs:label 'Design Stage' ;
    rdfs:comment 'Product development stage at which this FMEA was created or last updated, aligned with the Advanced Product Quality Planning (APQP) phase gate process.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionControl rdf:type rdf:Property ;
    rdfs:label 'Detection Control' ;
    rdfs:comment 'Description of existing controls used to detect the failure cause or failure mode before the product reaches the customer or the next process step (e.g., inspection, SPC, testing).' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:function rdf:type rdf:Property ;
    rdfs:label 'Function' ;
    rdfs:comment 'Description of the intended function or purpose of the item or process step being analyzed, forming the basis for failure mode identification.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelYearApplicability rdf:type rdf:Property ;
    rdfs:label 'Model Year Applicability' ;
    rdfs:comment 'Model year(s) or product generation(s) to which this FMEA analysis applies, supporting traceability across product lifecycle changes.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventionControl rdf:type rdf:Property ;
    rdfs:label 'Prevention Control' ;
    rdfs:comment 'Description of existing design or process controls that prevent the failure cause or failure mode from occurring (e.g., design standards, process parameters, mistake-proofing / Poka-Yoke).' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact Flag' ;
    rdfs:comment 'Indicates whether the failure mode has potential regulatory or compliance implications (e.g., CE Marking, RoHS, REACH, UL certification requirements).' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisedActionPriority rdf:type rdf:Property ;
    rdfs:label 'Revised Action Priority' ;
    rdfs:comment 'Updated Action Priority classification (High/Medium/Low) after mitigation actions have been implemented, confirming whether residual risk is acceptable.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characteristicClass rdf:type rdf:Property ;
    rdfs:label 'Characteristic Class' ;
    rdfs:comment 'Risk-based classification of the controlled characteristic indicating its impact on safety, regulatory compliance, or fit/function. Critical characteristics typically require 100% inspection or SPC monitoring.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlChartType rdf:type rdf:Property ;
    rdfs:label 'Control Chart Type' ;
    rdfs:comment 'Type of SPC control chart applied to monitor the characteristic (e.g., X-bar/R, Individuals/MR, p-chart for attribute data). Null or \'none\' if SPC is not applied.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlMethod rdf:type rdf:Property ;
    rdfs:label 'Control Method' ;
    rdfs:comment 'The method or technique used to control or monitor the characteristic (e.g., SPC charting, CMM measurement, go/no-go gauge, visual inspection, Poka-Yoke device).' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpkMinimum rdf:type rdf:Property ;
    rdfs:label 'Cpk Minimum' ;
    rdfs:comment 'Minimum acceptable Cpk (Process Capability Index - Centered) threshold required for this characteristic. Typically 1.33 for standard characteristics and 1.67 for critical/safety characteristics per AIAG standards.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementTechnique rdf:type rdf:Property ;
    rdfs:label 'Measurement Technique' ;
    rdfs:comment 'Specific measurement instrument, gauge, or test equipment used to evaluate the controlled characteristic (e.g., Vernier caliper, torque wrench, CMM, hardness tester).' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partRevision rdf:type rdf:Property ;
    rdfs:label 'Part Revision' ;
    rdfs:comment 'Engineering revision level of the part drawing or specification that this control plan is aligned to, ensuring traceability between design and process controls.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processCharacteristic rdf:type rdf:Property ;
    rdfs:label 'Process Characteristic' ;
    rdfs:comment 'The process parameter or input variable being controlled (e.g., temperature, torque, feed rate, pressure) that directly affects the product characteristic.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processFlowReference rdf:type rdf:Property ;
    rdfs:label 'Process Flow Reference' ;
    rdfs:comment 'Document number or identifier of the Process Flow Diagram (PFD) that this control plan is aligned to, maintaining the APQP triad linkage: PFD → PFMEA → Control Plan.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processName rdf:type rdf:Property ;
    rdfs:label 'Process Name' ;
    rdfs:comment 'Name of the manufacturing process or process step covered by this control plan (e.g., Welding, CNC Machining, Assembly, Painting).' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStepNumber rdf:type rdf:Property ;
    rdfs:label 'Process Step Number' ;
    rdfs:comment 'Sequential step number from the Process Flow Diagram (PFD) that this control plan entry corresponds to, enabling direct traceability between the process flow and control plan.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reactionPlan rdf:type rdf:Property ;
    rdfs:label 'Reaction Plan' ;
    rdfs:comment 'Documented corrective actions or containment steps to be taken when the process or product characteristic goes out of control or exceeds specification limits. Includes operator instructions and escalation path.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleFrequency rdf:type rdf:Property ;
    rdfs:label 'Sample Frequency' ;
    rdfs:comment 'Frequency or interval at which samples are taken for inspection or measurement (e.g., every 1 hour, every 50 parts, start of shift, per lot, continuous).' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationLowerLimit rdf:type rdf:Property ;
    rdfs:label 'Specification Lower Limit' ;
    rdfs:comment 'Lower Specification Limit (LSL) for the controlled characteristic. Values below this limit indicate a non-conformance requiring NCR initiation.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationNominal rdf:type rdf:Property ;
    rdfs:label 'Specification Nominal' ;
    rdfs:comment 'Target or nominal value for the controlled characteristic as specified in the engineering drawing or product specification (e.g., 25.00 mm, 150 Nm).' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationUpperLimit rdf:type rdf:Property ;
    rdfs:label 'Specification Upper Limit' ;
    rdfs:comment 'Upper Specification Limit (USL) for the controlled characteristic. Values exceeding this limit indicate a non-conformance requiring NCR initiation.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workInstructionReference rdf:type rdf:Property ;
    rdfs:label 'Work Instruction Reference' ;
    rdfs:comment 'Document number or identifier of the associated work instruction or Standard Operating Procedure (SOP) that operators follow to execute the controlled process step.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppapSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Ppap Submission Id' ;
    rdfs:comment 'Unique system-generated identifier for the PPAP submission record within the Quality Management System.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PpapSubmission .

ind:annualProductionVolume rdf:type rdf:Property ;
    rdfs:label 'Annual Production Volume' ;
    rdfs:comment 'Declared annual production volume (units per year) for the part as stated on the Part Submission Warrant (PSW), used to validate process capability studies.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appearanceApprovalComplete rdf:type rdf:Property ;
    rdfs:label 'Appearance Approval Complete' ;
    rdfs:comment 'Indicates whether the Appearance Approval Report (AAR) element has been completed and included in the PPAP submission package, applicable for appearance-critical parts.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capabilityStudyComplete rdf:type rdf:Property ;
    rdfs:label 'Capability Study Complete' ;
    rdfs:comment 'Indicates whether the initial process capability study (Cp/Cpk analysis) has been completed and included in the PPAP submission package.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlPlanComplete rdf:type rdf:Property ;
    rdfs:label 'Control Plan Complete' ;
    rdfs:comment 'Indicates whether the Control Plan element documenting all process controls, inspection methods, and reaction plans has been completed and included in the PPAP package.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerEngineerName rdf:type rdf:Property ;
    rdfs:label 'Customer Engineer Name' ;
    rdfs:comment 'Name of the customer\'s quality engineer or supplier quality engineer (SQE) responsible for reviewing and approving the PPAP submission.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Part Number' ;
    rdfs:comment 'The customer\'s own part number for the component, which may differ from the supplier\'s internal part number. Required for cross-reference on the PSW.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designRecordComplete rdf:type rdf:Property ;
    rdfs:label 'Design Record Complete' ;
    rdfs:comment 'Indicates whether the design record element (drawings, CAD models, specifications) has been completed and included in the PPAP submission package.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationNumber rdf:type rdf:Property ;
    rdfs:label 'Deviation Number' ;
    rdfs:comment 'Reference number of any interim approval, deviation, or waiver granted by the customer allowing limited production shipments while the PPAP is conditionally approved or pending full approval.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faiComplete rdf:type rdf:Property ;
    rdfs:label 'Fai Complete' ;
    rdfs:comment 'Indicates whether the First Article Inspection (FAI) / dimensional results element has been completed and included in the PPAP submission package.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturingProcessDescription rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Process Description' ;
    rdfs:comment 'Brief description of the key manufacturing processes used to produce the part (e.g., injection molding, CNC machining, stamping), as declared on the Part Submission Warrant (PSW).' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialTestResultsComplete rdf:type rdf:Property ;
    rdfs:label 'Material Test Results Complete' ;
    rdfs:comment 'Indicates whether material test results and performance test results (including functional testing) have been completed and included in the PPAP submission package.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minCpkValue rdf:type rdf:Property ;
    rdfs:label 'Min Cpk Value' ;
    rdfs:comment 'Minimum Cpk (Process Capability Index - Centered) value recorded across all critical and significant characteristics in the capability study, used to assess process stability and conformance.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:msaComplete rdf:type rdf:Property ;
    rdfs:label 'Msa Complete' ;
    rdfs:comment 'Indicates whether the Measurement System Analysis (MSA) / Gauge R&R studies have been completed and included in the PPAP submission package.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openActionCount rdf:type rdf:Property ;
    rdfs:label 'Open Action Count' ;
    rdfs:comment 'Number of open action items or deviations associated with the PPAP submission, particularly relevant for conditionally approved submissions requiring resolution before full approval.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallPpapCompletenessPct rdf:type rdf:Property ;
    rdfs:label 'Overall Ppap Completeness Pct' ;
    rdfs:comment 'Percentage of required PPAP elements that have been completed and submitted, calculated as completed elements divided by total required elements. Used for submission readiness tracking.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partRevisionLevel rdf:type rdf:Property ;
    rdfs:label 'Part Revision Level' ;
    rdfs:comment 'Engineering revision level or version of the part drawing/design record at the time of PPAP submission, ensuring traceability to the correct design baseline.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pfmeaComplete rdf:type rdf:Property ;
    rdfs:label 'Pfmea Complete' ;
    rdfs:comment 'Indicates whether the Process Failure Mode and Effects Analysis (PFMEA) element has been completed and included in the PPAP submission package.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionRunQuantity rdf:type rdf:Property ;
    rdfs:label 'Production Run Quantity' ;
    rdfs:comment 'Number of parts produced during the significant production run used to generate PPAP samples and capability data, typically a minimum of 300 consecutive parts per AIAG requirements.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pswNumber rdf:type rdf:Property ;
    rdfs:label 'Psw Number' ;
    rdfs:comment 'Unique reference number of the Part Submission Warrant (PSW) document, which is the formal cover document of the PPAP package signed by the supplier and accepted by the customer.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pswSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Psw Signatory Name' ;
    rdfs:comment 'Name of the supplier\'s authorized representative who signed the Part Submission Warrant (PSW), certifying compliance with all PPAP requirements.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pswSignedDate rdf:type rdf:Property ;
    rdfs:label 'Psw Signed Date' ;
    rdfs:comment 'Date on which the supplier\'s authorized representative signed the Part Submission Warrant (PSW), certifying that all PPAP requirements have been met.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Status' ;
    rdfs:comment 'Status of the part\'s compliance with applicable regulatory requirements (e.g., RoHS, REACH, CE Marking, UL) as declared in the PPAP submission.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Required Submission Date' ;
    rdfs:comment 'Customer-mandated or program-required deadline by which the PPAP submission must be completed and approved, used for program timing and launch readiness tracking.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleQuantity rdf:type rdf:Property ;
    rdfs:label 'Sample Quantity' ;
    rdfs:comment 'Number of sample parts submitted to the customer as part of the PPAP package for dimensional and functional verification.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionLevel rdf:type rdf:Property ;
    rdfs:label 'Submission Level' ;
    rdfs:comment 'PPAP submission level (1–5) as defined by AIAG, indicating the extent of documentation and physical samples required. Level 1 = Warrant only; Level 3 = Full PPAP; Level 5 = Full PPAP retained at supplier.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Number' ;
    rdfs:comment 'Human-readable business reference number for the PPAP submission, used for cross-system tracking and customer communication.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionReason rdf:type rdf:Property ;
    rdfs:label 'Submission Reason' ;
    rdfs:comment 'Business reason triggering the PPAP submission, such as new part introduction, Engineering Change Notice (ECN), tooling change, or annual revalidation.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierManufacturingSite rdf:type rdf:Property ;
    rdfs:label 'Supplier Manufacturing Site' ;
    rdfs:comment 'Name or identifier of the specific manufacturing facility or plant at the supplier where the part is produced, as required on the Part Submission Warrant (PSW).' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierQualityEngineer rdf:type rdf:Property ;
    rdfs:label 'Supplier Quality Engineer' ;
    rdfs:comment 'Name of the supplier\'s quality engineer responsible for preparing, coordinating, and submitting the PPAP package.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faiRecordId rdf:type rdf:Property ;
    rdfs:label 'Fai Record Id' ;
    rdfs:comment 'Unique system-generated identifier for the First Article Inspection (FAI) record. Serves as the primary key for this entity in the Databricks Silver Layer.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FaiRecord .

ind:balloonDrawingReference rdf:type rdf:Property ;
    rdfs:label 'Balloon Drawing Reference' ;
    rdfs:comment 'Reference identifier or document number of the ballooned drawing used during the FAI. A ballooned drawing annotates each dimension and characteristic with a numbered balloon corresponding to the inspection data sheet entries.' ;
    rdfs:domain ind:FaiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characteristicsConforming rdf:type rdf:Property ;
    rdfs:label 'Characteristics Conforming' ;
    rdfs:comment 'Number of inspected characteristics that were found to be within the specified engineering tolerances and fully conforming to the drawing requirements.' ;
    rdfs:domain ind:FaiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:characteristicsNonconforming rdf:type rdf:Property ;
    rdfs:label 'Characteristics Nonconforming' ;
    rdfs:comment 'Number of inspected characteristics that were found to be outside the specified engineering tolerances. Non-conforming characteristics trigger Non-Conformance Report (NCR) and Corrective and Preventive Action (CAPA) processes.' ;
    rdfs:domain ind:FaiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviationReference rdf:type rdf:Property ;
    rdfs:label 'Deviation Reference' ;
    rdfs:comment 'Reference number of any approved engineering deviation or waiver associated with this FAI, permitting use of a part that does not fully conform to the drawing specification under defined conditions.' ;
    rdfs:domain ind:FaiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposition rdf:type rdf:Property ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Final disposition decision for the FAI. \'Approved\' means the part fully conforms to all requirements. \'Approved with Deviation\' allows limited production under documented deviation. \'Rejected\' requires rework or re-inspection. \'Interim Approval\' permits limited production pending resolution of open items.' ;
    rdfs:domain ind:FaiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faiNumber rdf:type rdf:Property ;
    rdfs:label 'Fai Number' ;
    rdfs:comment 'Human-readable, business-assigned FAI reference number used for cross-referencing with engineering drawings, customer documentation, and quality records. Typically follows a structured naming convention tied to part number and revision.' ;
    rdfs:domain ind:FaiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faiReason rdf:type rdf:Property ;
    rdfs:label 'Fai Reason' ;
    rdfs:comment 'Business reason that triggered the FAI. Captures whether the inspection was initiated due to a new part introduction, engineering change, process change, supplier change, tooling change, production interruption, customer request, or Corrective and Preventive Action (CAPA).' ;
    rdfs:domain ind:FaiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faiType rdf:type rdf:Property ;
    rdfs:label 'Fai Type' ;
    rdfs:comment 'Classification of the FAI scope. \'Full\' indicates a complete FAI per AS9102. \'Partial\' covers a subset of characteristics. \'Delta\' is triggered by an Engineering Change Order (ECO) affecting specific features. \'Re-FAI\' is required after a process or supplier change.' ;
    rdfs:domain ind:FaiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:form1DesignDocumentationComplete rdf:type rdf:Property ;
    rdfs:label 'Form1 Design Documentation Complete' ;
    rdfs:comment 'Indicates whether AS9102 Form 1 (Design Documentation) has been fully completed and all required design documentation (drawings, specifications, material certifications) has been collected and verified.' ;
    rdfs:domain ind:FaiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:form2ProductAccountabilityComplete rdf:type rdf:Property ;
    rdfs:label 'Form2 Product Accountability Complete' ;
    rdfs:comment 'Indicates whether AS9102 Form 2 (Product Accountability, Materials, and Special Processes) has been fully completed, including raw material certifications, special process approvals (e.g., heat treatment, plating), and sub-tier supplier documentation.' ;
    rdfs:domain ind:FaiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:form3CharacteristicAccountabilityComplete rdf:type rdf:Property ;
    rdfs:label 'Form3 Characteristic Accountability Complete' ;
    rdfs:comment 'Indicates whether AS9102 Form 3 (Characteristic Accountability, Verification, and Compatibility Evaluation) has been fully completed, covering all dimensional, functional, and critical characteristics from the ballooned drawing.' ;
    rdfs:domain ind:FaiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:functionalTestStatus rdf:type rdf:Property ;
    rdfs:label 'Functional Test Status' ;
    rdfs:comment 'Status of functional performance testing conducted on the first article part to verify it meets operational and performance specifications beyond dimensional conformance.' ;
    rdfs:domain ind:FaiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'Date on which the First Article Inspection was physically performed. Used for scheduling, compliance tracking, and quality record retention.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionStandard rdf:type rdf:Property ;
    rdfs:label 'Inspection Standard' ;
    rdfs:comment 'Quality standard or specification framework governing the FAI process. AS9102 is the aerospace standard; AIAG PPAP is the automotive standard; customer-specific standards may apply for key accounts.' ;
    rdfs:domain ind:FaiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Material Certification Status' ;
    rdfs:comment 'Status of raw material certifications (mill certs, material test reports) required as part of the FAI package. Verifies that the material used in the first article conforms to the specified material standard.' ;
    rdfs:domain ind:FaiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openItemsCount rdf:type rdf:Property ;
    rdfs:label 'Open Items Count' ;
    rdfs:comment 'Number of FAI action items or discrepancies that remain open and unresolved at the time of record capture. Open items may prevent full approval and require resolution before final disposition.' ;
    rdfs:domain ind:FaiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pswStatus rdf:type rdf:Property ;
    rdfs:label 'Psw Status' ;
    rdfs:comment 'Status of the Part Submission Warrant (PSW), the PPAP cover document that summarizes the FAI results and certifies that the part meets all customer requirements. Required for PPAP-based FAI submissions.' ;
    rdfs:domain ind:FaiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialProcessApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Special Process Approval Status' ;
    rdfs:comment 'Status of approvals for special manufacturing processes (e.g., welding, heat treatment, surface treatment, non-destructive testing) applied to the first article part. Special processes typically require NADCAP or customer-specific accreditation.' ;
    rdfs:domain ind:FaiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCharacteristics rdf:type rdf:Property ;
    rdfs:label 'Total Characteristics' ;
    rdfs:comment 'Total number of dimensional, material, and functional characteristics identified on the ballooned drawing and required to be measured and verified during the FAI.' ;
    rdfs:domain ind:FaiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spcChartId rdf:type rdf:Property ;
    rdfs:label 'Spc Chart Id' ;
    rdfs:comment 'Unique system-generated identifier for the SPC chart master record within the Quality Management System.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpcChart .

ind:baselineEstablishedDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Established Date' ;
    rdfs:comment 'Date on which the SPC chart baseline (center line and control limits) was established from the initial process study. Used to track when the chart was last recalibrated.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineSampleCount rdf:type rdf:Property ;
    rdfs:label 'Baseline Sample Count' ;
    rdfs:comment 'Number of subgroups collected during the initial baseline study used to establish the center line and control limits. AIAG recommends a minimum of 25 subgroups for a stable baseline.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:centerLine rdf:type rdf:Property ;
    rdfs:label 'Center Line' ;
    rdfs:comment 'Center line value of the primary SPC chart representing the process grand mean (Xbar-bar) or process proportion (p-bar), established during the baseline study phase. Used as the reference for control limit calculations.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chartNumber rdf:type rdf:Property ;
    rdfs:label 'Chart Number' ;
    rdfs:comment 'Human-readable business identifier for the SPC chart, used for cross-referencing in quality documentation, PPAP packages, and audit records.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartType rdf:type rdf:Property ;
    rdfs:label 'Chart Type' ;
    rdfs:comment 'Type of Statistical Process Control (SPC) control chart used to monitor the process characteristic. Xbar-R and Xbar-S are used for variable data with subgroups; I-MR for individual measurements; p, np, c, u charts for attribute data; CUSUM and EWMA for detecting small shifts.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlLimitMethod rdf:type rdf:Property ;
    rdfs:label 'Control Limit Method' ;
    rdfs:comment 'Statistical method used to calculate the control limits for this chart. Standard is 3-sigma (99.73% confidence). Some applications use 2-sigma warning limits or custom multipliers.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpTarget rdf:type rdf:Property ;
    rdfs:label 'Cp Target' ;
    rdfs:comment 'Minimum acceptable target value for the Cp (Process Capability Index) for this characteristic. Cp measures the spread of the process relative to the specification width. Typical AIAG minimum is 1.33 for new processes.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpkTarget rdf:type rdf:Property ;
    rdfs:label 'Cpk Target' ;
    rdfs:comment 'Minimum acceptable target value for the Cpk (Centered Process Capability Index) for this characteristic. Cpk accounts for process centering relative to specification limits. Typical AIAG minimum is 1.33 for new processes.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectionRuleSet rdf:type rdf:Property ;
    rdfs:label 'Detection Rule Set' ;
    rdfs:comment 'Identifies the set of run rules applied to detect out-of-control conditions on the SPC chart. Common rule sets include Western Electric (AT&T) rules, Nelson rules, and AIAG rules. Governs alarm logic in Siemens Opcenter MES Quality module.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaugeType rdf:type rdf:Property ;
    rdfs:label 'Gauge Type' ;
    rdfs:comment 'Type of measurement gauge or instrument used to collect data for this SPC chart, e.g., \'CMM\', \'Caliper\', \'Vision System\', \'Load Cell\'. Supports Gauge R&R (Measurement System Analysis) traceability.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcl rdf:type rdf:Property ;
    rdfs:label 'Lcl' ;
    rdfs:comment 'Lower Control Limit for the primary chart, calculated as the process center minus three standard deviations (3-sigma). Measurements below LCL trigger an out-of-control signal. May be zero or null for attribute charts where negative values are not meaningful.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lsl rdf:type rdf:Property ;
    rdfs:label 'Lsl' ;
    rdfs:comment 'Lower engineering specification limit for the monitored characteristic as defined in the product drawing or control plan. Used to calculate process capability indices (Cp, Cpk). Distinct from the statistical LCL.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:msaRequired rdf:type rdf:Property ;
    rdfs:label 'Msa Required' ;
    rdfs:comment 'Indicates whether a Measurement System Analysis (MSA) / Gauge R&R study is required for the measurement system used with this SPC chart, as mandated by AIAG PPAP and APQP requirements.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rangeCenterLine rdf:type rdf:Property ;
    rdfs:label 'Range Center Line' ;
    rdfs:comment 'Center line of the range or standard deviation sub-chart, representing the average range (R-bar) or average standard deviation (S-bar) from the baseline study. Null for single-chart types.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rangeLcl rdf:type rdf:Property ;
    rdfs:label 'Range Lcl' ;
    rdfs:comment 'Lower Control Limit for the range (R) or standard deviation (S) sub-chart. Typically zero for small subgroup sizes (n < 7) in Xbar-R charts. Null for single-chart types.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rangeUcl rdf:type rdf:Property ;
    rdfs:label 'Range Ucl' ;
    rdfs:comment 'Upper Control Limit for the range (R) or standard deviation (S) sub-chart used in Xbar-R and Xbar-S charts to monitor process variability. Null for single-chart types such as p-chart or c-chart.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recalculationTrigger rdf:type rdf:Property ;
    rdfs:label 'Recalculation Trigger' ;
    rdfs:comment 'Defines the condition that triggers recalculation of the SPC chart control limits, such as a scheduled review, an Engineering Change Notice (ECN), a process change event, or automatic recalculation after a defined number of new subgroups.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingFrequency rdf:type rdf:Property ;
    rdfs:label 'Sampling Frequency' ;
    rdfs:comment 'Defined frequency or interval at which subgroup samples are collected for SPC monitoring, e.g., \'Every 1 hour\', \'Every 50 parts\', \'Every shift\'. Governs the sampling plan in Siemens Opcenter MES Quality module.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingFrequencyUnit rdf:type rdf:Property ;
    rdfs:label 'Sampling Frequency Unit' ;
    rdfs:comment 'Unit of the sampling frequency interval, indicating whether sampling is time-based (minutes, hours, shifts) or production-volume-based (parts, batches).' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingFrequencyValue rdf:type rdf:Property ;
    rdfs:label 'Sampling Frequency Value' ;
    rdfs:comment 'Numeric value of the sampling interval, used in conjunction with sampling_frequency_unit to define the complete sampling schedule, e.g., \'2\' hours or \'100\' parts.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sigmaLevel rdf:type rdf:Property ;
    rdfs:label 'Sigma Level' ;
    rdfs:comment 'Target sigma level for the monitored process characteristic, expressing the number of standard deviations between the process mean and the nearest specification limit. A Six Sigma target corresponds to 6.0.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subgroupSize rdf:type rdf:Property ;
    rdfs:label 'Subgroup Size' ;
    rdfs:comment 'Number of individual measurements collected per subgroup sample for the SPC chart. Determines the statistical basis for control limit calculations. Typically 2–10 for Xbar-R charts; 1 for I-MR charts.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ucl rdf:type rdf:Property ;
    rdfs:label 'Ucl' ;
    rdfs:comment 'Upper Control Limit for the primary (mean or proportion) chart, calculated statistically as the process center plus three standard deviations (3-sigma). Measurements exceeding UCL trigger an out-of-control signal in Siemens Opcenter MES.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usl rdf:type rdf:Property ;
    rdfs:label 'Usl' ;
    rdfs:comment 'Upper engineering specification limit for the monitored characteristic as defined in the product drawing or control plan. Used to calculate process capability indices (Cp, Cpk). Distinct from the statistical UCL.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spcSampleId rdf:type rdf:Property ;
    rdfs:label 'Spc Sample Id' ;
    rdfs:comment 'Unique system-generated identifier for each individual SPC data point record captured during production monitoring.' ;
    rdfs:domain ind:SpcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Indicates how the measurement was captured: manually entered by operator, automatically collected from a connected gauge, received from MES, SCADA system, or IIoT sensor. Affects data quality confidence.' ;
    rdfs:domain ind:SpcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfControlFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Control Flag' ;
    rdfs:comment 'Indicates whether this sample point triggered any out-of-control signal based on applied Western Electric or Nelson rules. True triggers immediate operator notification and potential process investigation.' ;
    rdfs:domain ind:SpcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sample Sequence Number' ;
    rdfs:comment 'Sequential position of this individual measurement within its subgroup (e.g., 1 of 5). Used to reconstruct subgroup composition for SPC recalculation.' ;
    rdfs:domain ind:SpcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleStatus rdf:type rdf:Property ;
    rdfs:label 'Sample Status' ;
    rdfs:comment 'Current processing status of the SPC sample record (e.g., COLLECTED upon initial entry, VALIDATED after quality review, REJECTED if measurement error detected, VOIDED if sample invalidated).' ;
    rdfs:domain ind:SpcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sample Timestamp' ;
    rdfs:comment 'Exact date and time when the subgroup sample measurement was collected on the shop floor, used for time-series SPC charting and trend analysis.' ;
    rdfs:domain ind:SpcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:samplingFrequencyCode rdf:type rdf:Property ;
    rdfs:label 'Sampling Frequency Code' ;
    rdfs:comment 'Code referencing the sampling plan frequency rule applied (e.g., EVERY_50_PARTS, HOURLY, EVERY_BATCH), as defined in the inspection plan. Supports audit of sampling compliance.' ;
    rdfs:domain ind:SpcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Spec Violation Flag' ;
    rdfs:comment 'Indicates whether the measured value falls outside the engineering specification limits (USL or LSL), representing a non-conforming measurement regardless of control chart status.' ;
    rdfs:domain ind:SpcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subgroupMean rdf:type rdf:Property ;
    rdfs:label 'Subgroup Mean' ;
    rdfs:comment 'Arithmetic mean of all measured values within the subgroup (X-bar). Plotted on the Xbar control chart to monitor process location.' ;
    rdfs:domain ind:SpcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subgroupNumber rdf:type rdf:Property ;
    rdfs:label 'Subgroup Number' ;
    rdfs:comment 'Identifier grouping individual measurements into a rational subgroup for Xbar-R or Xbar-S chart calculations. Multiple sample records share the same subgroup_id.' ;
    rdfs:domain ind:SpcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subgroupRange rdf:type rdf:Property ;
    rdfs:label 'Subgroup Range' ;
    rdfs:comment 'Range (maximum minus minimum) of measured values within the subgroup. Plotted on the R-chart to monitor process variability for small subgroup sizes.' ;
    rdfs:domain ind:SpcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subgroupStdDev rdf:type rdf:Property ;
    rdfs:label 'Subgroup Std Dev' ;
    rdfs:comment 'Sample standard deviation of measured values within the subgroup. Used in Xbar-S charts for larger subgroup sizes as a more efficient estimator of process spread.' ;
    rdfs:domain ind:SpcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidReason rdf:type rdf:Property ;
    rdfs:label 'Void Reason' ;
    rdfs:comment 'Free-text explanation for why a sample record was voided (e.g., gauge malfunction, operator error, environmental disturbance). Populated only when sample_status is VOIDED.' ;
    rdfs:domain ind:SpcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weRuleViolated rdf:type rdf:Property ;
    rdfs:label 'We Rule Violated' ;
    rdfs:comment 'Identifies the specific Western Electric rule that triggered the out-of-control signal (e.g., WE1: one point beyond 3-sigma, WE2: nine consecutive points on one side of center line). NONE if no violation detected.' ;
    rdfs:domain ind:SpcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneClassification rdf:type rdf:Property ;
    rdfs:label 'Zone Classification' ;
    rdfs:comment 'Zone classification of the plotted point relative to the control chart center line (Zone C: within 1-sigma, Zone B: 1–2 sigma, Zone A: 2–3 sigma). Used for Western Electric pattern rule evaluation.' ;
    rdfs:domain ind:SpcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableIndustrySector rdf:type rdf:Property ;
    rdfs:label 'Applicable Industry Sector' ;
    rdfs:comment 'Industry sector or product line for which this defect code is relevant (e.g., Automation Systems, Electrification, Smart Infrastructure, Transportation). Supports multi-division enterprises where defect taxonomies may differ by business unit.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableMaterialType rdf:type rdf:Property ;
    rdfs:label 'Applicable Material Type' ;
    rdfs:comment 'Type of material or product to which this defect code is applicable. Restricts defect code selection during inspection to relevant material types, reducing data entry errors and improving defect data quality.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaRequired rdf:type rdf:Property ;
    rdfs:label 'Capa Required' ;
    rdfs:comment 'Indicates whether detection of this defect type mandates the initiation of a CAPA record. Automates CAPA workflow triggering in the QMS for high-severity or recurring defect types.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:catalogCodeGroup rdf:type rdf:Property ;
    rdfs:label 'Catalog Code Group' ;
    rdfs:comment 'SAP QM catalog code group to which this defect code belongs. Code groups organize related defect codes within a catalog for structured selection during inspection result recording and NCR creation.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogType rdf:type rdf:Property ;
    rdfs:label 'Catalog Type' ;
    rdfs:comment 'SAP QM catalog type classification indicating whether this code represents a defect type (what went wrong), defect cause (why it went wrong), defect location (where on the part), or defect action (what was done). Aligns with SAP QM catalog 1/2/3/5 structure.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerStandardReference rdf:type rdf:Property ;
    rdfs:label 'Customer Standard Reference' ;
    rdfs:comment 'Reference to a customer-specific quality standard, drawing note, or specification that defines acceptance criteria for this defect type. Enables customer-specific defect taxonomy mapping for OEM and key account quality reporting.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultDisposition rdf:type rdf:Property ;
    rdfs:label 'Default Disposition' ;
    rdfs:comment 'Default material disposition action recommended for nonconforming product carrying this defect code. Provides a starting point for quality engineers during usage decision processing, though final disposition may be overridden case-by-case.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultSeverityRating rdf:type rdf:Property ;
    rdfs:label 'Default Severity Rating' ;
    rdfs:comment 'Default FMEA severity rating (1–10 scale) associated with this defect type, as defined in the enterprise FMEA reference manual. Used to pre-populate FMEA records and to prioritize defect types in Risk Priority Number (RPN) calculations.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectClass rdf:type rdf:Property ;
    rdfs:label 'Defect Class' ;
    rdfs:comment 'Severity classification of the defect based on its impact on product safety, function, and customer satisfaction. Critical defects may cause safety hazards or regulatory non-compliance; major defects significantly impair function or appearance; minor defects are slight deviations with minimal impact; incidental defects are negligible.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectFamily rdf:type rdf:Property ;
    rdfs:label 'Defect Family' ;
    rdfs:comment 'Grouping of related defect codes into a logical family for Pareto analysis, trend reporting, and Six Sigma improvement projects. Examples: \'Weld Defects\', \'Machining Defects\', \'Surface Treatment Defects\'. Enables roll-up reporting across defect codes.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCodeMapping rdf:type rdf:Property ;
    rdfs:label 'External Code Mapping' ;
    rdfs:comment 'Corresponding defect code or classification identifier used by a customer, supplier, or external standard body. Enables cross-reference between the enterprise defect taxonomy and external quality systems for EDI, customer portal reporting, and supplier scorecards.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoStandardReference rdf:type rdf:Property ;
    rdfs:label 'Iso Standard Reference' ;
    rdfs:comment 'Reference to the applicable ISO standard clause or section that defines or governs this defect type. Examples: ISO 9001:2015 Clause 8.7, ISO 1101 (Geometric Tolerancing), ISO 8062 (Casting Tolerances). Supports compliance traceability.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longDescription rdf:type rdf:Property ;
    rdfs:label 'Long Description' ;
    rdfs:comment 'Detailed narrative description of the defect, including observable characteristics, typical manifestation, and distinguishing features. Used for inspector training, FMEA documentation, and CAPA root cause analysis.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrAutoCreate rdf:type rdf:Property ;
    rdfs:label 'Ncr Auto Create' ;
    rdfs:comment 'Indicates whether detection of this defect type during inspection should automatically trigger creation of a Non-Conformance Report (NCR) in the QMS without manual intervention. Supports automated quality workflow execution.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plantApplicability rdf:type rdf:Property ;
    rdfs:label 'Plant Applicability' ;
    rdfs:comment 'Comma-separated list or wildcard pattern of plant codes where this defect code is valid and available for use. Supports multi-plant enterprises where certain defect types are specific to particular manufacturing sites or technologies.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppapRelevant rdf:type rdf:Property ;
    rdfs:label 'Ppap Relevant' ;
    rdfs:comment 'Indicates whether this defect type is relevant to PPAP submission requirements. PPAP-relevant defects must be addressed in the control plan and may require customer approval before production release.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppmThreshold rdf:type rdf:Property ;
    rdfs:label 'Ppm Threshold' ;
    rdfs:comment 'Maximum acceptable defect occurrence rate expressed in Parts Per Million (PPM) for this defect type. Used to set quality targets, trigger CAPA escalation, and evaluate supplier quality performance against contractual PPM commitments.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processStage rdf:type rdf:Property ;
    rdfs:label 'Process Stage' ;
    rdfs:comment 'Manufacturing or supply chain process stage at which this defect type is typically detected or originates. Used to route inspection findings to the correct process owner and to focus PFMEA and SPC controls at the right stage.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable' ;
    rdfs:comment 'Indicates whether occurrences of this defect type must be reported to a regulatory authority (e.g., CE Marking body, UL, EPA, OSHA). Drives automated regulatory notification workflows in the QMS.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reworkCostCategory rdf:type rdf:Property ;
    rdfs:label 'Rework Cost Category' ;
    rdfs:comment 'Categorical classification of the typical rework cost associated with this defect type. Used for cost-of-quality (COQ) analysis, scrap/rework budget planning, and prioritization of defect prevention investments.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rohsReachRelevant rdf:type rdf:Property ;
    rdfs:label 'Rohs Reach Relevant' ;
    rdfs:comment 'Indicates whether this defect type is relevant to RoHS or REACH regulatory compliance. When true, NCRs carrying this defect code may trigger mandatory regulatory reporting and customer notification workflows.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Brief, standardized label for the defect code used in dropdown selections, reports, and shop floor displays. Typically 5–50 characters for quick identification.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spcApplicable rdf:type rdf:Property ;
    rdfs:label 'Spc Applicable' ;
    rdfs:comment 'Indicates whether Statistical Process Control monitoring should be applied to track the occurrence rate of this defect type over time. When true, SPC charts (e.g., p-chart, c-chart) are generated for this defect code in the quality analytics platform.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Risk-based classification of the characteristic indicating its impact on safety, regulatory compliance, or product function. Critical characteristics affect safety or regulatory compliance; major characteristics affect product function or customer satisfaction; minor characteristics have limited impact; informational characteristics are tracked for data collection only.' ;
    rdfs:domain ind:Characteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpMinimumRequired rdf:type rdf:Property ;
    rdfs:label 'Cp Minimum Required' ;
    rdfs:comment 'The minimum acceptable Cp (Process Capability Index) value required for this characteristic, representing the ratio of specification width to process spread. Used alongside Cpk to assess both process spread and centering in capability studies.' ;
    rdfs:domain ind:Characteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctqFlag rdf:type rdf:Property ;
    rdfs:label 'Ctq Flag' ;
    rdfs:comment 'Indicates whether this characteristic is designated as Critical to Quality (CTQ) — a feature whose performance standard must be met to satisfy the customer. CTQ characteristics receive heightened inspection frequency, SPC monitoring, and PPAP documentation requirements.' ;
    rdfs:domain ind:Characteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drawingRevision rdf:type rdf:Property ;
    rdfs:label 'Drawing Revision' ;
    rdfs:comment 'Revision level of the engineering drawing from which this characteristic specification is sourced. Ensures that inspection requirements are aligned with the current approved design revision.' ;
    rdfs:domain ind:Characteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowerTolerance rdf:type rdf:Property ;
    rdfs:label 'Lower Tolerance' ;
    rdfs:comment 'The negative tolerance deviation from the nominal value (e.g., -0.05 mm). Together with upper_tolerance, defines the bilateral or unilateral tolerance band around the nominal value as specified on engineering drawings.' ;
    rdfs:domain ind:Characteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Flag' ;
    rdfs:comment 'Indicates whether this characteristic is subject to regulatory compliance requirements (e.g., RoHS/REACH chemical limits, CE marking dimensional tolerances, UL electrical ratings). Non-conformance may trigger mandatory regulatory reporting.' ;
    rdfs:domain ind:Characteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skipLotEligible rdf:type rdf:Property ;
    rdfs:label 'Skip Lot Eligible' ;
    rdfs:comment 'Indicates whether this characteristic is eligible for skip-lot inspection (reduced inspection frequency based on demonstrated supplier or process quality history). Safety-critical and CTQ characteristics are typically excluded from skip-lot programs.' ;
    rdfs:domain ind:Characteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spcChartType rdf:type rdf:Property ;
    rdfs:label 'Spc Chart Type' ;
    rdfs:comment 'The type of SPC control chart used to monitor this characteristic. Variable charts (Xbar-R, Xbar-S, I-MR) are used for continuous measurements; attribute charts (p, np, c, u) are used for pass/fail or count data. CUSUM and EWMA are used for detecting small shifts.' ;
    rdfs:domain ind:Characteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperTolerance rdf:type rdf:Property ;
    rdfs:label 'Upper Tolerance' ;
    rdfs:comment 'The positive tolerance deviation from the nominal value (e.g., +0.05 mm). Together with lower_tolerance, defines the bilateral or unilateral tolerance band around the nominal value as specified on engineering drawings.' ;
    rdfs:domain ind:Characteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accuracy rdf:type rdf:Property ;
    rdfs:label 'Accuracy' ;
    rdfs:comment 'Manufacturer-specified accuracy or maximum permissible error (MPE) of the gauge, expressed in the gauge\'s unit of measure. Used to assess fitness for purpose against tolerance requirements.' ;
    rdfs:domain ind:Gauge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetTagNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Number' ;
    rdfs:comment 'Internal fixed-asset tag or barcode label number affixed to the physical gauge, used for asset tracking in the EAM/CMMS system (Maximo) and physical inventory audits.' ;
    rdfs:domain ind:Gauge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedLocation rdf:type rdf:Property ;
    rdfs:label 'Assigned Location' ;
    rdfs:comment 'Physical location where the gauge is assigned and stored when not in use, such as a plant code, building, room, or work center (e.g., \'Plant 01 – Metrology Lab\', \'Work Center WC-100\').' ;
    rdfs:domain ind:Gauge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Calibration Certificate Number' ;
    rdfs:comment 'Reference number of the most recent calibration certificate issued by the calibrating laboratory. Provides traceability to national or international measurement standards.' ;
    rdfs:domain ind:Gauge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationLabAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Calibration Lab Accreditation Number' ;
    rdfs:comment 'Accreditation body certificate number for the calibration laboratory (e.g., A2LA, UKAS, DAkkS accreditation number), confirming traceability to national measurement standards.' ;
    rdfs:domain ind:Gauge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationLabName rdf:type rdf:Property ;
    rdfs:label 'Calibration Lab Name' ;
    rdfs:comment 'Name of the internal or external laboratory that performed the most recent calibration. External labs should be accredited to ISO/IEC 17025.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationStatus rdf:type rdf:Property ;
    rdfs:label 'Calibration Status' ;
    rdfs:comment 'Current calibration validity status of the gauge. \'Calibrated\' indicates the gauge is within its valid calibration period; \'overdue\' indicates the calibration due date has passed; \'out_of_service\' indicates the gauge is removed from use pending repair or calibration.' ;
    rdfs:domain ind:Gauge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReferenceStandard rdf:type rdf:Property ;
    rdfs:label 'Is Reference Standard' ;
    rdfs:comment 'Indicates whether this gauge serves as a reference or master standard used to calibrate other working gauges within the internal metrology hierarchy.' ;
    rdfs:domain ind:Gauge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMsaDate rdf:type rdf:Property ;
    rdfs:label 'Last Msa Date' ;
    rdfs:comment 'Date on which the most recent Measurement System Analysis (MSA) or Gauge Repeatability and Reproducibility (Gauge R&R) study was conducted for this gauge.' ;
    rdfs:domain ind:Gauge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementRangeMax rdf:type rdf:Property ;
    rdfs:label 'Measurement Range Max' ;
    rdfs:comment 'Upper bound of the gauge\'s measurement range, expressed in the gauge\'s unit of measure. Defines the maximum measurable value for capability assessment.' ;
    rdfs:domain ind:Gauge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementRangeMin rdf:type rdf:Property ;
    rdfs:label 'Measurement Range Min' ;
    rdfs:comment 'Lower bound of the gauge\'s measurement range, expressed in the gauge\'s unit of measure. Defines the minimum measurable value for capability assessment.' ;
    rdfs:domain ind:Gauge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outOfToleranceAction rdf:type rdf:Property ;
    rdfs:label 'Out Of Tolerance Action' ;
    rdfs:comment 'Defined action to be taken when the gauge is found out of tolerance during calibration. Drives the CAPA or NCR workflow for affected measurements made since the last valid calibration.' ;
    rdfs:domain ind:Gauge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseCost rdf:type rdf:Property ;
    rdfs:label 'Purchase Cost' ;
    rdfs:comment 'Original acquisition cost of the gauge in the transaction currency. Used for asset valuation, CAPEX reporting, and cost-benefit analysis of calibration vs. replacement decisions.' ;
    rdfs:domain ind:Gauge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseDate rdf:type rdf:Property ;
    rdfs:label 'Purchase Date' ;
    rdfs:comment 'Date on which the gauge was originally purchased or acquired. Used for asset lifecycle management, depreciation calculation, and warranty tracking.' ;
    rdfs:domain ind:Gauge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallRequired rdf:type rdf:Property ;
    rdfs:label 'Recall Required' ;
    rdfs:comment 'Indicates whether a measurement recall investigation is required for inspection results recorded with this gauge since its last valid calibration, triggered when the gauge is found out of tolerance.' ;
    rdfs:domain ind:Gauge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolution rdf:type rdf:Property ;
    rdfs:label 'Resolution' ;
    rdfs:comment 'Smallest increment of measurement the gauge can display or detect, expressed in the gauge\'s unit of measure (e.g., 0.001 mm for a digital micrometer). Used in Measurement System Analysis (MSA).' ;
    rdfs:domain ind:Gauge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsiblePerson rdf:type rdf:Property ;
    rdfs:label 'Responsible Person' ;
    rdfs:comment 'Name or employee ID of the quality or metrology technician responsible for managing the gauge\'s calibration schedule and custody. Supports accountability under ISO 9001.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rrPercent rdf:type rdf:Property ;
    rdfs:label 'Rr Percent' ;
    rdfs:comment 'Result of the most recent Gauge R&R study expressed as a percentage of total process variation or tolerance. Values below 10% are acceptable; 10–30% may be conditionally acceptable; above 30% requires corrective action.' ;
    rdfs:domain ind:Gauge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:traceabilityStandard rdf:type rdf:Property ;
    rdfs:label 'Traceability Standard' ;
    rdfs:comment 'National or international measurement standard to which the gauge\'s calibration is traceable (e.g., NIST, PTB, NPL, BIPM). Required for ISO 9001 and ISO/IEC 17025 compliance.' ;
    rdfs:domain ind:Gauge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaugeCalibrationId rdf:type rdf:Property ;
    rdfs:label 'Gauge Calibration Id' ;
    rdfs:comment 'Unique system-generated identifier for each gauge calibration event record in the Quality Management System.' ;
    rdfs:domain ind:GaugeCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentDescription rdf:type rdf:Property ;
    rdfs:label 'Adjustment Description' ;
    rdfs:comment 'Description of any adjustments, repairs, or corrective actions performed on the gauge during the calibration event.' ;
    rdfs:domain ind:GaugeCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentPerformed rdf:type rdf:Property ;
    rdfs:label 'Adjustment Performed' ;
    rdfs:comment 'Indicates whether the gauge required physical adjustment or repair during the calibration event to bring it within tolerance.' ;
    rdfs:domain ind:GaugeCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:asFoundCondition rdf:type rdf:Property ;
    rdfs:label 'As Found Condition' ;
    rdfs:comment 'Condition of the gauge as found at the start of calibration, before any adjustment. Indicates whether the instrument was within tolerance prior to calibration.' ;
    rdfs:domain ind:GaugeCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asLeftCondition rdf:type rdf:Property ;
    rdfs:label 'As Left Condition' ;
    rdfs:comment 'Condition of the gauge after calibration and any adjustments or repairs. Indicates the final state of the instrument upon return to service.' ;
    rdfs:domain ind:GaugeCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationEventNumber rdf:type rdf:Property ;
    rdfs:label 'Calibration Event Number' ;
    rdfs:comment 'Human-readable business identifier for the calibration event, used for traceability and audit trail purposes across the QMS.' ;
    rdfs:domain ind:GaugeCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationLabType rdf:type rdf:Property ;
    rdfs:label 'Calibration Lab Type' ;
    rdfs:comment 'Indicates whether the calibration was performed by an internal metrology lab or an accredited external calibration laboratory.' ;
    rdfs:domain ind:GaugeCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationProcedureNumber rdf:type rdf:Property ;
    rdfs:label 'Calibration Procedure Number' ;
    rdfs:comment 'Reference number of the Standard Operating Procedure (SOP) or work instruction used to perform the calibration, ensuring repeatability and compliance.' ;
    rdfs:domain ind:GaugeCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationResult rdf:type rdf:Property ;
    rdfs:label 'Calibration Result' ;
    rdfs:comment 'Overall pass/fail outcome of the calibration event. A \'fail\' result triggers gauge withdrawal from service and initiates a CAPA or NCR process.' ;
    rdfs:domain ind:GaugeCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationStandardUsed rdf:type rdf:Property ;
    rdfs:label 'Calibration Standard Used' ;
    rdfs:comment 'Reference standard or master gauge used during calibration (e.g., NIST-traceable gauge block set, reference thermometer), ensuring measurement traceability.' ;
    rdfs:domain ind:GaugeCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Code identifying the department or work center responsible for the gauge (e.g., metrology lab, production floor, quality inspection).' ;
    rdfs:domain ind:GaugeCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Lab Accreditation Number' ;
    rdfs:comment 'Accreditation certificate number of the external calibration laboratory (e.g., A2LA, NVLAP, UKAS accreditation number), confirming traceability to national standards.' ;
    rdfs:domain ind:GaugeCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msaStudyReference rdf:type rdf:Property ;
    rdfs:label 'Msa Study Reference' ;
    rdfs:comment 'Reference number of the associated Measurement System Analysis (MSA) study (Gauge R&R, linearity, bias study) linked to this calibration event.' ;
    rdfs:domain ind:GaugeCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Service Flag' ;
    rdfs:comment 'Indicates whether the gauge has been removed from service due to calibration failure, damage, or expiry. Triggers quarantine and prevents use in production measurements.' ;
    rdfs:domain ind:GaugeCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Required Flag' ;
    rdfs:comment 'Indicates whether a measurement recall is required for parts or products measured with this gauge during the period it was found out of tolerance, triggering a quality impact assessment.' ;
    rdfs:domain ind:GaugeCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'Name or employee ID of the quality engineer or metrology supervisor who reviewed and approved the calibration record.' ;
    rdfs:domain ind:GaugeCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardTraceabilityReference rdf:type rdf:Property ;
    rdfs:label 'Standard Traceability Reference' ;
    rdfs:comment 'Certificate or reference number of the calibration standard used, establishing the metrological traceability chain to national or international measurement standards.' ;
    rdfs:domain ind:GaugeCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerComplaintId rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying each customer complaint record in the Quality Management System.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerComplaint .

ind:complaintNumber rdf:type rdf:Property ;
    rdfs:label 'Complaint Number' ;
    rdfs:comment 'Human-readable business reference number assigned to the complaint, used for cross-system tracking and customer communication (e.g., CC-2024-000123).' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintType rdf:type rdf:Property ;
    rdfs:label 'Complaint Type' ;
    rdfs:comment 'Classification of the complaint by its nature and origin, distinguishing field failures, warranty claims, OEM partner complaints, safety concerns, and regulatory issues.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentAction rdf:type rdf:Property ;
    rdfs:label 'Containment Action' ;
    rdfs:comment 'Description of the immediate containment action taken to protect the customer from further exposure to the defect, corresponding to 8D Discipline 3 (D3).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Containment Completion Date' ;
    rdfs:comment 'Date on which the containment action was fully implemented and verified, used to measure response speed and SLA compliance for immediate customer protection.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerApprovedClosure rdf:type rdf:Property ;
    rdfs:label 'Customer Approved Closure' ;
    rdfs:comment 'Indicates whether the customer has formally accepted and approved the complaint resolution before the record is closed, ensuring customer sign-off is captured.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Rating' ;
    rdfs:comment 'Customer\'s satisfaction rating provided at complaint closure, measuring the effectiveness of the resolution process and informing Net Promoter Score (NPS) and customer retention analytics.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectCategory rdf:type rdf:Property ;
    rdfs:label 'Defect Category' ;
    rdfs:comment 'High-level category of the defect type, used for trend analysis, FMEA alignment, and quality reporting across product lines.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eightDStatus rdf:type rdf:Property ;
    rdfs:label 'Eight D Status' ;
    rdfs:comment 'Current step in the 8 Disciplines (8D) structured problem-solving process, tracking progression from team formation through root cause analysis to preventive action and closure.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureDate rdf:type rdf:Property ;
    rdfs:label 'Failure Date' ;
    rdfs:comment 'Date on which the product failure or quality issue was first observed or experienced by the customer, used for warranty age calculation and field reliability analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:failureDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Description' ;
    rdfs:comment 'Detailed narrative description of the failure or quality issue as reported by the customer, including observed symptoms, conditions of failure, and customer impact.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityComplained rdf:type rdf:Property ;
    rdfs:label 'Quantity Complained' ;
    rdfs:comment 'Number of units reported as defective or non-conforming in the customer complaint, used for PPM calculation and scope assessment.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date on which the complaint was formally received and registered in the Quality Management System, used for SLA tracking and response time measurement.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyRelated rdf:type rdf:Property ;
    rdfs:label 'Safety Related' ;
    rdfs:comment 'Indicates whether the complaint involves a potential safety hazard to end users or operators, triggering escalated priority handling and mandatory safety review.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'Channel through which the complaint was received, enabling analysis of complaint intake patterns and customer engagement touchpoints.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyStatus rdf:type rdf:Property ;
    rdfs:label 'Warranty Status' ;
    rdfs:comment 'Indicates whether the complained product is within the warranty period, out of warranty, or subject to a goodwill claim, driving financial liability and resolution approach.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionStage rdf:type rdf:Property ;
    rdfs:label 'Detection Stage' ;
    rdfs:comment 'Stage in the production or supply chain process at which the quality defect or nonconformance was detected. Supports escape analysis and process improvement initiatives.' ;
    rdfs:domain ind:QualityNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityDescription rdf:type rdf:Property ;
    rdfs:label 'Priority Description' ;
    rdfs:comment 'Human-readable label for the priority level (e.g., Very High, High, Medium, Low) to support reporting and user communication.' ;
    rdfs:domain ind:QualityNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedByDepartment rdf:type rdf:Property ;
    rdfs:label 'Reported By Department' ;
    rdfs:comment 'Organizational department of the person who reported the quality notification (e.g., Quality Assurance, Production, Procurement, Customer Service). Enables departmental quality reporting.' ;
    rdfs:domain ind:QualityNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeDescription rdf:type rdf:Property ;
    rdfs:label 'Type Description' ;
    rdfs:comment 'Human-readable description of the notification type (e.g., \'Internal Defect\', \'Customer Complaint\', \'Supplier Defect Notification\') to support reporting and user interfaces.' ;
    rdfs:domain ind:QualityNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateId rdf:type rdf:Property ;
    rdfs:label 'Certificate Id' ;
    rdfs:comment 'Unique surrogate identifier for the quality certificate record in the lakehouse silver layer.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certificate .

ind:applicableStandards rdf:type rdf:Property ;
    rdfs:label 'Applicable Standards' ;
    rdfs:comment 'Comma-separated list of quality, safety, or regulatory standards met by the certified product (e.g., ISO 9001:2015, IEC 61131, RoHS, REACH, CE, UL, ANSI). Stored as a delimited string for reporting.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Name' ;
    rdfs:comment 'Full name of the quality authority (e.g., Quality Manager, Quality Engineer) who authorized and signed the certificate, as required for legal and regulatory validity.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Title' ;
    rdfs:comment 'Job title or role of the authorized signatory (e.g., Quality Manager, Director of Quality Assurance), providing context for the authority level of the certification.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceMarkingApplicable rdf:type rdf:Property ;
    rdfs:label 'Ce Marking Applicable' ;
    rdfs:comment 'Indicates whether the product requires CE marking under applicable EU directives, confirming conformity with European health, safety, and environmental protection standards.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerSpecificRequirements rdf:type rdf:Property ;
    rdfs:label 'Customer Specific Requirements' ;
    rdfs:comment 'Description of any customer-specific quality certificate requirements (e.g., AIAG, IATF 16949 customer specifics, additional test data, format mandates) that must be met for this certificate.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStorageReference rdf:type rdf:Property ;
    rdfs:label 'Document Storage Reference' ;
    rdfs:comment 'Reference path or identifier to the signed certificate document stored in the document management system (e.g., Siemens Teamcenter DMS or SAP DMS), enabling retrieval of the original signed PDF.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingPlantCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Plant Code' ;
    rdfs:comment 'SAP plant code identifying the manufacturing facility that produced the goods and issued the quality certificate.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingPlantName rdf:type rdf:Property ;
    rdfs:label 'Issuing Plant Name' ;
    rdfs:comment 'Full descriptive name of the manufacturing plant issuing the certificate, used for display on printed certificates and customer-facing documents.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallConformanceResult rdf:type rdf:Property ;
    rdfs:label 'Overall Conformance Result' ;
    rdfs:comment 'Summary conformance decision for the certified batch or lot: Conforming (all characteristics within specification), Non-Conforming, or Conditionally Conforming (released with deviation).' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partName rdf:type rdf:Property ;
    rdfs:label 'Part Name' ;
    rdfs:comment 'Descriptive name of the part or material covered by the certificate, as defined in the SAP material master or PLM system.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityCertified rdf:type rdf:Property ;
    rdfs:label 'Quantity Certified' ;
    rdfs:comment 'Total quantity of product units or material covered by this certificate.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededByCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded By Certificate Number' ;
    rdfs:comment 'Certificate number of the replacement certificate when this certificate has been superseded, enabling version chain traceability.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResultsSummary rdf:type rdf:Property ;
    rdfs:label 'Test Results Summary' ;
    rdfs:comment 'Narrative or structured summary of key test results included on the certificate, such as dimensional, mechanical, chemical, or functional test outcomes.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingId rdf:type rdf:Property ;
    rdfs:label 'Packaging Id' ;
    rdfs:comment 'Foreign key linking to logistics.packaging. Business justification: shipment_item.packaging_type is a denormalized reference to the packaging master. Adding packaging_id FK normalizes this to the packaging master record, enabling packaging configuration lookups. packa' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Packaging .

ind:sparePartsRequestId rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Request Id' ;
    rdfs:comment 'Foreign key linking to service.spare_parts_request. Business justification: When a service technician raises a spare parts request, logistics fulfills it by creating shipment items. The warehouse/logistics team uses this link daily to pick, pack, and ship parts against open s' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SparePartsRequest .

ind:customsValue rdf:type rdf:Property ;
    rdfs:label 'Customs Value' ;
    rdfs:comment 'Declared monetary value of this shipment item for customs purposes, used to calculate import duties and taxes. Must align with the transaction value per WTO Customs Valuation Agreement.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Customs Value Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the customs declared value (e.g., USD, EUR, GBP). Required for accurate duty calculation and customs declaration filing.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCode rdf:type rdf:Property ;
    rdfs:label 'Hs Code' ;
    rdfs:comment 'Customs tariff classification code under the World Customs Organization Harmonized System. Mandatory for customs declarations, import/export duty calculation, and trade compliance reporting across global distribution networks.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemStatus rdf:type rdf:Property ;
    rdfs:label 'Item Status' ;
    rdfs:comment 'Current processing status of this shipment item line across the outbound logistics lifecycle, from warehouse picking through final delivery confirmation.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageCount rdf:type rdf:Property ;
    rdfs:label 'Package Count' ;
    rdfs:comment 'Number of individual packages or handling units comprising this shipment item line. Used for carrier manifest preparation, receiving verification, and proof-of-delivery confirmation.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promisedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Date' ;
    rdfs:comment 'Committed delivery date for this shipment item as confirmed to the customer via Available-to-Promise (ATP) or Capable-to-Promise (CTP) check in SAP S/4HANA. Used for on-time delivery KPI measurement.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'Original quantity requested on the sales order line for this material. Used to calculate fulfillment rate and identify short-shipments or over-shipments.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityShipped rdf:type rdf:Property ;
    rdfs:label 'Quantity Shipped' ;
    rdfs:comment 'Actual quantity of the material dispatched in this shipment item line. Compared against ordered quantity to identify partial shipments and calculate fulfillment rates.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesOrderLineNumber rdf:type rdf:Property ;
    rdfs:label 'Sales Order Line Number' ;
    rdfs:comment 'Line item number on the originating sales order corresponding to this shipment item. Supports item-level order-to-delivery reconciliation.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sales Order Number' ;
    rdfs:comment 'Reference to the originating sales order number from SAP S/4HANA SD. Enables traceability from physical delivery back to the customer order.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Free-text field capturing any special handling, stacking, orientation, or fragility instructions for this shipment item. Communicated to carriers and warehouse staff to prevent damage in transit.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRequirement rdf:type rdf:Property ;
    rdfs:label 'Temperature Requirement' ;
    rdfs:comment 'Temperature handling requirement for this shipment item during transport and storage. Relevant for temperature-sensitive materials such as chemicals, adhesives, or electronic components requiring controlled environments.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unNumber rdf:type rdf:Property ;
    rdfs:label 'Un Number' ;
    rdfs:comment 'United Nations four-digit identification number for hazardous substances and articles (e.g., UN1950 for aerosols). Mandatory on dangerous goods shipping documents and labels.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitPriceCurrency rdf:type rdf:Property ;
    rdfs:label 'Unit Price Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the unit price (e.g., USD, EUR). Supports multi-currency operations across global distribution networks.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for each approved freight carrier or logistics service provider (LSP) record in the master data.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:apiIntegrationType rdf:type rdf:Property ;
    rdfs:label 'Api Integration Type' ;
    rdfs:comment 'Type of digital integration method used to exchange shipment data with the carrier\'s systems. Determines TMS connectivity configuration and automation capability.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoLiabilityLimit rdf:type rdf:Property ;
    rdfs:label 'Cargo Liability Limit' ;
    rdfs:comment 'Maximum monetary value (in contract currency) the carrier is liable for in the event of cargo loss or damage, as specified in the insurance certificate and transportation contract.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimsRatio rdf:type rdf:Property ;
    rdfs:label 'Claims Ratio' ;
    rdfs:comment 'Percentage of shipments resulting in a freight damage or loss claim over the trailing 12-month period. Used in carrier performance evaluation and risk assessment.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Expiration date of the current transportation services contract. Triggers contract renewal workflows and restricts carrier use in TMS after expiry.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Effective start date of the current transportation services contract with the carrier. Used for contract validity checks during freight booking and audit.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countryOfRegistration rdf:type rdf:Property ;
    rdfs:label 'Country Of Registration' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where the carrier is legally registered and incorporated. Used for trade compliance, customs documentation, and regulatory verification.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerLicense rdf:type rdf:Property ;
    rdfs:label 'Customs Broker License' ;
    rdfs:comment 'License number issued by the relevant customs authority (e.g., CBP in the US) if the carrier also provides customs brokerage services. Supports trade compliance documentation for cross-border shipments.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Number' ;
    rdfs:comment 'USDOT-issued unique identifier required for commercial motor carriers operating in interstate commerce in the United States. Used for safety compliance verification and freight audit.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Dun & Bradstreet-assigned 9-digit Data Universal Numbering System (DUNS) number uniquely identifying the carrier\'s business entity. Used for supplier onboarding, credit checks, and SAP Ariba supplier management.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCapable rdf:type rdf:Property ;
    rdfs:label 'Edi Capable' ;
    rdfs:comment 'Indicates whether the carrier supports Electronic Data Interchange (EDI) for automated shipment tendering, status updates (214), and freight invoice exchange (210). Drives TMS integration configuration.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediQualifier rdf:type rdf:Property ;
    rdfs:label 'Edi Qualifier' ;
    rdfs:comment 'EDI interchange ID qualifier code used to identify the carrier in ANSI X12 EDI transactions (e.g., \'02\' for SCAC). Required for TMS EDI integration setup.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes or region descriptors representing the carrier\'s operational service territory. Used in TMS lane-to-carrier matching.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified' ;
    rdfs:comment 'Indicates whether the carrier is certified and authorized to transport hazardous materials (HAZMAT) in compliance with applicable regulations. Required for shipments of chemicals, batteries, and industrial components.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headquartersCountry rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the carrier\'s principal place of business. May differ from country of registration for multinational carriers.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataCode rdf:type rdf:Property ;
    rdfs:label 'Iata Code' ;
    rdfs:comment 'Two or three character IATA-assigned airline or air freight carrier code used for air freight bookings, airway bill generation, and global air cargo tracking.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Number' ;
    rdfs:comment 'Reference number of the carrier\'s current certificate of insurance (COI) covering cargo liability, general liability, and auto liability. Required for carrier approval and compliance audits.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiry Date' ;
    rdfs:comment 'Expiration date of the carrier\'s insurance certificate. Automated alerts are triggered before expiry to ensure continuous coverage and prevent use of uninsured carriers.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full legal registered business name of the freight carrier or logistics service provider as it appears on contracts, invoices, and regulatory filings.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityCurrency rdf:type rdf:Property ;
    rdfs:label 'Liability Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the cargo liability limit amount (e.g., USD, EUR, GBP). Supports multi-currency freight audit and claims processing.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mcNumber rdf:type rdf:Property ;
    rdfs:label 'Mc Number' ;
    rdfs:comment 'FMCSA-issued Motor Carrier (MC) operating authority number required for for-hire carriers transporting regulated commodities in interstate commerce. Validates carrier\'s legal right to operate.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTimeDeliveryRate rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate' ;
    rdfs:comment 'Percentage of shipments delivered on or before the committed delivery date over the trailing 12-month period. Key performance indicator (KPI) for carrier scorecard and performance tier assignment.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Carrier classification tier based on historical delivery performance, compliance scores, and strategic relationship value. Drives carrier selection priority in TMS route optimization and RFQ processes.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Business email address of the primary carrier account contact. Used for shipment notifications, rate negotiations, and operational communications.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary business contact at the carrier organization responsible for account management, escalations, and contract negotiations.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Business phone number of the primary carrier account contact. Used for urgent shipment escalations and operational coordination.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyRating rdf:type rdf:Property ;
    rdfs:label 'Safety Rating' ;
    rdfs:comment 'Official safety fitness rating assigned by the FMCSA (Federal Motor Carrier Safety Administration) for road carriers. Used in carrier qualification and compliance screening.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scacCode rdf:type rdf:Property ;
    rdfs:label 'Scac Code' ;
    rdfs:comment 'Unique 2–4 letter Standard Carrier Alpha Code (SCAC) assigned by the National Motor Freight Traffic Association (NMFTA) to identify the carrier in EDI transactions, freight bills, and TMS route planning.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceModes rdf:type rdf:Property ;
    rdfs:label 'Service Modes' ;
    rdfs:comment 'Comma-separated list of specific service offerings provided by the carrier (e.g., FTL, LTL, FCL, LCL, express, standard, white-glove, temperature-controlled). Supports TMS service-level matching.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingUrlTemplate rdf:type rdf:Property ;
    rdfs:label 'Tracking Url Template' ;
    rdfs:comment 'URL template with a placeholder (e.g., {tracking_number}) for the carrier\'s online shipment tracking portal. Used to generate direct tracking links in order management and customer service systems.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Operating or trade name (Doing Business As) of the carrier, which may differ from the legal name and is used in day-to-day communications and TMS displays.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'Primary transportation mode(s) offered by the carrier. Used in TMS route optimization and carrier selection for shipment planning across global distribution networks.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierServiceId rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Id' ;
    rdfs:comment 'Unique system-generated identifier for a carrier service offering within the Transportation Management System (TMS). Serves as the primary key for all carrier service records.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierService .

ind:applicableSurchargeTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Surcharge Types' ;
    rdfs:comment 'Comma-separated list of surcharge categories applicable to this carrier service (e.g., \'fuel_surcharge,residential_delivery,address_correction,peak_season,oversize,remote_area\'). Used in total freight cost estimation and rate shopping.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceIncluded rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Included' ;
    rdfs:comment 'Indicates whether customs clearance and brokerage services are included as part of this carrier service offering for cross-border shipments. Impacts landed cost calculation and trade compliance workflows.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cutoffTime rdf:type rdf:Property ;
    rdfs:label 'Cutoff Time' ;
    rdfs:comment 'Latest time of day (HH:MM in 24-hour format) by which a shipment must be tendered to the carrier at the origin facility to qualify for the stated transit time commitment. Used in order cut-off scheduling.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutoffTimezone rdf:type rdf:Property ;
    rdfs:label 'Cutoff Timezone' ;
    rdfs:comment 'IANA time zone identifier (e.g., \'America/Chicago\', \'Europe/Berlin\') applicable to the carrier cut-off time. Required for accurate scheduling across global distribution centers.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Days' ;
    rdfs:comment 'Comma-separated list of days of the week on which the carrier performs delivery under this service (e.g., \'MON,TUE,WED,THU,FRI,SAT\'). Used in delivery date commitment and customer promise calculations.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationRegion rdf:type rdf:Property ;
    rdfs:label 'Destination Region' ;
    rdfs:comment 'Geographic region or zone within the destination country covered by this service (e.g., state, province, postal zone, or carrier-defined zone code). Used for granular lane-level rate shopping and delivery planning.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimWeightFactor rdf:type rdf:Property ;
    rdfs:label 'Dim Weight Factor' ;
    rdfs:comment 'Carrier-specific dimensional weight divisor (DIM factor) used to calculate billable weight from volumetric dimensions (Length × Width × Height / DIM factor). Common values: 5000 (cm³/kg) for air, 4000 for express parcel. Used in freight cost estimation.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurchargeBasis rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Basis' ;
    rdfs:comment 'Method by which the fuel surcharge is calculated for this carrier service (percentage of base rate, flat fee per shipment, flat fee per kg, or linked to a published fuel index). Used in freight cost modeling and budgeting.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCapable rdf:type rdf:Property ;
    rdfs:label 'Hazmat Capable' ;
    rdfs:comment 'Indicates whether the carrier service is certified and authorized to transport hazardous materials (HAZMAT) in compliance with applicable regulations (IATA DGR, IMDG, DOT 49 CFR). Used in dangerous goods shipment routing.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermsSupported rdf:type rdf:Property ;
    rdfs:label 'Incoterms Supported' ;
    rdfs:comment 'Comma-separated list of Incoterms 2020 trade terms supported by this carrier service (e.g., \'EXW,FCA,CPT,CIP,DAP,DDP\'). Defines the risk and cost transfer points applicable to shipments using this service.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Liability Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the carrier liability limit amount (e.g., USD, EUR, GBP). Required for multi-currency global operations.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Limit Amount' ;
    rdfs:comment 'Maximum monetary value (in the liability currency) for which the carrier accepts liability for loss or damage per shipment under this service. Used in cargo insurance decisions and claims management.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxLengthCm rdf:type rdf:Property ;
    rdfs:label 'Max Length Cm' ;
    rdfs:comment 'Maximum allowable length in centimeters for a single piece or shipment under this carrier service. Used in dimensional compliance checks during TMS carrier selection.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimeDeliveryTargetPct rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Target Pct' ;
    rdfs:comment 'Contractually committed or carrier-published on-time delivery performance target percentage for this service (e.g., 98.5%). Used as the SLA benchmark for carrier performance scorecarding and KPI reporting.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the origin country covered by this carrier service lane. Defines the geographic scope of the service for TMS lane matching.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originRegion rdf:type rdf:Property ;
    rdfs:label 'Origin Region' ;
    rdfs:comment 'Geographic region or zone within the origin country covered by this service (e.g., state, province, postal zone, or carrier-defined zone code). Used for granular lane-level rate shopping.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupDays rdf:type rdf:Property ;
    rdfs:label 'Pickup Days' ;
    rdfs:comment 'Comma-separated list of days of the week on which the carrier offers pickup under this service (e.g., \'MON,TUE,WED,THU,FRI\'). Used in shipment scheduling and order fulfillment planning.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfDeliveryType rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Type' ;
    rdfs:comment 'Type of proof of delivery (POD) provided by the carrier upon successful delivery (electronic signature, paper POD, photo confirmation, or none). Used in dispute resolution and accounts receivable processes.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCode rdf:type rdf:Property ;
    rdfs:label 'Service Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the carrier service offering (e.g., UPS_GROUND, FEDEX_EXPRESS, DHL_LTL). Used in TMS rate shopping and carrier selection logic.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Speed and priority tier of the carrier service offering (e.g., standard, economy, express, priority, overnight, same-day). Used in SLA (Service Level Agreement) matching and order fulfillment planning.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceName rdf:type rdf:Property ;
    rdfs:label 'Service Name' ;
    rdfs:comment 'Full descriptive name of the carrier service offering as defined by the carrier (e.g., \'UPS Ground\', \'FedEx Priority Overnight\', \'DHL Express Worldwide\'). Used in user-facing TMS screens and reporting.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Classification of the transportation service mode. LTL (Less Than Truckload), FTL (Full Truckload), ocean FCL (Full Container Load), ocean LCL (Less than Container Load), air freight, intermodal, or parcel/express. Drives TMS carrier selection and rate shopping logic.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled' ;
    rdfs:comment 'Indicates whether this carrier service provides temperature-controlled (cold chain) transportation. Relevant for shipments of temperature-sensitive industrial components, chemicals, or materials.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trackingCapability rdf:type rdf:Property ;
    rdfs:label 'Tracking Capability' ;
    rdfs:comment 'Level of shipment tracking visibility provided by the carrier for this service (real-time GPS, milestone-based event updates, end-to-end tracking, or no tracking). Used in customer service and delivery performance monitoring.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitTimeBasis rdf:type rdf:Property ;
    rdfs:label 'Transit Time Basis' ;
    rdfs:comment 'Specifies whether the transit time commitment is measured in business days (excluding weekends and public holidays) or calendar days. Critical for accurate delivery date calculation.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitTimeDaysMax rdf:type rdf:Property ;
    rdfs:label 'Transit Time Days Max' ;
    rdfs:comment 'Maximum number of business or calendar days committed by the carrier for delivery from origin to destination under this service. Represents the upper bound of the transit time commitment window.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transitTimeDaysMin rdf:type rdf:Property ;
    rdfs:label 'Transit Time Days Min' ;
    rdfs:comment 'Minimum number of business or calendar days committed by the carrier for delivery from origin to destination under this service. Used in Available-to-Promise (ATP) and delivery date calculations.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routeId rdf:type rdf:Property ;
    rdfs:label 'Route Id' ;
    rdfs:comment 'Foreign key linking to logistics.route. Business justification: Freight orders execute along a defined transportation route/lane. Adding route_id FK normalizes the lane reference. origin_location_code and destination_location_code are retained as execution-specifi' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Route .

ind:transportPlanId rdf:type rdf:Property ;
    rdfs:label 'Transport Plan Id' ;
    rdfs:comment 'Foreign key linking to logistics.transport_plan. Business justification: Freight orders are generated from TMS transport plans. Adding transport_plan_id to freight_order establishes the plan→execution relationship, enabling plan fulfillment tracking and variance analysis b' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportPlan .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'Actual date and time at which the freight was delivered to the destination. Used to calculate on-time delivery (OTD) performance, transit time actuals, and SLA compliance against planned delivery windows.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualPickupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Pickup Timestamp' ;
    rdfs:comment 'Actual date and time at which the carrier collected the freight from the origin location. Used to calculate pickup punctuality, carrier on-time performance, and transit time actuals.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Unique identifier of the Bill of Lading (BOL) or Air Waybill (AWB) issued for the freight order. Serves as the primary transport document, title of goods, and carrier receipt. Required for customs, insurance, and payment terms.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierBookingReference rdf:type rdf:Property ;
    rdfs:label 'Carrier Booking Reference' ;
    rdfs:comment 'Carrier-assigned booking or reservation reference number confirming the carrier\'s acceptance of the freight order. Used for shipment tracking, carrier portal access, and proof of booking.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Legal or trade name of the transportation carrier assigned to execute the freight order. Used for carrier performance reporting, invoice reconciliation, and compliance documentation.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedFreightCost rdf:type rdf:Property ;
    rdfs:label 'Confirmed Freight Cost' ;
    rdfs:comment 'Carrier-confirmed or invoiced freight cost for the order after execution. Used for freight invoice reconciliation, actual vs. estimated variance analysis, and COGS allocation.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedFreightCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Freight Cost' ;
    rdfs:comment 'Pre-execution estimated freight cost for the order as calculated by the TMS rate engine or carrier quote. Used for freight budget planning, cost allocation, and purchase order approval workflows.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exportLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Export License Number' ;
    rdfs:comment 'Government-issued export license number authorizing the shipment of controlled goods across international borders. Required for dual-use goods, defense articles, and technology subject to export control regulations.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Indicates whether the freight order contains hazardous materials (Hazmat) requiring special handling, documentation, and regulatory compliance. Triggers ADR/IATA DGR/IMDG documentation requirements and carrier hazmat certification checks.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatUnNumber rdf:type rdf:Property ;
    rdfs:label 'Hazmat Un Number' ;
    rdfs:comment 'United Nations (UN) four-digit number identifying the specific hazardous substance or article in the freight order. Required on shipping documents, labels, and placards for regulatory compliance when hazmat_flag is true.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingMeters rdf:type rdf:Property ;
    rdfs:label 'Loading Meters' ;
    rdfs:comment 'Linear loading meters (LDM) required on a trailer or vehicle for the freight order. Standard European road freight capacity unit used for LTL/FTL determination, carrier rate calculation, and load planning.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone) at which the freight is scheduled to arrive at the destination. Supports time-window delivery commitments, receiving dock scheduling, and SLA compliance tracking.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedPickupDate rdf:type rdf:Property ;
    rdfs:label 'Planned Pickup Date' ;
    rdfs:comment 'Scheduled calendar date on which the carrier is expected to collect the freight from the origin location. Used for production scheduling, warehouse outbound planning, and carrier appointment management.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedPickupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Pickup Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone) at which the carrier is scheduled to collect the freight. Enables dock scheduling, labor planning, and carrier appointment window management at the origin facility.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:proNumber rdf:type rdf:Property ;
    rdfs:label 'Pro Number' ;
    rdfs:comment 'Carrier-assigned Progressive (PRO) number used to track LTL (Less-than-Truckload) shipments through the carrier\'s network. Standard identifier for freight tracking, claims, and invoice matching in North American road freight.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredTempMaxC rdf:type rdf:Property ;
    rdfs:label 'Required Temp Max C' ;
    rdfs:comment 'Maximum allowable temperature in degrees Celsius for temperature-controlled freight during transport. Used to specify cold chain upper limits for carrier compliance and monitoring alert thresholds.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredTempMinC rdf:type rdf:Property ;
    rdfs:label 'Required Temp Min C' ;
    rdfs:comment 'Minimum allowable temperature in degrees Celsius for temperature-controlled freight during transport. Used to specify cold chain requirements for carrier compliance and monitoring alert thresholds.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether the freight order requires temperature-controlled transport (cold chain or heated). Triggers selection of refrigerated or temperature-controlled vehicles and monitoring requirements.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryCarrierId rdf:type rdf:Property ;
    rdfs:label 'Primary Carrier Id' ;
    rdfs:comment 'FK to logistics.carrier' ;
    rdfs:domain ind:TransportPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:customsRequired rdf:type rdf:Property ;
    rdfs:label 'Customs Required' ;
    rdfs:comment 'Indicates whether customs clearance documentation and procedures are required for freight movements in this transport plan. True for cross-border international shipments.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drpRunReference rdf:type rdf:Property ;
    rdfs:label 'Drp Run Reference' ;
    rdfs:comment 'Reference identifier of the MRP II Distribution Requirements Planning (DRP) run that generated the shipment demands consolidated into this transport plan. Provides traceability from demand signal to transport execution.' ;
    rdfs:domain ind:TransportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightBudgetCode rdf:type rdf:Property ;
    rdfs:label 'Freight Budget Code' ;
    rdfs:comment 'Reference code linking this transport plan to the corresponding freight budget line item in the financial planning system. Enables freight spend tracking against approved OPEX budgets.' ;
    rdfs:domain ind:TransportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatIncluded rdf:type rdf:Property ;
    rdfs:label 'Hazmat Included' ;
    rdfs:comment 'Indicates whether any freight loads in this transport plan contain hazardous materials (HAZMAT) requiring special handling, documentation, and regulatory compliance.' ;
    rdfs:domain ind:TransportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optimizationObjective rdf:type rdf:Property ;
    rdfs:label 'Optimization Objective' ;
    rdfs:comment 'Primary optimization criterion used by the TMS route optimization engine when generating the transport plan. Drives carrier selection, load consolidation, and route assignment decisions.' ;
    rdfs:domain ind:TransportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCarrierCount rdf:type rdf:Property ;
    rdfs:label 'Planned Carrier Count' ;
    rdfs:comment 'Number of distinct carriers (logistics service providers) included in the planned carrier mix for this transport plan. Supports carrier diversification analysis and risk management.' ;
    rdfs:domain ind:TransportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedCo2EmissionsKg rdf:type rdf:Property ;
    rdfs:label 'Planned Co2 Emissions Kg' ;
    rdfs:comment 'Estimated CO2 equivalent emissions in kilograms for all freight movements in this transport plan, calculated by the TMS optimization engine. Supports sustainability reporting and carbon footprint management.' ;
    rdfs:domain ind:TransportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Date' ;
    rdfs:comment 'Planned date on which freight loads in this transport plan are scheduled to depart from the origin location. Used for production scheduling alignment and Available-to-Promise (ATP) calculations.' ;
    rdfs:domain ind:TransportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedFreightSpend rdf:type rdf:Property ;
    rdfs:label 'Planned Freight Spend' ;
    rdfs:comment 'Total planned freight cost in the plan currency for all loads and carriers in this transport plan. Used for freight budget management, cost-to-serve analysis, and OPEX reporting.' ;
    rdfs:domain ind:TransportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedLoadCount rdf:type rdf:Property ;
    rdfs:label 'Planned Load Count' ;
    rdfs:comment 'Total number of freight loads (shipment units, trucks, containers, or pallets) consolidated and planned within this transport plan. Key metric for capacity planning and freight budget management.' ;
    rdfs:domain ind:TransportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedShipmentCount rdf:type rdf:Property ;
    rdfs:label 'Planned Shipment Count' ;
    rdfs:comment 'Total number of individual shipment demands (orders, deliveries, or transfer orders) consolidated into this transport plan. Distinct from load count as multiple shipments may be consolidated into a single load.' ;
    rdfs:domain ind:TransportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Planned Volume M3' ;
    rdfs:comment 'Total planned freight volume in cubic meters for all loads in this transport plan. Used for container/truck utilization optimization and freight cost estimation.' ;
    rdfs:domain ind:TransportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Planned Weight Kg' ;
    rdfs:comment 'Total planned gross weight in kilograms of all freight included in this transport plan. Used for carrier capacity validation, freight cost calculation, and load optimization.' ;
    rdfs:domain ind:TransportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningHorizonEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon End Date' ;
    rdfs:comment 'End date of the planning window covered by this transport plan. Defines the latest shipment delivery date included in the plan.' ;
    rdfs:domain ind:TransportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningHorizonStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Start Date' ;
    rdfs:comment 'Start date of the planning window covered by this transport plan. Defines the earliest shipment pickup or departure date included in the plan, aligned with MRP II Distribution Requirements Planning (DRP) cycles.' ;
    rdfs:domain ind:TransportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningOrganization rdf:type rdf:Property ;
    rdfs:label 'Planning Organization' ;
    rdfs:comment 'Organizational unit (e.g., logistics planning center, distribution hub, or plant code) responsible for creating and managing this transport plan. Supports multi-entity global operations.' ;
    rdfs:domain ind:TransportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmsPlanReference rdf:type rdf:Property ;
    rdfs:label 'Tms Plan Reference' ;
    rdfs:comment 'External reference identifier assigned by the source Transportation Management System (TMS) to this transport plan. Used for cross-system reconciliation between the TMS and the lakehouse Silver Layer.' ;
    rdfs:domain ind:TransportPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLogisticsLocationId rdf:type rdf:Property ;
    rdfs:label 'Origin Logistics Location Id' ;
    rdfs:comment 'Foreign key linking to logistics.logistics_location. Business justification: Route origin is a physical logistics network location. Adding origin_logistics_location_id FK normalizes the origin reference to the logistics_location master. origin_location_code is retained as a co' ;
    rdfs:domain ind:Route ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:borderCrossingCount rdf:type rdf:Property ;
    rdfs:label 'Border Crossing Count' ;
    rdfs:comment 'Number of international border crossings on this route. Used to assess customs complexity, transit documentation requirements, and potential delay risk.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:co2EmissionFactorKgPerKm rdf:type rdf:Property ;
    rdfs:label 'Co2 Emission Factor Kg Per Km' ;
    rdfs:comment 'Carbon dioxide (CO2) emission factor for this route expressed in kilograms of CO2 per kilometer, based on transport mode and carrier fleet data. Used for environmental reporting, carbon footprint calculation, and ISO 14001 / ESG compliance.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:departureDays rdf:type rdf:Property ;
    rdfs:label 'Departure Days' ;
    rdfs:comment 'Comma-separated list of days of the week on which departures are scheduled on this route (e.g., \'MON,WED,FRI\'). Used for shipment scheduling and Available to Promise (ATP) calculations.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceKm rdf:type rdf:Property ;
    rdfs:label 'Distance Km' ;
    rdfs:comment 'Total distance of the route measured in kilometers. Used for freight cost calculation, carbon emission estimation, and TMS route optimization.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceMiles rdf:type rdf:Property ;
    rdfs:label 'Distance Miles' ;
    rdfs:comment 'Total distance of the route measured in miles. Provided for regions using imperial measurement (e.g., USA, UK) and for carrier rate agreements denominated in miles.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Operational frequency at which shipments are dispatched on this route. Used for production planning, inventory replenishment scheduling, and carrier capacity booking.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatPermitted rdf:type rdf:Property ;
    rdfs:label 'Hazmat Permitted' ;
    rdfs:comment 'Indicates whether the transport of hazardous materials (HAZMAT) is permitted on this route. Governs compliance with dangerous goods regulations and carrier restrictions.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumTransitDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Transit Days' ;
    rdfs:comment 'Maximum number of calendar days allowed for transit on this route before a shipment is considered delayed. Used for SLA (Service Level Agreement) breach monitoring and carrier performance management.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumTransitDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Transit Days' ;
    rdfs:comment 'Minimum number of calendar days achievable for transit on this route under optimal conditions. Used for express service planning and Available to Promise (ATP) calculations.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originLocationCode rdf:type rdf:Property ;
    rdfs:label 'Origin Location Code' ;
    rdfs:comment 'Standardized code identifying the departure point of the route (e.g., plant code, warehouse code, port code, or UN/LOCODE). Represents where freight originates.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Carrier Code' ;
    rdfs:comment 'Code identifying the primary/preferred carrier assigned to this route based on carrier selection criteria such as cost, reliability, and service level. Used by TMS for automatic carrier assignment.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardFreightCost rdf:type rdf:Property ;
    rdfs:label 'Standard Freight Cost' ;
    rdfs:comment 'Standard or benchmark freight cost for a full shipment on this route, expressed in the route\'s base currency. Used for freight budget planning, cost allocation, and carrier rate benchmarking.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardTransitDays rdf:type rdf:Property ;
    rdfs:label 'Standard Transit Days' ;
    rdfs:comment 'Standard number of calendar days expected for freight to travel from origin to destination on this route under normal operating conditions. Used for delivery date calculation and SLA (Service Level Agreement) commitments.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tmsRouteCode rdf:type rdf:Property ;
    rdfs:label 'Tms Route Code' ;
    rdfs:comment 'External route identifier as recorded in the source Transportation Management System (TMS), used for cross-system reconciliation and data lineage tracing.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tollApplicable rdf:type rdf:Property ;
    rdfs:label 'Toll Applicable' ;
    rdfs:comment 'Indicates whether road tolls, port fees, canal dues, or other infrastructure usage charges apply on this route. Used for accurate freight cost estimation and carrier invoice validation.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transitHubCode rdf:type rdf:Property ;
    rdfs:label 'Transit Hub Code' ;
    rdfs:comment 'Code identifying the intermediate consolidation or transshipment hub used on hub-and-spoke or relay routes. Applicable when route_type is \'hub_and_spoke\' or \'relay\'.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeStopId rdf:type rdf:Property ;
    rdfs:label 'Route Stop Id' ;
    rdfs:comment 'Unique system-generated identifier for each individual stop or waypoint within a transportation route. Serves as the primary key for the route_stop entity.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Actual date and time the carrier arrived at this stop, captured via TMS event, driver mobile app, or geofence trigger. Used for on-time arrival performance tracking and carrier SLA measurement.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Actual date and time the carrier departed from this stop. Used to calculate actual dwell time, identify detention events, and measure stop-level execution performance.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDwellTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Dwell Time Minutes' ;
    rdfs:comment 'Actual duration in minutes the carrier remained at this stop, derived from actual arrival and departure timestamps. Used to identify detention, inefficiencies, and carrier performance deviations.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualLoadQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Load Quantity' ;
    rdfs:comment 'Actual quantity of goods loaded onto the vehicle at this stop, as confirmed by the driver, warehouse staff, or WMS. Compared against planned load quantity to identify discrepancies.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualUnloadQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Unload Quantity' ;
    rdfs:comment 'Actual quantity of goods unloaded from the vehicle at this stop, as confirmed by the receiver or WMS. Used for proof-of-delivery validation and discrepancy management.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appointmentReference rdf:type rdf:Property ;
    rdfs:label 'Appointment Reference' ;
    rdfs:comment 'Reference number for the dock or facility appointment scheduled for this stop. Links the route stop to the appointment management system for dock scheduling and carrier check-in.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrivalVarianceMinutes rdf:type rdf:Property ;
    rdfs:label 'Arrival Variance Minutes' ;
    rdfs:comment 'Difference in minutes between actual and planned arrival timestamps. Positive values indicate late arrival; negative values indicate early arrival. Key metric for on-time delivery (OTD) performance reporting.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customsClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Required' ;
    rdfs:comment 'Indicates whether customs clearance activities are required at this stop. True for border crossings, customs offices, or bonded warehouse stops. Triggers customs documentation workflow.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dockDoorNumber rdf:type rdf:Property ;
    rdfs:label 'Dock Door Number' ;
    rdfs:comment 'Identifier of the specific dock door or bay assigned to this stop at the facility. Used for dock scheduling, yard management, and operational coordination between TMS and WMS.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geofenceArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Geofence Arrival Timestamp' ;
    rdfs:comment 'Timestamp when the vehicle entered the geofenced boundary of the stop location, as detected by the telematics or IIoT platform. Provides an objective, system-generated arrival signal independent of driver input.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:geofenceDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Geofence Departure Timestamp' ;
    rdfs:comment 'Timestamp when the vehicle exited the geofenced boundary of the stop location, as detected by the telematics or IIoT platform. Used to validate actual dwell time and departure confirmation.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isFirstStop rdf:type rdf:Property ;
    rdfs:label 'Is First Stop' ;
    rdfs:comment 'Indicates whether this stop is the origin or first stop of the route. Used to distinguish route origin from intermediate stops in multi-leg route analysis and reporting.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLastStop rdf:type rdf:Property ;
    rdfs:label 'Is Last Stop' ;
    rdfs:comment 'Indicates whether this stop is the final destination or last stop of the route. Used to identify route completion events and trigger final delivery confirmation workflows.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTimeWindowMet rdf:type rdf:Property ;
    rdfs:label 'Is Time Window Met' ;
    rdfs:comment 'Indicates whether the carrier arrived within the agreed delivery or pickup time window at this stop. True if actual arrival falls within the time window; False if outside. Used for SLA compliance reporting.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Arrival Timestamp' ;
    rdfs:comment 'Scheduled date and time the carrier is expected to arrive at this stop, as defined in the Transportation Management System (TMS) route plan. Baseline for on-time performance measurement.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Timestamp' ;
    rdfs:comment 'Scheduled date and time the carrier is expected to depart from this stop, as defined in the TMS route plan. Used to calculate planned dwell time and downstream stop arrival windows.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedDwellTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Planned Dwell Time Minutes' ;
    rdfs:comment 'Planned duration in minutes the carrier is expected to remain at this stop for loading, unloading, or other activities. Used for route scheduling and carrier appointment management.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedLoadQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Load Quantity' ;
    rdfs:comment 'Planned quantity of goods to be loaded onto the vehicle at this stop, expressed in the unit of measure defined at the shipment level. Applicable for pickup and cross-dock stop types.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedUnloadQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Unload Quantity' ;
    rdfs:comment 'Planned quantity of goods to be unloaded from the vehicle at this stop. Applicable for delivery and cross-dock stop types. Used for dock resource planning and shipment verification.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proofOfDeliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Number' ;
    rdfs:comment 'Reference number for the proof of delivery document captured at this stop upon successful goods handover. Used for invoice verification, dispute resolution, and customer confirmation.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverName rdf:type rdf:Property ;
    rdfs:label 'Receiver Name' ;
    rdfs:comment 'Name of the individual or entity who received or handed over goods at this stop, as recorded on the proof of delivery. Used for delivery confirmation and dispute resolution.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingCode rdf:type rdf:Property ;
    rdfs:label 'Special Handling Code' ;
    rdfs:comment 'Code indicating any special handling requirements applicable to goods at this stop, such as hazardous materials (HAZMAT), temperature-controlled, or high-value cargo. Drives compliance and operational procedures.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Stop Distance Km' ;
    rdfs:comment 'Distance in kilometers from the previous stop (or route origin for the first stop) to this stop. Used for freight cost allocation, carrier rate calculation, and route optimization analysis.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stopExceptionCode rdf:type rdf:Property ;
    rdfs:label 'Stop Exception Code' ;
    rdfs:comment 'Standardized code identifying any exception or deviation that occurred at this stop. Used for root cause analysis, carrier performance management, and CAPA (Corrective and Preventive Action) processes.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopExceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Stop Exception Notes' ;
    rdfs:comment 'Free-text description providing additional context for any exception or deviation recorded at this stop. Supplements the exception code with operational details for investigation and resolution.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Stop Sequence Number' ;
    rdfs:comment 'Ordinal position of this stop within the overall route, starting from 1. Determines the order in which the carrier visits locations along the route. Used for milk-run and multi-leg route planning.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stopStatus rdf:type rdf:Property ;
    rdfs:label 'Stop Status' ;
    rdfs:comment 'Current operational status of the stop within the route execution lifecycle. Tracks progression from planned through arrival, completion, or exception states such as delay, skip, or cancellation.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopType rdf:type rdf:Property ;
    rdfs:label 'Stop Type' ;
    rdfs:comment 'Classification of the purpose of this stop within the route. Determines operational activities performed at the stop, such as loading (pickup), unloading (delivery), cross-docking, customs clearance, or driver rest.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeWindowEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Time Window End Timestamp' ;
    rdfs:comment 'Latest acceptable arrival time at this stop as agreed with the customer or facility. Defines the closing of the delivery or pickup appointment window. Arrivals after this time are flagged as SLA breaches.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:timeWindowStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Time Window Start Timestamp' ;
    rdfs:comment 'Earliest acceptable arrival time at this stop as agreed with the customer or facility. Defines the opening of the delivery or pickup appointment window for dock scheduling.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualShipDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ship Date' ;
    rdfs:comment 'The actual date on which goods were physically dispatched from the shipping point. Captured at goods issue posting and used for carrier performance and lead time analysis.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Terms defining who bears the freight cost for this delivery — whether the shipper prepays, the consignee pays on collection, or a third party is billed. Impacts accounts payable and customer invoicing.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazmat Indicator' ;
    rdfs:comment 'Flag indicating whether the delivery contains hazardous materials subject to special handling, labeling, and transport regulations. Triggers hazmat documentation requirements and carrier restrictions.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overShipQuantity rdf:type rdf:Property ;
    rdfs:label 'Over Ship Quantity' ;
    rdfs:comment 'Quantity of goods shipped in excess of the ordered quantity. Requires customer approval or return authorization and may trigger credit memo processing.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallGoodsMovementStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Goods Movement Status' ;
    rdfs:comment 'Aggregate goods movement status across all line items in the delivery, indicating whether goods issue has been fully posted, partially posted, or not yet started. Derived from SAP SD header-level goods movement status.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingListNumber rdf:type rdf:Property ;
    rdfs:label 'Packing List Number' ;
    rdfs:comment 'Reference number of the packing list document associated with this delivery, detailing the contents, quantities, and packaging of shipped goods. Required for customs clearance and receiving verification.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingStatus rdf:type rdf:Property ;
    rdfs:label 'Packing Status' ;
    rdfs:comment 'Status of the packing process for this delivery, indicating whether goods have been fully, partially, or not yet packed into handling units or shipping containers.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickingStatus rdf:type rdf:Property ;
    rdfs:label 'Picking Status' ;
    rdfs:comment 'Status of the warehouse picking process for this delivery, indicating whether warehouse staff have fully, partially, or not yet picked the goods from storage locations.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedShipDate rdf:type rdf:Property ;
    rdfs:label 'Planned Ship Date' ;
    rdfs:comment 'The scheduled date on which goods are planned to be dispatched from the shipping point. Used for transportation planning, carrier booking, and warehouse workload scheduling.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:podDate rdf:type rdf:Property ;
    rdfs:label 'Pod Date' ;
    rdfs:comment 'The date on which proof of delivery was confirmed by the recipient or carrier, indicating that goods were received at the destination. Triggers billing and revenue recognition in POD-based billing scenarios.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:podReference rdf:type rdf:Property ;
    rdfs:label 'Pod Reference' ;
    rdfs:comment 'Reference number or identifier for the proof-of-delivery document, such as a carrier-issued POD number, electronic signature reference, or consignment note number. Used for dispute resolution and audit.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipFromCountryCode rdf:type rdf:Property ;
    rdfs:label 'Ship From Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the origin location from which goods are shipped. Required for customs declarations, trade compliance, and export control screening.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToCountryCode rdf:type rdf:Property ;
    rdfs:label 'Ship To Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the destination country to which goods are being delivered. Used for import duty calculation, trade compliance, and export control classification.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortShipQuantity rdf:type rdf:Property ;
    rdfs:label 'Short Ship Quantity' ;
    rdfs:comment 'Quantity of goods that was ordered but not shipped due to stock shortages, picking errors, or capacity constraints. A non-zero value triggers back-order processing and customer notification.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDeliveryQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Delivery Quantity' ;
    rdfs:comment 'Total quantity of all line items included in this delivery document, expressed in the base unit of measure. Used for fulfillment rate calculation and short-ship/over-ship variance analysis.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGrossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of all items in the delivery including packaging, expressed in kilograms. Used for freight cost calculation, carrier capacity planning, and customs declarations.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Net Weight Kg' ;
    rdfs:comment 'Total net weight of all items in the delivery excluding packaging, expressed in kilograms. Used for customs valuation, product compliance declarations, and REACH/RoHS reporting.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Volume M3' ;
    rdfs:comment 'Total volumetric measurement of all items in the delivery expressed in cubic meters. Used for truck load planning, container utilization, and freight cost calculation based on dimensional weight.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Carrier-issued tracking number (e.g., waybill number, bill of lading number, or parcel tracking ID) used to monitor shipment progress through the carrier\'s tracking system.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingLogisticsLocationId rdf:type rdf:Property ;
    rdfs:label 'Receiving Logistics Location Id' ;
    rdfs:comment 'Foreign key linking to logistics.logistics_location. Business justification: Inbound deliveries are received at a specific logistics location (plant, warehouse, distribution center). Adding receiving_logistics_location_id FK links the inbound delivery to the logistics_location' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:deliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Number' ;
    rdfs:comment 'Business-facing document number assigned to the inbound delivery, sourced from SAP S/4HANA MM (transaction VL32N / MIGO) or Infor WMS. Used for cross-system reconciliation and supplier communication.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryType rdf:type rdf:Property ;
    rdfs:label 'Delivery Type' ;
    rdfs:comment 'Classification of the inbound delivery by its business scenario. Determines processing rules, inventory posting logic, and financial accounting treatment in SAP S/4HANA.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryValue rdf:type rdf:Property ;
    rdfs:label 'Delivery Value' ;
    rdfs:comment 'Total monetary value of the received goods (received quantity × net price) in the transaction currency. Used for GRN valuation, inventory accounting, and accounts payable accrual.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Flag' ;
    rdfs:comment 'Indicates whether a quantity, quality, or documentation discrepancy was identified during the receiving process. Triggers Non-Conformance Report (NCR) creation and supplier corrective action workflows.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyType rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Type' ;
    rdfs:comment 'Classification of the discrepancy identified during receiving. Drives routing to the appropriate resolution workflow (e.g., supplier return, NCR, CAPA) and supports supplier performance analytics.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'Planned date on which the supplier is expected to deliver the goods to the receiving facility, as confirmed on the Purchase Order. Used for on-time delivery performance measurement and production scheduling.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grnPostingDate rdf:type rdf:Property ;
    rdfs:label 'Grn Posting Date' ;
    rdfs:comment 'Accounting date on which the Goods Receipt Note (GRN) was posted in SAP S/4HANA MM, triggering inventory valuation and accounts payable accrual. Critical for period-end financial close.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Indicates whether the received material requires a quality inspection lot to be created in SAP S/4HANA QM before the goods can be released to unrestricted stock. Driven by material master QM settings and AQL sampling plans.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Current status of the quality inspection lot associated with this inbound delivery in SAP S/4HANA QM. Determines whether received stock can be transferred to unrestricted inventory or must be quarantined.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumberRange rdf:type rdf:Property ;
    rdfs:label 'Serial Number Range' ;
    rdfs:comment 'Range or list of serial numbers for serialized components received in this delivery (e.g., \'SN001-SN050\'). Supports asset lifecycle tracking in Maximo EAM and warranty management.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierDeliveryNote rdf:type rdf:Property ;
    rdfs:label 'Supplier Delivery Note' ;
    rdfs:comment 'Supplier-provided delivery note or packing slip reference number accompanying the physical shipment. Used for supplier reconciliation, discrepancy resolution, and audit trail.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingEventId rdf:type rdf:Property ;
    rdfs:label 'Tracking Event Id' ;
    rdfs:comment 'Unique system-generated identifier for each shipment tracking event record in the logistics domain.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierEventCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Event Code' ;
    rdfs:comment 'The carrier\'s proprietary status or event code transmitted via EDI or API feed (e.g., X1, D1, OFD). Used for carrier-specific event interpretation and reconciliation with TMS records.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierEventDescription rdf:type rdf:Property ;
    rdfs:label 'Carrier Event Description' ;
    rdfs:comment 'Human-readable description of the carrier event code as provided by the carrier\'s EDI or API feed. Supplements the standardized event type with carrier-specific detail.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Reference Number' ;
    rdfs:comment 'Official customs declaration or entry reference number assigned by the customs authority for cross-border shipments. Required for trade compliance documentation and regulatory audit trails.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Status' ;
    rdfs:comment 'Current customs clearance status of the shipment at the time of this event. Critical for cross-border trade compliance, import/export documentation management, and REACH/RoHS regulatory adherence.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dwellTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Dwell Time Minutes' ;
    rdfs:comment 'Duration in minutes the shipment remained stationary at the event location before the next movement. Used for terminal efficiency analysis, detention charge management, and bottleneck identification.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Date' ;
    rdfs:comment 'Carrier-provided or TMS-calculated estimated delivery date updated at the time of this tracking event. Used for OTIF measurement, customer promise management, and ATP/CTP calculations.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventSource rdf:type rdf:Property ;
    rdfs:label 'Event Source' ;
    rdfs:comment 'Identifies the originating system or feed that generated the tracking event, such as carrier EDI, TMS, GPS telematics, IIoT sensor, or manual entry. Supports data lineage and source reliability analysis.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'The exact date and time at which the tracking event occurred, as reported by the carrier, IIoT telematics, GPS device, or TMS integration. Used for transit time analysis and OTIF measurement.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventTimezone rdf:type rdf:Property ;
    rdfs:label 'Event Timezone' ;
    rdfs:comment 'IANA timezone identifier for the location where the event occurred (e.g., America/Chicago, Europe/Berlin). Enables accurate local-time reporting across global distribution networks.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Categorizes the nature of the shipment milestone or status change event, such as departed, in-transit, customs-cleared, out-for-delivery, delivered, or exception. Drives OTIF performance measurement and shipment visibility dashboards.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Standardized code classifying the type of shipment exception when is_exception is true. Used for root cause analysis, CAPA processes, and carrier performance management.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Free-text description of the shipment exception providing additional context beyond the exception code, such as specific damage details, delay reason, or customs hold explanation.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isException rdf:type rdf:Property ;
    rdfs:label 'Is Exception' ;
    rdfs:comment 'Boolean flag indicating whether this tracking event represents a shipment exception (e.g., delay, damage, lost, refused delivery). Triggers exception management workflows and customer notifications.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rawPayloadReference rdf:type rdf:Property ;
    rdfs:label 'Raw Payload Reference' ;
    rdfs:comment 'Reference key or identifier pointing to the original raw EDI, API, or telematics message stored in the Bronze layer. Supports data lineage, reprocessing, and audit trail requirements.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedBy rdf:type rdf:Property ;
    rdfs:label 'Signed By' ;
    rdfs:comment 'Name or identifier of the person who signed for the delivery at the destination, as captured in the proof-of-delivery (POD) record. Used for delivery confirmation and dispute resolution.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureC rdf:type rdf:Property ;
    rdfs:label 'Temperature C' ;
    rdfs:comment 'Ambient or cargo temperature in degrees Celsius recorded by IIoT telematics or cold-chain sensors at the time of the event. Used for cold-chain compliance monitoring and quality assurance of temperature-sensitive goods.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleCode rdf:type rdf:Property ;
    rdfs:label 'Vehicle Code' ;
    rdfs:comment 'Identifier of the vehicle, vessel, aircraft, or rail car transporting the shipment at the time of this event (e.g., truck license plate, IMO vessel number, flight number). Supports asset tracking and incident investigation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightRateId rdf:type rdf:Property ;
    rdfs:label 'Freight Rate Id' ;
    rdfs:comment 'Unique system-generated identifier for each freight rate record in the Transportation Management System (TMS). Serves as the primary key for all freight rate lookups, cost estimation, and freight audit processes.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commodityType rdf:type rdf:Property ;
    rdfs:label 'Commodity Type' ;
    rdfs:comment 'Classification of the goods or commodity type to which this rate applies. Freight rates often vary by commodity due to density, handling requirements, or hazardous material classification. Aligns with NMFC commodity codes for road freight or HS codes for international shipments.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelIndexReference rdf:type rdf:Property ;
    rdfs:label 'Fuel Index Reference' ;
    rdfs:comment 'Name or identifier of the fuel price index used to calculate or adjust the fuel surcharge component of this rate (e.g., DOE Weekly Retail On-Highway Diesel, IATA Jet Fuel Monitor, Platts Bunker Index). Ensures transparent and auditable fuel cost pass-through in carrier contracts.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargePct rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Pct' ;
    rdfs:comment 'Fuel surcharge rate expressed as a percentage of the base freight rate. Applied dynamically based on fuel index benchmarks (e.g., DOE diesel index). Used in TMS freight cost estimation when rate_type is base_rate to calculate the total all-in freight cost.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatEligible rdf:type rdf:Property ;
    rdfs:label 'Hazmat Eligible' ;
    rdfs:comment 'Indicates whether this freight rate applies to shipments containing hazardous materials (Hazmat). Hazmat shipments require special handling, documentation, and regulatory compliance under DOT, IATA DGR, and IMDG regulations. Used in TMS carrier selection and compliance screening.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermCode rdf:type rdf:Property ;
    rdfs:label 'Incoterm Code' ;
    rdfs:comment 'International Commercial Terms (Incoterms) code defining the division of costs, risks, and responsibilities between buyer and seller for the shipment covered by this rate. Determines which party bears the freight cost and at what point risk transfers. Critical for customs/trade compliance documentation.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumCharge rdf:type rdf:Property ;
    rdfs:label 'Maximum Charge' ;
    rdfs:comment 'The maximum freight charge cap applicable for a shipment on this lane. Protects shippers from excessive charges on large shipments. Used in TMS freight cost estimation to apply ceiling pricing when calculated charges exceed this threshold.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCharge rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge' ;
    rdfs:comment 'The minimum freight charge applicable for a shipment on this lane regardless of weight, volume, or quantity. Ensures carrier cost recovery for small shipments. Used in TMS freight cost estimation to apply floor pricing when calculated charges fall below this threshold.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiatedBy rdf:type rdf:Property ;
    rdfs:label 'Negotiated By' ;
    rdfs:comment 'Name or identifier of the procurement/logistics team member or department responsible for negotiating this freight rate with the carrier. Used for accountability tracking in carrier management and contract lifecycle management.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Amount' ;
    rdfs:comment 'The contracted or spot freight rate value expressed per the defined rate basis (e.g., rate per kg, per pallet, per container, per mile). Core financial field used in TMS freight cost estimation, carrier invoice validation, and freight audit. Stored with 4 decimal precision to support per-unit micro-rates.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateBasis rdf:type rdf:Property ;
    rdfs:label 'Rate Basis' ;
    rdfs:comment 'The unit of measure upon which the freight rate is applied. Determines how the rate is multiplied against shipment characteristics to calculate total freight cost. Critical for TMS freight cost estimation and carrier invoice validation during freight audit.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateNumber rdf:type rdf:Property ;
    rdfs:label 'Rate Number' ;
    rdfs:comment 'Business-facing alphanumeric identifier for the freight rate record, used in TMS freight cost estimation, freight audit, and carrier negotiations. Typically references the rate tariff or contract schedule number.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateSource rdf:type rdf:Property ;
    rdfs:label 'Rate Source' ;
    rdfs:comment 'Indicates the origin or basis of the freight rate. Contract rates are pre-negotiated with carriers; spot rates are obtained for individual shipments; benchmark rates are used for market comparison; tariff rates are published carrier schedules. Drives rate selection logic in TMS.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of the freight rate component. Base rate is the primary transportation charge; fuel surcharge adjusts for fuel cost fluctuations; accessorial covers special handling services; other types cover specific operational scenarios. Used in TMS freight cost estimation and freight audit.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffNumber rdf:type rdf:Property ;
    rdfs:label 'Tariff Number' ;
    rdfs:comment 'Published carrier tariff or rate schedule number from which this rate is derived. Used for tariff-based rate validation during freight audit and regulatory compliance with published rate requirements (e.g., FMC tariff filing for ocean freight).' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitDays rdf:type rdf:Property ;
    rdfs:label 'Transit Days' ;
    rdfs:comment 'Contracted or standard number of calendar or business days for transit from origin to destination under this rate and service level. Used in TMS delivery date calculation, SLA compliance monitoring, and customer order promising (Available to Promise / ATP).' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightBreakMaxKg rdf:type rdf:Property ;
    rdfs:label 'Weight Break Max Kg' ;
    rdfs:comment 'Maximum shipment weight in kilograms for which this rate applies. Defines the upper bound of the weight break tier in tiered rate structures. Used in TMS rate selection logic to match shipment weight to the correct rate tier.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightBreakMinKg rdf:type rdf:Property ;
    rdfs:label 'Weight Break Min Kg' ;
    rdfs:comment 'Minimum shipment weight in kilograms for which this rate applies. Defines the lower bound of the weight break tier in tiered rate structures. Used in TMS rate selection logic to match shipment weight to the correct rate tier.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Freight Invoice Id' ;
    rdfs:comment 'Unique surrogate identifier for the freight invoice record in the lakehouse silver layer. Serves as the primary key for all downstream joins and lineage tracking.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessorialAmount rdf:type rdf:Property ;
    rdfs:label 'Accessorial Amount' ;
    rdfs:comment 'Total accessorial charges billed on this invoice, including but not limited to liftgate, residential delivery, inside delivery, detention, redelivery, and hazmat handling fees. Subject to contracted accessorial rate validation.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'Amount approved for payment after freight audit, dispute resolution, and any adjustments. May differ from invoiced_amount if overcharges, duplicate charges, or unauthorized accessorials are identified and disputed.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditExceptionCode rdf:type rdf:Property ;
    rdfs:label 'Audit Exception Code' ;
    rdfs:comment 'Standardized exception code identifying the reason for a freight audit failure or discrepancy (e.g., RATE_MISMATCH, DUPLICATE_INVOICE, UNAUTHORIZED_ACCESSORIAL, WEIGHT_DISCREPANCY). Used for dispute management and carrier performance tracking.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Status of the freight audit process for this invoice, indicating whether the invoice has been validated against contracted rates, shipment data, and accessorial entitlements. Distinct from payment status.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseFreightAmount rdf:type rdf:Property ;
    rdfs:label 'Base Freight Amount' ;
    rdfs:comment 'Line-level base freight charge billed by the carrier, excluding surcharges and accessorials. Derived from contracted rate applied to shipment weight, volume, or distance. Used for rate audit and cost benchmarking.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the transportation service period covered by this invoice. Used in conjunction with billing_period_start_date to define the scope of services billed.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the transportation service period covered by this invoice. Relevant for consolidated or periodic billing arrangements with carriers.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:carrierReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Reference Number' ;
    rdfs:comment 'Carrier\'s internal reference or pro number associated with the shipment or freight movement being billed. Used to cross-reference the invoice against the carrier\'s own records and the TMS shipment record.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierTaxNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Tax Number' ;
    rdfs:comment 'Tax identification number (e.g., EIN, VAT registration number) of the carrier. Required for tax compliance, 1099 reporting, and accounts payable vendor master validation.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Contractual discount or rebate applied by the carrier on this invoice (e.g., volume discount, early payment discount). Reduces the net payable amount and must be validated against the carrier contract terms.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Free-text or coded description of the reason for disputing the freight invoice (e.g., rate overcharge, duplicate billing, service failure, unauthorized accessorial). Populated when audit_status is \'failed\' or status is \'disputed\'.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'Date on which the freight invoice dispute was resolved between the company and the carrier. Used to measure dispute cycle time and carrier responsiveness KPIs.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Date by which payment must be made to the carrier to comply with contracted payment terms and avoid late payment penalties or interest charges.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fuelSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Amount' ;
    rdfs:comment 'Fuel surcharge billed by the carrier, typically calculated as a percentage of the base freight charge based on the applicable fuel index (e.g., DOE diesel index). Subject to contracted fuel surcharge table validation.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'ISO 4217 currency code of the company\'s functional reporting currency (e.g., USD) to which the invoice amount is converted for financial consolidation and IFRS/GAAP reporting.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the freight invoice by billing type. Distinguishes standard per-shipment invoices from consolidated periodic invoices, credit/debit adjustments, and corrected re-bills.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Amount' ;
    rdfs:comment 'Total gross amount billed by the carrier on this invoice in the invoice currency, inclusive of all charges (base freight, fuel surcharge, accessorials, taxes). The primary amount subject to freight audit and payment approval.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoicedAmountFunctional rdf:type rdf:Property ;
    rdfs:label 'Invoiced Amount Functional' ;
    rdfs:comment 'Total invoiced amount converted to the company\'s functional reporting currency using the exchange_rate. Used for financial consolidation, cost center allocation, and management reporting.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Actual date the invoice was paid to the carrier. Populated upon payment confirmation from the accounts payable system. Used for cash flow reporting and on-time payment KPI tracking.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Method used or designated for payment of this freight invoice (e.g., ACH, wire transfer, check, virtual card). Drives accounts payable processing workflow and bank reconciliation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'Payment transaction reference number (e.g., ACH trace number, check number, wire reference) generated upon payment execution. Used for bank reconciliation and payment confirmation to the carrier.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositAmount rdf:type rdf:Property ;
    rdfs:label 'Deposit Amount' ;
    rdfs:comment 'Deposit value charged per returnable packaging unit to incentivize return. Applicable when is_returnable is true. Used in accounts receivable, reverse logistics, and deposit reconciliation.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositCurrency rdf:type rdf:Property ;
    rdfs:label 'Deposit Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the returnable packaging deposit amount. Supports multi-currency deposit management across global operations.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionalWeightFactor rdf:type rdf:Property ;
    rdfs:label 'Dimensional Weight Factor' ;
    rdfs:comment 'Carrier-specific volumetric divisor used to calculate dimensional (chargeable) weight from package volume. Typically 5000 for air freight (IATA) or 4000/3000 for road/ocean. Used in freight cost estimation.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ghsPictogramCode rdf:type rdf:Property ;
    rdfs:label 'Ghs Pictogram Code' ;
    rdfs:comment 'GHS hazard pictogram code(s) required on the packaging label for chemical or hazardous content (e.g., \'GHS01\', \'GHS06\'). Applicable for HAZMAT-compatible packaging types.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Gross Volume M3' ;
    rdfs:comment 'Total external cubic volume of the packaging unit in cubic meters, calculated from external L×W×H dimensions. Used in load planning, vehicle utilization, and freight billing.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatUnCertification rdf:type rdf:Property ;
    rdfs:label 'Hazmat Un Certification' ;
    rdfs:comment 'UN certification code assigned to this packaging type for hazardous materials transport (e.g., \'1A1/Y1.8/150\'). Required for HAZMAT shipments under IATA, IMDG, and ADR regulations.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Internal Volume M3' ;
    rdfs:comment 'Usable internal cubic volume of the packaging unit in cubic meters. Used in volumetric capacity planning, load optimization, and dimensional weight calculations.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isHazmatCompatible rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Compatible' ;
    rdfs:comment 'Indicates whether this packaging type is certified and approved for use with hazardous materials. Drives carrier selection, documentation requirements, and regulatory compliance checks.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReturnable rdf:type rdf:Property ;
    rdfs:label 'Is Returnable' ;
    rdfs:comment 'Indicates whether the packaging unit is returnable (reusable) or disposable (single-use). Drives reverse logistics processes, deposit tracking, and sustainability reporting.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStackable rdf:type rdf:Property ;
    rdfs:label 'Is Stackable' ;
    rdfs:comment 'Indicates whether this packaging type can be stacked on top of other units during storage or transport. Drives load planning stacking rules and warehouse slotting logic.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTemperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Is Temperature Controlled' ;
    rdfs:comment 'Indicates whether this packaging type provides temperature control or insulation capability for cold chain or temperature-sensitive freight.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoContainerTypeCode rdf:type rdf:Property ;
    rdfs:label 'Iso Container Type Code' ;
    rdfs:comment 'Four-character ISO 6346 container type and size code (e.g., \'22G1\' for 20ft general purpose dry container). Applicable only for ISO container packaging types used in ocean and intermodal freight.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialComposition rdf:type rdf:Property ;
    rdfs:label 'Material Composition' ;
    rdfs:comment 'Primary material from which the packaging unit is constructed. Used in sustainability reporting, REACH/RoHS compliance checks, customs documentation, and recycling classification.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxGrossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Gross Weight Kg' ;
    rdfs:comment 'Maximum allowable total weight (tare + payload) of the packaging unit in kilograms. Used for carrier compliance, vehicle load limits, and structural safety validation.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxPayloadKg rdf:type rdf:Property ;
    rdfs:label 'Max Payload Kg' ;
    rdfs:comment 'Maximum allowable net content weight in kilograms that the packaging unit can safely carry. Used in load planning to prevent overloading and ensure structural integrity.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxStackLayers rdf:type rdf:Property ;
    rdfs:label 'Max Stack Layers' ;
    rdfs:comment 'Maximum number of identical packaging units that can be safely stacked vertically. Applicable when is_stackable is true. Used in warehouse slotting and load planning.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tareWeightKg rdf:type rdf:Property ;
    rdfs:label 'Tare Weight Kg' ;
    rdfs:comment 'Empty weight of the packaging unit in kilograms, excluding any contents. Used to calculate gross weight from net weight and for freight cost computation.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max C' ;
    rdfs:comment 'Maximum temperature in degrees Celsius that this packaging can maintain or withstand. Applicable for temperature-controlled packaging types used in cold chain logistics.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min C' ;
    rdfs:comment 'Minimum temperature in degrees Celsius that this packaging can maintain or withstand. Applicable for temperature-controlled packaging types used in cold chain logistics.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportModeCompatibility rdf:type rdf:Property ;
    rdfs:label 'Transport Mode Compatibility' ;
    rdfs:comment 'Transport modes for which this packaging type is approved and certified. Used in carrier selection, route planning, and compliance validation within the TMS.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Unit Cost Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the packaging unit cost (e.g., USD, EUR, CNY). Supports multi-currency operations across global distribution networks.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address of the logistics location, including street number and street name. Used for carrier pickup/delivery instructions and customs documentation.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address detail such as suite, building, floor, or unit number for the logistics location.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBondExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Customs Bond Expiry Date' ;
    rdfs:comment 'Expiration date of the customs bond or bonded warehouse license. Triggers renewal workflows to ensure uninterrupted bonded storage operations and trade compliance.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customsBondNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Bond Number' ;
    rdfs:comment 'Official customs bond or warehouse license number issued by the relevant customs authority for bonded warehouse locations. Required for customs compliance documentation and audit trails.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockCount rdf:type rdf:Property ;
    rdfs:label 'Dock Count' ;
    rdfs:comment 'Total number of loading/unloading dock doors available at the logistics location. Used in capacity planning, appointment slot management, and freight order scheduling within TMS and WMS.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ftzZoneNumber rdf:type rdf:Property ;
    rdfs:label 'Ftz Zone Number' ;
    rdfs:comment 'Official FTZ or SEZ designation number assigned by the relevant trade authority for locations within a free trade zone. Used in customs and export control documentation.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataAirportCode rdf:type rdf:Property ;
    rdfs:label 'Iata Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code for logistics locations that are air freight terminals or co-located with airports. Used in air freight routing, carrier service selection, and customs documentation.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundDockCount rdf:type rdf:Property ;
    rdfs:label 'Inbound Dock Count' ;
    rdfs:comment 'Number of dock doors designated exclusively for inbound freight receiving operations. Supports inbound appointment scheduling and GRN (Goods Receipt Note) throughput planning.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCustomsBonded rdf:type rdf:Property ;
    rdfs:label 'Is Customs Bonded' ;
    rdfs:comment 'Indicates whether the logistics location is a licensed customs bonded warehouse authorized to store imported goods before customs duties are paid. Critical for trade compliance routing and customs declaration management.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFreeTradeZone rdf:type rdf:Property ;
    rdfs:label 'Is Free Trade Zone' ;
    rdfs:comment 'Indicates whether the logistics location is situated within a designated Free Trade Zone (FTZ) or Special Economic Zone (SEZ). Affects duty deferral, tariff treatment, and export control compliance.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Certified' ;
    rdfs:comment 'Indicates whether the logistics location is certified and equipped to handle, store, or process hazardous materials (HAZMAT) in compliance with applicable regulations. Drives routing logic for hazmat shipments.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxWeightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Max Weight Capacity Kg' ;
    rdfs:comment 'Maximum total weight in kilograms that the logistics location can handle or store at any given time. Used in freight order feasibility checks and load planning.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingDays rdf:type rdf:Property ;
    rdfs:label 'Operating Days' ;
    rdfs:comment 'Comma-separated list of days of the week the location is operational (e.g., \'MON,TUE,WED,THU,FRI\'). Used by TMS to validate delivery windows and avoid scheduling shipments on non-operating days.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Operating Hours End' ;
    rdfs:comment 'Standard daily closing time of the logistics location in HH:MM (24-hour) format, expressed in the location\'s local timezone. Defines the latest permissible arrival or departure time for freight operations.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursStart rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Start' ;
    rdfs:comment 'Standard daily opening time of the logistics location in HH:MM (24-hour) format, expressed in the location\'s local timezone. Used for appointment scheduling, carrier pickup windows, and TMS cutoff enforcement.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outboundDockCount rdf:type rdf:Property ;
    rdfs:label 'Outbound Dock Count' ;
    rdfs:comment 'Number of dock doors designated exclusively for outbound freight dispatch operations. Supports outbound shipment scheduling and carrier pickup coordination.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity M3' ;
    rdfs:comment 'Total volumetric storage capacity of the logistics location in cubic meters. Used for inventory planning, warehouse utilization reporting, and network capacity optimization.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tempMaxC rdf:type rdf:Property ;
    rdfs:label 'Temp Max C' ;
    rdfs:comment 'Maximum temperature in degrees Celsius that the location\'s temperature-controlled storage can maintain. Used alongside temp_min_c to validate cold chain compatibility for inbound and outbound shipments.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tempMinC rdf:type rdf:Property ;
    rdfs:label 'Temp Min C' ;
    rdfs:comment 'Minimum temperature in degrees Celsius that the location\'s temperature-controlled storage can maintain. Used to validate suitability for cold chain shipments with specific temperature requirements.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unLocode rdf:type rdf:Property ;
    rdfs:label 'Un Locode' ;
    rdfs:comment 'UN/LOCODE (United Nations Code for Trade and Transport Locations) for the logistics location. Internationally recognized code used in customs declarations, bills of lading, and cross-border trade documentation.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Business-facing unique contract reference number assigned by the TMS or procurement system (SAP Ariba / SAP S/4HANA MM) to identify the freight contract across all operational systems.' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractOwner rdf:type rdf:Property ;
    rdfs:label 'Contract Owner' ;
    rdfs:comment 'Name or employee ID of the internal logistics or procurement manager responsible for negotiating, managing, and renewing this freight contract.' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerageIncluded rdf:type rdf:Property ;
    rdfs:label 'Customs Brokerage Included' ;
    rdfs:comment 'Indicates whether customs brokerage and trade compliance services are included within the scope of this freight contract or must be procured separately.' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Geographic coverage of the freight contract: domestic (single country), regional (multi-country within a continent), international (cross-border), or global (worldwide).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceMinimumCoverage rdf:type rdf:Property ;
    rdfs:label 'Insurance Minimum Coverage' ;
    rdfs:comment 'Minimum cargo insurance coverage amount the carrier must maintain, denominated in the contract currency. Verified during carrier onboarding and annual review.' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Required Flag' ;
    rdfs:comment 'Indicates whether the carrier is contractually required to maintain cargo insurance coverage for shipments executed under this agreement.' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoicingFrequency rdf:type rdf:Property ;
    rdfs:label 'Invoicing Frequency' ;
    rdfs:comment 'Agreed frequency at which the carrier submits freight invoices to the shipper under this contract (per shipment, weekly, bi-weekly, monthly, or quarterly).' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumVolumeCap rdf:type rdf:Property ;
    rdfs:label 'Maximum Volume Cap' ;
    rdfs:comment 'Maximum freight volume the carrier is contractually obligated to accept under this agreement. Volumes above this cap may require spot procurement or separate negotiation.' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumVolumeCommitment rdf:type rdf:Property ;
    rdfs:label 'Minimum Volume Commitment' ;
    rdfs:comment 'Contractually obligated minimum freight volume (in the unit specified by volume_commitment_uom) that the shipper must tender to the carrier over the contract period. Failure to meet this may trigger shortfall penalties.' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateEscalationClause rdf:type rdf:Property ;
    rdfs:label 'Rate Escalation Clause' ;
    rdfs:comment 'Type of rate escalation mechanism embedded in the contract: none (fixed rates), CPI-indexed (Consumer Price Index), fuel-indexed (linked to fuel surcharge index), annual percentage increase, or negotiated at renewal.' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateEscalationPct rdf:type rdf:Property ;
    rdfs:label 'Rate Escalation Pct' ;
    rdfs:comment 'Annual percentage rate by which contracted freight rates escalate under a fixed or annual-percentage escalation clause. Expressed as a decimal percentage (e.g., 3.50 = 3.50%).' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaOnTimeDeliveryTargetPct rdf:type rdf:Property ;
    rdfs:label 'Sla On Time Delivery Target Pct' ;
    rdfs:comment 'Contractually committed on-time delivery performance target expressed as a percentage (e.g., 95.00 = 95%). Carrier must meet or exceed this threshold to avoid SLA penalty clauses.' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Sla Penalty Amount' ;
    rdfs:comment 'Monetary value of the SLA penalty per occurrence or per day of non-performance, denominated in the contract currency. Applicable when sla_penalty_clause is fixed_amount or credit_per_day.' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaPenaltyClause rdf:type rdf:Property ;
    rdfs:label 'Sla Penalty Clause' ;
    rdfs:comment 'Type of financial penalty applied when the carrier fails to meet the contracted SLA: none, credit per day of delay, percentage of invoice value, fixed monetary amount, or service credit.' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCommitmentUom rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Uom' ;
    rdfs:comment 'Unit of measure for the minimum volume commitment (e.g., shipments, kg, metric tons, TEU for ocean containers, pallets, cubic meters, or loads).' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCategory rdf:type rdf:Property ;
    rdfs:label 'Account Category' ;
    rdfs:comment 'Indicates which primary financial statement the account feeds into: balance sheet (assets, liabilities, equity), income statement (revenue, expense), cash flow statement, or statistical (non-financial tracking). Supports automated financial statement generation.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'The account group classification used to organize GL accounts into logical groupings for number range assignment, field selection, and reporting hierarchy. Corresponds to SAP field KTOKS defining account group.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Level' ;
    rdfs:comment 'The numeric level of this account within the financial reporting hierarchy (e.g., level 1 = major category, level 2 = sub-category, level 3 = detailed account). Supports drill-down financial reporting and rollup aggregations.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountLongName rdf:type rdf:Property ;
    rdfs:label 'Account Long Name' ;
    rdfs:comment 'The full descriptive name or long text of the general ledger account providing complete context for the account purpose. Corresponds to SAP field TXT50 (long text).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'The alphanumeric code assigned to the general ledger account within the chart of accounts. This is the primary business identifier used in journal entries, financial statements, and ERP transactions. Corresponds to SAP GL account number (SAKNR).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'The fundamental financial classification of the account indicating its role in the financial statements: asset, liability, equity, revenue, or expense. Drives debit/credit behavior and financial statement placement.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Alternative Account Number' ;
    rdfs:comment 'The alternative account number used for local statutory reporting, mapping the group chart of accounts entry to the country-specific statutory chart of accounts. Supports multi-chart configurations for local GAAP versus group IFRS reporting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceInLocalCurrencyOnly rdf:type rdf:Property ;
    rdfs:label 'Balance In Local Currency Only' ;
    rdfs:comment 'Indicates whether the account balance is managed only in local (company code) currency, suppressing foreign currency balance tracking. Typically set for tax accounts and clearing accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockedForPosting rdf:type rdf:Property ;
    rdfs:label 'Blocked For Posting' ;
    rdfs:comment 'Indicates whether this account is blocked from receiving new journal entry postings. Blocked accounts are typically inactive, under review, or retired accounts that should not accept new transactions.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capexOpexIndicator rdf:type rdf:Property ;
    rdfs:label 'Capex Opex Indicator' ;
    rdfs:comment 'Classifies the account as relating to capital expenditure (CAPEX - investment in long-term assets) or operational expenditure (OPEX - day-to-day operating costs). Critical for CAPEX/OPEX tracking, budgeting, and EBITDA reporting in Manufacturing.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cogsIndicator rdf:type rdf:Property ;
    rdfs:label 'Cogs Indicator' ;
    rdfs:comment 'Indicates whether this account contributes to the Cost of Goods Sold (COGS) calculation. Used to identify and aggregate all manufacturing cost accounts for gross margin and COGS reporting in income statements.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consolidationAccount rdf:type rdf:Property ;
    rdfs:label 'Consolidation Account' ;
    rdfs:comment 'The group-level consolidation account number to which this local chart of accounts entry maps during intercompany elimination and group financial consolidation. Enables multi-entity consolidation across Manufacturing legal entities.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroup rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group' ;
    rdfs:comment 'The consolidation group or reporting unit to which this account is assigned for group financial reporting. Supports multi-level consolidation hierarchies across Manufacturing\'s global legal entity structure.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'Indicates whether this GL account is linked to a primary cost element (direct costs posted from FI to CO), secondary cost element (internal allocations within CO), or not applicable. Critical for COGS, EBITDA, and cost center accounting in SAP Controlling.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementType rdf:type rdf:Property ;
    rdfs:label 'Cost Element Type' ;
    rdfs:comment 'The cost element type classification used in SAP Controlling to categorize the nature of costs or revenues flowing through this account. Supports COGS analysis, overhead allocation, and EBITDA reporting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebitdaLine rdf:type rdf:Property ;
    rdfs:label 'Ebitda Line' ;
    rdfs:comment 'Maps this account to a specific line in the EBITDA bridge or management P&L reporting structure. Enables automated EBITDA calculation and management reporting for Manufacturing\'s financial performance analysis.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'The field status group assigned to this account that controls which fields are required, optional, or suppressed during document entry. Enforces data quality and completeness rules for postings to this account.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementItem rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Item' ;
    rdfs:comment 'The specific line item or caption on the published financial statement (e.g., \'Trade Receivables\', \'Property Plant and Equipment\', \'Cost of Goods Sold\') to which this GL account maps. Enables automated financial statement population and IFRS/GAAP disclosure.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'The functional area to which this account is assigned for cost-of-sales accounting and segment reporting. Enables income statement presentation by function of expense (e.g., manufacturing, R&D, G&A) as required under IFRS IAS 1.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaapClassification rdf:type rdf:Property ;
    rdfs:label 'Gaap Classification' ;
    rdfs:comment 'The US GAAP ASC topic or classification code assigned to this account for entities reporting under US GAAP. Supports dual-reporting environments where Manufacturing entities must comply with both IFRS and US GAAP.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrsClassification rdf:type rdf:Property ;
    rdfs:label 'Ifrs Classification' ;
    rdfs:comment 'The IFRS standard or taxonomy classification code assigned to this account for group consolidation and statutory reporting under IFRS (e.g., IAS 16 PP&E, IAS 2 Inventories, IFRS 15 Revenue). Supports IFRS taxonomy mapping for XBRL reporting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemDisplay rdf:type rdf:Property ;
    rdfs:label 'Line Item Display' ;
    rdfs:comment 'Indicates whether individual line items posted to this account are stored and displayable for audit and reconciliation purposes. When enabled, all individual postings are retained for drill-down reporting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:normalBalance rdf:type rdf:Property ;
    rdfs:label 'Normal Balance' ;
    rdfs:comment 'Indicates whether the account normally carries a debit or credit balance. Assets and expenses normally carry debit balances; liabilities, equity, and revenue normally carry credit balances. Used for automated variance detection and trial balance validation.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openItemManagement rdf:type rdf:Property ;
    rdfs:label 'Open Item Management' ;
    rdfs:comment 'Indicates whether open item management is activated for this account, requiring individual line items to be matched and cleared (e.g., GR/IR clearing accounts, bank clearing accounts). Supports accounts payable/receivable reconciliation.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingWithoutTaxAllowed rdf:type rdf:Property ;
    rdfs:label 'Posting Without Tax Allowed' ;
    rdfs:comment 'Indicates whether journal entry postings to this account are permitted without a tax code. When false, a tax code is mandatory for all postings, enforcing tax compliance controls.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitLossIndicator rdf:type rdf:Property ;
    rdfs:label 'Profit Loss Indicator' ;
    rdfs:comment 'Indicates whether the account is a profit and loss account (income statement) or a balance sheet account. Determines year-end closing behavior — P&L accounts are closed to retained earnings; balance sheet accounts carry forward.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationAccountType rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Type' ;
    rdfs:comment 'Identifies if this GL account serves as a reconciliation account for a subledger (accounts receivable, accounts payable, fixed assets). Reconciliation accounts cannot be posted to directly; they are updated automatically from subledger transactions.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'The sort key code that determines which document field is automatically populated in the assignment field of line items posted to this account. Used for sorting and grouping line items in account statements and open item lists.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'Specifies the tax relevance of the account: input tax (deductible VAT on purchases), output tax (VAT on sales), tax account (for posting tax amounts), or not relevant. Controls tax code entry requirements during document posting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityTypeActive rdf:type rdf:Property ;
    rdfs:label 'Activity Type Active' ;
    rdfs:comment 'Indicates whether activity type accounting is activated for this controlling area. When true, cost centers can record and allocate costs based on activity quantities (e.g., machine hours, labor hours), enabling activity-based costing and product cost calculation.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Default internal cost allocation method configured for this controlling area. Governs how overhead costs are distributed across cost centers, orders, and profit centers. Options include assessment (with secondary cost elements), distribution (with primary cost elements), indirect activity allocation, and template allocation.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexBudgetProfile rdf:type rdf:Property ;
    rdfs:label 'Capex Budget Profile' ;
    rdfs:comment 'Identifier of the CAPEX budget profile assigned to this controlling area, defining the rules for capital expenditure budgeting, availability control, and tolerance limits for investment orders and WBS elements. Supports CAPEX governance and IFRS IAS 16 compliance.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coVersion rdf:type rdf:Property ;
    rdfs:label 'Co Version' ;
    rdfs:comment 'Default controlling version used for plan/actual comparisons within this controlling area. Version \'0\' is the standard actual version; other versions (e.g., \'1\', \'2\') represent planning versions for budget scenarios, forecasts, or what-if analyses.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCodeAssignmentType rdf:type rdf:Property ;
    rdfs:label 'Company Code Assignment Type' ;
    rdfs:comment 'SAP assignment type governing how company codes are linked to the controlling area. Value \'1\' = controlling area and company codes use the same fiscal year variant and chart of accounts; Value \'2\' = company codes may have different fiscal year variants (cross-company code controlling).' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copaType rdf:type rdf:Property ;
    rdfs:label 'Copa Type' ;
    rdfs:comment 'Type of Profitability Analysis configured for this controlling area. \'costing_based\' uses value fields for flexible margin analysis; \'account_based\' aligns with G/L accounts for IFRS-compliant segment reporting; \'both\' enables parallel CO-PA for comprehensive profitability management.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStandardHierarchy rdf:type rdf:Property ;
    rdfs:label 'Cost Center Standard Hierarchy' ;
    rdfs:comment 'Name or identifier of the standard hierarchy for cost centers within this controlling area. The standard hierarchy defines the top-level grouping structure for all cost centers, enabling hierarchical cost reporting, allocation cycles, and management reporting roll-ups.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyType rdf:type rdf:Property ;
    rdfs:label 'Currency Type' ;
    rdfs:comment 'SAP currency type code defining the role of the controlling area currency in multi-currency accounting. Standard values: 10=Company Code Currency, 20=Controlling Area Currency, 30=Group Currency, 40=Hard Currency, 50=Index-Based Currency, 60=Global Company Currency. Governs how currency translation is applied in CO documents.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'SAP fiscal year variant code (e.g., \'K4\' for calendar year, \'V3\' for April-March) that defines the fiscal year structure — number of posting periods, special periods, and period-to-calendar-month mapping — applied across all company codes assigned to this controlling area.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageKey rdf:type rdf:Property ;
    rdfs:label 'Language Key' ;
    rdfs:comment 'ISO 639-1 two-letter language code representing the primary language used for text descriptions, reports, and correspondence within this controlling area (e.g., \'EN\' for English, \'DE\' for German, \'ZH\' for Chinese). Supports multi-language operations in multinational environments.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfPostingPeriods rdf:type rdf:Property ;
    rdfs:label 'Number Of Posting Periods' ;
    rdfs:comment 'Total number of regular posting periods defined for the fiscal year variant of this controlling area (typically 12 for calendar-year companies, 13 for 4-4-5 fiscal calendars). Determines the granularity of period-based cost reporting.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfSpecialPeriods rdf:type rdf:Property ;
    rdfs:label 'Number Of Special Periods' ;
    rdfs:comment 'Number of special (adjustment) posting periods beyond the regular periods, used for year-end closing adjustments, audit corrections, and statutory adjustments. Typically 1-4 special periods are configured.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderManagementActive rdf:type rdf:Property ;
    rdfs:label 'Order Management Active' ;
    rdfs:comment 'Indicates whether internal order management (CO-OPA) is activated for this controlling area. When true, internal orders can be used to collect and settle costs for specific projects, campaigns, or capital expenditure requests.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productCostControllingActive rdf:type rdf:Property ;
    rdfs:label 'Product Cost Controlling Active' ;
    rdfs:comment 'Indicates whether Product Cost Controlling (CO-PC) is activated for this controlling area. When true, standard cost estimates, work-in-progress (WIP) calculations, and variance analysis for manufactured products are enabled.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterAccountingActive rdf:type rdf:Property ;
    rdfs:label 'Profit Center Accounting Active' ;
    rdfs:comment 'Indicates whether Profit Center Accounting (CO-PCA) is activated for this controlling area. When true, all CO postings are simultaneously updated in profit center ledgers, enabling segment-level P&L and balance sheet reporting.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterStandardHierarchy rdf:type rdf:Property ;
    rdfs:label 'Profit Center Standard Hierarchy' ;
    rdfs:comment 'Name or identifier of the standard hierarchy for profit centers within this controlling area. Defines the organizational structure for profit center accounting, enabling segment-level profitability reporting and internal P&L analysis.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitabilityAnalysisActive rdf:type rdf:Property ;
    rdfs:label 'Profitability Analysis Active' ;
    rdfs:comment 'Indicates whether Profitability Analysis (CO-PA) is activated for this controlling area. When true, revenues and costs are analyzed by market segments (e.g., customer, product, region) to support EBITDA reporting and contribution margin analysis.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferPriceVariant rdf:type rdf:Property ;
    rdfs:label 'Transfer Price Variant' ;
    rdfs:comment 'Identifier of the transfer price variant configured for this controlling area, governing how intercompany and intra-company goods and service transfers are priced for internal cost accounting and profit center reporting. Supports arm\'s-length pricing compliance.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorPeriodFiscalPeriodId rdf:type rdf:Property ;
    rdfs:label 'Prior Period Fiscal Period Id' ;
    rdfs:comment 'Reference to the immediately preceding fiscal period record. Enables period-over-period variance analysis, prior period comparisons in financial statements, and sequential period navigation in reporting tools without requiring complex date calculations.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiscalPeriod .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:comment 'The accounting standard framework under which this fiscal period is reported. \'IFRS\' for International Financial Reporting Standards, \'GAAP\' for US Generally Accepted Accounting Principles, \'IFRS_GAAP\' for dual-reporting entities, \'LOCAL_GAAP\' for local statutory reporting, \'STAT\' for statutory-only periods.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apPostingAllowed rdf:type rdf:Property ;
    rdfs:label 'Ap Posting Allowed' ;
    rdfs:comment 'Flag indicating whether accounts payable postings (vendor invoices, payments, credit memos) are permitted for this fiscal period. Independently controlled from GL postings via the SAP posting period variant by account type.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:arPostingAllowed rdf:type rdf:Property ;
    rdfs:label 'Ar Posting Allowed' ;
    rdfs:comment 'Flag indicating whether accounts receivable postings (customer invoices, payments, credit memos) are permitted for this fiscal period. Independently controlled from GL postings via the SAP posting period variant by account type.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assetPostingAllowed rdf:type rdf:Property ;
    rdfs:label 'Asset Posting Allowed' ;
    rdfs:comment 'Flag indicating whether fixed asset accounting postings (acquisitions, retirements, depreciation runs) are permitted for this fiscal period. Asset accounting periods may be closed independently from other sub-ledgers.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closeCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Completed Timestamp' ;
    rdfs:comment 'Date and time when the period-end close process was fully completed and the period was officially closed for all postings. Used to measure close cycle time and track compliance with internal close calendar SLAs.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closeInitiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Initiated Timestamp' ;
    rdfs:comment 'Date and time when the period-end close process was formally initiated. Marks the start of the close workflow including sub-ledger reconciliation, accrual posting, and management review activities.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closeTargetDate rdf:type rdf:Property ;
    rdfs:label 'Close Target Date' ;
    rdfs:comment 'The planned target date by which the fiscal period close should be completed, as defined in the financial close calendar. Used to monitor close cycle performance and identify delays against the internal close SLA.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glPostingAllowed rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Allowed' ;
    rdfs:comment 'Flag indicating whether general ledger journal entry postings are currently permitted for this fiscal period. Controlled by the posting period variant and period status. When false, all GL postings to this period are blocked.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:halfYearNumber rdf:type rdf:Property ;
    rdfs:label 'Half Year Number' ;
    rdfs:comment 'The fiscal half-year (1 or 2) to which this period belongs. Used for semi-annual financial reporting and interim statutory filings required in certain jurisdictions.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isAdjustmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Adjustment Period' ;
    rdfs:comment 'Flag indicating whether this period is designated for audit adjustments and prior-period corrections. Adjustment periods allow authorized postings after the standard period close to accommodate external audit findings and statutory corrections.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSpecialPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Special Period' ;
    rdfs:comment 'Flag indicating whether this is a special adjustment period (periods 13–16 in SAP) used exclusively for year-end audit adjustments, closing entries, and statutory corrections. Special periods do not correspond to calendar months and are restricted to authorized finance users.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isYearEndPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Year End Period' ;
    rdfs:comment 'Flag indicating whether this period is the final closing period of the fiscal year. Triggers year-end close workflows including balance carryforward, retained earnings posting, and statutory financial statement preparation.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledgerCode rdf:type rdf:Property ;
    rdfs:label 'Ledger Code' ;
    rdfs:comment 'Code identifying the accounting ledger (leading or non-leading) in SAP S/4HANA to which this fiscal period applies. Supports parallel accounting where multiple ledgers are maintained for different accounting standards (e.g., IFRS ledger \'0L\', local GAAP ledger \'L1\').' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityCode rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Code' ;
    rdfs:comment 'Code identifying the legal entity (company code in SAP) for which this fiscal period definition applies. Supports multi-entity and multinational operations where different legal entities may have different fiscal calendars or period statuses.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mmPostingAllowed rdf:type rdf:Property ;
    rdfs:label 'Mm Posting Allowed' ;
    rdfs:comment 'Flag indicating whether materials management postings (goods receipts, goods issues, inventory movements) are permitted for this fiscal period. MM period close is managed separately from FI period close in SAP and must be aligned for COGS and inventory valuation accuracy.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Human-readable name of the fiscal period (e.g., \'January 2024\', \'Q1 FY2024\', \'Period 01 FY2024\'). Used in financial reports, dashboards, and period-end close communications.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodNumber rdf:type rdf:Property ;
    rdfs:label 'Period Number' ;
    rdfs:comment 'Sequential number of the period within the fiscal year. Standard periods are 1–12 (monthly) or 1–4 (quarterly). Periods 13–16 are reserved for special year-end adjustment periods used for audit corrections and closing entries.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodShortCode rdf:type rdf:Property ;
    rdfs:label 'Period Short Code' ;
    rdfs:comment 'Abbreviated alphanumeric code for the fiscal period used in financial reports, dashboards, and system interfaces (e.g., \'JAN24\', \'Q1FY24\', \'P01.2024\'). Provides a compact, human-readable period identifier for display in Power BI reports and management dashboards.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingPeriodVariant rdf:type rdf:Property ;
    rdfs:label 'Posting Period Variant' ;
    rdfs:comment 'SAP posting period variant code that controls which account types (assets, customers, vendors, general ledger) are open for posting in this period. Maps directly to the SAP FI posting period variant configuration (transaction OB52) and determines posting authorization by account type.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarterNumber rdf:type rdf:Property ;
    rdfs:label 'Quarter Number' ;
    rdfs:comment 'The fiscal quarter (1–4) to which this period belongs. Derived from the period number based on the fiscal year variant. Used for quarterly financial reporting, EBITDA reporting, and regulatory filings.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reopenReason rdf:type rdf:Property ;
    rdfs:label 'Reopen Reason' ;
    rdfs:comment 'Business justification provided when a closed fiscal period is reopened for additional postings. Documents the reason for the exception (e.g., \'External audit adjustment\', \'Prior period error correction per IAS 8\'). Required for audit trail and SOX compliance.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reopenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reopen Timestamp' ;
    rdfs:comment 'Date and time when a previously closed fiscal period was reopened for additional postings. Populated only when a period has been reopened after closure, typically for audit adjustments or error corrections. Null if the period has never been reopened.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code representing the group reporting (presentation) currency used for consolidated financial statements. Enables multi-currency consolidation where local functional currency differs from the group reporting currency.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxPeriodNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Period Number' ;
    rdfs:comment 'The tax reporting period number corresponding to this fiscal period, used for VAT/GST returns, withholding tax filings, and other statutory tax submissions. May differ from the financial posting period number in jurisdictions with different tax calendars.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weeksInPeriod rdf:type rdf:Property ;
    rdfs:label 'Weeks In Period' ;
    rdfs:comment 'Number of calendar weeks contained within this fiscal period. Relevant for 4-4-5, 4-5-4, or 5-4-4 fiscal calendar configurations used in manufacturing and retail industries where periods are defined in weeks rather than calendar months.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workingDaysCount rdf:type rdf:Property ;
    rdfs:label 'Working Days Count' ;
    rdfs:comment 'Number of business working days within this fiscal period, excluding weekends and public holidays. Used for production planning, labor cost accruals, depreciation calculations, and period-over-period performance normalization in manufacturing operations.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amountInGroupCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount In Group Currency' ;
    rdfs:comment 'The monetary amount of the journal entry line item translated into the group consolidation currency. Used for consolidated financial reporting and EBITDA/COGS analysis at the enterprise level.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountInLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount In Local Currency' ;
    rdfs:comment 'The monetary amount of the journal entry line item translated into the company code local (functional) currency. Used for statutory reporting in the country of incorporation. Corresponds to DMBTR in SAP BSEG.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountInTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount In Transaction Currency' ;
    rdfs:comment 'The monetary amount of the journal entry line item expressed in the transaction (document) currency. Positive for debits, negative for credits per SAP convention. Corresponds to WRBTR in SAP BSEG.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'SAP business area code used for cross-company-code segment reporting and internal balance sheet/P&L preparation by business division (e.g., Automation Systems, Electrification Solutions). Corresponds to GSBER in SAP BSEG.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date on which the open item was cleared (matched/settled) in accounts payable or accounts receivable. Used for aging analysis and cash flow reporting. Corresponds to AUGDT in SAP BSEG.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'The document number of the clearing document that settled this open item (e.g., payment document clearing an invoice). Populated when the line item has been cleared/matched. Corresponds to AUGBL in SAP BSEG.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicates whether the journal entry line item is a debit (S=Soll/Debit) or credit (H=Haben/Credit) posting. Fundamental to double-entry bookkeeping integrity. Corresponds to SHKZG in SAP BSEG.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentHeaderText rdf:type rdf:Property ;
    rdfs:label 'Document Header Text' ;
    rdfs:comment 'Free-text description at the document header level providing context for the journal entry (e.g., \'Monthly depreciation run\', \'Accrual reversal Q3\'). Corresponds to BKTXT in SAP BKPF.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Document Type Description' ;
    rdfs:comment 'Human-readable description of the document type for reporting and analytics purposes (e.g., \'General Ledger Document\', \'Vendor Invoice\', \'Customer Invoice\', \'Asset Posting\').' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'The exact date and time when the journal entry was created in the source system (SAP S/4HANA). Supports audit trail requirements and intraday financial monitoring. Derived from CPUDT and CPUTM in SAP BKPF.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'The exchange rate type used for currency translation (e.g., M=Standard translation at average rate, B=Bank buying rate, G=Bank selling rate). Controls which rate table is used for conversion. Corresponds to KURSF type in SAP.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'SAP internal order number used to track costs for specific projects, CAPEX investments, or temporary cost collection objects (e.g., R&D projects, capital expenditure orders). Corresponds to AUFNR in SAP BSEG.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemText rdf:type rdf:Property ;
    rdfs:label 'Line Item Text' ;
    rdfs:comment 'Free-text description at the journal entry line item level providing additional context for the individual posting (e.g., \'Depreciation - CNC Machine Line 3\', \'Accrual - Q4 Warranty Provision\'). Corresponds to SGTXT in SAP BSEG.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plant rdf:type rdf:Property ;
    rdfs:label 'Plant' ;
    rdfs:comment 'The SAP plant code associated with the journal entry, representing a manufacturing facility or distribution center. Enables cost and revenue analysis by production site and supports plant-level COGS and OEE financial reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'Two-digit SAP posting key that determines the debit/credit indicator and account type for each line item (e.g., 40=Debit G/L, 50=Credit G/L, 01=Customer Invoice, 31=Vendor Invoice). Corresponds to BSCHL in SAP BSEG.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current status of the journal entry in the financial system lifecycle. \'posted\' indicates a completed and active posting; \'reversed\' indicates the entry has been reversed; \'parked\' indicates a saved but not yet posted document; \'cleared\' indicates open items have been matched.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual journal entry line item in the silver layer lakehouse. Serves as the primary key for this entity.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amountGroupCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Group Currency' ;
    rdfs:comment 'The monetary amount of the line item translated into the group (consolidation) currency for multinational financial consolidation and group-level EBITDA and COGS reporting. Corresponds to KURSF/group currency amount in SAP.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Local Currency' ;
    rdfs:comment 'The monetary amount of the line item translated into the local (company code) currency. Used for statutory reporting and local financial statements. Corresponds to DMBTR in SAP.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Transaction Currency' ;
    rdfs:comment 'The monetary amount of the line item expressed in the original transaction currency (e.g., the currency of the invoice or payment). Used for foreign currency analysis and reconciliation. Corresponds to WRBTR in SAP.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignment rdf:type rdf:Property ;
    rdfs:label 'Assignment' ;
    rdfs:comment 'Free-form assignment field used to link the line item to a reference document, payment run, or clearing transaction. Commonly populated with invoice numbers, payment references, or order numbers for account clearing and reconciliation. Corresponds to ZUONR in SAP.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDocument rdf:type rdf:Property ;
    rdfs:label 'Clearing Document' ;
    rdfs:comment 'The document number of the clearing transaction that offset this open item (e.g., payment clearing an invoice). Populated when the line item has been cleared; blank for open items. Corresponds to AUGBL in SAP.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The date on which the journal entry was entered into the system. Used for audit trail and to distinguish from posting date and document date. Corresponds to CPUDT in SAP.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ledgerGroup rdf:type rdf:Property ;
    rdfs:label 'Ledger Group' ;
    rdfs:comment 'The ledger group to which this posting applies, supporting parallel accounting under multiple accounting standards (e.g., IFRS ledger, GAAP ledger, local GAAP ledger). Corresponds to LEDGER_GROUP in SAP New GL.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Line Item Number' ;
    rdfs:comment 'Sequential line item number within the parent journal entry document, uniquely identifying this posting line within the document. Corresponds to BUZEI field in SAP BSEG table.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:localCurrency rdf:type rdf:Property ;
    rdfs:label 'Local Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the company code\'s local (functional) currency. Used for statutory financial reporting in the entity\'s country of domicile. Corresponds to PSWSL in SAP.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialGlIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Gl Indicator' ;
    rdfs:comment 'Special General Ledger (GL) indicator for down payments, guarantees, bills of exchange, or other special transactions that are posted to alternative reconciliation accounts. Corresponds to UMSKZ in SAP.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the original transaction (e.g., USD, EUR, CNY). Identifies the currency in which the business transaction was originally denominated. Corresponds to WAERS in SAP.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amountInCompanyCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount In Company Currency' ;
    rdfs:comment 'Gross invoice amount translated into the company code local currency using the exchange rate at posting date. Used for local financial reporting and EBITDA calculation.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'The reference date used as the starting point for calculating payment due dates and cash discount periods based on the payment terms. May differ from invoice date.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:companyCodeCurrency rdf:type rdf:Property ;
    rdfs:label 'Company Code Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the local company code currency. Used for local statutory reporting and financial consolidation.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountDueDate rdf:type rdf:Property ;
    rdfs:label 'Discount Due Date' ;
    rdfs:comment 'The last date by which payment must be made to qualify for the early payment cash discount. Supports working capital optimization and discount capture reporting.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total gross amount of the invoice including all taxes and charges, expressed in the invoice currency. Represents the full liability to the vendor before any discounts.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceCurrency rdf:type rdf:Property ;
    rdfs:label 'Invoice Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the vendor invoice is denominated. Supports multi-currency AP processing and foreign exchange reporting.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date printed on the vendor invoice document. Used as the baseline for payment term calculations and aging analysis.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'The external invoice number as printed on the vendor/supplier invoice document. Used for three-way match reconciliation and vendor communication.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current processing status of the AP invoice through its lifecycle from receipt to payment. Drives workflow routing, aging analysis, and cash flow forecasting.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Net amount of the invoice excluding tax, expressed in the invoice currency. Represents the base value for cost accounting, COGS, and CAPEX/OPEX classification.' ;
    rdfs:domain ind:Shared ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockIndicator rdf:type rdf:Property ;
    rdfs:label 'Payment Block Indicator' ;
    rdfs:comment 'SAP payment block key indicating whether the invoice is blocked from automatic payment processing and the reason for the block (e.g., R=Manual block, A=Blocked for payment, I=In dispute).' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The date by which payment must be made to the vendor to comply with agreed payment terms and avoid late payment penalties. Derived from invoice date and payment terms.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'The Purchase Order number referenced on the vendor invoice. Links the invoice to the originating procurement document for three-way match and CAPEX/OPEX classification.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrg rdf:type rdf:Property ;
    rdfs:label 'Purchasing Org' ;
    rdfs:comment 'SAP purchasing organization responsible for procuring goods or services covered by the invoice. Supports procurement analytics and supplier spend reporting.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Result of the three-way matching process comparing the Purchase Order (PO), Goods Receipt Note (GRN), and vendor invoice. A matched status is required for invoice approval and payment release.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Account Number' ;
    rdfs:comment 'The SAP vendor master account number identifying the supplier from whom the invoice was received. Links to the vendor master record for payment and reconciliation.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'Amount of withholding tax deducted from the invoice payment at source, as required by local tax regulations. Relevant for cross-border vendor payments.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxCode rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Code' ;
    rdfs:comment 'Tax code identifying the applicable withholding tax type and rate for the invoice. Determines the withholding tax calculation method per jurisdiction.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Billing Document Number' ;
    rdfs:comment 'Reference to the originating billing document in SAP S/4HANA SD module (transaction VF01/VF02). Links the AR open item to the billing generation process in billing.invoice.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingStatus rdf:type rdf:Property ;
    rdfs:label 'Clearing Status' ;
    rdfs:comment 'Current payment clearing status of the AR invoice. \'open\' indicates no payment received; \'partially_cleared\' indicates partial payment; \'fully_cleared\' indicates full payment received; \'written_off\' indicates bad debt write-off.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeIndicator rdf:type rdf:Property ;
    rdfs:label 'Dispute Indicator' ;
    rdfs:comment 'Indicates whether the customer has raised a formal dispute against this invoice (True = disputed). Triggers dispute management workflow and blocks automatic dunning.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Code' ;
    rdfs:comment 'Standardized code identifying the reason for the customer dispute (e.g., pricing discrepancy, quantity mismatch, quality issue, delivery problem). Populated when dispute_indicator is True.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningBlock rdf:type rdf:Property ;
    rdfs:label 'Dunning Block' ;
    rdfs:comment 'Indicates whether the invoice is blocked from the dunning program (True = blocked). Applied when a dispute is open or a payment arrangement is in place.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunningDate rdf:type rdf:Property ;
    rdfs:label 'Dunning Date' ;
    rdfs:comment 'Date on which the most recent dunning notice was issued for this invoice. Used to track collection escalation timeline and customer communication history.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openAmount rdf:type rdf:Property ;
    rdfs:label 'Open Amount' ;
    rdfs:comment 'Remaining unpaid amount on the invoice in the transaction currency. Calculated as gross amount minus payments received and credit memos applied. Drives AR aging and cash collection.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payerAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Payer Account Number' ;
    rdfs:comment 'SAP account number of the payer party responsible for making payment, which may differ from the bill-to customer in complex customer hierarchies.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlock rdf:type rdf:Property ;
    rdfs:label 'Payment Block' ;
    rdfs:comment 'SAP payment block indicator applied to the invoice to prevent automatic payment processing (e.g., \'R\' for review, \'D\' for dispute). Blank indicates no block.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Description' ;
    rdfs:comment 'Human-readable description of the payment terms (e.g., \'Net 30 Days\', \'2% 10 Net 30\'). Supports invoice presentation and customer communication.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Status' ;
    rdfs:comment 'Current status of revenue recognition for this invoice under IFRS 15 / ASC 606. Indicates whether revenue has been recognized, deferred, or is pending performance obligation fulfillment.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Unique surrogate identifier for each payment transaction record in the finance data product. Serves as the primary key for the payment entity in the Databricks Silver Layer.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Internal identifier of the company\'s house bank account used to execute or receive the payment. References the bank account master data in SAP, enabling bank statement reconciliation and liquidity management. Not a full account number (PCI-sensitive data is masked).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The gross payment amount in the transaction currency. For outgoing payments, this is the amount disbursed to the payee. For incoming payments, this is the amount received from the payer. Stored with 4 decimal places to support high-precision currencies.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountLocal rdf:type rdf:Property ;
    rdfs:label 'Amount Local' ;
    rdfs:comment 'The payment amount converted to the local (company code) currency using the exchange rate at the time of posting. Used for statutory reporting, local GAAP compliance, and legal entity financial statements.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:block rdf:type rdf:Property ;
    rdfs:label 'Block' ;
    rdfs:comment 'SAP payment block key indicating whether the payment is blocked from processing and the reason (e.g., R = manual block, A = blocked for payment, blank = not blocked). Used for payment approval workflows and dispute management.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearedAmount rdf:type rdf:Property ;
    rdfs:label 'Cleared Amount' ;
    rdfs:comment 'The monetary amount of the invoice cleared by this specific payment allocation. For partial payments, this is less than the invoice gross amount. Belongs to the clearing event, not to the payment or invoice alone.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountTaken rdf:type rdf:Property ;
    rdfs:label 'Discount Taken' ;
    rdfs:comment 'The cash discount amount actually captured on this specific clearing event. Reflects whether the early payment discount was applied at the time of this allocation. Belongs to the clearing event, not to the payment or invoice alone.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:houseBank rdf:type rdf:Property ;
    rdfs:label 'House Bank' ;
    rdfs:comment 'The SAP house bank key identifying the bank institution through which the payment is processed. Used for bank-level cash position reporting, bank fee analysis, and treasury management.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReversed rdf:type rdf:Property ;
    rdfs:label 'Is Reversed' ;
    rdfs:comment 'Boolean flag indicating whether this payment document has been reversed (cancelled) in the general ledger. A value of True means the payment has been voided and a reversal document exists. Used for audit trail and reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:methodSupplement rdf:type rdf:Property ;
    rdfs:label 'Method Supplement' ;
    rdfs:comment 'Additional qualifier for the payment method, used in SAP to differentiate variants within a payment method (e.g., domestic vs. international wire, standard vs. express ACH). Supports bank-specific routing and format selection.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reference rdf:type rdf:Property ;
    rdfs:label 'Reference' ;
    rdfs:comment 'Free-text or structured reference transmitted with the payment to the bank or counterparty (e.g., remittance information, payment advice text, check memo line). Used for bank statement matching and counterparty reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The date on which the payment reversal was posted to the general ledger. Populated only when is_reversed = True. Used for period-close adjustments and audit trail.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountCloseDate rdf:type rdf:Property ;
    rdfs:label 'Account Close Date' ;
    rdfs:comment 'The date on which the bank account was or is scheduled to be closed. Null for active accounts. Used for account lifecycle management and treasury decommissioning processes.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountCurrency rdf:type rdf:Property ;
    rdfs:label 'Account Currency' ;
    rdfs:comment 'The ISO 4217 three-letter currency code in which the bank account is denominated (e.g., USD, EUR, GBP, JPY). Drives multi-currency consolidation and foreign exchange exposure reporting.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountOpenDate rdf:type rdf:Property ;
    rdfs:label 'Account Open Date' ;
    rdfs:comment 'The date on which the bank account was officially opened with the banking institution. Used for account lifecycle management, audit trails, and regulatory reporting of account tenure.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountPurpose rdf:type rdf:Property ;
    rdfs:label 'Account Purpose' ;
    rdfs:comment 'The designated business purpose for which the bank account is used within Manufacturing treasury operations. Supports segregation of funds, internal controls, and cash flow categorization for CAPEX/OPEX tracking.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSignatory1 rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory 1' ;
    rdfs:comment 'Full name of the primary authorized signatory for the bank account, as registered with the banking institution. Required for bank mandate documentation, internal controls, and audit compliance.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSignatory2 rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory 2' ;
    rdfs:comment 'Full name of the secondary authorized signatory for the bank account, as registered with the banking institution. Supports dual-control authorization requirements for high-value payment transactions.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankBranchName rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Name' ;
    rdfs:comment 'The name of the specific branch of the banking institution where the account is maintained. Relevant for domestic accounts where branch-level identification is required for payment routing.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCity rdf:type rdf:Property ;
    rdfs:label 'Bank City' ;
    rdfs:comment 'The city where the banking institution or branch is located. Used for bank relationship management and payment routing documentation.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankContactEmail rdf:type rdf:Property ;
    rdfs:label 'Bank Contact Email' ;
    rdfs:comment 'Email address of the primary relationship manager or contact person at the banking institution. Used for treasury operations communication and bank relationship management.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankContactName rdf:type rdf:Property ;
    rdfs:label 'Bank Contact Name' ;
    rdfs:comment 'Name of the primary relationship manager or contact person at the banking institution responsible for this account. Used for bank relationship management and escalation during payment disputes or account issues.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCountry rdf:type rdf:Property ;
    rdfs:label 'Bank Country' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code of the country where the banking institution is domiciled. Used for multi-currency consolidation, regulatory reporting, and cross-border payment compliance.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankKey rdf:type rdf:Property ;
    rdfs:label 'Bank Key' ;
    rdfs:comment 'The country-specific bank identification key used in SAP S/4HANA to identify the bank (e.g., BLZ in Germany, BSB in Australia, IFSC in India). Complements SWIFT/BIC for domestic payment routing.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'The full legal name of the banking institution where the corporate account is held (e.g., Deutsche Bank AG, JPMorgan Chase Bank N.A.). Used for treasury reporting and bank relationship management.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Number' ;
    rdfs:comment 'The American Bankers Association (ABA) routing transit number for US-domiciled bank accounts. Used for ACH and domestic wire payment routing in the United States.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankStatementFormat rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Format' ;
    rdfs:comment 'The electronic bank statement format used for automated reconciliation in SAP S/4HANA FI. MT940 and CAMT.053 are SWIFT/ISO 20022 formats; BAI2 is the US standard; OFX is used for online banking integrations.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedReason rdf:type rdf:Property ;
    rdfs:label 'Blocked Reason' ;
    rdfs:comment 'The reason code explaining why the bank account has been blocked or restricted from payment processing. Populated only when status is \'blocked\' or \'under_review\'. Supports internal controls and audit documentation.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashPoolRole rdf:type rdf:Property ;
    rdfs:label 'Cash Pool Role' ;
    rdfs:comment 'The role of this bank account within the cash pooling structure. Header accounts aggregate balances from participant accounts; participant accounts contribute to or draw from the pool. Not applicable for accounts outside a pooling arrangement.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicBankingEnabled rdf:type rdf:Property ;
    rdfs:label 'Electronic Banking Enabled' ;
    rdfs:comment 'Indicates whether electronic banking (e-banking) services are activated for this account, enabling automated bank statement downloads (MT940/CAMT.053) and electronic payment file submission in SAP S/4HANA FI.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'The International Bank Account Number (IBAN) assigned to the corporate bank account, used for cross-border payment processing and SEPA transactions. Mandatory for accounts in SEPA-participating countries.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'The date of the most recent bank statement reconciliation performed for this account in SAP S/4HANA FI. Supports month-end close processes and audit compliance for accounts payable and receivable.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdraftLimit rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit' ;
    rdfs:comment 'The maximum overdraft facility amount authorized by the banking institution for this account, expressed in the account currency. Used for liquidity planning and credit facility monitoring in treasury operations.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethodAllowed rdf:type rdf:Property ;
    rdfs:label 'Payment Method Allowed' ;
    rdfs:comment 'Comma-separated list of payment methods authorized for use with this bank account (e.g., ACH, WIRE, CHECK, SEPA_CT, SEPA_DD, SWIFT). Drives payment program configuration in SAP S/4HANA FI-AP and FI-AR.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Payroll Account Flag' ;
    rdfs:comment 'Indicates whether this bank account is designated exclusively for payroll disbursements. Payroll accounts are subject to additional internal controls, segregation of duties requirements, and labor law compliance.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signingAuthorityType rdf:type rdf:Property ;
    rdfs:label 'Signing Authority Type' ;
    rdfs:comment 'The type of signing authority required to authorize transactions on this bank account. Single authority allows one signatory; dual authority requires two signatories; board resolution or power of attorney may be required for specific transaction types.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortCode rdf:type rdf:Property ;
    rdfs:label 'Sort Code' ;
    rdfs:comment 'The six-digit sort code identifying the bank and branch for UK-domiciled accounts. Used for BACS, CHAPS, and Faster Payments routing in the United Kingdom.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftBicCode rdf:type rdf:Property ;
    rdfs:label 'Swift Bic Code' ;
    rdfs:comment 'The SWIFT/BIC code identifying the banking institution and branch for international wire transfers and correspondent banking. Consists of 8 or 11 alphanumeric characters per ISO 9362 standard.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClassCode rdf:type rdf:Property ;
    rdfs:label 'Asset Class Code' ;
    rdfs:comment 'The SAP FI-AA asset class code categorizing the fixed asset (e.g., machinery, buildings, vehicles, IT equipment, leasehold improvements). Drives depreciation method, useful life, and account determination for the transaction.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetValueDate rdf:type rdf:Property ;
    rdfs:label 'Asset Value Date' ;
    rdfs:comment 'The date from which the asset transaction takes effect for asset valuation and depreciation calculation purposes. May differ from the posting date; used to determine the start of depreciation for acquisitions or the end date for retirements.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationArea rdf:type rdf:Property ;
    rdfs:label 'Depreciation Area' ;
    rdfs:comment 'SAP FI-AA depreciation area code identifying the valuation view under which the transaction is posted (e.g., 01=Book depreciation/IFRS, 02=Tax depreciation, 15=GAAP local, 30=Cost accounting). Enables parallel valuation for multi-GAAP and tax reporting.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBookValueAfter rdf:type rdf:Property ;
    rdfs:label 'Net Book Value After' ;
    rdfs:comment 'The net book value (carrying amount) of the asset in local currency immediately after the transaction is applied. Provides the closing balance and is used for balance sheet reporting and impairment assessment.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netBookValueBefore rdf:type rdf:Property ;
    rdfs:label 'Net Book Value Before' ;
    rdfs:comment 'The net book value (carrying amount) of the asset in local currency immediately before the transaction is applied. Provides the opening balance for the transaction and is essential for impairment testing and audit compliance.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Remaining Useful Life Years' ;
    rdfs:comment 'The remaining useful life of the asset in years at the time of the transaction posting. Used for impairment testing, depreciation recalculation, and asset lifecycle reporting.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'The gross financial amount of the asset transaction posted in the transaction currency. Represents the acquisition cost, retirement proceeds, write-down amount, or depreciation charge depending on the transaction type.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionText rdf:type rdf:Property ;
    rdfs:label 'Transaction Text' ;
    rdfs:comment 'Free-text description or narrative entered at the time of posting the asset transaction, providing additional context about the nature of the financial movement (e.g., \'Acquisition of CNC machine line 3\', \'Partial retirement due to component replacement\').' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTypeCategory rdf:type rdf:Property ;
    rdfs:label 'Transaction Type Category' ;
    rdfs:comment 'Business-level classification of the asset transaction category, grouping SAP transaction type codes into meaningful financial movement categories for CAPEX reporting, impairment testing, and audit compliance.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTypeCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Type Code' ;
    rdfs:comment 'SAP FI-AA transaction type code identifying the nature of the financial movement on the asset (e.g., 100=External acquisition, 200=Retirement, 300=Transfer, 400=Write-down, 600=Depreciation posting). Drives posting logic and account determination.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'The monetary amount allocated from the sender to the receiver in the transaction currency. Represents the cost portion distributed during the allocation cycle execution.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedAmountCompanyCurrency rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount Company Currency' ;
    rdfs:comment 'The allocated amount converted to the company code\'s local currency. Used for statutory financial reporting and legal entity consolidation.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedAmountControllingCurrency rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount Controlling Currency' ;
    rdfs:comment 'The allocated amount expressed in the controlling area currency, used for management accounting and cross-company cost analysis.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationBasisQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis Quantity' ;
    rdfs:comment 'The numeric quantity of the allocation basis used to determine the receiver\'s share (e.g., headcount, floor area in m², machine hours, kilowatt-hours). Applicable when allocation method is statistical key figure or activity quantity.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationBasisUnit rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis Unit' ;
    rdfs:comment 'The unit of measure for the allocation basis quantity (e.g., EA for headcount, H for hours, M2 for square meters, KWH for kilowatt-hours). Provides context for interpreting the allocation basis quantity.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The business date on which the cost allocation is executed and posted. Determines the period assignment for the allocation transaction.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Document Number' ;
    rdfs:comment 'Business document number assigned by the controlling system (e.g., SAP CO) to uniquely identify the allocation posting document within a fiscal period.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'The percentage share of total sender costs allocated to this specific receiver. Applicable when allocation method is percentage-based. Values between 0 and 100.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Classification of the cost allocation method used: distribution (reallocates primary cost elements), assessment (uses secondary cost elements), reposting (manual correction), overhead calculation (surcharge-based), activity allocation (quantity-based), or template allocation (formula-based).' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleName rdf:type rdf:Property ;
    rdfs:label 'Cycle Name' ;
    rdfs:comment 'Name of the allocation or assessment cycle as defined in the controlling system (e.g., SAP CO cycle name). Identifies the configured rule set used to distribute costs during period-end close.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Original Document Number' ;
    rdfs:comment 'Reference to the original allocation document number that this record reverses or corrects. Populated only when reversal_flag is true, enabling audit trail linkage.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planActualIndicator rdf:type rdf:Property ;
    rdfs:label 'Plan Actual Indicator' ;
    rdfs:comment 'Distinguishes whether this allocation record represents a planned allocation (budget/forecast), an actual posted allocation, or a commitment. Supports plan vs. actual variance analysis in management reporting.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverCostCenter rdf:type rdf:Property ;
    rdfs:label 'Receiver Cost Center' ;
    rdfs:comment 'The cost center receiving the allocated costs. Represents the organizational unit absorbing the shared or overhead costs from the sender.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverWbsElement rdf:type rdf:Property ;
    rdfs:label 'Receiver Wbs Element' ;
    rdfs:comment 'Work Breakdown Structure element receiving the allocated costs, used for capital project cost absorption and CAPEX tracking.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderCostElement rdf:type rdf:Property ;
    rdfs:label 'Sender Cost Element' ;
    rdfs:comment 'The cost element (GL account in controlling) from which costs are being sent. For assessments, this is typically a secondary cost element; for distributions, it is the original primary cost element.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderCostElementGroup rdf:type rdf:Property ;
    rdfs:label 'Sender Cost Element Group' ;
    rdfs:comment 'The cost element group defining the range of cost elements included in the sender pool for this allocation cycle segment. Used when multiple cost elements are allocated together.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalKeyFigure rdf:type rdf:Property ;
    rdfs:label 'Statistical Key Figure' ;
    rdfs:comment 'The statistical key figure code used as the allocation tracing factor (e.g., HEADCOUNT, FLOORAREA, MACHHR). Statistical key figures are non-monetary quantities that drive cost distribution.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingDate rdf:type rdf:Property ;
    rdfs:label 'Costing Date' ;
    rdfs:comment 'The reference date used to determine prices and rates during the cost estimate calculation (e.g., material prices, activity rates). Controls which price conditions are selected from the system.' ;
    rdfs:domain ind:ProductCostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costingRunNumber rdf:type rdf:Property ;
    rdfs:label 'Costing Run Number' ;
    rdfs:comment 'Unique identifier of the costing run in SAP CO-PC that generated this cost estimate. Used to trace the estimate back to its originating batch costing execution.' ;
    rdfs:domain ind:ProductCostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingStatus rdf:type rdf:Property ;
    rdfs:label 'Costing Status' ;
    rdfs:comment 'Current processing status of the cost estimate in SAP CO-PC. Only estimates with status \'released\' are used for inventory valuation and standard cost rolls. Errors must be resolved before release.' ;
    rdfs:domain ind:ProductCostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingType rdf:type rdf:Property ;
    rdfs:label 'Costing Type' ;
    rdfs:comment 'Classification of the cost estimate by its business purpose. Standard cost estimates feed inventory valuation; simulation estimates support what-if analysis; sales order costing supports margin analysis.' ;
    rdfs:domain ind:ProductCostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingVersion rdf:type rdf:Property ;
    rdfs:label 'Costing Version' ;
    rdfs:comment 'Version number of the cost estimate within a costing variant. Allows multiple parallel cost estimates (e.g., plan vs. simulation) to coexist for the same material and period.' ;
    rdfs:domain ind:ProductCostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorIndicator rdf:type rdf:Property ;
    rdfs:label 'Error Indicator' ;
    rdfs:comment 'Flag indicating whether the cost estimate contains errors or warnings that prevented successful completion. Estimates with errors cannot be released for inventory valuation until resolved.' ;
    rdfs:domain ind:ProductCostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:groupCurrencyCost rdf:type rdf:Property ;
    rdfs:label 'Group Currency Cost' ;
    rdfs:comment 'Total standard cost translated into the group reporting currency (e.g., USD for a US-headquartered multinational). Supports consolidated COGS and inventory valuation reporting across legal entities.' ;
    rdfs:domain ind:ProductCostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborCost rdf:type rdf:Property ;
    rdfs:label 'Labor Cost' ;
    rdfs:comment 'Planned direct labor cost for manufacturing the product per the base quantity. Calculated from routing operations, activity types, and planned labor rates in the work center.' ;
    rdfs:domain ind:ProductCostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSize rdf:type rdf:Property ;
    rdfs:label 'Lot Size' ;
    rdfs:comment 'Production lot size used in the cost estimate for calculating setup and fixed cost components. Lot-size-dependent costs (e.g., setup time) are spread over this quantity to derive per-unit costs.' ;
    rdfs:domain ind:ProductCostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:machineCost rdf:type rdf:Property ;
    rdfs:label 'Machine Cost' ;
    rdfs:comment 'Planned machine activity cost for manufacturing the product per the base quantity. Derived from routing machine time and machine activity rates defined in the work center.' ;
    rdfs:domain ind:ProductCostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:makeBuyIndicator rdf:type rdf:Property ;
    rdfs:label 'Make Buy Indicator' ;
    rdfs:comment 'Indicates whether the product is manufactured in-house (Make to Stock, Make to Order, Engineer to Order, Assemble to Order) or procured externally (Buy). Influences the cost component structure and costing methodology.' ;
    rdfs:domain ind:ProductCostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCost rdf:type rdf:Property ;
    rdfs:label 'Material Cost' ;
    rdfs:comment 'Planned cost of raw materials, components, and purchased parts consumed in manufacturing the product per the base quantity. Derived from the Bill of Materials (BOM) and material price conditions.' ;
    rdfs:domain ind:ProductCostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overheadCost rdf:type rdf:Property ;
    rdfs:label 'Overhead Cost' ;
    rdfs:comment 'Planned manufacturing overhead cost allocated to the product per the base quantity. Includes fixed and variable overhead applied via overhead costing sheets or activity-based costing.' ;
    rdfs:domain ind:ProductCostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overheadKey rdf:type rdf:Property ;
    rdfs:label 'Overhead Key' ;
    rdfs:comment 'SAP overhead costing sheet key applied to calculate manufacturing overhead in this cost estimate. Determines the overhead rates and absorption basis used for fixed and variable overhead allocation.' ;
    rdfs:domain ind:ProductCostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingAlternative rdf:type rdf:Property ;
    rdfs:label 'Routing Alternative' ;
    rdfs:comment 'Alternative routing sequence used in the cost estimate when multiple production routings exist for a material. Supports costing of alternative manufacturing paths.' ;
    rdfs:domain ind:ProductCostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractingCost rdf:type rdf:Property ;
    rdfs:label 'Subcontracting Cost' ;
    rdfs:comment 'Planned cost for externally subcontracted manufacturing operations or services included in the product cost estimate. Relevant for products with outsourced processing steps.' ;
    rdfs:domain ind:ProductCostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStandardCost rdf:type rdf:Property ;
    rdfs:label 'Total Standard Cost' ;
    rdfs:comment 'Total planned cost of goods manufactured (COGM) per the base quantity, representing the sum of all cost components (material, labor, machine, overhead, subcontracting). This value is used as the standard price for inventory valuation and COGS calculation.' ;
    rdfs:domain ind:ProductCostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualLaborCost rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Cost' ;
    rdfs:comment 'Actual direct labor cost charged to the production order based on confirmed activity quantities and labor rates. Supports labor efficiency variance analysis.' ;
    rdfs:domain ind:ProductionOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualMachineCost rdf:type rdf:Property ;
    rdfs:label 'Actual Machine Cost' ;
    rdfs:comment 'Actual machine or equipment usage cost charged to the production order based on confirmed machine activity and machine rates. Supports machine efficiency variance analysis.' ;
    rdfs:domain ind:ProductionOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Actual Material Cost' ;
    rdfs:comment 'Actual cost of raw materials and components consumed in the production order, as posted via goods issues from inventory. Key component of COGS and material variance analysis.' ;
    rdfs:domain ind:ProductionOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualOverheadCost rdf:type rdf:Property ;
    rdfs:label 'Actual Overhead Cost' ;
    rdfs:comment 'Actual manufacturing overhead cost applied to the production order via overhead costing sheets or activity-based costing. Includes indirect costs such as utilities, depreciation, and facility costs.' ;
    rdfs:domain ind:ProductionOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualTotalCost rdf:type rdf:Property ;
    rdfs:label 'Actual Total Cost' ;
    rdfs:comment 'Total actual cost incurred on the production order, representing the sum of actual material, labor, machine, and overhead costs. Primary input for COGS and production cost reporting.' ;
    rdfs:domain ind:ProductionOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderCurrency rdf:type rdf:Property ;
    rdfs:label 'Order Currency' ;
    rdfs:comment 'ISO 4217 currency code in which the production order costs are recorded (transaction currency). Supports multi-currency cost reporting and consolidation.' ;
    rdfs:domain ind:ProductionOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderFinishDate rdf:type rdf:Property ;
    rdfs:label 'Order Finish Date' ;
    rdfs:comment 'Scheduled or actual finish date of the production order. Used to determine the cost collection period and support lead time analysis.' ;
    rdfs:domain ind:ProductionOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Order Quantity Unit' ;
    rdfs:comment 'Unit of measure for the production order quantity (e.g., EA, KG, L, M). Ensures correct unit cost calculations and cross-order comparisons.' ;
    rdfs:domain ind:ProductionOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStartDate rdf:type rdf:Property ;
    rdfs:label 'Order Start Date' ;
    rdfs:comment 'Scheduled or actual start date of the production order. Used to align cost collection with the production execution timeline.' ;
    rdfs:domain ind:ProductionOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current system status of the production order (e.g., Created, Released, Technically Complete, Closed). Determines whether further cost postings or settlements are permitted.' ;
    rdfs:domain ind:ProductionOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Cost Amount' ;
    rdfs:comment 'Total planned (standard) cost estimate for the production order as calculated by SAP CO-PC cost estimate. Represents the expected cost based on standard BOM and routing.' ;
    rdfs:domain ind:ProductionOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reworkCost rdf:type rdf:Property ;
    rdfs:label 'Rework Cost' ;
    rdfs:comment 'Cost of rework activities performed on the production order to correct non-conformances. Supports quality cost analysis and Non-Conformance Report (NCR) cost tracking.' ;
    rdfs:domain ind:ProductionOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'Date on which the production order costs were settled to the receiving cost objects. Used for period-end close tracking and audit trail.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Current settlement status of the production order cost object, indicating whether accumulated costs have been settled to the receiving cost objects (e.g., material stock, profitability segment, G/L account). Drives period-end close activities.' ;
    rdfs:domain ind:ProductionOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Technical Completion Date' ;
    rdfs:comment 'Date on which the production order was set to technically complete status in SAP, preventing further goods movements and activity confirmations. Marks the end of cost collection.' ;
    rdfs:domain ind:ProductionOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'Difference between actual total cost and planned (standard) cost for the production order. Positive value indicates cost overrun; negative indicates favorable variance. Core metric for manufacturing cost variance analysis.' ;
    rdfs:domain ind:ProductionOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceCategory rdf:type rdf:Property ;
    rdfs:label 'Variance Category' ;
    rdfs:comment 'SAP CO-PC variance category classifying the root cause of the cost variance (e.g., price variance, quantity variance, scrap variance, lot size variance). Enables targeted corrective action and CAPA processes.' ;
    rdfs:domain ind:ProductionOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipValue rdf:type rdf:Property ;
    rdfs:label 'Wip Value' ;
    rdfs:comment 'Value of Work In Progress (WIP) calculated for the production order at period-end. Represents costs accumulated on open orders not yet delivered to inventory. Required for balance sheet inventory valuation under IFRS IAS 2 and GAAP ASC 330.' ;
    rdfs:domain ind:ProductionOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Service Territory Id' ;
    rdfs:comment 'Foreign key linking to service.service_territory. Business justification: In industrial manufacturing, profitability is analyzed by service territory (region/zone). Finance maps profitability segments to service territories to report margin by geography — standard in CO-PA ' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceTerritory .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'SAP business area code representing an independent area of operations or responsibility within the enterprise, used for internal segment reporting and balance sheet preparation.' ;
    rdfs:domain ind:ProfitabilitySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cogsRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Cogs Relevant Flag' ;
    rdfs:comment 'Indicates whether cost of goods sold (COGS) postings are relevant for this profitability segment, controlling whether COGS flows into the contribution margin calculation.' ;
    rdfs:domain ind:ProfitabilitySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contributionMarginLevel rdf:type rdf:Property ;
    rdfs:label 'Contribution Margin Level' ;
    rdfs:comment 'Defines the contribution margin hierarchy level at which this segment is evaluated (CM1 = revenue minus variable COGS, CM2 = CM1 minus variable selling costs, CM3 = CM2 minus fixed costs, CM4 = CM3 minus overhead, EBITDA = earnings before interest, taxes, depreciation, and amortization).' ;
    rdfs:domain ind:ProfitabilitySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'Code classifying the functional area (e.g., manufacturing, sales, administration, R&D) for cost-of-sales accounting and income statement reporting by function of expense.' ;
    rdfs:domain ind:ProfitabilitySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs8ReportableSegmentFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs8 Reportable Segment Flag' ;
    rdfs:comment 'Indicates whether this profitability segment qualifies as a reportable operating segment under IFRS 8, requiring separate disclosure in external financial statements.' ;
    rdfs:domain ind:ProfitabilitySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:industryCode rdf:type rdf:Property ;
    rdfs:label 'Industry Code' ;
    rdfs:comment 'Industry classification code of the customer segment within this profitability segment (e.g., automotive, aerospace, energy, food and beverage), supporting vertical market profitability analysis.' ;
    rdfs:domain ind:ProfitabilitySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Parent Segment Code' ;
    rdfs:comment 'Code of the parent profitability segment in the hierarchy, enabling roll-up of contribution margin and EBITDA from sub-segments to higher-level reporting segments.' ;
    rdfs:domain ind:ProfitabilitySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productGroupCode rdf:type rdf:Property ;
    rdfs:label 'Product Group Code' ;
    rdfs:comment 'Code identifying the product group or product line dimension of the profitability segment, enabling contribution margin analysis by product family.' ;
    rdfs:domain ind:ProfitabilitySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productHierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Product Hierarchy Code' ;
    rdfs:comment 'SAP product hierarchy node code used to classify products within the segment for multi-level profitability drill-down reporting.' ;
    rdfs:domain ind:ProfitabilitySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Segment Hierarchy Level' ;
    rdfs:comment 'Numeric level within the profitability segment hierarchy, where level 1 represents the top-most aggregation and higher numbers represent more granular sub-segments.' ;
    rdfs:domain ind:ProfitabilitySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Descriptive name of the profitability segment used in management reporting and EBITDA dashboards.' ;
    rdfs:domain ind:ProfitabilitySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the segment dimension type used for multi-dimensional profitability analysis (e.g., product line, customer segment, geography, sales channel).' ;
    rdfs:domain ind:ProfitabilitySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPriceIndicator rdf:type rdf:Property ;
    rdfs:label 'Transfer Price Indicator' ;
    rdfs:comment 'Indicates whether intercompany transfer pricing is applied to postings within this profitability segment, relevant for eliminations and arm\'s-length pricing compliance.' ;
    rdfs:domain ind:ProfitabilitySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averagingMethod rdf:type rdf:Property ;
    rdfs:label 'Averaging Method' ;
    rdfs:comment 'For average-type exchange rates, specifies the mathematical method used to compute the average (e.g., simple average of daily closing rates, weighted average by transaction volume). Required for IAS 21 compliance when using average rates for P&L translation.' ;
    rdfs:domain ind:CurrencyExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationRelevant rdf:type rdf:Property ;
    rdfs:label 'Consolidation Relevant' ;
    rdfs:comment 'Indicates whether this exchange rate is designated for use in group financial consolidation and translation of subsidiary financial statements into the group reporting currency. Supports IAS 21 and IFRS 10 consolidation translation requirements.' ;
    rdfs:domain ind:CurrencyExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currencyPair rdf:type rdf:Property ;
    rdfs:label 'Currency Pair' ;
    rdfs:comment 'Concatenated display representation of the currency pair in standard FX market notation (e.g., USD/EUR, GBP/JPY). Used for reporting, dashboards, and FX analytics. Derived from from_currency_code and to_currency_code but stored for query performance.' ;
    rdfs:domain ind:CurrencyExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fromCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'From Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code of the source currency being converted from (e.g., USD, EUR, GBP). Represents the transaction or base currency in the exchange rate pair.' ;
    rdfs:domain ind:CurrencyExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inverseRate rdf:type rdf:Property ;
    rdfs:label 'Inverse Rate' ;
    rdfs:comment 'The reciprocal of the exchange rate (1 / exchange_rate), expressing how many units of the from-currency equal one unit of the to-currency. Stored explicitly to avoid division-by-zero errors and to support bidirectional conversion lookups in financial systems.' ;
    rdfs:domain ind:CurrencyExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isTriangulationRate rdf:type rdf:Property ;
    rdfs:label 'Is Triangulation Rate' ;
    rdfs:comment 'Indicates whether this exchange rate was derived via triangulation through a third reference currency (e.g., EUR as the pivot currency for non-EUR pairs within the Eurozone). Required for EU regulatory compliance and for auditing cross-rate derivation methodology.' ;
    rdfs:domain ind:CurrencyExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quotationMethod rdf:type rdf:Property ;
    rdfs:label 'Quotation Method' ;
    rdfs:comment 'Indicates whether the exchange rate is expressed as a direct quotation (units of domestic currency per one unit of foreign currency) or indirect quotation (units of foreign currency per one unit of domestic currency). Affects how the rate is applied in currency conversion calculations.' ;
    rdfs:domain ind:CurrencyExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCategory rdf:type rdf:Property ;
    rdfs:label 'Rate Category' ;
    rdfs:comment 'Categorizes the rate as mid-market, bank buying, bank selling, official central bank rate, or parallel market rate. Relevant for countries with multiple official exchange rate regimes and for treasury operations distinguishing between buy/sell rates.' ;
    rdfs:domain ind:CurrencyExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateDate rdf:type rdf:Property ;
    rdfs:label 'Rate Date' ;
    rdfs:comment 'The specific market date on which the exchange rate was observed or published by the rate source. For spot rates, this is the trade date. For average rates, this may be the last day of the averaging period. Distinct from valid_from_date which governs ERP applicability.' ;
    rdfs:domain ind:CurrencyExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateKey rdf:type rdf:Property ;
    rdfs:label 'Rate Key' ;
    rdfs:comment 'Business natural key uniquely identifying a rate record, composed of from-currency code, to-currency code, rate type, and valid-from date (e.g., USD_EUR_SPOT_2024-01-01). Supports idempotent upserts and deduplication in the lakehouse.' ;
    rdfs:domain ind:CurrencyExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateRatioFrom rdf:type rdf:Property ;
    rdfs:label 'Rate Ratio From' ;
    rdfs:comment 'The number of from-currency units used as the base for the exchange rate quotation (e.g., 100 for currencies quoted per 100 units such as JPY). Supports indirect quotation conventions where the rate is expressed per N units rather than per 1 unit.' ;
    rdfs:domain ind:CurrencyExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateRatioTo rdf:type rdf:Property ;
    rdfs:label 'Rate Ratio To' ;
    rdfs:comment 'The number of to-currency units used as the target for the exchange rate quotation. Together with rate_ratio_from, defines the exact quotation convention (e.g., 1 USD = 100 JPY expressed as ratio 1:100). Required for accurate cross-rate calculations.' ;
    rdfs:domain ind:CurrencyExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateSourceReference rdf:type rdf:Property ;
    rdfs:label 'Rate Source Reference' ;
    rdfs:comment 'Specific reference identifier or URL from the rate source (e.g., ECB publication reference, Reuters RIC code, Bloomberg ticker, or central bank bulletin reference). Provides traceability for audit and regulatory compliance purposes.' ;
    rdfs:domain ind:CurrencyExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rate Timestamp' ;
    rdfs:comment 'The precise date and time at which the exchange rate was captured or published, including timezone offset. Critical for intraday spot rates and for reconciling rates across time zones in a multinational treasury environment.' ;
    rdfs:domain ind:CurrencyExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rateTypeCode rdf:type rdf:Property ;
    rdfs:label 'Rate Type Code' ;
    rdfs:comment 'Short system code identifying the exchange rate type as configured in the ERP (e.g., \'M\' for standard translation, \'P\' for budget, \'B\' for bank buying rate in SAP S/4HANA). Enables direct mapping to source system rate type keys.' ;
    rdfs:domain ind:CurrencyExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revaluationRelevant rdf:type rdf:Property ;
    rdfs:label 'Revaluation Relevant' ;
    rdfs:comment 'Indicates whether this exchange rate is designated for use in foreign currency revaluation runs (e.g., month-end balance sheet revaluation of open items and balances). Supports IAS 21 revaluation processes in SAP S/4HANA FI.' ;
    rdfs:domain ind:CurrencyExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spreadRate rdf:type rdf:Property ;
    rdfs:label 'Spread Rate' ;
    rdfs:comment 'The bid-ask spread applied to the mid-market rate to derive the buying or selling rate used in actual transactions. Relevant for bank-fed rates and treasury operations where transaction costs are embedded in the rate.' ;
    rdfs:domain ind:CurrencyExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'To Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code of the target currency being converted to (e.g., EUR, USD, JPY). Represents the reporting or group currency in the exchange rate pair.' ;
    rdfs:domain ind:CurrencyExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triangulationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Triangulation Currency Code' ;
    rdfs:comment 'ISO 4217 code of the intermediate reference currency used in triangulation rate derivation (typically EUR for Eurozone cross-rates). Populated only when is_triangulation_rate is true.' ;
    rdfs:domain ind:CurrencyExchangeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:euTaxFlag rdf:type rdf:Property ;
    rdfs:label 'Eu Tax Flag' ;
    rdfs:comment 'Indicates whether this tax code is applicable to European Union intra-community transactions. When true, the tax code is used for EU cross-border supplies and acquisitions subject to EU VAT rules, including EC Sales List and Intrastat reporting.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glAccountTaxReceivable rdf:type rdf:Property ;
    rdfs:label 'Gl Account Tax Receivable' ;
    rdfs:comment 'GL account number assigned for posting tax receivable / deductible input tax amounts when this tax code is applied on purchase transactions. Supports VAT reclaim and input tax recovery processes.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'Code identifying the tax jurisdiction to which this tax code applies (e.g., country code, state/province code, or composite jurisdiction code for US sales tax). Supports multi-jurisdiction tax determination and cross-border transaction processing.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumTaxBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Tax Base Amount' ;
    rdfs:comment 'Minimum transaction base amount threshold below which this tax code is not applied. Used for de minimis tax rules and small transaction exemptions in certain jurisdictions.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nonDeductiblePercentage rdf:type rdf:Property ;
    rdfs:label 'Non Deductible Percentage' ;
    rdfs:comment 'Percentage of the input tax that is non-deductible and cannot be reclaimed as input VAT credit (e.g., 50% non-deductible for mixed-use assets). Used in partial VAT recovery calculations and tax return preparation.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingIndicator rdf:type rdf:Property ;
    rdfs:label 'Posting Indicator' ;
    rdfs:comment 'Controls how the tax amount is posted in the general ledger: posted to a separate tax GL account, distributed to the expense/revenue line item, or not posted at all. Determines the accounting treatment of tax amounts in financial postings.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingTaxCodeFlag rdf:type rdf:Property ;
    rdfs:label 'Purchasing Tax Code Flag' ;
    rdfs:comment 'Indicates whether this tax code is configured for use in purchasing (procurement) transactions within SAP MM/Ariba. When true, the code is available for assignment on purchase orders, goods receipts, and vendor invoices.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingCategory rdf:type rdf:Property ;
    rdfs:label 'Reporting Category' ;
    rdfs:comment 'Categorization of the tax code for statutory tax reporting purposes. Determines which tax return or regulatory report this tax code contributes to (e.g., VAT return box mapping, Intrastat, EC Sales List, withholding tax return). Supports automated tax return preparation.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reverseChargeFlag rdf:type rdf:Property ;
    rdfs:label 'Reverse Charge Flag' ;
    rdfs:comment 'Indicates whether this tax code applies the reverse charge mechanism, where the tax liability is shifted from the supplier to the customer (common in B2B cross-border EU transactions and construction services). When true, the buyer self-accounts for VAT.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesTaxCodeFlag rdf:type rdf:Property ;
    rdfs:label 'Sales Tax Code Flag' ;
    rdfs:comment 'Indicates whether this tax code is configured for use in sales (order-to-cash) transactions within SAP SD. When true, the code is available for assignment on sales orders, billing documents, and customer invoices.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Name' ;
    rdfs:comment 'Name of the tax authority or revenue agency responsible for administering this tax code (e.g., \'Bundeszentralamt für Steuern\' for Germany, \'IRS\' for USA, \'HMRC\' for UK). Used for tax remittance and compliance reporting.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxBaseAmountType rdf:type rdf:Property ;
    rdfs:label 'Tax Base Amount Type' ;
    rdfs:comment 'Defines the basis on which the tax rate is applied: net amount (tax calculated on net invoice value), gross amount (tax calculated on gross including other taxes), tax-on-tax (cascading tax), or fixed amount. Determines the tax calculation logic for financial transactions.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionReason rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Reason' ;
    rdfs:comment 'Description or code of the legal basis for tax exemption when the tax rate is zero or the category is \'exempt\' (e.g., \'Intra-community supply Article 138 VAT Directive\', \'Export supply\', \'Medical exemption\'). Required for statutory reporting and audit trail.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxGroup rdf:type rdf:Property ;
    rdfs:label 'Tax Group' ;
    rdfs:comment 'Grouping classification for tax codes used in tax reporting, analytics, and consolidation (e.g., \'EU_VAT\', \'US_SALES_TAX\', \'WITHHOLDING\', \'EXCISE\'). Supports aggregated tax reporting across jurisdictions and tax type consolidation.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxProcedureCode rdf:type rdf:Property ;
    rdfs:label 'Tax Procedure Code' ;
    rdfs:comment 'Code identifying the tax calculation procedure or tax schema to which this tax code belongs (e.g., SAP tax procedure TAXD for Germany, TAXUS for USA). Determines the sequence of condition types used in tax calculation.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRateChangeReason rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Change Reason' ;
    rdfs:comment 'Description of the reason for a tax rate change or new tax code creation (e.g., \'Legislative amendment effective 2024-01-01\', \'COVID-19 temporary rate reduction\', \'Post-Brexit UK VAT adjustment\'). Provides audit trail for tax rate history.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percentage' ;
    rdfs:comment 'The applicable tax rate expressed as a percentage (e.g., 19.0000 for 19% German VAT, 7.2500 for 7.25% California sales tax). Used in tax calculation on financial transactions and tax return filings.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxReturnBoxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Return Box Code' ;
    rdfs:comment 'Reference code mapping this tax code to a specific box or line on the statutory tax return form (e.g., VAT return box number, sales tax schedule line). Enables automated population of tax returns from transaction data.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'Classification of the tax code by tax mechanism. Distinguishes between input VAT (recoverable tax on purchases), output VAT (tax charged on sales), withholding tax (tax deducted at source), sales tax, use tax, excise duty, and other tax types. Critical for VAT return preparation and tax compliance reporting.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDirection rdf:type rdf:Property ;
    rdfs:label 'Transaction Direction' ;
    rdfs:comment 'Indicates whether this tax code is applicable to purchase transactions (accounts payable / input tax), sales transactions (accounts receivable / output tax), or both directions. Controls tax code availability in procurement and sales processes.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxType rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Type' ;
    rdfs:comment 'For withholding tax codes, specifies whether withholding tax is calculated and posted at the time of invoice posting, payment posting, or both. Applicable only when tax_type is \'withholding_tax\'. Supports accurate WHT liability tracking and remittance.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Sla Commitment Id' ;
    rdfs:comment 'Foreign key linking to service.sla_commitment. Business justification: Each service request is governed by a specific SLA commitment that defines response and resolution targets. The sla_tier, sla_response_target_hours, and sla_resolution_target_hours on request are deno' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaCommitment .

ind:assignedEngineer rdf:type rdf:Property ;
    rdfs:label 'Assigned Engineer' ;
    rdfs:comment 'Full name of the support engineer or field service technician currently assigned as the primary owner responsible for resolving this service request.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned Team' ;
    rdfs:comment 'Name of the support team or service group to which the service request is currently assigned, used for workload distribution and team-level SLA reporting.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Human-readable, business-facing case reference number assigned at case creation, used for customer communication and cross-system tracking.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Current escalation level of the service request (0=not escalated, 1=first-level escalation, 2=management escalation, 3=executive escalation), tracking how far the case has been elevated.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Reason code explaining why the service request was escalated, used for root cause analysis of escalation patterns and process improvement.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'External Reference Number' ;
    rdfs:comment 'Customer-provided reference number or ticket number from the customer\'s own system, used for cross-referencing and customer communication.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Response Timestamp' ;
    rdfs:comment 'Date and time when the first substantive response was provided to the customer, used to measure first response time against SLA targets.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isEscalated rdf:type rdf:Property ;
    rdfs:label 'Is Escalated' ;
    rdfs:comment 'Flag indicating whether the service request has been escalated beyond the initial support tier, triggering escalation workflows and management notifications.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWarrantyClaim rdf:type rdf:Property ;
    rdfs:label 'Is Warranty Claim' ;
    rdfs:comment 'Flag indicating whether this service request has been formally classified as a warranty claim, triggering warranty claim processing workflows and cost recovery from manufacturing.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opened Timestamp' ;
    rdfs:comment 'Date and time when the service request was officially opened and entered into the system, marking the start of SLA clock for response and resolution time measurement.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originChannel rdf:type rdf:Property ;
    rdfs:label 'Origin Channel' ;
    rdfs:comment 'The channel through which the customer initiated the service request (e.g., phone, email, web portal, field technician). Used for channel analytics and SLA routing.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Detailed description of the steps taken and actions performed to resolve the service request, including any parts replaced, configuration changes, or software updates applied.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionType rdf:type rdf:Property ;
    rdfs:label 'Resolution Type' ;
    rdfs:comment 'Classification of the resolution method applied to close the service request, used for service cost analysis and field service optimization.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolved Timestamp' ;
    rdfs:comment 'Date and time when the service request issue was technically resolved and the resolution was communicated to the customer, used for resolution time SLA measurement.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Business impact severity classification of the service request, used to prioritize response and determine SLA tier. Critical indicates production stoppage or safety risk.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subCategory rdf:type rdf:Property ;
    rdfs:label 'Sub Category' ;
    rdfs:comment 'Secondary classification providing more granular categorization within the primary case category (e.g., under \'technical_support\': hardware_failure, software_bug, configuration_issue).' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyClaimId rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Id' ;
    rdfs:comment 'Unique system-generated identifier for each warranty claim record in the Manufacturing service domain.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarrantyClaim .

ind:technicianId rdf:type rdf:Property ;
    rdfs:label 'Technician Id' ;
    rdfs:comment 'Foreign key linking to service.technician. Business justification: The warranty_claim.service_technician_name STRING is a denormalized reference to the technician who performed the warranty service. Adding technician_id FK normalizes this to the authoritative technic' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:claimNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Number' ;
    rdfs:comment 'Human-readable business reference number for the warranty claim, used in customer communications and cross-system tracking. Formatted as WC-YYYY-NNNNNNNN.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Classification of the warranty claim resolution type requested: repair of the defective unit, replacement with a new unit, credit note issuance, cash refund, on-site field service, or product exchange.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimedAmount rdf:type rdf:Property ;
    rdfs:label 'Claimed Amount' ;
    rdfs:comment 'The total monetary amount claimed by the customer for warranty coverage, including repair costs, replacement parts, labor, and logistics.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decision rdf:type rdf:Property ;
    rdfs:label 'Decision' ;
    rdfs:comment 'Final or interim adjudication decision on the warranty claim indicating whether the claim has been approved, rejected, or partially approved for coverage.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectLocation rdf:type rdf:Property ;
    rdfs:label 'Defect Location' ;
    rdfs:comment 'Specific component, assembly, or functional area of the product where the defect was identified, such as \'power supply module\', \'CPU board\', or \'terminal block\'.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalClaimReference rdf:type rdf:Property ;
    rdfs:label 'External Claim Reference' ;
    rdfs:comment 'Customer-provided or third-party reference number for the warranty claim, such as a customer\'s internal purchase order or insurance claim number.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isWithinWarranty rdf:type rdf:Property ;
    rdfs:label 'Is Within Warranty' ;
    rdfs:comment 'Indicates whether the product was within its active warranty period at the time the claim was submitted. Determined during claim validation against warranty start and end dates.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productModelNumber rdf:type rdf:Property ;
    rdfs:label 'Product Model Number' ;
    rdfs:comment 'Model or part number of the product under warranty claim, identifying the product family and configuration from the product catalog.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairCost rdf:type rdf:Property ;
    rdfs:label 'Repair Cost' ;
    rdfs:comment 'Actual cost incurred to repair the defective product under warranty, including labor, parts, and overhead. Used for warranty reserve accounting and cost of quality reporting.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replacementPartNumber rdf:type rdf:Property ;
    rdfs:label 'Replacement Part Number' ;
    rdfs:comment 'Part number of the replacement component or unit provided under the warranty claim. Applicable when claim type is replacement or repair requiring parts.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Replacement Serial Number' ;
    rdfs:comment 'Serial number of the replacement unit dispatched to the customer under the warranty claim. Used to update the installed base and transfer warranty coverage.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'The date on which the warranty claim was operationally resolved (repair completed, replacement shipped, or service performed), distinct from financial settlement date.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnMaterialAuthorization rdf:type rdf:Property ;
    rdfs:label 'Return Material Authorization' ;
    rdfs:comment 'Return Material Authorization (RMA) number issued to the customer for returning the defective product. Required for logistics tracking and goods receipt processing.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierChargebackAmount rdf:type rdf:Property ;
    rdfs:label 'Supplier Chargeback Amount' ;
    rdfs:comment 'Monetary amount to be recovered from the supplier responsible for the defective component or material that caused the warranty claim.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierChargebackFlag rdf:type rdf:Property ;
    rdfs:label 'Supplier Chargeback Flag' ;
    rdfs:comment 'Indicates whether the warranty claim cost has been or will be charged back to a supplier due to a supplier-caused defect. Triggers supplier quality management and procurement processes.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availabilityTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Availability Target Percent' ;
    rdfs:comment 'Contractually committed equipment or system availability percentage for the covered asset on this line (e.g., 99.5%). Used for SLA compliance reporting and penalty/bonus calculations.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'Frequency at which this contract line is invoiced to the customer (e.g., monthly, quarterly, annually, or one-time). Drives the billing plan and revenue recognition schedule.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPlanType rdf:type rdf:Property ;
    rdfs:label 'Billing Plan Type' ;
    rdfs:comment 'Type of billing plan applied to this contract line, indicating whether billing is periodic (time-based), milestone-driven, on-demand, prepaid, or postpaid. Determines the invoicing logic in SAP SD.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageEndDate rdf:type rdf:Property ;
    rdfs:label 'Coverage End Date' ;
    rdfs:comment 'Date on which service coverage for this specific contract line expires. Used for renewal tracking, SLA enforcement, and billing period management.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageHours rdf:type rdf:Property ;
    rdfs:label 'Coverage Hours' ;
    rdfs:comment 'Service coverage window for this contract line, defining the hours and days during which the SLA obligations apply (e.g., 8x5 for 8 hours/5 days, 24x7 for round-the-clock coverage).' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageStartDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Start Date' ;
    rdfs:comment 'Date on which service coverage for this specific contract line becomes effective. May differ from the parent contract start date if coverage for individual assets is staggered.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coveredEquipmentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Covered Equipment Serial Number' ;
    rdfs:comment 'Serial number of the specific physical equipment or asset covered by this contract line. Links the service obligation to a unique installed asset in the field. Corresponds to the installed base serial number.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installedBaseReference rdf:type rdf:Property ;
    rdfs:label 'Installed Base Reference' ;
    rdfs:comment 'Reference identifier for the installed base record associated with this contract line. Used when coverage applies to an installed base entry rather than a single serialized asset, supporting multi-unit or fleet coverage scenarios.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineDescription rdf:type rdf:Property ;
    rdfs:label 'Line Description' ;
    rdfs:comment 'Free-text description of the service scope, covered equipment, or service bundle for this specific contract line item. Provides human-readable context for the contracted service.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineValue rdf:type rdf:Property ;
    rdfs:label 'Line Value' ;
    rdfs:comment 'Total monetary value of this contract line, calculated as net price multiplied by quantity. Represents the contracted revenue for this specific line item over the coverage period.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClauseApplicable rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Applicable' ;
    rdfs:comment 'Indicates whether financial penalties apply to this contract line if SLA targets (response time, resolution time, availability) are not met. Triggers penalty calculation workflows upon SLA breach.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveVisitsPerYear rdf:type rdf:Property ;
    rdfs:label 'Preventive Visits Per Year' ;
    rdfs:comment 'Number of scheduled preventive maintenance visits included in this contract line per year. Drives field service scheduling and resource planning for the covered asset.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productNumber rdf:type rdf:Property ;
    rdfs:label 'Product Number' ;
    rdfs:comment 'Material or product number identifying the service product, spare part bundle, or equipment model covered by this contract line. Aligns with the product catalog in SAP S/4HANA MM.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCategory rdf:type rdf:Property ;
    rdfs:label 'Service Category' ;
    rdfs:comment 'High-level category grouping for the service line, aligning with the company\'s service portfolio structure (e.g., hardware maintenance, software support, electrification services). Used for revenue reporting and portfolio analysis.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softwareUpdatesIncluded rdf:type rdf:Property ;
    rdfs:label 'Software Updates Included' ;
    rdfs:comment 'Indicates whether firmware and software updates for the covered equipment are included in the scope of this contract line. Relevant for PLC, SCADA, HMI, and automation system contracts.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableCountryCode rdf:type rdf:Property ;
    rdfs:label 'Applicable Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code specifying the country to which this SLA commitment applies when geographic_scope is set to \'country\'. Supports country-specific regulatory and operational SLA variations.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableProductCategory rdf:type rdf:Property ;
    rdfs:label 'Applicable Product Category' ;
    rdfs:comment 'The product or equipment category to which this SLA commitment applies, such as automation systems, electrification solutions, smart infrastructure components, or MRO spare parts. Allows SLA commitments to be scoped to specific product lines within the installed base.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableServiceRequestCategory rdf:type rdf:Property ;
    rdfs:label 'Applicable Service Request Category' ;
    rdfs:comment 'The type of service request or work order category to which this SLA commitment applies. Enables different SLA targets for different service activities (e.g., emergency breakdown response vs. scheduled preventive maintenance).' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachCountPeriod rdf:type rdf:Property ;
    rdfs:label 'Breach Count Period' ;
    rdfs:comment 'The time window over which breach counts are accumulated for the purpose of evaluating max_breach_count_before_termination and penalty caps. Defines the rolling or calendar period for breach tracking.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Breach Threshold Value' ;
    rdfs:comment 'The numeric value at which the SLA is considered breached. For time-based SLAs, this is the maximum allowable duration before a breach is triggered. For rate-based SLAs, this is the minimum acceptable performance level below which a breach is declared.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageHoursType rdf:type rdf:Property ;
    rdfs:label 'Coverage Hours Type' ;
    rdfs:comment 'Defines the operational coverage window within which the SLA commitment is measured and enforced. 24x7 means the SLA clock runs continuously; Business Hours means only standard working hours count; Extended Hours covers evenings and weekends; Custom requires reference to a defined schedule.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageTimezone rdf:type rdf:Property ;
    rdfs:label 'Coverage Timezone' ;
    rdfs:comment 'The IANA timezone identifier used as the reference timezone for measuring SLA coverage hours and breach calculations (e.g., America/New_York, Europe/Berlin, Asia/Singapore). Critical for multinational operations where service delivery spans multiple time zones.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerTier rdf:type rdf:Property ;
    rdfs:label 'Customer Tier' ;
    rdfs:comment 'The customer segment or tier to which this SLA commitment applies. Enables differentiated service levels based on customer value, contract type, or strategic importance. Platinum and Gold tiers typically receive more aggressive response and resolution commitments.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTriggerUnit rdf:type rdf:Property ;
    rdfs:label 'Escalation Trigger Unit' ;
    rdfs:comment 'Unit of measure for the escalation_trigger_value, defining how the escalation threshold is quantified (e.g., hours elapsed, percent of target consumed).' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTriggerValue rdf:type rdf:Property ;
    rdfs:label 'Escalation Trigger Value' ;
    rdfs:comment 'The numeric threshold at which an escalation action is automatically triggered, typically set before the breach threshold to provide a warning window. For example, escalate at 3 hours for a 4-hour response SLA. Enables proactive intervention before a formal breach occurs.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRegulatoryMandated rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Mandated' ;
    rdfs:comment 'Indicates whether this SLA commitment is mandated by a regulatory body or government authority (e.g., OSHA safety response requirements, EPA environmental incident response). Regulatory-mandated SLAs may carry legal penalties beyond contractual penalties.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxBreachCountBeforeTermination rdf:type rdf:Property ;
    rdfs:label 'Max Breach Count Before Termination' ;
    rdfs:comment 'The maximum number of SLA breaches within a defined period before the customer is contractually entitled to terminate the service contract. Provides a quantitative threshold for contract termination rights.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementStartEvent rdf:type rdf:Property ;
    rdfs:label 'Measurement Start Event' ;
    rdfs:comment 'Defines the business event that starts the SLA clock for measurement purposes. Case Creation starts the timer when the service request is logged; Case Assignment starts when a technician is assigned; Customer Notification starts when the customer is informed; Engineer Dispatch starts when a field engineer is dispatched.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStopEvent rdf:type rdf:Property ;
    rdfs:label 'Measurement Stop Event' ;
    rdfs:comment 'Defines the business event that stops the SLA clock for measurement purposes. Case Resolved stops the timer when the service case is closed; Customer Confirmed stops when the customer acknowledges resolution; System Restored stops when the equipment is returned to operational status.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCapPeriod rdf:type rdf:Property ;
    rdfs:label 'Penalty Cap Period' ;
    rdfs:comment 'The time period over which the penalty_cap_value is applied and reset. Defines the accumulation window for penalty calculations (e.g., monthly cap resets at the start of each calendar month).' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyUnit rdf:type rdf:Property ;
    rdfs:label 'Penalty Unit' ;
    rdfs:comment 'Defines how the penalty_value is applied and measured. Percent of Monthly Fee applies the penalty as a percentage of the monthly service fee; Fixed Amount applies a flat monetary penalty; Percent Per Hour Breach applies a compounding penalty for each hour of breach duration.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyValue rdf:type rdf:Property ;
    rdfs:label 'Penalty Value' ;
    rdfs:comment 'The numeric value of the penalty applied upon SLA breach. For financial penalties and service credits, this represents the monetary amount or percentage of contract value. Interpreted in conjunction with penalty_unit. Classified as confidential due to commercial sensitivity.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceDeliveryChannel rdf:type rdf:Property ;
    rdfs:label 'Service Delivery Channel' ;
    rdfs:comment 'Specifies the mode of service delivery to which this SLA commitment applies. On-Site requires a field engineer dispatch; Remote covers telephone, email, or digital support; Hybrid combines remote and on-site; Parts Only covers spare part delivery without labor.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMetricValue rdf:type rdf:Property ;
    rdfs:label 'Target Metric Value' ;
    rdfs:comment 'The numeric performance target defined for this SLA commitment. For example, 4 (hours) for a response time SLA, 99.5 (percent) for an uptime guarantee, or 85 (percent) for a first-time fix rate. Interpreted in conjunction with measurement_unit.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTrackingId rdf:type rdf:Property ;
    rdfs:label 'Sla Tracking Id' ;
    rdfs:comment 'Unique system-generated identifier for each SLA tracking record. Serves as the primary key for the sla_tracking data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Assigned Technician Id' ;
    rdfs:comment 'Employee identifier of the field service technician or support engineer currently assigned to resolve the service request or field service order. Used for individual-level SLA performance tracking.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:dispatchScheduleId rdf:type rdf:Property ;
    rdfs:label 'Dispatch Schedule Id' ;
    rdfs:comment 'Foreign key linking to service.dispatch_schedule. Business justification: SLA tracking records monitor compliance for field service orders that are executed via dispatch schedules. Linking sla_tracking.dispatch_schedule_id → dispatch_schedule.dispatch_schedule_id connects t' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DispatchSchedule .

ind:actualResolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Timestamp' ;
    rdfs:comment 'The actual date and time at which the service issue was fully resolved and the case or field service order was closed. Null if resolution has not yet occurred. Used to determine resolution SLA compliance.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Response Timestamp' ;
    rdfs:comment 'The actual date and time at which the service team provided the initial response or acknowledgement to the customer. Null if the response has not yet been made. Used to determine response SLA compliance.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breachDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Breach Duration Minutes' ;
    rdfs:comment 'The number of minutes by which the SLA target was exceeded at the time of resolution or as of the current timestamp for open breaches. Zero or null for records that have not breached. Used for breach severity analysis and penalty calculations.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachReasonCode rdf:type rdf:Property ;
    rdfs:label 'Breach Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why the SLA was breached. Used for root cause analysis, CAPA (Corrective and Preventive Action) workflows, and service improvement initiatives.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Breach Reason Description' ;
    rdfs:comment 'Free-text narrative providing additional context for the SLA breach beyond the standardized breach reason code. Captures specific circumstances, contributing factors, and corrective actions taken.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessHoursCalendar rdf:type rdf:Property ;
    rdfs:label 'Business Hours Calendar' ;
    rdfs:comment 'Name or code of the business hours calendar applied to this SLA tracking record. Determines which hours count toward SLA elapsed time (e.g., 24x7, 8x5, regional business hours). Critical for multinational operations with varying time zones.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'The date and time at which the SLA tracking record was escalated. Null if no escalation has occurred. Used to measure escalation response time and management intervention effectiveness.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationSent rdf:type rdf:Property ;
    rdfs:label 'Notification Sent' ;
    rdfs:comment 'Indicates whether an at-risk or breach warning notification has been sent to the assigned team, service manager, or customer for this SLA tracking record. Used to prevent duplicate notifications and track proactive communication.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pauseDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Pause Duration Minutes' ;
    rdfs:comment 'Total accumulated minutes for which the SLA clock was paused for this tracking record. Used to adjust effective SLA elapsed time and ensure fair compliance measurement when delays are customer-attributable.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pauseReason rdf:type rdf:Property ;
    rdfs:label 'Pause Reason' ;
    rdfs:comment 'Reason for pausing the SLA clock. Used to distinguish customer-attributable delays from service team delays in SLA compliance reporting.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pauseStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pause Start Timestamp' ;
    rdfs:comment 'The date and time at which the SLA clock was paused, typically due to awaiting customer response, pending parts delivery, or other customer-side dependencies. Null if the SLA clock has not been paused.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'The financial penalty or service credit amount applicable for the SLA breach, expressed in the contract currency. Populated only when penalty_applicable is true and the breach has been confirmed. Used for financial reporting and customer credit processing.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyApplicable rdf:type rdf:Property ;
    rdfs:label 'Penalty Applicable' ;
    rdfs:comment 'Indicates whether a financial penalty or service credit is contractually applicable for a breach of this SLA commitment. Determined by the terms of the governing service contract.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordSource rdf:type rdf:Property ;
    rdfs:label 'Record Source' ;
    rdfs:comment 'Identifies the operational system of record from which this SLA tracking record originated. Used for data lineage, reconciliation, and audit purposes in the Databricks Silver Layer.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Due Timestamp' ;
    rdfs:comment 'The committed deadline by which the service issue must be fully resolved and the case or field service order closed. Calculated from the SLA start timestamp plus the contracted resolution time target.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Specific compliance status for the resolution SLA milestone. Indicates whether the service issue was resolved within the committed resolution target time.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Resolution Target Minutes' ;
    rdfs:comment 'The contracted SLA target for full resolution, expressed in minutes. Derived from the applicable SLA tier and priority combination. Used as the baseline for resolution compliance measurement.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseDueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Due Timestamp' ;
    rdfs:comment 'The committed deadline by which the service team must provide an initial response or acknowledgement to the customer. Calculated from the SLA start timestamp plus the contracted response time target.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Specific compliance status for the response SLA milestone. Indicates whether the initial response was provided within the committed response target time.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Response Target Minutes' ;
    rdfs:comment 'The contracted SLA target for initial response, expressed in minutes. Derived from the applicable SLA tier and priority combination. Used as the baseline for response compliance measurement.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Start Timestamp' ;
    rdfs:comment 'The exact date and time at which the SLA clock started for this tracking record. Typically corresponds to the moment the service request was created or the field service order was dispatched, after any applicable business hours calendar adjustments.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Classification of the SLA commitment being tracked. Distinguishes between response SLAs (time to acknowledge), resolution SLAs (time to close), on-site arrival SLAs (field dispatch), and other commitment types.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warningThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Warning Threshold Percent' ;
    rdfs:comment 'The percentage of the SLA target time elapsed at which the status transitions from on-track to at-risk, triggering proactive warning notifications. Typically set at 75-80% of the target time.' ;
    rdfs:domain ind:SlaTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activeWorkOrderCount rdf:type rdf:Property ;
    rdfs:label 'Active Work Order Count' ;
    rdfs:comment 'Current number of open or in-progress work orders assigned to the technician. Used by the dispatch scheduling engine to assess workload capacity before assigning new work orders. Updated in near-real-time from the field service management system.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'Real-time operational availability of the technician for new dispatch assignments. Distinct from employment status — a technician may be \'active\' but currently \'dispatched\' on an existing work order. Used by the field service scheduling engine for optimal dispatch.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseLocationCity rdf:type rdf:Property ;
    rdfs:label 'Base Location City' ;
    rdfs:comment 'City of the technician\'s primary base location. Used for geographic dispatch optimization, travel time calculations, and regional reporting.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseLocationName rdf:type rdf:Property ;
    rdfs:label 'Base Location Name' ;
    rdfs:comment 'Name of the technician\'s primary base location or service depot (e.g., \'Chicago Service Center\', \'Frankfurt Depot\', \'Singapore Hub\'). Represents the physical facility from which the technician is dispatched and to which they return after field assignments.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseLocationStateProvince rdf:type rdf:Property ;
    rdfs:label 'Base Location State Province' ;
    rdfs:comment 'State or province of the technician\'s primary base location. Used for regional dispatch grouping, labor law compliance determination, and territory management.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this technician record was sourced or last updated. Supports data lineage tracking and conflict resolution when records are updated from multiple upstream systems.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electricalSafetyCertExpiry rdf:type rdf:Property ;
    rdfs:label 'Electrical Safety Cert Expiry' ;
    rdfs:comment 'Expiration date of the technician\'s electrical safety certification. Dispatch systems must validate this date before assigning electrical work orders. Triggers recertification workflow when within 30 days of expiry.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:electricalSafetyCertified rdf:type rdf:Property ;
    rdfs:label 'Electrical Safety Certified' ;
    rdfs:comment 'Indicates whether the technician holds a current electrical safety certification required for work on live electrical panels, switchgear, and high-voltage automation equipment. Mandatory for compliance with OSHA 29 CFR 1910.333 and NFPA 70E. Blocks assignment to electrical work orders if false.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date on which the technician was hired or onboarded into the service organization. Used to calculate tenure, determine eligibility for advanced certifications, and support workforce analytics.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:installationAuthorized rdf:type rdf:Property ;
    rdfs:label 'Installation Authorized' ;
    rdfs:comment 'Indicates whether the technician is certified and authorized to perform new product installation and commissioning at customer sites. Installation work requires completion of product-specific commissioning training and safety certifications.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborRateCurrency rdf:type rdf:Property ;
    rdfs:label 'Labor Rate Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the technician\'s standard labor rate (e.g., \'USD\', \'EUR\', \'GBP\'). Required for multi-currency service order costing in multinational operations.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagesSpoken rdf:type rdf:Property ;
    rdfs:label 'Languages Spoken' ;
    rdfs:comment 'Pipe-delimited list of ISO 639-1 language codes representing languages the technician can communicate in (e.g., \'en|de|fr|zh\'). Used for customer-facing dispatch matching in multinational operations to ensure effective on-site communication.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCertificationReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Certification Review Date' ;
    rdfs:comment 'Date of the most recent formal review of the technician\'s skill certifications and competency records. Used to trigger periodic recertification workflows and ensure compliance with ISO 9001 competence management requirements.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxConcurrentWorkOrders rdf:type rdf:Property ;
    rdfs:label 'Max Concurrent Work Orders' ;
    rdfs:comment 'Maximum number of work orders the technician is authorized to hold simultaneously, based on role, seniority, and service agreement requirements. Used as a capacity constraint in the dispatch scheduling algorithm.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextCertificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Certification Due Date' ;
    rdfs:comment 'Date by which the technician must complete their next certification renewal or competency assessment. Drives automated recertification reminders and dispatch eligibility checks for regulated work types.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productLineCompetency rdf:type rdf:Property ;
    rdfs:label 'Product Line Competency' ;
    rdfs:comment 'Pipe-delimited list of product lines the technician is qualified to service (e.g., \'drives|PLCs|HMI|switchgear|motors|robotics\'). Derived from completed product-specific training and certification programs. Used by dispatch to match technician competency to the product requiring service.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteSupportCapable rdf:type rdf:Property ;
    rdfs:label 'Remote Support Capable' ;
    rdfs:comment 'Indicates whether the technician is equipped and authorized to provide remote technical support via digital tools (e.g., Siemens MindSphere, remote desktop, AR-assisted support). Enables routing of remote support cases to qualified technicians without physical dispatch.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seniorityLevel rdf:type rdf:Property ;
    rdfs:label 'Seniority Level' ;
    rdfs:comment 'Experience and seniority classification of the technician within the service organization. Used for work order complexity routing, mentoring assignments, and labor cost tier determination.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceContractEligible rdf:type rdf:Property ;
    rdfs:label 'Service Contract Eligible' ;
    rdfs:comment 'Indicates whether the technician is authorized to perform work under contracted service agreements (SLAs). Technicians without this flag may only be assigned to time-and-material or warranty work orders, not to SLA-governed service contracts.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Start Date' ;
    rdfs:comment 'Date on which the technician was activated in the service domain system (Salesforce Field Service). May differ from hire_date if the technician transferred from another department or was onboarded to field service after initial employment.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:skillCertifications rdf:type rdf:Property ;
    rdfs:label 'Skill Certifications' ;
    rdfs:comment 'Pipe-delimited list of technical skill certifications held by the technician (e.g., \'PLC_programming|drive_commissioning|HMI_configuration|electrical_safety|SCADA_configuration|CNC_maintenance\'). Each certification corresponds to a validated competency assessment. Used for skill-based dispatch routing.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardLaborRate rdf:type rdf:Property ;
    rdfs:label 'Standard Labor Rate' ;
    rdfs:comment 'Standard hourly billing rate for the technician\'s labor, used for service order costing, customer invoice generation, and profitability analysis. Expressed in the technician\'s base currency. Classified as confidential business data.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:travelAuthorized rdf:type rdf:Property ;
    rdfs:label 'Travel Authorized' ;
    rdfs:comment 'Indicates whether the technician is authorized for international travel assignments. Requires valid passport, work visa eligibility, and completion of international travel safety training. Used to filter eligible technicians for cross-border dispatch.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyWorkAuthorized rdf:type rdf:Property ;
    rdfs:label 'Warranty Work Authorized' ;
    rdfs:comment 'Indicates whether the technician is authorized to perform warranty repair and replacement work. Warranty work requires specific product training and authorization to ensure compliance with warranty terms and avoid voiding customer warranty coverage.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:activeTechnicianCount rdf:type rdf:Property ;
    rdfs:label 'Active Technician Count' ;
    rdfs:comment 'Current number of active field service technicians assigned to this territory, used for capacity planning, workload balancing, and dispatch optimization.' ;
    rdfs:domain ind:ServiceTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:areaSizeKm2 rdf:type rdf:Property ;
    rdfs:label 'Area Size Km2' ;
    rdfs:comment 'Total geographic area of the service territory measured in square kilometers, used for workload density analysis, technician travel time estimation, and territory rebalancing.' ;
    rdfs:domain ind:ServiceTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageDays rdf:type rdf:Property ;
    rdfs:label 'Coverage Days' ;
    rdfs:comment 'Comma-separated list of days of the week on which field service coverage is provided in this territory (e.g., MON,TUE,WED,THU,FRI). Supports SLA scheduling and dispatch availability checks.' ;
    rdfs:domain ind:ServiceTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Coverage Hours End' ;
    rdfs:comment 'Daily end time (HH:MM, 24-hour format) of standard field service coverage for this territory, used in SLA scheduling and dispatch window enforcement.' ;
    rdfs:domain ind:ServiceTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageHoursStart rdf:type rdf:Property ;
    rdfs:label 'Coverage Hours Start' ;
    rdfs:comment 'Daily start time (HH:MM, 24-hour format) of standard field service coverage for this territory, used in SLA scheduling and dispatch window enforcement.' ;
    rdfs:domain ind:ServiceTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchPriority rdf:type rdf:Property ;
    rdfs:label 'Dispatch Priority' ;
    rdfs:comment 'Numeric priority ranking used by the dispatch engine to sequence territory-based assignments when multiple territories overlap or compete for the same technician resource. Lower values indicate higher priority.' ;
    rdfs:domain ind:ServiceTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:is24x7Coverage rdf:type rdf:Property ;
    rdfs:label 'Is 24x7 Coverage' ;
    rdfs:comment 'Indicates whether this service territory provides round-the-clock, 24 hours a day, 7 days a week field service coverage. Relevant for critical infrastructure and high-priority SLA contracts.' ;
    rdfs:domain ind:ServiceTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxTechnicianCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Technician Capacity' ;
    rdfs:comment 'Maximum number of technicians this territory is designed to support based on geographic size, workload projections, and service center capacity. Used for workforce planning and territory expansion decisions.' ;
    rdfs:domain ind:ServiceTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postalCodeEnd rdf:type rdf:Property ;
    rdfs:label 'Postal Code End' ;
    rdfs:comment 'Ending postal code defining the upper bound of the postal code range covered by this service territory, used in conjunction with postal_code_start for boundary definition.' ;
    rdfs:domain ind:ServiceTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCodeStart rdf:type rdf:Property ;
    rdfs:label 'Postal Code Start' ;
    rdfs:comment 'Starting postal code defining the lower bound of the postal code range covered by this service territory, used for geographic boundary enforcement in dispatch.' ;
    rdfs:domain ind:ServiceTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCenterCode rdf:type rdf:Property ;
    rdfs:label 'Service Center Code' ;
    rdfs:comment 'Alphanumeric code identifying the service center assigned to this territory, used for cross-system integration with SAP S/4HANA and Maximo EAM.' ;
    rdfs:domain ind:ServiceTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCenterName rdf:type rdf:Property ;
    rdfs:label 'Service Center Name' ;
    rdfs:comment 'Name of the primary service center or depot responsible for dispatching technicians and managing spare parts inventory for this territory.' ;
    rdfs:domain ind:ServiceTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelTimeLimitMinutes rdf:type rdf:Property ;
    rdfs:label 'Travel Time Limit Minutes' ;
    rdfs:comment 'Maximum acceptable one-way travel time in minutes for a technician dispatched from the service center to a customer site within this territory. Used in dispatch optimization and SLA feasibility checks.' ;
    rdfs:domain ind:ServiceTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualArrival rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival' ;
    rdfs:comment 'Actual datetime when the field service technician arrived at the customer site, captured via mobile check-in or GPS confirmation. Used for SLA adherence measurement.' ;
    rdfs:domain ind:DispatchSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDeparture rdf:type rdf:Property ;
    rdfs:label 'Actual Departure' ;
    rdfs:comment 'Actual datetime when the field service technician departed the customer site after completing or suspending the service activity.' ;
    rdfs:domain ind:DispatchSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDurationMin rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Min' ;
    rdfs:comment 'Actual time in minutes the technician spent on-site performing the service activity, calculated from actual arrival and departure timestamps.' ;
    rdfs:domain ind:DispatchSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualTravelTimeMin rdf:type rdf:Property ;
    rdfs:label 'Actual Travel Time Min' ;
    rdfs:comment 'Actual travel time in minutes recorded for the technician\'s journey to the customer site, used for route optimization analysis and workforce utilization reporting.' ;
    rdfs:domain ind:DispatchSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerSignatureObtained rdf:type rdf:Property ;
    rdfs:label 'Customer Signature Obtained' ;
    rdfs:comment 'Indicates whether a customer signature was obtained upon completion of the field service visit, confirming service delivery acceptance.' ;
    rdfs:domain ind:DispatchSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerSiteName rdf:type rdf:Property ;
    rdfs:label 'Customer Site Name' ;
    rdfs:comment 'Name of the customer facility or site where the field service activity is to be performed, used for dispatch routing and on-site coordination.' ;
    rdfs:domain ind:DispatchSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatcherNotes rdf:type rdf:Property ;
    rdfs:label 'Dispatcher Notes' ;
    rdfs:comment 'Free-text notes entered by the dispatcher providing additional context, special instructions, or site access information for the assigned technician.' ;
    rdfs:domain ind:DispatchSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTravelTimeMin rdf:type rdf:Property ;
    rdfs:label 'Estimated Travel Time Min' ;
    rdfs:comment 'Estimated travel time in minutes from the technician\'s current location or previous job site to the customer site, calculated by the scheduling optimization engine.' ;
    rdfs:domain ind:DispatchSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partsRequired rdf:type rdf:Property ;
    rdfs:label 'Parts Required' ;
    rdfs:comment 'Indicates whether spare parts or materials are required to complete the field service activity, used for pre-dispatch parts staging and inventory coordination.' ;
    rdfs:domain ind:DispatchSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredSkill rdf:type rdf:Property ;
    rdfs:label 'Required Skill' ;
    rdfs:comment 'Primary skill or certification required to perform the field service activity, used to validate technician qualification and support skill-based scheduling.' ;
    rdfs:domain ind:DispatchSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rescheduleCount rdf:type rdf:Property ;
    rdfs:label 'Reschedule Count' ;
    rdfs:comment 'Number of times this dispatch schedule has been rescheduled, used to identify problematic service orders and measure scheduling stability.' ;
    rdfs:domain ind:DispatchSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledDurationMin rdf:type rdf:Property ;
    rdfs:label 'Scheduled Duration Min' ;
    rdfs:comment 'Planned duration in minutes allocated for the service activity, derived from the work type standard duration and used for capacity planning.' ;
    rdfs:domain ind:DispatchSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledEnd rdf:type rdf:Property ;
    rdfs:label 'Scheduled End' ;
    rdfs:comment 'Planned datetime when the field service technician is expected to complete the service activity, used for scheduling window management and technician utilization.' ;
    rdfs:domain ind:DispatchSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStart rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start' ;
    rdfs:comment 'Planned datetime when the field service technician is scheduled to begin the service activity at the customer site, used for SLA compliance and workforce planning.' ;
    rdfs:domain ind:DispatchSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:schedulingMethod rdf:type rdf:Property ;
    rdfs:label 'Scheduling Method' ;
    rdfs:comment 'Method by which the dispatch was scheduled — manual assignment by a dispatcher, auto-optimized by the scheduling engine, or semi-automated with dispatcher override.' ;
    rdfs:domain ind:DispatchSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAddress rdf:type rdf:Property ;
    rdfs:label 'Site Address' ;
    rdfs:comment 'Full street address of the customer site where the field service technician is dispatched, used for navigation and geographic reporting.' ;
    rdfs:domain ind:DispatchSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCity rdf:type rdf:Property ;
    rdfs:label 'Site City' ;
    rdfs:comment 'City of the customer site where the field service activity is scheduled, used for geographic dispatch analysis and territory management.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCountryCode rdf:type rdf:Property ;
    rdfs:label 'Site Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the customer site, supporting multinational dispatch operations and regional compliance reporting.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDue rdf:type rdf:Property ;
    rdfs:label 'Sla Due' ;
    rdfs:comment 'Contractual deadline by which the field service activity must be completed per the applicable SLA agreement, used for breach detection and escalation.' ;
    rdfs:domain ind:DispatchSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:technicianNotes rdf:type rdf:Property ;
    rdfs:label 'Technician Notes' ;
    rdfs:comment 'Free-text notes entered by the field service technician during or after the service visit, capturing observations, actions taken, or follow-up requirements.' ;
    rdfs:domain ind:DispatchSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sparePartsCatalogId rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Catalog Id' ;
    rdfs:comment 'Foreign key linking to service.spare_parts_catalog. Business justification: Each spare parts request references a specific part from the spare parts catalog. Adding spare_parts_catalog_id FK normalizes the relationship to the authoritative catalog record, enabling retrieval o' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SparePartsCatalog .

ind:equipmentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Equipment Serial Number' ;
    rdfs:comment 'Serial number of the specific customer equipment unit requiring the spare part, enabling precise asset-level parts consumption tracking and failure pattern analysis.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentNotes rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Notes' ;
    rdfs:comment 'Free-text notes entered by warehouse staff or service coordinators regarding fulfillment exceptions, substitutions, partial shipments, or special handling instructions for the spare parts request.' ;
    rdfs:domain ind:SparePartsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityBackordered rdf:type rdf:Property ;
    rdfs:label 'Quantity Backordered' ;
    rdfs:comment 'Quantity of the spare part that could not be fulfilled from current stock and has been placed on backorder, requiring procurement or inter-warehouse transfer to satisfy the demand.' ;
    rdfs:domain ind:SparePartsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityIssued rdf:type rdf:Property ;
    rdfs:label 'Quantity Issued' ;
    rdfs:comment 'Actual number of units of the spare part physically issued from the warehouse against this request, which may differ from the quantity requested due to partial availability or substitution.' ;
    rdfs:domain ind:SparePartsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'Number of units of the spare part requested to fulfill the service order or warranty repair, expressed in the part\'s base unit of measure.' ;
    rdfs:domain ind:SparePartsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Calendar date on which the spare parts request was formally submitted by the field service technician or service coordinator.' ;
    rdfs:domain ind:SparePartsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Human-readable business reference number assigned to the spare parts request, used for cross-system tracking and communication with field technicians and warehouse teams.' ;
    rdfs:domain ind:SparePartsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone) when the spare parts request was created in the system, supporting SLA tracking and audit trail requirements.' ;
    rdfs:domain ind:SparePartsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Classification of the spare parts request by the nature of the service demand, distinguishing between field service, warranty repair, preventive maintenance, emergency breakdown, commissioning, upgrade, and MRO replenishment scenarios.' ;
    rdfs:domain ind:SparePartsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentReference rdf:type rdf:Property ;
    rdfs:label 'Shipment Reference' ;
    rdfs:comment 'Reference number of the outbound shipment or delivery document associated with the physical dispatch of the spare part to the field service location, enabling end-to-end logistics traceability.' ;
    rdfs:domain ind:SparePartsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'Mode of transportation selected for delivering the spare part to the field service location, influencing freight cost, delivery lead time, and SLA compliance.' ;
    rdfs:domain ind:SparePartsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Source Storage Location' ;
    rdfs:comment 'Specific storage location or bin within the source warehouse from which the spare part is picked, supporting precise inventory management and warehouse execution.' ;
    rdfs:domain ind:SparePartsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceWarehouseCode rdf:type rdf:Property ;
    rdfs:label 'Source Warehouse Code' ;
    rdfs:comment 'Code identifying the warehouse or storage location from which the spare part is to be issued, enabling multi-warehouse fulfillment routing and inventory depletion tracking.' ;
    rdfs:domain ind:SparePartsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutePartNumber rdf:type rdf:Property ;
    rdfs:label 'Substitute Part Number' ;
    rdfs:comment 'Part number of an approved substitute or alternative spare part used when the originally requested part is unavailable, supporting continuity of service and backorder resolution.' ;
    rdfs:domain ind:SparePartsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCost rdf:type rdf:Property ;
    rdfs:label 'Total Cost' ;
    rdfs:comment 'Total cost of the spare parts request calculated as unit cost multiplied by quantity issued, representing the actual parts cost charged to the service order or warranty claim.' ;
    rdfs:domain ind:SparePartsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:urgencyLevel rdf:type rdf:Property ;
    rdfs:label 'Urgency Level' ;
    rdfs:comment 'Priority classification indicating the operational urgency of the spare parts request, used to drive warehouse picking priority, expedited shipping decisions, and SLA compliance management.' ;
    rdfs:domain ind:SparePartsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyCovered rdf:type rdf:Property ;
    rdfs:label 'Warranty Covered' ;
    rdfs:comment 'Indicates whether the spare part request is covered under an active warranty agreement, determining whether the cost is charged to the customer or absorbed as a warranty liability.' ;
    rdfs:domain ind:SparePartsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:catalogEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Catalog Effective Date' ;
    rdfs:comment 'Date from which this spare part record is commercially active and available for ordering in the aftermarket catalog. Used for catalog versioning and price list validity management.' ;
    rdfs:domain ind:SparePartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:catalogExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Catalog Expiry Date' ;
    rdfs:comment 'Date after which this spare part record is no longer commercially active in the aftermarket catalog. Null if the part has no planned expiry. Used for catalog lifecycle management and phase-out planning.' ;
    rdfs:domain ind:SparePartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compatibleProductLines rdf:type rdf:Property ;
    rdfs:label 'Compatible Product Lines' ;
    rdfs:comment 'Comma-separated list or free-text description of specific product lines, model numbers, or series within the product family that are compatible with this spare part. Supports cross-reference lookups in field service and customer portals.' ;
    rdfs:domain ind:SparePartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPriceUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Price Update Date' ;
    rdfs:comment 'Date on which the list price for this spare part was last updated in the aftermarket catalog. Supports price audit trails and annual price list revision tracking.' ;
    rdfs:domain ind:SparePartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partCategory rdf:type rdf:Property ;
    rdfs:label 'Part Category' ;
    rdfs:comment 'Business category grouping for the spare part within the aftermarket catalog hierarchy (e.g., Electrical, Mechanical, Hydraulic, Electronic, Pneumatic, Safety). Supports catalog navigation and reporting.' ;
    rdfs:domain ind:SparePartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Reach Compliant Flag' ;
    rdfs:comment 'Indicates whether the spare part complies with the EU REACH regulation for chemical substance registration, evaluation, and authorization. Required for sale and distribution within the European Union.' ;
    rdfs:domain ind:SparePartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rohsCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Rohs Compliant Flag' ;
    rdfs:comment 'Indicates whether the spare part complies with the EU RoHS Directive restricting the use of specific hazardous substances in electrical and electronic equipment. Required for CE Marking and sale in the European Union.' ;
    rdfs:domain ind:SparePartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceContractEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Service Contract Eligible Flag' ;
    rdfs:comment 'Indicates whether this spare part is eligible for coverage under service contracts and maintenance agreements. Drives entitlement checks during field service dispatch and warranty claim processing.' ;
    rdfs:domain ind:SparePartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededByPartNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded By Part Number' ;
    rdfs:comment 'Part number of the newer replacement part that supersedes this part in the aftermarket catalog. Represents the forward link in the supersession chain (old part to new part). Null if this part has not been superseded.' ;
    rdfs:domain ind:SparePartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersedesPartNumber rdf:type rdf:Property ;
    rdfs:label 'Supersedes Part Number' ;
    rdfs:comment 'Part number of the older part that this part replaces in the aftermarket catalog. Represents the backward link in the supersession chain. Null if this part does not supersede a prior part.' ;
    rdfs:domain ind:SparePartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Exact date and time when the installation and commissioning activity was completed on site, used for duration calculation and service performance reporting.' ;
    rdfs:domain ind:InstallationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ceMarkingVerified rdf:type rdf:Property ;
    rdfs:label 'Ce Marking Verified' ;
    rdfs:comment 'Indicates whether CE marking compliance was verified for the installed product at the time of commissioning, required for products sold in the European Economic Area.' ;
    rdfs:domain ind:InstallationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checklistCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Checklist Completion Percentage' ;
    rdfs:comment 'Percentage of commissioning checklist items that have been completed and verified, providing a quantitative measure of commissioning progress.' ;
    rdfs:domain ind:InstallationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checklistCompletionStatus rdf:type rdf:Property ;
    rdfs:label 'Checklist Completion Status' ;
    rdfs:comment 'Status indicating whether the commissioning checklist has been fully completed, partially completed, or completed with noted exceptions, ensuring all installation steps are verified.' ;
    rdfs:domain ind:InstallationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSignOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Sign Off Timestamp' ;
    rdfs:comment 'Exact date and time when the customer formally signed off on the installation, marking the official acceptance and triggering warranty activation.' ;
    rdfs:domain ind:InstallationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Customer Signatory Name' ;
    rdfs:comment 'Full name of the customer representative who signed off on the installation acceptance, used for legal and contractual documentation.' ;
    rdfs:domain ind:InstallationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faiDate rdf:type rdf:Property ;
    rdfs:label 'Fai Date' ;
    rdfs:comment 'Date on which the First Article Inspection (FAI) was conducted at the customer site during commissioning.' ;
    rdfs:domain ind:InstallationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:faiReportReference rdf:type rdf:Property ;
    rdfs:label 'Fai Report Reference' ;
    rdfs:comment 'Document reference number or URL for the FAI report generated during commissioning, stored in the document management system for traceability.' ;
    rdfs:domain ind:InstallationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faiResult rdf:type rdf:Property ;
    rdfs:label 'Fai Result' ;
    rdfs:comment 'Outcome of the First Article Inspection (FAI) performed during commissioning to verify that the installed product meets all design and specification requirements before handover.' ;
    rdfs:domain ind:InstallationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalLocationCode rdf:type rdf:Property ;
    rdfs:label 'Functional Location Code' ;
    rdfs:comment 'Structured code identifying the functional location within the customer plant or facility where the asset is installed, aligned with SAP PM and Maximo EAM hierarchies.' ;
    rdfs:domain ind:InstallationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Handover Document Reference' ;
    rdfs:comment 'Reference number or document management system link for the installation handover package, including as-built drawings, test reports, manuals, and certificates.' ;
    rdfs:domain ind:InstallationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationNotes rdf:type rdf:Property ;
    rdfs:label 'Installation Notes' ;
    rdfs:comment 'Free-text field capturing any notable observations, deviations from standard installation procedures, site-specific conditions, or exceptions recorded by the commissioning engineer.' ;
    rdfs:domain ind:InstallationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationType rdf:type rdf:Property ;
    rdfs:label 'Installation Type' ;
    rdfs:comment 'Classification of the installation activity indicating whether it is a new installation, an upgrade to existing equipment, a replacement of a failed unit, a relocation, or a decommission.' ;
    rdfs:domain ind:InstallationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCustomerSignedOff rdf:type rdf:Property ;
    rdfs:label 'Is Customer Signed Off' ;
    rdfs:comment 'Indicates whether the customer has formally signed off on the completed installation and commissioning, confirming acceptance of the installed product.' ;
    rdfs:domain ind:InstallationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productSku rdf:type rdf:Property ;
    rdfs:label 'Product Sku' ;
    rdfs:comment 'Stock Keeping Unit (SKU) code identifying the specific product model being installed, aligned with the product catalog and ERP master data.' ;
    rdfs:domain ind:InstallationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectReference rdf:type rdf:Property ;
    rdfs:label 'Project Reference' ;
    rdfs:comment 'Reference to the associated project or sales order under which the installation was contracted, linking the installation record to the commercial transaction.' ;
    rdfs:domain ind:InstallationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCheckCompleted rdf:type rdf:Property ;
    rdfs:label 'Safety Check Completed' ;
    rdfs:comment 'Indicates whether all mandatory safety checks and electrical safety tests were completed prior to energizing or commissioning the installed equipment.' ;
    rdfs:domain ind:InstallationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Planned calendar date on which the installation and commissioning activity is scheduled to begin, used for resource planning and customer coordination.' ;
    rdfs:domain ind:InstallationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Site Address Line1' ;
    rdfs:comment 'Primary street address line of the customer installation site, used for field engineer dispatch and logistics.' ;
    rdfs:domain ind:InstallationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Site Address Line2' ;
    rdfs:comment 'Secondary address line (suite, floor, building number) of the customer installation site.' ;
    rdfs:domain ind:InstallationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteStateProvince rdf:type rdf:Property ;
    rdfs:label 'Site State Province' ;
    rdfs:comment 'State or province of the customer installation site, used for regional compliance and service territory management.' ;
    rdfs:domain ind:InstallationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyActivationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Activation Date' ;
    rdfs:comment 'Date on which the product warranty is activated following successful installation and customer sign-off, marking the start of the warranty coverage period.' ;
    rdfs:domain ind:InstallationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportId rdf:type rdf:Property ;
    rdfs:label 'Report Id' ;
    rdfs:comment 'Unique system-generated identifier for the field service completion report. Serves as the primary key for this record across all downstream systems.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingType rdf:type rdf:Property ;
    rdfs:label 'Billing Type' ;
    rdfs:comment 'Classification of how the service visit will be billed to the customer or charged internally. Determines the invoicing process, revenue recognition treatment, and cost allocation.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerAcceptanceNotes rdf:type rdf:Property ;
    rdfs:label 'Customer Acceptance Notes' ;
    rdfs:comment 'Any comments, reservations, or conditions noted by the customer representative at the time of signing the service report. Captures partial acceptance or outstanding concerns that may affect billing or follow-up.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSignatureName rdf:type rdf:Property ;
    rdfs:label 'Customer Signature Name' ;
    rdfs:comment 'Full name of the customer representative who signed and accepted the service report on-site. Constitutes legal acknowledgment of service completion and is required for billing and warranty claim substantiation.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Signed Timestamp' ;
    rdfs:comment 'Date and time when the customer representative signed and accepted the service report on-site. Constitutes formal proof of service delivery and triggers billing eligibility.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:equipmentConditionFound rdf:type rdf:Property ;
    rdfs:label 'Equipment Condition Found' ;
    rdfs:comment 'Condition of the equipment as assessed by the technician upon arrival at the site, prior to performing any work. Used for failure analysis, warranty assessment, and FMEA data collection.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentConditionLeft rdf:type rdf:Property ;
    rdfs:label 'Equipment Condition Left' ;
    rdfs:comment 'Condition of the equipment as assessed by the technician upon completion of the service visit. Indicates whether the equipment was fully restored to operational status or requires further action.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentModel rdf:type rdf:Property ;
    rdfs:label 'Equipment Model' ;
    rdfs:comment 'Model or part number of the equipment serviced. Used for spare parts lookup, technical documentation retrieval, and warranty eligibility determination.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFollowUpRequired rdf:type rdf:Property ;
    rdfs:label 'Is Follow Up Required' ;
    rdfs:comment 'Indicates whether the technician has identified the need for a follow-up service visit or additional work order. When true, a new field service order should be created based on the recommendations.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyIncidentReported rdf:type rdf:Property ;
    rdfs:label 'Is Safety Incident Reported' ;
    rdfs:comment 'Indicates whether a safety incident or near-miss was observed and formally reported during the service visit. Triggers mandatory safety incident management workflow per ISO 45001 and OSHA requirements.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWarrantyApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Warranty Applicable' ;
    rdfs:comment 'Indicates whether the service performed is covered under an active product or service warranty. Determines billing treatment and triggers warranty claim processing workflow.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborHoursTotal rdf:type rdf:Property ;
    rdfs:label 'Labor Hours Total' ;
    rdfs:comment 'Total number of labor hours expended by the technician(s) during the service visit, including all activity types. Used for billing, SLA compliance measurement, and workforce productivity analytics.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsConsumedCost rdf:type rdf:Property ;
    rdfs:label 'Parts Consumed Cost' ;
    rdfs:comment 'Total cost of all spare parts and materials consumed during the service visit, in the transaction currency. Used for service billing, warranty cost tracking, and COGS reporting.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsReplacedDescription rdf:type rdf:Property ;
    rdfs:label 'Parts Replaced Description' ;
    rdfs:comment 'Narrative listing of all spare parts replaced during the service visit, including part numbers, descriptions, and quantities. Used for inventory reconciliation, warranty claim substantiation, and billing.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendations rdf:type rdf:Property ;
    rdfs:label 'Recommendations' ;
    rdfs:comment 'Technician\'s recommendations for follow-up work, preventive maintenance actions, spare parts to be stocked, or equipment upgrades identified during the service visit. Drives future service order creation and proactive maintenance planning.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Code' ;
    rdfs:comment 'Standardized code indicating the type of resolution applied during the service visit. Used for service analytics, spare parts consumption reporting, and billing classification.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Root Cause Code' ;
    rdfs:comment 'Standardized code categorizing the root cause of the equipment failure or service need. Used for CAPA initiation, warranty chargeback decisions, and quality trend analysis.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyObservations rdf:type rdf:Property ;
    rdfs:label 'Safety Observations' ;
    rdfs:comment 'Technician\'s documented observations regarding safety conditions at the customer site or on the equipment, including hazards identified, PPE used, and any safety incidents or near-misses during the service visit.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Technician Certification Number' ;
    rdfs:comment 'Professional certification or qualification number of the technician performing the service, demonstrating competency for the specific equipment type. Required for regulatory compliance and warranty validity.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testOutcome rdf:type rdf:Property ;
    rdfs:label 'Test Outcome' ;
    rdfs:comment 'Overall outcome of post-service functional testing. A \'pass\' result is required for equipment release to operation and warranty validation. \'Fail\' or \'conditional_pass\' triggers follow-up action.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResultsDescription rdf:type rdf:Property ;
    rdfs:label 'Test Results Description' ;
    rdfs:comment 'Narrative description of all functional tests, measurements, and performance verifications conducted on the equipment after service completion. Includes pass/fail outcomes and measured values. Required for commissioning sign-off and warranty validation.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelTimeHours rdf:type rdf:Property ;
    rdfs:label 'Travel Time Hours' ;
    rdfs:comment 'Number of hours spent by the technician traveling to and from the customer site. Used for billing (if billable travel is included in the service contract), cost allocation, and territory optimization.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workPerformedDescription rdf:type rdf:Property ;
    rdfs:label 'Work Performed Description' ;
    rdfs:comment 'Detailed narrative of all work performed by the technician during the service visit, including diagnostic steps, repairs, adjustments, and tests conducted. Serves as the official record of service delivery for warranty substantiation and customer proof of service.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'The actual date on which the entitlement was activated and made available for service consumption. May differ from start_date if activation was delayed pending installation or commissioning.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coveredProductFamily rdf:type rdf:Property ;
    rdfs:label 'Covered Product Family' ;
    rdfs:comment 'The product family or product line covered under this entitlement when coverage applies to a group of products rather than a single SKU (e.g., \'SIMATIC S7 PLC Series\', \'SINAMIC Drive Family\').' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coveredProductSku rdf:type rdf:Property ;
    rdfs:label 'Covered Product Sku' ;
    rdfs:comment 'The specific product SKU covered under this entitlement. When populated, entitlement validation in Salesforce Service Cloud checks that the case product matches this SKU.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coveredSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Covered Serial Number' ;
    rdfs:comment 'The specific equipment serial number covered under this entitlement. When populated, restricts entitlement consumption to service cases for that specific installed asset.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentsConsumed rdf:type rdf:Property ;
    rdfs:label 'Incidents Consumed' ;
    rdfs:comment 'The number of service incidents consumed against this entitlement to date. Updated each time a case is validated and accepted under this entitlement. Used to calculate remaining incident balance.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incidentsRemaining rdf:type rdf:Property ;
    rdfs:label 'Incidents Remaining' ;
    rdfs:comment 'The number of service incidents remaining available for consumption under this entitlement (total_incidents_allowed minus incidents_consumed). A null value indicates unlimited incidents remain.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isTransferable rdf:type rdf:Property ;
    rdfs:label 'Is Transferable' ;
    rdfs:comment 'Indicates whether this entitlement can be transferred to a new owner upon sale or transfer of the covered equipment. Relevant for installed base management and secondary market support.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onSiteSupportFlag rdf:type rdf:Property ;
    rdfs:label 'On Site Support Flag' ;
    rdfs:comment 'Indicates whether on-site field service visits are included in this entitlement. When true, field service orders can be dispatched under this entitlement without additional billing authorization.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:owningBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Owning Business Unit' ;
    rdfs:comment 'The internal business unit or division responsible for fulfilling service obligations under this entitlement (e.g., Automation Services, Electrification Services). Used for cost allocation and P&L reporting.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Remote Support Flag' ;
    rdfs:comment 'Indicates whether remote technical support (phone, email, or remote access) is included in this entitlement. Drives routing logic in Salesforce Service Cloud for case assignment.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceHoursCoverage rdf:type rdf:Property ;
    rdfs:label 'Service Hours Coverage' ;
    rdfs:comment 'The hours of service coverage included in this entitlement (e.g., 24x7 for round-the-clock support, 8x5 for standard business hours). Determines when SLA clocks run and when dispatches can be scheduled.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sparePartsCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Coverage Flag' ;
    rdfs:comment 'Indicates whether spare parts consumed during service are covered under this entitlement at no additional charge to the customer. Drives parts billing decisions in SAP S/4HANA SD.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sparePartsCoverageLimit rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Coverage Limit' ;
    rdfs:comment 'Maximum monetary value of spare parts covered under this entitlement per contract period. When the limit is reached, additional parts are billed to the customer. Null indicates no monetary cap.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalIncidentsAllowed rdf:type rdf:Property ;
    rdfs:label 'Total Incidents Allowed' ;
    rdfs:comment 'The total number of service incidents (cases or field service visits) included in this entitlement. A null value indicates unlimited incidents. Used to enforce consumption limits in Salesforce Service Cloud.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableFirmwareVersion rdf:type rdf:Property ;
    rdfs:label 'Applicable Firmware Version' ;
    rdfs:comment 'Firmware or software version range to which this article applies, ensuring technicians apply the correct resolution for the installed firmware on the equipment.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableProductSkus rdf:type rdf:Property ;
    rdfs:label 'Applicable Product Skus' ;
    rdfs:comment 'Comma-separated list of specific Stock Keeping Unit (SKU) identifiers for products to which this article applies, enabling precise product-level filtering in service workflows.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:articleNumber rdf:type rdf:Property ;
    rdfs:label 'Article Number' ;
    rdfs:comment 'Human-readable business identifier for the knowledge article, used for cross-referencing in service cases, field service orders, and customer portals.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCodes rdf:type rdf:Property ;
    rdfs:label 'Error Codes' ;
    rdfs:comment 'Comma-separated list of system error codes, fault codes, or alarm identifiers (from PLC, SCADA, MES, or HMI systems) that this article addresses, enabling automated article suggestion.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:helpfulVotes rdf:type rdf:Property ;
    rdfs:label 'Helpful Votes' ;
    rdfs:comment 'Number of times users have rated the article as helpful, used to assess article quality and prioritize content improvement efforts.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notHelpfulVotes rdf:type rdf:Property ;
    rdfs:label 'Not Helpful Votes' ;
    rdfs:comment 'Number of times users have rated the article as not helpful, used to identify articles requiring revision or retirement.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionSteps rdf:type rdf:Property ;
    rdfs:label 'Resolution Steps' ;
    rdfs:comment 'Step-by-step instructions for resolving the issue, performing the repair procedure, or executing the described process, authored by service engineers or product specialists.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewComments rdf:type rdf:Property ;
    rdfs:label 'Review Comments' ;
    rdfs:comment 'Reviewer feedback, revision notes, or approval comments recorded during the technical review process.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current status of the editorial and technical review process for the knowledge article prior to publication.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Full name of the subject matter expert or quality reviewer who approved the article for publication.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyAdvisoryFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Advisory Flag' ;
    rdfs:comment 'Indicates whether this article contains safety-critical information requiring mandatory compliance, such as electrical safety warnings, lockout/tagout procedures, or OSHA-regulated hazard notifications.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:searchKeywords rdf:type rdf:Property ;
    rdfs:label 'Search Keywords' ;
    rdfs:comment 'Comma-separated list of keywords and tags that enhance discoverability of the article in knowledge base search, including error codes, product names, and symptom terms.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTerritoryScope rdf:type rdf:Property ;
    rdfs:label 'Service Territory Scope' ;
    rdfs:comment 'Geographic or regional scope for which this article is applicable (e.g., specific country codes or regions), supporting localized service delivery and regulatory variation.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:symptomDescription rdf:type rdf:Property ;
    rdfs:label 'Symptom Description' ;
    rdfs:comment 'Detailed description of the observable symptoms, fault conditions, or error codes that trigger the need for this knowledge article, used for search and first-call resolution matching.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visibility rdf:type rdf:Property ;
    rdfs:label 'Visibility' ;
    rdfs:comment 'Defines the audience scope for the article: internal service engineers only, partner network, customer self-service portal, or publicly accessible.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSupplierId rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Id' ;
    rdfs:comment 'Primary key for the preferred_supplier association' ;
    rdfs:domain ind:PreferredSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractCoverageId rdf:type rdf:Property ;
    rdfs:label 'Contract Coverage Id' ;
    rdfs:comment 'Primary key for the contract_coverage association' ;
    rdfs:domain ind:ContractCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coveredVisitCount rdf:type rdf:Property ;
    rdfs:label 'Covered Visit Count' ;
    rdfs:comment 'The number of preventive maintenance visits allocated to this specific maintenance plan under this contract. Enables tracking of visit budget consumption per plan-contract pairing. Sourced directly from detection phase relationship data.' ;
    rdfs:domain ind:ContractCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentToolingAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Component Tooling Assignment Id' ;
    rdfs:comment 'Primary key for the component_tooling_assignment association' ;
    rdfs:domain ind:ComponentToolingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:setupSequence rdf:type rdf:Property ;
    rdfs:label 'Setup Sequence' ;
    rdfs:comment 'Numeric order in which this tool must be set up relative to other tools required for the same BOM component. Belongs to the assignment because sequence is specific to the component-tool pairing, not to the tool or component alone.' ;
    rdfs:domain ind:ComponentToolingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageType rdf:type rdf:Property ;
    rdfs:label 'Usage Type' ;
    rdfs:comment 'Classifies the functional role of the tool in manufacturing this component (e.g., FIXTURE for holding, CUTTING_TOOL for machining, GAUGE for inspection). Belongs to the assignment because the same tool may serve different roles for different components.' ;
    rdfs:domain ind:ComponentToolingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingCoverageAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Pricing Coverage Assignment Id' ;
    rdfs:comment 'Primary key for the pricing_coverage_assignment association' ;
    rdfs:domain ind:PricingCoverageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cashApplicationId rdf:type rdf:Property ;
    rdfs:label 'Cash Application Id' ;
    rdfs:comment 'Primary key for the cash_application association' ;
    rdfs:domain ind:CashApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remittanceReference rdf:type rdf:Property ;
    rdfs:label 'Remittance Reference' ;
    rdfs:comment 'The customer-provided reference number or line identifier from the remittance advice that links this payment to this specific invoice. Used by AR teams to match incoming payments to open invoices during manual and automated cash application.' ;
    rdfs:domain ind:CashApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .
